<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Monthly Summary</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --bg: #f0f2f8;
      --surf: #fff;
      --s2: #f6f7fb;
      --s3: #eef0f7;
      --brd: #e2e6f0;
      --brd2: #eaecf5;
      --t1: #0c0f1e;
      --t2: #566080;
      --t3: #9099b8;
      --ac: #1d4ed8;
      --acl: #eff3ff;
      --acs: #c7d7fd;
      --gr: #15803d;
      --grl: #f0fdf4;
      --grs: #bbf7d0;
      --am: #b45309;
      --aml: #fffbeb;
      --ams: #fde68a;
      --rd: #b91c1c;
      --rdl: #fff1f2;
      --rds: #fecdd3;
      --vi: #6d28d9;
      --vil: #f5f3ff;
      --vis: #ddd6fe;
      --cy: #0e7490;
      --cyl: #ecfeff;
      --cys: #a5f3fc;
      --or: #c2410c;
      --orl: #fff7ed;
      --ors: #fed7aa;
      --sidebar-w: 240px;
      --r: 12px;
      --rs: 7px;
      --sh: 0 1px 3px rgba(12, 18, 60, .06), 0 1px 2px rgba(12, 18, 60, .04);
      --shm: 0 4px 16px rgba(12, 18, 60, .09), 0 2px 5px rgba(12, 18, 60, .05);
      --shl: 0 16px 48px rgba(12, 18, 60, .14), 0 4px 12px rgba(12, 18, 60, .07);
    }

    html.dark {
      --bg: #080b15;
      --surf: #10152a;
      --s2: #151c32;
      --s3: #1c2440;
      --brd: #202844;
      --brd2: #1a2238;
      --t1: #e0e6f8;
      --t2: #6878a8;
      --t3: #384060;
      --ac: #4a6ef5;
      --acl: #171e48;
      --acs: #1f2e80;
      --grl: #061410;
      --grs: #0f3020;
      --aml: #150e00;
      --ams: #381e00;
      --rdl: #150408;
      --rds: #380412;
      --sh: 0 1px 3px rgba(0, 0, 0, .4);
      --shm: 0 4px 16px rgba(0, 0, 0, .5);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--t1);
      display: flex;
      min-height: 100vh;
      overflow-x: hidden
    }

    /* SIDEBAR */
    .sb {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--surf);
      border-right: 1px solid var(--brd);
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0;
      top: 0;
      z-index: 60;
      transition: transform .28s cubic-bezier(.4, 0, .2, 1)
    }

    .sb-logo {
      height: 56px;
      padding: 0 16px 0 20px;
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0
    }

    .logo-m {
      width: 32px;
      height: 32px;
      background: var(--ac);
      border-radius: 8px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 12px;
      font-weight: 800;
      flex-shrink: 0
    }

    .logo-n {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -.3px
    }

    .logo-sub {
      font-size: 9.5px;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-top: 1px
    }

    .sb-x {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      border: 1px solid var(--brd);
      background: var(--s2);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      flex-shrink: 0;
      transition: all .14s
    }

    .sb-x:hover {
      background: var(--rdl);
      color: var(--rd);
      border-color: var(--rds)
    }

    .sb-x svg {
      width: 13px;
      height: 13px
    }

    .sb-nav {
      flex: 1;
      padding: 10px 8px;
      overflow-y: auto
    }

    .nsec {
      font-size: 9.5px;
      font-weight: 700;
      color: var(--t3);
      letter-spacing: .9px;
      text-transform: uppercase;
      padding: 10px 10px 4px;
      margin-top: 4px
    }

    .ni {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      border-radius: var(--rs);
      color: var(--t2);
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      transition: all .14s;
      margin-bottom: 1px
    }

    .ni:hover {
      background: var(--s2);
      color: var(--t1)
    }

    .ni.on {
      background: var(--acl);
      color: var(--ac);
      font-weight: 600
    }

    .ni svg {
      width: 15px;
      height: 15px;
      flex-shrink: 0
    }

    .nbdg {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 8px;
      font-family: 'DM Mono', monospace;
      background: var(--rds);
      color: var(--rd)
    }

    .nbdg.am {
      background: var(--ams);
      color: var(--am)
    }

    .sb-foot {
      padding: 12px 8px;
      border-top: 1px solid var(--brd);
      flex-shrink: 0
    }

    .urow {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 9px 12px;
      border-radius: var(--rs);
      cursor: pointer;
      transition: background .14s
    }

    .urow:hover {
      background: var(--s2)
    }

    .uav {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gr), var(--cy));
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0
    }

    .veil {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      z-index: 55;
      cursor: pointer
    }

    /* MAIN */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      transition: margin-left .28s cubic-bezier(.4, 0, .2, 1);
      min-width: 0;
      overflow-x: hidden
    }

    /* NAV */
    .nav {
      height: 56px;
      background: var(--surf);
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 10px;
      position: sticky;
      top: 0;
      z-index: 40;
      flex-shrink: 0
    }

    .togbtn {
      width: 32px;
      height: 32px;
      border-radius: var(--rs);
      border: 1px solid var(--brd);
      background: var(--surf);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      transition: all .14s;
      flex-shrink: 0
    }

    .togbtn:hover {
      border-color: var(--ac);
      color: var(--ac);
      background: var(--acl)
    }

    .togbtn svg {
      width: 15px;
      height: 15px
    }

    .nav-info {
      flex: 1;
      min-width: 0
    }

    .nav-ttl {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: -.2px
    }

    .nav-bc {
      font-size: 11px;
      color: var(--t3)
    }

    .nav-r {
      display: flex;
      align-items: center;
      gap: 7px;
      flex-shrink: 0
    }

    .nsrch {
      display: flex;
      align-items: center;
      gap: 7px;
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 6px 10px;
      font-size: 12px;
      color: var(--t3);
      cursor: text;
      min-width: 160px
    }

    .nsrch svg {
      width: 12px;
      height: 12px;
      flex-shrink: 0
    }

    .nico {
      width: 32px;
      height: 32px;
      border-radius: var(--rs);
      border: 1px solid var(--brd);
      background: var(--surf);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      transition: all .14s;
      flex-shrink: 0;
      position: relative
    }

    .nico:hover {
      border-color: var(--ac);
      color: var(--ac);
      background: var(--acl)
    }

    .nico svg {
      width: 14px;
      height: 14px
    }

    .nico-dot {
      position: absolute;
      top: 5px;
      right: 5px;
      width: 7px;
      height: 7px;
      background: var(--rd);
      border-radius: 50%;
      border: 1.5px solid var(--surf)
    }

    .avp {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 3px 10px 3px 3px;
      border-radius: var(--rs);
      border: 1px solid var(--brd);
      background: var(--surf);
      cursor: pointer;
      flex-shrink: 0
    }

    .avp-a {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gr), var(--cy));
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 9px;
      font-weight: 700
    }

    /* CONTENT */
    .content {
      padding: 20px;
      flex: 1
    }

    /* PAGE HEADER */
    .pghdr {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 12px
    }

    .pghdr h1 {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -.5px
    }

    .pghdr p {
      font-size: 13px;
      color: var(--t3);
      margin-top: 3px
    }

    /* MONTH SELECTOR */
    .month-bar {
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      padding: 12px 16px;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      box-shadow: var(--sh)
    }

    .month-nav {
      display: flex;
      align-items: center;
      gap: 6px
    }

    .mnav-btn {
      width: 30px;
      height: 30px;
      border-radius: 6px;
      border: 1px solid var(--brd);
      background: var(--s2);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      transition: all .14s;
      flex-shrink: 0
    }

    .mnav-btn:hover {
      border-color: var(--ac);
      color: var(--ac)
    }

    .mnav-btn svg {
      width: 13px;
      height: 13px
    }

    .month-label {
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -.3px;
      min-width: 140px;
      text-align: center
    }

    .month-bar-right {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-left: auto
    }

    /* STAT CARDS */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 20px
    }

    .sc {
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      padding: 16px 18px;
      box-shadow: var(--sh)
    }

    .sc-icon {
      width: 38px;
      height: 38px;
      border-radius: 9px;
      display: grid;
      place-items: center;
      margin-bottom: 10px
    }

    .sc-icon svg {
      width: 18px;
      height: 18px
    }

    .sc-icon.gr {
      background: var(--grl);
      color: var(--gr)
    }

    .sc-icon.am {
      background: var(--aml);
      color: var(--am)
    }

    .sc-icon.ac {
      background: var(--acl);
      color: var(--ac)
    }

    .sc-icon.rd {
      background: var(--rdl);
      color: var(--rd)
    }

    .sc-icon.vi {
      background: var(--vil);
      color: var(--vi)
    }

    .sc-val {
      font-size: 22px;
      font-weight: 800;
      font-family: 'DM Mono', monospace;
      letter-spacing: -.5px;
      line-height: 1
    }

    .sc-lbl {
      font-size: 11.5px;
      color: var(--t3);
      margin-top: 4px;
      font-weight: 500
    }

    .sc-sub {
      font-size: 11px;
      font-weight: 600;
      margin-top: 4px
    }

    .sc-sub.gr {
      color: var(--gr)
    }

    .sc-sub.rd {
      color: var(--rd)
    }

    /* MAIN GRID */
    .mgrid {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 16px;
      align-items: start
    }

    /* PANEL */
    .panel {
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      box-shadow: var(--sh);
      overflow: hidden;
      margin-bottom: 16px
    }

    .panel:last-child {
      margin-bottom: 0
    }

    .ph {
      padding: 14px 18px;
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap
    }

    .ph-title {
      font-size: 13.5px;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .ph-title svg {
      width: 15px;
      height: 15px;
      color: var(--ac);
      flex-shrink: 0
    }

    .ph-sub {
      font-size: 11.5px;
      color: var(--t3);
      margin-top: 2px
    }

    /* TABLE */
    .tbl-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch
    }

    .tbl {
      width: 100%;
      border-collapse: collapse;
      min-width: 520px
    }

    .tbl th {
      font-size: 10px;
      font-weight: 700;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .5px;
      padding: 10px 14px;
      text-align: left;
      background: var(--s2);
      border-bottom: 1px solid var(--brd);
      white-space: nowrap
    }

    .tbl td {
      padding: 12px 14px;
      font-size: 13px;
      border-bottom: 1px solid var(--brd2);
      vertical-align: middle
    }

    .tbl tr:last-child td {
      border-bottom: none
    }

    .tbl tbody tr {
      transition: background .12s
    }

    .tbl tbody tr:hover td {
      background: var(--s2)
    }

    .tbl-footer {
      padding: 10px 16px;
      background: var(--s2);
      border-top: 1px solid var(--brd);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px
    }

    .tbl-info {
      font-size: 12px;
      color: var(--t3)
    }

    /* COLLECTION BARS */
    .cbar-wrap {
      padding: 16px 18px
    }

    .cbar-row {
      margin-bottom: 14px
    }

    .cbar-row:last-child {
      margin-bottom: 0
    }

    .cbar-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 5px
    }

    .cbar-lbl {
      font-size: 12.5px;
      font-weight: 600
    }

    .cbar-amt {
      font-size: 12px;
      font-family: 'DM Mono', monospace;
      color: var(--t2);
      font-weight: 600
    }

    .bar-track {
      height: 8px;
      background: var(--brd);
      border-radius: 4px;
      overflow: hidden
    }

    .bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width .6s ease
    }

    .bar-fill.gr {
      background: linear-gradient(90deg, var(--gr), var(--cy))
    }

    .bar-fill.ac {
      background: linear-gradient(90deg, var(--ac), var(--vi))
    }

    .bar-fill.am {
      background: linear-gradient(90deg, var(--am), var(--or))
    }

    .bar-fill.cy {
      background: linear-gradient(90deg, var(--cy), var(--ac))
    }

    /* SECTION BREAKDOWN */
    .sec-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 16px;
      border-bottom: 1px solid var(--brd2)
    }

    .sec-item:last-child {
      border-bottom: none
    }

    .sec-left {
      display: flex;
      align-items: center;
      gap: 10px
    }

    .sec-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0
    }

    .sec-name {
      font-size: 12.5px;
      font-weight: 600
    }

    .sec-count {
      font-size: 11px;
      color: var(--t3);
      margin-top: 1px
    }

    .sec-right {
      text-align: right
    }

    .sec-amt {
      font-size: 13px;
      font-weight: 800;
      font-family: 'DM Mono', monospace;
      color: var(--gr)
    }

    .sec-pct {
      font-size: 11px;
      color: var(--t3);
      margin-top: 1px
    }

    /* CALENDAR HEATMAP */
    .cal-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 3px;
      padding: 14px 16px
    }

    .cal-hdr {
      text-align: center;
      font-size: 10px;
      font-weight: 700;
      color: var(--t3);
      padding: 3px 0
    }

    .cal-cell {
      height: 32px;
      border-radius: 5px;
      display: grid;
      place-items: center;
      font-size: 11.5px;
      font-weight: 600;
      cursor: pointer;
      transition: all .14s;
      position: relative
    }

    .cal-cell:hover {
      opacity: .8;
      transform: scale(1.08)
    }

    .cal-cell.empty {
      background: transparent;
      cursor: default
    }

    .cal-cell.empty:hover {
      transform: none;
      opacity: 1
    }

    .cal-cell.no-collect {
      background: var(--s2);
      color: var(--t3)
    }

    .cal-cell.low {
      background: #bbf7d0;
      color: #14532d
    }

    .cal-cell.mid {
      background: #4ade80;
      color: #14532d
    }

    .cal-cell.high {
      background: #16a34a;
      color: #fff
    }

    .cal-cell.today-mark {
      box-shadow: 0 0 0 2px var(--ac)
    }

    .cal-cell.future {
      background: var(--s2);
      color: var(--brd);
      cursor: default
    }

    .cal-cell.future:hover {
      transform: none;
      opacity: 1
    }

    .cal-footer {
      padding: 8px 16px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid var(--brd2)
    }

    .cal-legend {
      display: flex;
      align-items: center;
      gap: 8px
    }

    .cal-legend-item {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      color: var(--t3)
    }

    .cal-swatch {
      width: 10px;
      height: 10px;
      border-radius: 2px
    }

    /* OUTSTANDING */
    .ot-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 11px 16px;
      border-bottom: 1px solid var(--brd2);
      gap: 10px;
      flex-wrap: wrap
    }

    .ot-item:last-child {
      border-bottom: none
    }

    .ot-vendor {
      font-size: 12.5px;
      font-weight: 600
    }

    .ot-stall {
      font-size: 11px;
      color: var(--t3)
    }

    .ot-right {
      text-align: right;
      flex-shrink: 0
    }

    .ot-amt {
      font-size: 13px;
      font-weight: 800;
      font-family: 'DM Mono', monospace;
      color: var(--rd)
    }

    /* BADGES */
    .bdg {
      display: inline-flex;
      align-items: center;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap
    }

    .bdg.gr {
      background: var(--grs);
      color: var(--gr)
    }

    .bdg.am {
      background: var(--ams);
      color: var(--am)
    }

    .bdg.rd {
      background: var(--rds);
      color: var(--rd)
    }

    .bdg.ac {
      background: var(--acs);
      color: var(--ac)
    }

    .bdg.vi {
      background: var(--vis);
      color: var(--vi)
    }

    .bdg.cy {
      background: var(--cys);
      color: var(--cy)
    }

    /* METHOD BADGE */
    .mbdg {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap
    }

    .mbdg.cash {
      background: var(--grs);
      color: var(--gr)
    }

    .mbdg.gcash {
      background: var(--vis);
      color: var(--vi)
    }

    .mbdg.maya {
      background: var(--cys);
      color: var(--cy)
    }

    /* PRINT SUMMARY CARD */
    .print-card {
      background: linear-gradient(135deg, var(--ac) 0%, var(--vi) 100%);
      border-radius: var(--r);
      padding: 16px 18px;
      color: #fff;
      margin-bottom: 16px
    }

    .print-card-title {
      font-size: 11px;
      font-weight: 700;
      opacity: .8;
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 6px
    }

    .print-card-val {
      font-size: 28px;
      font-weight: 900;
      font-family: 'DM Mono', monospace;
      letter-spacing: -1px;
      line-height: 1
    }

    .print-card-sub {
      font-size: 12px;
      opacity: .75;
      margin-top: 4px
    }

    /* BUTTONS */
    .btn {
      padding: 8px 16px;
      border-radius: var(--rs);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      font-family: 'DM Sans', sans-serif;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all .14s
    }

    .btn svg {
      width: 13px;
      height: 13px;
      flex-shrink: 0
    }

    .btn.pri {
      background: var(--ac);
      color: #fff
    }

    .btn.pri:hover {
      filter: brightness(1.1)
    }

    .btn.gr {
      background: var(--gr);
      color: #fff
    }

    .btn.gr:hover {
      filter: brightness(1.08)
    }

    .btn.gh {
      background: var(--surf);
      border: 1px solid var(--brd);
      color: var(--t2)
    }

    .btn.gh:hover {
      border-color: var(--ac);
      color: var(--ac)
    }

    .btn.sm {
      padding: 6px 12px;
      font-size: 12px
    }

    .btn.xs {
      padding: 4px 9px;
      font-size: 11.5px
    }

    /* TOAST */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--t1);
      color: #fff;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: all .22s;
      white-space: nowrap
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0)
    }

    /* RESPONSIVE */
    @media(max-width:1100px) {
      .stats {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    @media(max-width:1024px) {
      .mgrid {
        grid-template-columns: 1fr
      }
    }

    @media(max-width:768px) {
      .main {
        margin-left: 0 !important;
        min-width: 0
      }

      .sb {
        transform: translateX(calc(-1 * var(--sidebar-w)))
      }

      .nsrch {
        display: none
      }

      .avp span,
      .avp svg:last-child {
        display: none
      }

      .content {
        padding: 14px
      }

      .stats {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    @media(max-width:540px) {
      .content {
        padding: 10px
      }

      .pghdr {
        flex-direction: column;
        align-items: flex-start
      }

      .stats {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    ::-webkit-scrollbar {
      width: 4px;
      height: 4px
    }

    ::-webkit-scrollbar-track {
      background: transparent
    }

    ::-webkit-scrollbar-thumb {
      background: var(--brd);
      border-radius: 10px
    }
  </style>
</head>

<body>

  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,
    fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">

          <!-- Page header -->
          <div class="pghdr">
            <div>
              <h1>Monthly Summary</h1>
              <p>Collection report for your assigned stalls &mdash; <span id="pgSubMonth">
                  <%= currentMonth.label %>
                </span></p>
            </div>
            <button class="btn gh sm" onclick="showToast('Downloading PDF report...')">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
