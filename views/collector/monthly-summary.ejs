<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Monthly Summary</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/collector/monthly-summary.css">
</head>

<body>

  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,
    fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">

          <!-- Page header -->
          <div class="pghdr">
            <div>
              <h1>Monthly Summary</h1>
              <p>Collection report for your assigned stalls &mdash; <span id="pgSubMonth">
                  <%= currentMonth.label %>
                </span></p>
            </div>
            <button class="btn gh sm" onclick="showToast('Downloading PDF report...')">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              Download Report
            </button>
          </div>

          <!-- Month selector -->
          <div class="month-bar">
            <div class="month-nav">
              <div class="mnav-btn" onclick="changeMonth(-1)"><svg xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6" />
                </svg></div>
              <div class="month-label" id="monthLabel">
                <%= currentMonth.label %>
              </div>
              <div class="mnav-btn" onclick="changeMonth(1)"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6" />
                </svg></div>
            </div>
            <div class="month-bar-right">
              <select id="monthPicker"
                style="background:var(--s2);border:1px solid var(--brd);border-radius:var(--rs);padding:6px 10px;font-size:12.5px;font-family:'DM Sans',sans-serif;color:var(--t1);cursor:pointer;outline:none"
                onchange="jumpMonth(this.value)">
                <% monthOptions.forEach(opt=> { %>
                  <option value="<%= opt.value %>" <%=opt.value===currentMonth.key ? 'selected' : '' %>><%= opt.label %>
                  </option>
                  <% }) %>
              </select>
            </div>
          </div>

          <!-- Stat cards — JS-rendered (depend on selected month) -->
          <div class="stats" id="statsRow"></div>

          <!-- Main grid -->
          <div class="mgrid">

            <!-- LEFT -->
            <div>

              <!-- Section breakdown -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <line x1="3" y1="9" x2="21" y2="9" />
                        <line x1="3" y1="15" x2="21" y2="15" />
                        <line x1="9" y1="3" x2="9" y2="21" />
                        <line x1="15" y1="3" x2="15" y2="21" />
                      </svg>Collection by Section</div>
                    <div class="ph-sub">Breakdown of collected amounts per floor section</div>
                  </div>
                </div>
                <div id="sectionBreakdown"></div>
              </div>

              <!-- Payment method breakdown -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <rect x="1" y="4" width="22" height="16" rx="2" />
                        <line x1="1" y1="10" x2="23" y2="10" />
                      </svg>Payment Methods</div>
                    <div class="ph-sub">How vendors paid this month</div>
                  </div>
                </div>
                <div class="cbar-wrap" id="methodBars"></div>
              </div>

              <!-- Collection log table — structure in EJS, rows in JS -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>Collection Log</div>
                    <div class="ph-sub" id="logSub">All transactions this month</div>
                  </div>
                  <button class="btn gh xs" onclick="showToast('Printing log...')">Print</button>
                </div>
                <div class="tbl-wrap">
                  <table class="tbl">
                    <thead>
                      <tr>
                        <th>Date</th>
                        <th>OR No.</th>
                        <th>Vendor</th>
                        <th>Section</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Source</th>
                      </tr>
                    </thead>
                    <tbody id="logTbody"></tbody>
                  </table>
                </div>
                <div class="tbl-footer">
                  <span class="tbl-info" id="logInfo">--</span>
                  <button class="btn gh xs" onclick="showToast('Exporting CSV...')">Export CSV</button>
                </div>
              </div>

            </div>

            <!-- RIGHT -->
            <div>

              <!-- Total summary hero card -->
              <div class="print-card">
                <div class="print-card-title">Total Collected</div>
                <div class="print-card-val" id="totalVal">&#8369;0</div>
                <div class="print-card-sub" id="totalSub">Loading...</div>
              </div>

              <!-- Collection calendar heatmap -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg>Collection Days</div>
                    <div class="ph-sub">Daily collection heatmap</div>
                  </div>
                </div>
                <div class="cal-grid" id="calGrid"></div>
                <div class="cal-footer">
                  <div class="cal-legend">
                    <div class="cal-legend-item">
                      <div class="cal-swatch" style="background:var(--s2)"></div>None
                    </div>
                    <div class="cal-legend-item">
                      <div class="cal-swatch" style="background:#bbf7d0"></div>Low
                    </div>
                    <div class="cal-legend-item">
                      <div class="cal-swatch" style="background:#4ade80"></div>Mid
                    </div>
                    <div class="cal-legend-item">
                      <div class="cal-swatch" style="background:#16a34a"></div>High
                    </div>
                  </div>
                  <span style="font-size:11px;color:var(--t3)" id="calDaysCount">--</span>
                </div>
              </div>

              <!-- Outstanding balances -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path
                          d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                      </svg>Outstanding Balances</div>
                    <div class="ph-sub">Unpaid as of end of month</div>
                  </div>
                  <span class="bdg rd" id="outstandingBdg">--</span>
                </div>
                <div id="outstandingList"></div>
                <div class="tbl-footer">
                  <span class="tbl-info" id="outstandingTotal">--</span>
                </div>
              </div>

              <!-- Month-over-month comparison -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                      </svg>Month-over-Month</div>
                  </div>
                </div>
                <div id="momList"></div>
              </div>

            </div>
          </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <%# Inject all month data and initial index from server %>
      <script>
        const MONTHS = <%- JSON.stringify(months) %>;
        let MONTH_IDX = <%- initialMonthIdx %>;
      </script>

      <script src="/js/collector/monthly-summary.js"></script>
</body>

</html>