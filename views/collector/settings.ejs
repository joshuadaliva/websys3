<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Settings</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/collector/settings.css">
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,
    fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">
          <div class="pghdr">
            <h1>Settings</h1>
            <p>Customize how the app works for you</p>
          </div>

          <!-- Appearance -->
          <div class="scard">
            <div class="scard-head">
              <div class="scard-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="5" />
                  <line x1="12" y1="1" x2="12" y2="3" />
                  <line x1="12" y1="21" x2="12" y2="23" />
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                  <line x1="1" y1="12" x2="3" y2="12" />
                  <line x1="21" y1="12" x2="23" y2="12" />
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                </svg></div>
              <div>
                <div class="scard-ttl">Appearance</div>
                <div class="scard-sub">Display and visual preferences</div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Theme</div>
                <div class="s-desc">Choose between light, dark, or system default</div>
              </div>
              <div class="s-right">
                <div class="theme-opts">
                  <div class="th-opt th-light <%= settings.appearance.theme === 'light' ? 'on' : '' %>" id="th-light"
                    onclick="setTheme('light')" title="Light"></div>
                  <div class="th-opt th-dark  <%= settings.appearance.theme === 'dark'  ? 'on' : '' %>" id="th-dark"
                    onclick="setTheme('dark')" title="Dark"></div>
                  <div class="th-opt th-auto  <%= settings.appearance.theme === 'auto'  ? 'on' : '' %>" id="th-auto"
                    onclick="setTheme('auto')" title="System"></div>
                </div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Font Size</div>
                <div class="s-desc">Adjust text size for readability</div>
              </div>
              <div class="s-right">
                <div class="rgrp">
                  <div class="ropt <%= settings.appearance.fontSize === 'sm' ? 'on' : '' %>" id="fs-sm"
                    onclick="setFontSize('sm')">Small</div>
                  <div class="ropt <%= settings.appearance.fontSize === 'md' ? 'on' : '' %>" id="fs-md"
                    onclick="setFontSize('md')">Medium</div>
                  <div class="ropt <%= settings.appearance.fontSize === 'lg' ? 'on' : '' %>" id="fs-lg"
                    onclick="setFontSize('lg')">Large</div>
                </div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Compact Layout</div>
                <div class="s-desc">Reduce spacing to fit more content on screen</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.appearance.compactLayout ? 'on' : '' %>" id="tog-compact"
                  onclick="tog('compact')"></div>
              </div>
            </div>
          </div>

          <!-- Notifications -->
          <div class="scard">
            <div class="scard-head">
              <div class="scard-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                  <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg></div>
              <div>
                <div class="scard-ttl">Notifications</div>
                <div class="scard-sub">Control which alerts you receive</div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Payment Alerts</div>
                <div class="s-desc">Get notified when online payments are auto-detected for your stalls</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.notifications.paymentAlerts ? 'on' : '' %>" id="tog-npay"
                  onclick="tog('npay')"></div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Overdue Reminders</div>
                <div class="s-desc">Daily digest of overdue accounts on your route</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.notifications.overdueReminders ? 'on' : '' %>" id="tog-nover"
                  onclick="tog('nover')"></div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">System Announcements</div>
                <div class="s-desc">Route updates, admin messages, and maintenance notices</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.notifications.systemAnnouncements ? 'on' : '' %>" id="tog-nsys"
                  onclick="tog('nsys')"></div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Reminder Time</div>
                <div class="s-desc">When to send daily overdue digest</div>
              </div>
              <div class="s-right">
                <select class="s-select" onchange="showToast('Reminder time saved')">
                  <option <%=settings.notifications.reminderTime==='7:00 AM' ? 'selected' : '' %>>7:00 AM</option>
                  <option <%=settings.notifications.reminderTime==='8:00 AM' ? 'selected' : '' %>>8:00 AM</option>
                  <option <%=settings.notifications.reminderTime==='9:00 AM' ? 'selected' : '' %>>9:00 AM</option>
                  <option <%=settings.notifications.reminderTime==='12:00 PM' ? 'selected' : '' %>>12:00 PM</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Collection -->
          <div class="scard">
            <div class="scard-head">
              <div class="scard-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg></div>
              <div>
                <div class="scard-ttl">Collection</div>
                <div class="scard-sub">Payment and receipt preferences</div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Auto-fill Amount</div>
                <div class="s-desc">Pre-fill the amount field with the vendor balance when selecting a vendor</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.collection.autoFillAmount ? 'on' : '' %>" id="tog-autofill"
                  onclick="tog('autofill')"></div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">OR Number Format</div>
                <div class="s-desc">Format used when printing official receipts</div>
              </div>
              <div class="s-right">
                <div class="rgrp">
                  <div class="ropt <%= settings.collection.orFormat === 'num'  ? 'on' : '' %>" id="orf-num"
                    onclick="setORFormat('num')">OR-YYYY-0000</div>
                  <div class="ropt <%= settings.collection.orFormat === 'dash' ? 'on' : '' %>" id="orf-dash"
                    onclick="setORFormat('dash')">OR-0000</div>
                </div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Show Proof of Payment</div>
                <div class="s-desc">Show the upload field in the cash payment form by default</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.collection.showProofUpload ? 'on' : '' %>" id="tog-proof"
                  onclick="tog('proof')"></div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Default Payment Period</div>
                <div class="s-desc">Pre-select the current month in the payment form</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.collection.defaultPaymentPeriod ? 'on' : '' %>" id="tog-defperiod"
                  onclick="tog('defperiod')"></div>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="scard">
            <div class="scard-head">
              <div class="scard-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <polyline points="9 22 9 12 15 12 15 22" />
                </svg></div>
              <div>
                <div class="scard-ttl">Stall Map</div>
                <div class="scard-sub">Market floor plan preferences</div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Default Floor</div>
                <div class="s-desc">Which floor to show when opening My Stalls</div>
              </div>
              <div class="s-right">
                <select class="s-select" onchange="showToast('Default floor saved')">
                  <option <%=settings.map.defaultFloor==='Ground Floor' ? 'selected' : '' %>>Ground Floor</option>
                  <option <%=settings.map.defaultFloor==='Second Floor' ? 'selected' : '' %>>Second Floor</option>
                </select>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Highlight My Stalls</div>
                <div class="s-desc">Dim stalls not on your route to make yours stand out</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.map.highlightMyStalls ? 'on' : '' %>" id="tog-highlight"
                  onclick="tog('highlight')"></div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Show Tooltips</div>
                <div class="s-desc">Display vendor name and status on stall hover</div>
              </div>
              <div class="s-right">
                <div class="toggle <%= settings.map.showTooltips ? 'on' : '' %>" id="tog-tooltips"
                  onclick="tog('tooltips')"></div>
              </div>
            </div>
          </div>

          <!-- About -->
          <div class="scard">
            <div class="scard-head">
              <div class="scard-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="12" y1="8" x2="12" y2="12" />
                  <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg></div>
              <div>
                <div class="scard-ttl">About</div>
                <div class="scard-sub">Application info</div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Application</div>
              </div>
              <div class="s-right" style="font-size:13px;font-weight:600;color:var(--t2)">
                <%= settings.about.appName %>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Version</div>
              </div>
              <div class="s-right" style="font-size:13px;font-family:'DM Mono',monospace;color:var(--ac)">
                <%= settings.about.version %>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Market</div>
              </div>
              <div class="s-right" style="font-size:13px;font-weight:600;color:var(--t2)">
                <%= settings.about.market %>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Last Sync</div>
              </div>
              <div class="s-right" style="font-size:12.5px;color:var(--t3)">
                <%= settings.about.lastSync %>
              </div>
            </div>
          </div>

          <!-- Danger zone -->
          <div class="scard danger-zone">
            <div class="scard-head">
              <div class="scard-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                  <polyline points="16 17 21 12 16 7" />
                  <line x1="21" y1="12" x2="9" y2="12" />
                </svg></div>
              <div>
                <div class="scard-ttl" style="color:var(--rd)">Sign Out</div>
                <div class="scard-sub">End your current session</div>
              </div>
            </div>
            <div class="s-row">
              <div class="s-left">
                <div class="s-lbl">Sign out</div>
                <div class="s-desc">You will be redirected to the login page</div>
              </div>
              <div class="s-right"><button class="btn danger" onclick="showToast('Signed out')">Sign Out</button></div>
            </div>
          </div>

        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script src="/js/collector/settings.js"></script>
</body>

</html>