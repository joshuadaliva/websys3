<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ARKIPAISI &mdash; My Stalls</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f0f2f8;--surf:#fff;--s2:#f6f7fb;--s3:#eef0f7;
  --brd:#e2e6f0;--brd2:#eaecf5;
  --t1:#0c0f1e;--t2:#566080;--t3:#9099b8;
  --ac:#1d4ed8;--acl:#eff3ff;--acs:#c7d7fd;
  --gr:#15803d;--grl:#f0fdf4;--grs:#bbf7d0;
  --am:#b45309;--aml:#fffbeb;--ams:#fde68a;
  --rd:#b91c1c;--rdl:#fff1f2;--rds:#fecdd3;
  --cy:#0e7490;--cyl:#ecfeff;--cys:#a5f3fc;
  --sidebar-w:240px;--r:12px;--rs:7px;
  --sh:0 1px 3px rgba(12,18,60,.06),0 1px 2px rgba(12,18,60,.04);
  --shm:0 4px 16px rgba(12,18,60,.09),0 2px 5px rgba(12,18,60,.05);
  --shl:0 16px 48px rgba(12,18,60,.14),0 4px 12px rgba(12,18,60,.07);
}
html.dark{--bg:#080b15;--surf:#10152a;--s2:#151c32;--s3:#1c2440;--brd:#202844;--brd2:#1a2238;--t1:#e0e6f8;--t2:#6878a8;--t3:#384060;--ac:#4a6ef5;--acl:#171e48;--acs:#1f2e80;--grl:#061410;--grs:#0f3020;--aml:#150e00;--ams:#381e00;--rdl:#150408;--rds:#380412;--sh:0 1px 3px rgba(0,0,0,.4);--shm:0 4px 16px rgba(0,0,0,.5)}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t1);display:flex;min-height:100vh;overflow-x:hidden}

/* SIDEBAR */
.sb{width:var(--sidebar-w);min-height:100vh;background:var(--surf);border-right:1px solid var(--brd);display:flex;flex-direction:column;position:fixed;left:0;top:0;z-index:60;transition:transform .28s cubic-bezier(.4,0,.2,1)}
.sb-logo{height:56px;padding:0 16px 0 20px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-m{width:32px;height:32px;background:var(--ac);border-radius:8px;display:grid;place-items:center;color:#fff;font-size:12px;font-weight:800;flex-shrink:0}
.logo-n{font-size:14px;font-weight:800;letter-spacing:-.3px}
.logo-sub{font-size:9.5px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-top:1px}
.sb-x{width:26px;height:26px;border-radius:6px;border:1px solid var(--brd);background:var(--s2);display:grid;place-items:center;cursor:pointer;color:var(--t2);flex-shrink:0;transition:all .14s}
.sb-x:hover{background:var(--rdl);color:var(--rd);border-color:var(--rds)}
.sb-x svg{width:13px;height:13px}
.sb-nav{flex:1;padding:10px 8px;overflow-y:auto}
.nsec{font-size:9.5px;font-weight:700;color:var(--t3);letter-spacing:.9px;text-transform:uppercase;padding:10px 10px 4px;margin-top:4px}
.ni{display:flex;align-items:center;gap:9px;padding:8px 12px;border-radius:var(--rs);color:var(--t2);cursor:pointer;font-size:13px;font-weight:500;transition:all .14s;margin-bottom:1px}
.ni:hover{background:var(--s2);color:var(--t1)}
.ni.on{background:var(--acl);color:var(--ac);font-weight:600}
.ni svg{width:15px;height:15px;flex-shrink:0}
.nbdg{margin-left:auto;font-size:10px;font-weight:700;padding:1px 6px;border-radius:8px;font-family:'DM Mono',monospace;background:var(--rds);color:var(--rd)}
.nbdg.am{background:var(--ams);color:var(--am)}
.sb-foot{padding:12px 8px;border-top:1px solid var(--brd);flex-shrink:0}
.urow{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:var(--rs);cursor:pointer;transition:background .14s}
.urow:hover{background:var(--s2)}
.uav{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--gr),var(--cy));display:grid;place-items:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0}
.veil{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:55;cursor:pointer}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;margin-left:var(--sidebar-w);min-height:100vh;transition:margin-left .28s cubic-bezier(.4,0,.2,1);min-width:0;overflow-x:hidden}

/* NAV */
.nav{height:56px;background:var(--surf);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 16px;gap:10px;position:sticky;top:0;z-index:40;flex-shrink:0}
.togbtn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surf);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0}
.togbtn:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}
.togbtn svg{width:15px;height:15px}
.nav-info{flex:1;min-width:0}
.nav-ttl{font-size:14px;font-weight:700;letter-spacing:-.2px}
.nav-bc{font-size:11px;color:var(--t3)}
.nav-r{display:flex;align-items:center;gap:7px;flex-shrink:0}
.nsrch{display:flex;align-items:center;gap:7px;background:var(--s2);border:1px solid var(--brd);border-radius:var(--rs);padding:6px 10px;font-size:12px;color:var(--t3);cursor:text;min-width:160px}
.nsrch svg{width:12px;height:12px;flex-shrink:0}
.nico{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surf);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0;position:relative}
.nico:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}
.nico svg{width:14px;height:14px}
.nico-dot{position:absolute;top:5px;right:5px;width:7px;height:7px;background:var(--rd);border-radius:50%;border:1.5px solid var(--surf)}
.avp{display:flex;align-items:center;gap:7px;padding:3px 10px 3px 3px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surf);cursor:pointer;flex-shrink:0}
.avp-a{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--gr),var(--cy));display:grid;place-items:center;color:#fff;font-size:9px;font-weight:700}

/* CONTENT */
.content{padding:20px;flex:1}
.pghdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:12px}
.pghdr h1{font-size:20px;font-weight:800;letter-spacing:-.5px}
.pghdr p{font-size:13px;color:var(--t3);margin-top:3px}

/* SUMMARY STRIP */
.sum-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:11px;margin-bottom:18px}
.sum-card{background:var(--surf);border:1px solid var(--brd);border-radius:var(--r);padding:12px 15px;box-shadow:var(--sh)}
.sum-val{font-size:19px;font-weight:800;font-family:'DM Mono',monospace;letter-spacing:-.5px}
.sum-lbl{font-size:11px;color:var(--t3);margin-top:3px;font-weight:500}

/* FLOOR TABS */
.floor-tabs{display:flex;gap:2px;background:var(--s2);border:1px solid var(--brd);border-radius:var(--r);padding:4px;margin-bottom:16px;width:fit-content}
.floor-tab{padding:7px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;color:var(--t2);transition:all .14s;white-space:nowrap}
.floor-tab:hover{color:var(--t1)}
.floor-tab.on{background:var(--surf);color:var(--t1);box-shadow:var(--sh)}

/* MAP CONTAINER */
.map-container{background:var(--surf);border:1px solid var(--brd);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden;margin-bottom:16px}
.map-header{padding:13px 18px;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.map-title{font-size:13px;font-weight:700}
.map-legend{display:flex;gap:12px;flex-wrap:wrap}
.map-legend-item{display:flex;align-items:center;gap:5px;font-size:11.5px;color:var(--t2)}
.map-legend-swatch{width:11px;height:11px;border-radius:3px;flex-shrink:0}
.map-body{padding:18px;overflow-x:auto}

/* FLOOR PLAN */
.floor-plan{position:relative;min-width:800px}
.fp-room{background:var(--s2);border:1.5px solid var(--brd);border-radius:6px;display:flex;align-items:center;justify-content:center;text-align:center;font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;line-height:1.3;padding:6px 4px}
.fp-room.dashed{border-style:dashed}
.fp-room.ramp{border-style:dashed;font-size:14px;font-weight:800;color:var(--ac);letter-spacing:2px}
.fp-sec-lbl{font-size:9.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px;padding-bottom:4px;border-bottom:1px solid var(--brd2)}
.fp-section{display:inline-flex;flex-direction:column;background:var(--s2);border:1px solid var(--brd);border-radius:8px;padding:8px;gap:4px}
.fp-row{display:flex;gap:4px}

/* STALL CELLS */
.stall{width:52px;height:52px;border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:'DM Mono',monospace;font-size:13px;font-weight:800;border:2px solid transparent;transition:all .14s;position:relative;flex-shrink:0;cursor:default}
.stall.mine{cursor:pointer}
.stall.mine:hover{transform:scale(1.1);z-index:5}
.stall.mine.active{box-shadow:0 0 0 3px var(--ac);transform:scale(1.12);z-index:6}
.stall.paid{background:var(--grl);border-color:var(--grs);color:var(--gr)}
.stall.paid:hover{border-color:var(--gr)}
.stall.overdue{background:var(--rdl);border-color:var(--rds);color:var(--rd)}
.stall.overdue:hover{border-color:var(--rd)}
.stall.partial{background:var(--aml);border-color:var(--ams);color:var(--am)}
.stall.partial:hover{border-color:var(--am)}
.stall.vacant{background:var(--s3);border-color:var(--brd);color:var(--t3)}
.stall.other{background:var(--s2);border-color:var(--brd2);color:var(--t3);opacity:.4}
.stall.eatery{background:#fef3c7;border-color:#d97706;color:#92400e}
.stall.rtw{background:#f0f9ff;border-color:#0ea5e9;color:#0369a1}
.stall.service{background:#f0fdf4;border-color:#16a34a;color:#14532d}
.stall.footwear{background:#faf5ff;border-color:#9333ea;color:#581c87}
.stall.misc{background:#fff1f2;border-color:#e11d48;color:#881337}
.stall.ukay{background:#fef9c3;border-color:#ca8a04;color:#78350f}
.stall.veggie{background:#f0fdf4;border-color:#16a34a;color:#14532d}
.stall.fruit{background:#dcfce7;border-color:#22c55e;color:#15803d}
.stall.egg{background:#fffbeb;border-color:#f59e0b;color:#78350f}
.stall-dot{position:absolute;top:3px;right:3px;width:7px;height:7px;border-radius:50%;border:1.5px solid var(--surf)}
.stall.overdue .stall-dot{background:var(--rd)}
.stall.partial .stall-dot{background:var(--am)}

/* TOOLTIP */
.tt{position:relative}
.tt::before{content:attr(data-tip);position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:var(--t1);color:#fff;font-size:10.5px;font-weight:600;white-space:nowrap;padding:5px 9px;border-radius:6px;pointer-events:none;opacity:0;transition:opacity .14s;z-index:200;font-family:'DM Sans',sans-serif}
.tt::after{content:'';position:absolute;bottom:calc(100% + 1px);left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:var(--t1);pointer-events:none;opacity:0;transition:opacity .14s}
.tt:hover::before,.tt:hover::after{opacity:1}

/* DETAIL PANEL */
.detail-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:100;display:none;cursor:pointer}
.detail-overlay.open{display:block}
.detail-panel{position:fixed;top:0;right:0;height:100vh;width:380px;background:var(--surf);border-left:1.5px solid var(--brd);box-shadow:var(--shl);z-index:101;transform:translateX(100%);transition:transform .28s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;overflow:hidden}
.detail-panel.open{transform:translateX(0)}
.dp-head{padding:15px 18px;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between;gap:10px;flex-shrink:0}
.dp-title{font-size:15px;font-weight:800;letter-spacing:-.3px}
.dp-x{width:28px;height:28px;border-radius:6px;border:1px solid var(--brd);background:var(--s2);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0}
.dp-x:hover{background:var(--rdl);color:var(--rd);border-color:var(--rds)}
.dp-x svg{width:13px;height:13px}
.dp-body{flex:1;overflow-y:auto;padding:18px}
.dp-foot{padding:13px 18px;border-top:1px solid var(--brd);background:var(--s2);display:flex;gap:8px;flex-shrink:0}
.stall-hero{border-radius:10px;padding:14px;margin-bottom:14px}
.stall-hero-num{font-size:38px;font-weight:900;font-family:'DM Mono',monospace;letter-spacing:-2px;line-height:1}
.stall-hero-meta{font-size:12px;margin-top:4px;opacity:.75}
.d-sec{margin-bottom:14px}
.d-sec-lbl{font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px}
.d-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--brd2)}
.d-row:last-child{border-bottom:none;padding-bottom:0}
.d-lbl{font-size:12px;color:var(--t2);font-weight:500}
.d-val{font-size:13px;font-weight:700}
.d-val.mono{font-family:'DM Mono',monospace}
.d-val.gr{color:var(--gr)}
.d-val.rd{color:var(--rd)}
.d-val.am{color:var(--am)}
.ph-item{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--brd2);gap:8px}
.ph-item:last-child{border-bottom:none;padding-bottom:0}

/* BADGES */
.bdg{display:inline-flex;align-items:center;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap}
.bdg.gr{background:var(--grs);color:var(--gr)}
.bdg.am{background:var(--ams);color:var(--am)}
.bdg.rd{background:var(--rds);color:var(--rd)}
.bdg.ac{background:var(--acs);color:var(--ac)}
.bdg.gy{background:var(--s3);color:var(--t3)}

/* BUTTONS */
.btn{padding:8px 16px;border-radius:var(--rs);font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px;transition:all .14s}
.btn svg{width:13px;height:13px;flex-shrink:0}
.btn.pri{background:var(--ac);color:#fff}
.btn.gr{background:var(--gr);color:#fff}
.btn.gh{background:var(--surf);border:1px solid var(--brd);color:var(--t2)}
.btn.gh:hover{border-color:var(--ac);color:var(--ac)}
.btn.sm{padding:6px 12px;font-size:12px}

/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(8px);background:var(--t1);color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;z-index:999;opacity:0;pointer-events:none;transition:all .22s;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* RESPONSIVE */
@media(max-width:768px){
  .main{margin-left:0!important;min-width:0}
  .sb{transform:translateX(calc(-1 * var(--sidebar-w)))}
  .nsrch{display:none}
  .avp span,.avp svg:last-child{display:none}
  .content{padding:14px}
  .sum-strip{grid-template-columns:repeat(3,1fr)}
  .detail-panel{width:100%;border-left:none;top:auto;bottom:0;height:88vh;transform:translateY(100%);border-radius:14px 14px 0 0}
  .detail-panel.open{transform:translateY(0)}
}
@media(max-width:540px){.content{padding:10px}.sum-strip{grid-template-columns:repeat(2,1fr)}}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--brd);border-radius:10px}
</style>
</head>
<body>

<div class="veil" id="veil" onclick="closeSB()"></div>

<%- include('../partials/sidebar.ejs') %>

<div class="main" id="main">
  <%- include('../partials/header.ejs') %>

  <div class="content">
    <div class="pghdr">
      <div>
        <h1>My Stalls</h1>
        <p>Pili Public Market Building (PPMB-23) &mdash; Your assigned collection route</p>
      </div>
      <button class="btn gh sm" onclick="showToast('Downloading route...')">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export
      </button>
    </div>

    <!-- Summary strip — server-rendered counts -->
    <div class="sum-strip">
      <div class="sum-card"><div class="sum-val" style="color:var(--ac)"><%= summary.total %></div><div class="sum-lbl">Total Assigned</div></div>
      <div class="sum-card"><div class="sum-val" style="color:var(--gr)"><%= summary.paid %></div><div class="sum-lbl">Paid</div></div>
      <div class="sum-card"><div class="sum-val" style="color:var(--rd)"><%= summary.overdue %></div><div class="sum-lbl">Overdue</div></div>
      <div class="sum-card"><div class="sum-val" style="color:var(--am)"><%= summary.partial %></div><div class="sum-lbl">Partial</div></div>
      <div class="sum-card"><div class="sum-val" style="color:var(--t3)"><%= summary.vacant %></div><div class="sum-lbl">Vacant</div></div>
    </div>

    <!-- Floor tabs -->
    <div class="floor-tabs">
      <div class="floor-tab on" onclick="setFloor('gf',this)">Ground Floor</div>
      <div class="floor-tab" onclick="setFloor('sf',this)">Second Floor</div>
    </div>

    <!-- Ground Floor -->
    <div id="floor-gf">
      <div class="map-container">
        <div class="map-header">
          <div class="map-title">Ground Floor &mdash; PPMB-23</div>
          <div class="map-legend">
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--grl);border:2px solid var(--grs)"></div>Paid (Mine)</div>
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--rdl);border:2px solid var(--rds)"></div>Overdue</div>
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--aml);border:2px solid var(--ams)"></div>Partial</div>
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--s2);border:2px solid var(--brd2);opacity:.5"></div>Other</div>
          </div>
        </div>
        <div class="map-body"><div class="floor-plan" id="gfPlan"></div></div>
      </div>
    </div>

    <!-- Second Floor -->
    <div id="floor-sf" style="display:none">
      <div class="map-container">
        <div class="map-header">
          <div class="map-title">Second Floor &mdash; PPMB-23</div>
          <div class="map-legend">
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--grl);border:2px solid var(--grs)"></div>Paid (Mine)</div>
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--rdl);border:2px solid var(--rds)"></div>Overdue</div>
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--aml);border:2px solid var(--ams)"></div>Partial</div>
            <div class="map-legend-item"><div class="map-legend-swatch" style="background:var(--s2);border:2px solid var(--brd2);opacity:.5"></div>Other</div>
          </div>
        </div>
        <div class="map-body"><div class="floor-plan" id="sfPlan"></div></div>
      </div>
    </div>
  </div>
</div>

<!-- DETAIL PANEL -->
<div class="detail-overlay" id="detailOverlay" onclick="closeDetail()"></div>
<div class="detail-panel" id="detailPanel">
  <div class="dp-head">
    <div class="dp-title" id="dpTitle">Stall Details</div>
    <div class="dp-x" onclick="closeDetail()">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </div>
  </div>
  <div class="dp-body" id="dpBody"></div>
  <div class="dp-foot" id="dpFoot"></div>
</div>

<div class="toast" id="toast"></div>

<%# Inject server-side stall data as a JS variable %>
<script>
  const STALLS = <%- JSON.stringify(stalls) %>;
</script>

<script>
/* ═══ SIDEBAR ═══ */
let SB_OPEN = window.innerWidth >= 768;
let DARK = false;

function openSB() {
  SB_OPEN = true;
  document.getElementById('sb').style.transform = 'translateX(0)';
  if (window.innerWidth < 768) {
    document.getElementById('veil').style.display = 'block';
    document.getElementById('main').style.marginLeft = '0';
  } else {
    document.getElementById('veil').style.display = 'none';
    document.getElementById('main').style.marginLeft = 'var(--sidebar-w)';
  }
}
function closeSB() {
  SB_OPEN = false;
  document.getElementById('sb').style.transform = 'translateX(calc(-1 * var(--sidebar-w)))';
  document.getElementById('veil').style.display = 'none';
  document.getElementById('main').style.marginLeft = '0';
}
function toggleSB() { SB_OPEN ? closeSB() : openSB(); }

(function () {
  if (window.innerWidth < 768) closeSB(); else openSB();
  window.addEventListener('resize', function () {
    if (window.innerWidth >= 768) {
      document.getElementById('veil').style.display = 'none';
      if (SB_OPEN) document.getElementById('main').style.marginLeft = 'var(--sidebar-w)';
    } else {
      document.getElementById('main').style.marginLeft = '0';
      if (SB_OPEN) document.getElementById('veil').style.display = 'block';
    }
  });
})();

function toggleTheme() {
  DARK = !DARK;
  document.documentElement.classList.toggle('dark', DARK);
  const ico = document.getElementById('themeIco');
  ico.innerHTML = DARK
    ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'
    : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
}

/* ═══ FLOOR TABS ═══ */
function setFloor(id, el) {
  document.getElementById('floor-gf').style.display = id === 'gf' ? 'block' : 'none';
  document.getElementById('floor-sf').style.display = id === 'sf' ? 'block' : 'none';
  document.querySelectorAll('.floor-tab').forEach(t => t.classList.remove('on'));
  if (el) el.classList.add('on');
  closeDetail();
}

/* ═══ STALL HELPERS ═══ */
function sc(id) {
  const s = STALLS[id];
  if (!s) {
    const num = id.split('-').pop();
    return `<div class="stall other tt" data-tip="Stall ${num} - Other route"><span>${num}</span></div>`;
  }
  const cls = s.mine ? s.status : 'other';
  const tip = `Stall ${s.num} - ${s.section} - ${s.vendor || 'Vacant'}`
    + (s.mine && s.status === 'overdue' ? ` - ${s.overdueDays} days overdue` : '')
    + (s.mine && s.status === 'partial' ? ` - Balance PHP ${s.balance}` : '')
    + (!s.mine ? ' (not your route)' : '');
  const dot = (s.mine && (s.status === 'overdue' || s.status === 'partial')) ? '<div class="stall-dot"></div>' : '';
  const click = s.mine ? ` onclick="openDetail('${id}')"` : '';
  return `<div class="stall ${cls}${s.mine ? ' mine' : ''} tt" data-tip="${tip}" id="st-${id}"${click}><span>${s.num}</span>${dot}</div>`;
}

function row(ids) { return '<div class="fp-row">' + ids.map(sc).join('') + '</div>'; }
function section(label, rows) { return `<div class="fp-section"><div class="fp-sec-lbl">${label}</div>${rows.join('')}</div>`; }
function room(label, w, h, extra = '') { return `<div class="fp-room${extra}" style="width:${w}px;height:${h}px">${label}</div>`; }

