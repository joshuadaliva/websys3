<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; My Stalls</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/collector/my-stalls.css">
</head>

<body>

  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,
    fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">
          <div class="pghdr">
            <div>
              <h1>My Stalls</h1>
              <p>Pili Public Market Building (PPMB-23) &mdash; Your assigned collection route</p>
            </div>
            <button class="btn gh sm" onclick="showToast('Downloading route...')">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              Export
            </button>
          </div>

          <!-- Summary strip — server-rendered counts -->
          <div class="sum-strip">
            <div class="sum-card">
              <div class="sum-val" style="color:var(--ac)">
                <%= summary.total %>
              </div>
              <div class="sum-lbl">Total Assigned</div>
            </div>
            <div class="sum-card">
              <div class="sum-val" style="color:var(--gr)">
                <%= summary.paid %>
              </div>
              <div class="sum-lbl">Paid</div>
            </div>
            <div class="sum-card">
              <div class="sum-val" style="color:var(--rd)">
                <%= summary.overdue %>
              </div>
              <div class="sum-lbl">Overdue</div>
            </div>
            <div class="sum-card">
              <div class="sum-val" style="color:var(--am)">
                <%= summary.partial %>
              </div>
              <div class="sum-lbl">Partial</div>
            </div>
            <div class="sum-card">
              <div class="sum-val" style="color:var(--t3)">
                <%= summary.vacant %>
              </div>
              <div class="sum-lbl">Vacant</div>
            </div>
          </div>

          <!-- Floor tabs -->
          <div class="floor-tabs">
            <div class="floor-tab on" onclick="setFloor('gf',this)">Ground Floor</div>
            <div class="floor-tab" onclick="setFloor('sf',this)">Second Floor</div>
          </div>

          <!-- Ground Floor -->
          <div id="floor-gf">
            <div class="map-container">
              <div class="map-header">
                <div class="map-title">Ground Floor &mdash; PPMB-23</div>
                <div class="map-legend">
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--grl);border:2px solid var(--grs)"></div>Paid
                    (Mine)
                  </div>
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--rdl);border:2px solid var(--rds)"></div>
                    Overdue
                  </div>
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--aml);border:2px solid var(--ams)"></div>
                    Partial
                  </div>
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--s2);border:2px solid var(--brd2);opacity:.5">
                    </div>Other
                  </div>
                </div>
              </div>
              <div class="map-body">
                <div class="floor-plan" id="gfPlan"></div>
              </div>
            </div>
          </div>

          <!-- Second Floor -->
          <div id="floor-sf" style="display:none">
            <div class="map-container">
              <div class="map-header">
                <div class="map-title">Second Floor &mdash; PPMB-23</div>
                <div class="map-legend">
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--grl);border:2px solid var(--grs)"></div>Paid
                    (Mine)
                  </div>
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--rdl);border:2px solid var(--rds)"></div>
                    Overdue
                  </div>
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--aml);border:2px solid var(--ams)"></div>
                    Partial
                  </div>
                  <div class="map-legend-item">
                    <div class="map-legend-swatch" style="background:var(--s2);border:2px solid var(--brd2);opacity:.5">
                    </div>Other
                  </div>
                </div>
              </div>
              <div class="map-body">
                <div class="floor-plan" id="sfPlan"></div>
              </div>
            </div>
          </div>
        </div>
    </div>

    <!-- DETAIL PANEL -->
    <div class="detail-overlay" id="detailOverlay" onclick="closeDetail()"></div>
    <div class="detail-panel" id="detailPanel">
      <div class="dp-head">
        <div class="dp-title" id="dpTitle">Stall Details</div>
        <div class="dp-x" onclick="closeDetail()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </div>
      </div>
      <div class="dp-body" id="dpBody"></div>
      <div class="dp-foot" id="dpFoot"></div>
    </div>

    <div class="toast" id="toast"></div>

    <%# Inject server-side stall data as a JS variable %>
      <script>
        const STALLS = <%- JSON.stringify(stalls) %>;
      </script>

      <script src="/js/collector/my-stalls.js"></script>
</body>

</html>