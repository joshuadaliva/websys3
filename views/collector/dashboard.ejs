                  <div class="act-time">11:15 AM &middot; OR-2026-0845</div>
                </div>
              </div>
              <div class="act-item">
                <div class="act-dot ac"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <rect x="5" y="2" width="14" height="20" rx="2" />
                    <line x1="12" y1="18" x2="12.01" y2="18" />
                  </svg></div>
                <div class="act-body">
                  <div class="act-text"><strong>GCash payment</strong> &mdash; Ana Lim, Stall #19, &#8369;1,500 via Maya
                  </div>
                  <div class="act-time">10:28 AM &middot; OR-2026-0844</div>
                </div>
              </div>
              <div class="act-item">
                <div class="act-dot am"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07" />
                  </svg></div>
                <div class="act-body">
                  <div class="act-text"><strong>SMS reminder sent</strong> &mdash; Grace Cruz, Stall #09 overdue notice
                  </div>
                  <div class="act-time">09:00 AM &middot; Automated</div>
                </div>
              </div>
              <div class="act-item">
                <div class="act-dot gr"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12" />
                  </svg></div>
                <div class="act-body">
                  <div class="act-text"><strong>Payment recorded</strong> &mdash; Maria Santos, Stall #07, &#8369;1,000
                    cash</div>
                  <div class="act-time">10:02 AM &middot; OR-2026-0843</div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ═══ RECORD PAYMENT MODAL ═══ -->
  <div class="modal-bg" id="paymentModal">
    <div class="modal">
      <div class="modal-head">
        <div class="modal-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <line x1="12" y1="1" x2="12" y2="23" />
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
          </svg>Record Payment</div>
        <div class="modal-x" onclick="closeModal('paymentModal')"><svg xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="modal-body">
        <div class="infobox bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          <div>An Official Receipt will be auto-generated after saving.</div>
        </div>
        <div class="fgrid">
          <div class="fg"><label>Vendor / Stall</label>
            <select class="finp" id="pm-vendor">
              <option value="">-- Select Vendor --</option>
              <option>Juan Dela Cruz &mdash; Stall #01</option>
              <option>Pedro Reyes &mdash; Stall #03</option>
              <option>Maria Santos &mdash; Stall #07</option>
              <option>Ana Lim &mdash; Stall #19</option>
              <option>Roberto Go &mdash; Stall #24</option>
              <option>Carla Bautista &mdash; Stall #06</option>
              <option>Luis Villanueva &mdash; Stall #11</option>
              <option>Grace Cruz &mdash; Stall #09</option>
              <option>Diego Cruz &mdash; Stall #15</option>
            </select>
          </div>
          <div class="fg"><label>Payment Period</label>
            <select class="finp" id="pm-period">
              <option selected>March 2026</option>
              <option>February 2026</option>
              <option>January 2026</option>
            </select>
          </div>
        </div>
        <div class="fgrid">
          <div class="fg"><label>Amount (PHP)</label>
            <div class="pfx"><span class="pfx-lbl">&#8369;</span><input class="finp" id="pm-amount" type="number"
                min="0" step="50" placeholder="0.00" /></div>
          </div>
          <div class="fg"><label>Payment Method</label>
            <select class="finp" id="pm-method">
              <option>Cash</option>
              <option>GCash</option>
              <option>Maya (PayMaya)</option>
              <option>Bank Transfer</option>
            </select>
          </div>
        </div>
        <div class="fgrid">
          <div class="fg"><label>Date Paid</label><input class="finp" id="pm-date" type="date" /></div>
          <div class="fg"><label>OR Number</label><input class="finp" id="pm-or" placeholder="Auto-generated" readonly
              style="background:var(--s3);color:var(--t3)" /></div>
        </div>
        <div class="fgrid full">
          <div class="fg"><label>Remarks (optional)</label><input class="finp" id="pm-remarks"
              placeholder="e.g. Partial payment, installment 1 of 2" /></div>
        </div>
      </div>
      <div class="modal-foot">
        <button class="btn gh sm" onclick="closeModal('paymentModal')">Cancel</button>
        <button class="btn gr sm" onclick="savePayment()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12" />
          </svg>Save &amp; Issue OR</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script src="/js/collector/dashboard.js"></script>
</body>

</html>