<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Payments</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --bg: #f0f2f8;
      --surf: #fff;
      --s2: #f6f7fb;
      --s3: #eef0f7;
      --brd: #e2e6f0;
      --brd2: #eaecf5;
      --t1: #0c0f1e;
      --t2: #566080;
      --t3: #9099b8;
      --ac: #1d4ed8;
      --acl: #eff3ff;
      --acs: #c7d7fd;
      --gr: #15803d;
      --grl: #f0fdf4;
      --grs: #bbf7d0;
      --am: #b45309;
      --aml: #fffbeb;
      --ams: #fde68a;
      --rd: #b91c1c;
      --rdl: #fff1f2;
      --rds: #fecdd3;
      --vi: #6d28d9;
      --vil: #f5f3ff;
      --vis: #ddd6fe;
      --cy: #0e7490;
      --cyl: #ecfeff;
      --cys: #a5f3fc;
      --or: #c2410c;
      --orl: #fff7ed;
      --ors: #fed7aa;
      --sidebar-w: 240px;
      --r: 12px;
      --rs: 7px;
      --sh: 0 1px 3px rgba(12, 18, 60, .06), 0 1px 2px rgba(12, 18, 60, .04);
      --shm: 0 4px 16px rgba(12, 18, 60, .09), 0 2px 5px rgba(12, 18, 60, .05);
      --shl: 0 16px 48px rgba(12, 18, 60, .14), 0 4px 12px rgba(12, 18, 60, .07);
    }

    html.dark {
      --bg: #080b15;
      --surf: #10152a;
      --s2: #151c32;
      --s3: #1c2440;
      --brd: #202844;
      --brd2: #1a2238;
      --t1: #e0e6f8;
      --t2: #6878a8;
      --t3: #384060;
      --ac: #4a6ef5;
      --acl: #171e48;
      --acs: #1f2e80;
      --grl: #061410;
      --grs: #0f3020;
      --aml: #150e00;
      --ams: #381e00;
      --rdl: #150408;
      --rds: #380412;
      --sh: 0 1px 3px rgba(0, 0, 0, .4);
      --shm: 0 4px 16px rgba(0, 0, 0, .5);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--t1);
      display: flex;
      min-height: 100vh;
      overflow-x: hidden
    }

    /* SIDEBAR */
    .sb {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--surf);
      border-right: 1px solid var(--brd);
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0;
      top: 0;
      z-index: 60;
      transition: transform .28s cubic-bezier(.4, 0, .2, 1)
    }

    .sb-logo {
      height: 56px;
      padding: 0 16px 0 20px;
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0
    }

    .logo-m {
      width: 32px;
      height: 32px;
      background: var(--ac);
      border-radius: 8px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 12px;
      font-weight: 800;
      flex-shrink: 0
    }

    .logo-n {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -.3px
    }

    .logo-sub {
      font-size: 9.5px;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-top: 1px
    }

    .sb-x {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      border: 1px solid var(--brd);
      background: var(--s2);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      flex-shrink: 0;
      transition: all .14s
    }

    .sb-x:hover {
      background: var(--rdl);
      color: var(--rd);
      border-color: var(--rds)
    }

    .sb-x svg {
      width: 13px;
      height: 13px
    }

    .sb-nav {
      flex: 1;
      padding: 10px 8px;
      overflow-y: auto
    }

    .nsec {
      font-size: 9.5px;
      font-weight: 700;
      color: var(--t3);
      letter-spacing: .9px;
      text-transform: uppercase;
      padding: 10px 10px 4px;
      margin-top: 4px
    }

    .ni {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      border-radius: var(--rs);
      color: var(--t2);
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      transition: all .14s;
      margin-bottom: 1px
    }

    .ni:hover {
      background: var(--s2);
      color: var(--t1)
    }

    .ni.on {
      background: var(--acl);
      color: var(--ac);
      font-weight: 600
    }

    .ni svg {
      width: 15px;
      height: 15px;
      flex-shrink: 0
    }

    .nbdg {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 8px;
      font-family: 'DM Mono', monospace;
      background: var(--rds);
      color: var(--rd)
    }

    .nbdg.am {
      background: var(--ams);
      color: var(--am)
    }

    .nbdg.gr {
      background: var(--grs);
      color: var(--gr)
    }

    .sb-foot {
      padding: 12px 8px;
      border-top: 1px solid var(--brd);
      flex-shrink: 0
    }

    .urow {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 9px 12px;
      border-radius: var(--rs);
      cursor: pointer;
      transition: background .14s
    }

    .urow:hover {
      background: var(--s2)
    }

    .uav {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gr), var(--cy));
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0
    }

    .veil {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      z-index: 55;
      cursor: pointer
    }

    /* MAIN */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      transition: margin-left .28s cubic-bezier(.4, 0, .2, 1);
      min-width: 0;
      overflow-x: hidden
    }

    /* NAV */
    .nav {
      height: 56px;
      background: var(--surf);
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 10px;
      position: sticky;
      top: 0;
      z-index: 40;
      flex-shrink: 0
    }

    .togbtn {
      width: 32px;
      height: 32px;
      border-radius: var(--rs);
      border: 1px solid var(--brd);
      background: var(--surf);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      transition: all .14s;
      flex-shrink: 0
    }

    .togbtn:hover {
      border-color: var(--ac);
      color: var(--ac);
      background: var(--acl)
    }

    .togbtn svg {
      width: 15px;
      height: 15px
    }

    .nav-info {
      flex: 1;
      min-width: 0
    }

    .nav-ttl {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: -.2px
    }

    .nav-bc {
      font-size: 11px;
      color: var(--t3)
    }

    .nav-r {
      display: flex;
      align-items: center;
      gap: 7px;
      flex-shrink: 0
    }

    .nsrch {
      display: flex;
      align-items: center;
      gap: 7px;
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 6px 10px;
      font-size: 12px;
      color: var(--t3);
      cursor: text;
      min-width: 170px
    }

    .nsrch svg {
      width: 12px;
      height: 12px;
      flex-shrink: 0
    }

    .nsrch kbd {
      margin-left: auto;
      font-size: 10px;
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: 3px;
      padding: 1px 5px;
      font-family: 'DM Mono', monospace
    }

    .nico {
      width: 32px;
      height: 32px;
      border-radius: var(--rs);
      border: 1px solid var(--brd);
      background: var(--surf);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      transition: all .14s;
      flex-shrink: 0;
      position: relative
    }

    .nico:hover {
      border-color: var(--ac);
      color: var(--ac);
      background: var(--acl)
    }

    .nico svg {
      width: 14px;
      height: 14px
    }

    .nico-dot {
      position: absolute;
      top: 5px;
      right: 5px;
      width: 7px;
      height: 7px;
      background: var(--rd);
      border-radius: 50%;
      border: 1.5px solid var(--surf)
    }

    .avp {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 3px 10px 3px 3px;
      border-radius: var(--rs);
      border: 1px solid var(--brd);
      background: var(--surf);
      cursor: pointer;
      flex-shrink: 0
    }

    .avp-a {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gr), var(--cy));
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 9px;
      font-weight: 700
    }

    /* CONTENT */
    .content {
      padding: 20px;
      flex: 1
    }

    .pghdr {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 12px
    }

    .pghdr h1 {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -.5px
    }

    .pghdr p {
      font-size: 13px;
      color: var(--t3);
      margin-top: 3px
    }

    /* STAT CARDS */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 18px
    }

    .sc {
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      padding: 16px 18px;
      box-shadow: var(--sh)
    }

    .sc-icon {
      width: 38px;
      height: 38px;
      border-radius: 9px;
      display: grid;
      place-items: center;
      margin-bottom: 10px
    }

    .sc-icon svg {
      width: 18px;
      height: 18px
    }

    .sc-icon.gr {
      background: var(--grl);
      color: var(--gr)
    }

    .sc-icon.am {
      background: var(--aml);
      color: var(--am)
    }

    .sc-icon.ac {
      background: var(--acl);
      color: var(--ac)
    }

    .sc-icon.vi {
      background: var(--vil);
      color: var(--vi)
    }

    .sc-val {
      font-size: 21px;
      font-weight: 800;
      font-family: 'DM Mono', monospace;
      letter-spacing: -.5px;
      line-height: 1
    }

    .sc-lbl {
      font-size: 11.5px;
      color: var(--t3);
      margin-top: 4px;
      font-weight: 500
    }

    .sc-sub {
      font-size: 11px;
      font-weight: 600;
      margin-top: 4px
    }

    .sc-sub.gr {
      color: var(--gr)
    }

    .sc-sub.am {
      color: var(--am)
    }

    .sc-sub.rd {
      color: var(--rd)
    }

    /* LIVE BANNER */
    .auto-banner {
      background: linear-gradient(135deg, var(--vil), var(--acl));
      border: 1px solid var(--acs);
      border-radius: var(--r);
      padding: 14px 18px;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 12px
    }

    .auto-pulse {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--gr);
      flex-shrink: 0;
      animation: pulse 2s infinite
    }

    @keyframes pulse {

      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(21, 128, 61, .4)
      }

      50% {
        box-shadow: 0 0 0 6px rgba(21, 128, 61, 0)
      }
    }

    .auto-banner-text {
      flex: 1;
      font-size: 12.5px;
      color: var(--ac)
    }

    /* TABS */
    .tabs {
      display: flex;
      gap: 2px;
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      padding: 4px;
      margin-bottom: 18px;
      overflow-x: auto;
      scrollbar-width: none
    }

    .tabs::-webkit-scrollbar {
      display: none
    }

    .tab {
      padding: 7px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      color: var(--t2);
      transition: all .14s;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 6px
    }

    .tab:hover {
      color: var(--t1)
    }

    .tab.on {
      background: var(--surf);
      color: var(--t1);
      box-shadow: var(--sh)
    }

    .tab-cnt {
      font-size: 10.5px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 8px;
      font-family: 'DM Mono', monospace;
      background: var(--rds);
      color: var(--rd)
    }

    .tab.on .tab-cnt {
      background: var(--acs);
      color: var(--ac)
    }

    .tab-cnt.gr {
      background: var(--grs);
      color: var(--gr)
    }

    /* PANEL */
    .panel {
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      box-shadow: var(--sh);
      overflow: hidden;
      margin-bottom: 16px
    }

    .panel:last-child {
      margin-bottom: 0
    }

    .ph {
      padding: 14px 18px;
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap
    }

    .ph-title {
      font-size: 13.5px;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .ph-title svg {
      width: 15px;
      height: 15px;
      color: var(--ac);
      flex-shrink: 0
    }

    .ph-sub {
      font-size: 11.5px;
      color: var(--t3);
      margin-top: 2px
    }

    /* FILTER BAR */
    .fbar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--brd);
      flex-wrap: wrap;
      background: var(--s2)
    }

    .fsrch {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 7px 11px;
      flex: 1;
      min-width: 160px;
      transition: border .14s
    }

    .fsrch:focus-within {
      border-color: var(--ac)
    }

    .fsrch svg {
      width: 13px;
      height: 13px;
      color: var(--t3);
      flex-shrink: 0
    }

    .fsrch input {
      border: none;
      background: transparent;
      outline: none;
      font-size: 13px;
      color: var(--t1);
      width: 100%;
      font-family: 'DM Sans', sans-serif
    }

    .fsrch input::placeholder {
      color: var(--t3)
    }

    .fsel {
      background: var(--surf);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 7px 10px;
      font-size: 12.5px;
      color: var(--t1);
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      outline: none
    }

    .fsel:focus {
      border-color: var(--ac)
    }

    /* TABLE */
    .tbl-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch
    }

    .tbl {
      width: 100%;
      border-collapse: collapse;
      min-width: 680px
    }

    .tbl th {
      font-size: 10px;
      font-weight: 700;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .5px;
      padding: 10px 14px;
      text-align: left;
      background: var(--s2);
      border-bottom: 1px solid var(--brd);
      white-space: nowrap
    }

    .tbl td {
      padding: 12px 14px;
      font-size: 13px;
      border-bottom: 1px solid var(--brd2);
      vertical-align: middle
    }

    .tbl tr:last-child td {
      border-bottom: none
    }

    .tbl tbody tr {
      cursor: pointer;
      transition: background .12s
    }

    .tbl tbody tr:hover td {
      background: var(--s2)
    }

    .tbl-footer {
      padding: 10px 16px;
      background: var(--s2);
      border-top: 1px solid var(--brd);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px
    }

    .tbl-info {
      font-size: 12px;
      color: var(--t3)
    }

    /* VENDOR CELL */
    .vcell {
      display: flex;
      align-items: center;
      gap: 9px
    }

    .vav {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      flex-shrink: 0
    }

    /* METHOD BADGE */
    .method-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap
    }

    .method-badge.cash {
      background: var(--grs);
      color: var(--gr)
    }

    .method-badge.gcash {
      background: var(--vis);
      color: var(--vi)
    }

    .method-badge.maya {
      background: var(--cys);
      color: var(--cy)
    }

    .method-badge.bank {
      background: var(--acs);
      color: var(--ac)
    }

    /* AUTO TAG */
    .auto-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 10px;
      font-weight: 700;
      color: var(--gr);
      background: var(--grl);
      border: 1px solid var(--grs);
      border-radius: 20px;
      padding: 1px 7px;
      white-space: nowrap
    }

    .auto-tag svg {
      width: 9px;
      height: 9px
    }

    /* BADGES */
    .bdg {
      display: inline-flex;
      align-items: center;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap
    }

    .bdg.gr {
      background: var(--grs);
      color: var(--gr)
    }

    .bdg.am {
      background: var(--ams);
      color: var(--am)
    }

    .bdg.rd {
      background: var(--rds);
      color: var(--rd)
    }

    .bdg.ac {
      background: var(--acs);
      color: var(--ac)
    }

    .bdg.vi {
      background: var(--vis);
      color: var(--vi)
    }

    .bdg.cy {
      background: var(--cys);
      color: var(--cy)
    }

    .bdg.gy {
      background: var(--s3);
      color: var(--t3)
    }

    /* ONLINE QUEUE ITEM */
    .online-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 13px 18px;
      border-bottom: 1px solid var(--brd2);
      gap: 12px;
      flex-wrap: wrap;
      transition: background .12s
    }

    .online-item:last-child {
      border-bottom: none
    }

    .online-item:hover {
      background: var(--s2)
    }

    .oi-left {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
      min-width: 0
    }

    .oi-av {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0
    }

    .oi-name {
      font-size: 13px;
      font-weight: 700
    }

    .oi-stall {
      font-size: 11.5px;
      color: var(--t3)
    }

    .oi-mid {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px
    }

    .oi-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
      flex-shrink: 0
    }

    .oi-amount {
      font-size: 15px;
      font-weight: 800;
      font-family: 'DM Mono', monospace;
      color: var(--gr)
    }

    .oi-ref {
      font-size: 11px;
      color: var(--t3);
      font-family: 'DM Mono', monospace
    }

    /* CASH FORM */
    .pay-form {
      padding: 18px
    }

    .fgrid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px
    }

    .fgrid.full {
      grid-template-columns: 1fr
    }

    .fg {
      display: flex;
      flex-direction: column;
      gap: 5px
    }

    .fg label {
      font-size: 11px;
      font-weight: 700;
      color: var(--t2);
      text-transform: uppercase;
      letter-spacing: .3px
    }

    .hint {
      font-size: 11px;
      color: var(--t3);
      line-height: 1.4;
      margin-top: 2px
    }

    .finp {
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 9px 12px;
      font-size: 13px;
      color: var(--t1);
      font-family: 'DM Sans', sans-serif;
      outline: none;
      transition: border .14s;
      width: 100%
    }

    .finp:focus {
      border-color: var(--ac);
      background: var(--surf)
    }

    .finp::placeholder {
      color: var(--t3)
    }

    select.finp {
      cursor: pointer
    }

    .pfx {
      display: flex;
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      overflow: hidden;
      background: var(--s2);
      transition: border .14s
    }

    .pfx:focus-within {
      border-color: var(--ac)
    }

    .pfx-lbl {
      padding: 0 11px;
      background: var(--s3);
      border-right: 1px solid var(--brd);
      font-size: 12px;
      font-weight: 600;
      color: var(--t3);
      display: flex;
      align-items: center;
      white-space: nowrap;
      flex-shrink: 0
    }

    .pfx .finp {
      border: none;
      background: transparent;
      border-radius: 0
    }

    .pfx .finp:focus {
      background: transparent
    }

    /* OR SEQUENCE EDITOR */
    .or-seq {
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 11px 14px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px
    }

    .or-seq-info {
      flex: 1;
      min-width: 0
    }

    .or-seq-lbl {
      font-size: 11px;
      font-weight: 700;
      color: var(--t2);
      text-transform: uppercase;
      letter-spacing: .3px;
      margin-bottom: 2px
    }

    .or-seq-sub {
      font-size: 11.5px;
      color: var(--t3)
    }

    .or-seq-ctrl {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0
    }

    .or-prefix {
      font-size: 12px;
      font-weight: 600;
      color: var(--t2);
      white-space: nowrap
    }

    .or-num-inp {
      width: 70px;
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      padding: 6px 8px;
      border: 1.5px solid var(--brd);
      border-radius: 6px;
      background: var(--surf);
      color: var(--t1);
      outline: none;
      text-align: center
    }

    .or-num-inp:focus {
      border-color: var(--ac)
    }

    /* AMOUNT PREVIEW */
    .amt-preview {
      background: var(--grl);
      border: 1px solid var(--grs);
      border-radius: var(--rs);
      padding: 10px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px
    }

    .amt-preview-val {
      font-size: 18px;
      font-weight: 800;
      font-family: 'DM Mono', monospace;
      color: var(--gr)
    }

    /* UPLOAD */
    .upload-zone {
      border: 1.5px dashed var(--brd);
      border-radius: var(--rs);
      padding: 20px 16px;
      text-align: center;
      cursor: pointer;
      transition: all .18s;
      background: var(--s2);
      position: relative;
      margin-bottom: 0
    }

    .upload-zone:hover,
    .upload-zone.drag {
      border-color: var(--ac);
      background: var(--acl)
    }

    .upload-zone input[type=file] {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      cursor: pointer;
      z-index: 1
    }

    .upload-zone-icon {
      width: 34px;
      height: 34px;
      border-radius: 8px;
      background: var(--acl);
      display: grid;
      place-items: center;
      margin: 0 auto 9px;
      color: var(--ac)
    }

    .upload-zone-icon svg {
      width: 16px;
      height: 16px
    }

    .upload-zone-lbl {
      font-size: 12.5px;
      font-weight: 600;
      color: var(--t1);
      margin-bottom: 3px
    }

    .upload-zone-sub {
      font-size: 11.5px;
      color: var(--t3)
    }

    .upload-zone-sub span {
      color: var(--ac);
      font-weight: 600;
      cursor: pointer;
      position: relative;
      z-index: 2
    }

    .preview-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px
    }

    .prev-item {
      position: relative;
      width: 68px;
      height: 68px;
      border-radius: var(--rs);
      overflow: hidden;
      border: 1px solid var(--brd);
      background: var(--s3);
      flex-shrink: 0
    }

    .prev-file {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px
    }

    .prev-ext {
      font-size: 9px;
      font-weight: 700;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .3px
    }

    .prev-del {
      position: absolute;
      top: 2px;
      right: 2px;
      width: 15px;
      height: 15px;
      background: var(--rd);
      border-radius: 50%;
      border: none;
      cursor: pointer;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 9px;
      font-weight: 700;
      padding: 0;
      line-height: 1;
      z-index: 2
    }

    /* INFOBOX */
    .infobox {
      display: flex;
      gap: 9px;
      padding: 10px 13px;
      border-radius: var(--rs);
      font-size: 12.5px;
      line-height: 1.5;
      margin-bottom: 14px
    }

    .infobox svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      margin-top: 1px
    }

    .infobox.bl {
      background: var(--acl);
      border: 1px solid var(--acs);
      color: var(--ac)
    }

    .infobox.vi {
      background: var(--vil);
      border: 1px solid var(--vis);
      color: var(--vi)
    }

    .infobox.am {
      background: var(--aml);
      border: 1px solid var(--ams);
      color: var(--am)
    }

    /* BUTTONS */
    .btn {
      padding: 8px 16px;
      border-radius: var(--rs);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      font-family: 'DM Sans', sans-serif;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all .14s
    }

    .btn svg {
      width: 13px;
      height: 13px;
      flex-shrink: 0
    }

    .btn.pri {
      background: var(--ac);
      color: #fff
    }

    .btn.pri:hover {
      filter: brightness(1.1)
    }

    .btn.gr {
      background: var(--gr);
      color: #fff
    }

    .btn.gr:hover {
      filter: brightness(1.08)
    }

    .btn.gh {
      background: var(--surf);
      border: 1px solid var(--brd);
      color: var(--t2)
    }

    .btn.gh:hover {
      border-color: var(--ac);
      color: var(--ac)
    }

    .btn.sm {
      padding: 6px 12px;
      font-size: 12px
    }

    .btn.xs {
      padding: 4px 9px;
      font-size: 11.5px
    }

    /* TOAST */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--t1);
      color: var(--surf);
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: all .22s;
      white-space: nowrap
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0)
    }

    /* RESPONSIVE */
    @media(max-width:1100px) {
      .stats {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    @media(max-width:768px) {
      .main {
        margin-left: 0 !important;
        min-width: 0
      }

      .sb {
        transform: translateX(calc(-1 * var(--sidebar-w)))
      }

      .nsrch {
        display: none
      }

      .avp span,
      .avp svg:last-child {
        display: none
      }

      .content {
        padding: 14px
      }

      .stats {
        grid-template-columns: repeat(2, 1fr)
      }

      .fgrid {
        grid-template-columns: 1fr
      }
    }

    @media(max-width:540px) {
      .content {
        padding: 10px
      }

      .pghdr {
        flex-direction: column;
        align-items: flex-start
      }
    }

    ::-webkit-scrollbar {
      width: 4px;
      height: 4px
    }

    ::-webkit-scrollbar-track {
      background: transparent
    }

    ::-webkit-scrollbar-thumb {
      background: var(--brd);
      border-radius: 10px
    }
  </style>
</head>

<body>

  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,
    fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">

          <div class="pghdr">
            <div>
              <h1>Payments</h1>
              <p>Record cash payments &mdash; GCash &amp; Maya payments are detected and posted automatically</p>
            </div>
          </div>

          <!-- Stats -->
          <div class="stats">
            <div class="sc">
              <div class="sc-icon gr"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg></div>
              <div class="sc-val">&#8369;14,800</div>
              <div class="sc-lbl">Collected Today</div>
              <div class="sc-sub gr">12 transactions</div>
            </div>
            <div class="sc">
              <div class="sc-icon vi"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="5" y="2" width="14" height="20" rx="2" />
                  <line x1="12" y1="18" x2="12.01" y2="18" />
                </svg></div>
              <div class="sc-val" id="onlineTotalStat">&#8369;7,600</div>
              <div class="sc-lbl">Auto-detected Online</div>
              <div class="sc-sub am" id="pendingCountStat">
                <%= onlinePayments.length %> awaiting OR
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon ac"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="2" y="6" width="20" height="12" rx="2" />
                  <circle cx="12" cy="12" r="2" />
                </svg></div>
              <div class="sc-val">&#8369;7,200</div>
              <div class="sc-lbl">Cash Collected</div>
              <div class="sc-sub gr">
                <%= cashReceipts.length %> receipts issued
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon am"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                </svg></div>
              <div class="sc-val">
                <%= overdueAccounts.length %>
              </div>
              <div class="sc-lbl">Still Unpaid</div>
              <div class="sc-sub rd">&#8369;38,400 total balance</div>
            </div>
          </div>

          <!-- Live detection banner -->
          <div class="auto-banner">
            <div class="auto-pulse"></div>
            <div class="auto-banner-text">
              <strong>Online payment detection is live.</strong> GCash and Maya payments sent to the market account are
              matched using the vendor reference code and posted automatically. You only need to assign an OR number
              from your booklet.
            </div>
          </div>

          <!-- Tabs -->
          <div class="tabs">
            <div class="tab on" onclick="setTab('online',this)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" width="13" height="13">
                <rect x="5" y="2" width="14" height="20" rx="2" />
                <line x1="12" y1="18" x2="12.01" y2="18" />
              </svg>
              Online Payments <span class="tab-cnt" id="tabCntOnline">
                <%= onlinePayments.length %>
              </span>
            </div>
            <div class="tab" onclick="setTab('cash',this)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" width="13" height="13">
                <rect x="2" y="6" width="20" height="12" rx="2" />
                <circle cx="12" cy="12" r="2" />
              </svg>
              Cash Payment <span class="tab-cnt gr" id="tabCntCash">
                <%= cashReceipts.length %>
              </span>
            </div>
            <div class="tab" onclick="setTab('history',this)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" width="13" height="13">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              History <span class="tab-cnt gr">
                <%= historyBase.length %>
              </span>
            </div>
            <div class="tab" onclick="setTab('overdue',this)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" width="13" height="13">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              </svg>
              Overdue <span class="tab-cnt">
                <%= overdueAccounts.length %>
              </span>
            </div>
          </div>

          <!-- ONLINE PAYMENTS TAB -->
          <div id="tab-online">
            <div class="panel">
              <div class="ph">
                <div>
                  <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2">
                      <rect x="5" y="2" width="14" height="20" rx="2" />
                      <line x1="12" y1="18" x2="12.01" y2="18" />
                    </svg>Auto-Posted Online Payments</div>
                  <div class="ph-sub">Matched &amp; posted automatically &mdash; assign an OR number from your booklet
                  </div>
                </div>
                <div class="auto-tag"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>Live</div>
              </div>
              <div id="onlineQueue"></div>
            </div>
            <div class="panel">
              <div class="ph">
                <div>
                  <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>OR Assigned Today</div>
                  <div class="ph-sub">Online payments that have been issued an OR number</div>
                </div>
                <button class="btn gh xs" onclick="showToast('Printing...')">Print</button>
              </div>
              <div class="tbl-wrap">
                <table class="tbl" style="min-width:560px">
                  <thead>
                    <tr>
                      <th>OR No.</th>
                      <th>Vendor</th>
                      <th>Stall</th>
                      <th>Amount</th>
                      <th>Method</th>
                      <th>Received</th>
                    </tr>
                  </thead>
                  <tbody id="confirmedOnlineBody"></tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- CASH PAYMENT TAB -->
          <div id="tab-cash" style="display:none">
            <div class="panel">
              <div class="ph">
                <div>
                  <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2">
                      <line x1="12" y1="1" x2="12" y2="23" />
                      <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>Record Cash Payment</div>
                  <div class="ph-sub">Issue an Official Receipt for cash collected in the field</div>
                </div>
              </div>
              <div class="pay-form">
                <div class="infobox bl">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                  </svg>
                  <div>Cash payments must be recorded manually. Select the vendor, enter the amount, and an OR will be
                    auto-assigned in sequence.</div>
                </div>
                <!-- OR Sequence -->
                <div class="or-seq">
                  <div class="or-seq-info">
                    <div class="or-seq-lbl">OR Sequence</div>
                    <div class="or-seq-sub">Next OR to be issued. Edit if your physical booklet is on a different
                      number.</div>
                  </div>
                  <div class="or-seq-ctrl">
                    <span class="or-prefix">OR-2026-</span>
                    <input class="or-num-inp" id="orBaseInput" type="number" min="1" />
                    <button class="btn gh xs" onclick="updateORBase()">Set</button>
                  </div>
                </div>
                <div class="fgrid" style="margin-bottom:14px">
                  <div class="fg">
                    <label>Vendor / Stall</label>
                    <select class="finp" id="f-vendor" onchange="updateAmountHint()">
                      <option value="">-- Select Vendor --</option>
                      <%- vendorOptions.map(v=>
                        `<option value="${v.value}" data-rate="${v.rate}" data-bal="${v.bal}">${v.label}</option>`
                        ).join('') %>
                    </select>
                  </div>
                  <div class="fg">
                    <label>Payment Period</label>
                    <select class="finp" id="f-period">
                      <option selected>March 2026</option>
                      <option>February 2026</option>
                      <option>January 2026</option>
                    </select>
                  </div>
                </div>
                <div class="fgrid" style="margin-bottom:14px">
                  <div class="fg">
                    <label>Amount (PHP)</label>
                    <div class="pfx"><span class="pfx-lbl">&#8369;</span><input class="finp" id="f-amount" type="number"
                        min="1" step="50" placeholder="0.00" oninput="updatePreview()" /></div>
                    <span class="hint" id="amtHint"></span>
                  </div>
                  <div class="fg">
                    <label>Date Collected</label>
                    <input class="finp" id="f-date" type="date" />
                  </div>
                </div>
                <div class="fgrid" style="margin-bottom:14px">
                  <div class="fg">
                    <label>OR Number</label>
                    <input class="finp" id="f-or" readonly
                      style="font-family:'DM Mono',monospace;background:var(--s3);color:var(--t3)" />
                  </div>
                  <div class="fg">
                    <label>Remarks</label>
                    <input class="finp" id="f-remarks" placeholder="Optional e.g. Partial payment" />
                  </div>
                </div>
                <div class="amt-preview" id="amtPreview" style="display:none">
                  <div>
                    <div
                      style="font-size:10.5px;font-weight:700;color:var(--gr);text-transform:uppercase;letter-spacing:.3px">
                      Receipt Preview</div>
                    <div id="previewVendor" style="font-size:12.5px;color:var(--t2);margin-top:2px"></div>
                  </div>
                  <div class="amt-preview-val" id="previewAmt">&#8369;0</div>
                </div>
                <!-- Upload -->
                <div style="margin-bottom:14px">
                  <div
                    style="font-size:11px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.3px;margin-bottom:6px">
                    Proof of Payment <span
                      style="font-weight:400;font-size:11px;text-transform:none;color:var(--t3)">(optional)</span>
                  </div>
                  <div class="upload-zone" id="uploadZone" ondragover="onDragOver(event)"
                    ondragleave="onDragLeave(event)" ondrop="onDrop(event)">
                    <input type="file" id="fileInput" accept="image/*,.pdf" multiple onchange="onFileChange(event)" />
                    <div class="upload-zone-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                        fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="17 8 12 3 7 8" />
                        <line x1="12" y1="3" x2="12" y2="15" />
                      </svg></div>
                    <div class="upload-zone-lbl">Drag &amp; drop receipt photo here</div>
                    <div class="upload-zone-sub">or <span
                        onclick="document.getElementById('fileInput').click();event.stopPropagation()">browse
                        files</span> &mdash; JPG, PNG, PDF &mdash; max 5 files</div>
                  </div>
                  <div class="preview-strip" id="previewStrip" style="display:none"></div>
                </div>
                <div style="display:flex;gap:8px;justify-content:flex-end">
                  <button class="btn gh" onclick="clearForm()">Clear</button>
                  <button class="btn gr" onclick="submitCash()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    Save &amp; Issue OR
                  </button>
                </div>
              </div>
              <!-- Today's receipts -->
              <div style="border-top:1px solid var(--brd)">
                <div
                  style="padding:11px 18px;background:var(--s2);font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.5px">
                  Today's Cash Receipts</div>
                <div class="tbl-wrap">
                  <table class="tbl" style="min-width:540px">
                    <thead>
                      <tr>
                        <th>OR No.</th>
                        <th>Vendor</th>
                        <th>Stall</th>
                        <th>Period</th>
                        <th>Amount</th>
                        <th>Time</th>
                      </tr>
                    </thead>
                    <tbody id="cashTbody"></tbody>
                  </table>
                </div>
                <div class="tbl-footer"><span class="tbl-info" id="cashInfo">No receipts yet today</span><button
                    class="btn gh xs" onclick="showToast('Printing receipts...')">Print All</button></div>
              </div>
            </div>
          </div>

          <!-- HISTORY TAB -->
          <div id="tab-history" style="display:none">
            <div class="panel">
              <div class="ph">
                <div>
                  <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>Payment History</div>
                  <div class="ph-sub">All transactions for your assigned stalls</div>
                </div>
                <button class="btn gh sm" onclick="showToast('Downloading...')"><svg xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="7 10 12 15 17 10" />
                    <line x1="12" y1="15" x2="12" y2="3" />
                  </svg>Export</button>
              </div>
              <div class="fbar">
                <div class="fsrch"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                  </svg><input id="histSearch" placeholder="Search vendor or OR number..."
                    oninput="filterHistory(this.value)" /></div>
                <select class="fsel" id="histMethod"
                  onchange="filterHistory(document.getElementById('histSearch').value)">
                  <option value="">All Methods</option>
                  <option value="Cash">Cash</option>
                  <option value="GCash">GCash</option>
                  <option value="Maya">Maya</option>
                </select>
                <select class="fsel" id="histMonth"
                  onchange="filterHistory(document.getElementById('histSearch').value)">
                  <option value="">All Months</option>
                  <option value="March 2026" selected>March 2026</option>
                  <option value="February 2026">February 2026</option>
                  <option value="January 2026">January 2026</option>
                </select>
              </div>
              <div class="tbl-wrap">
                <table class="tbl">
                  <thead>
                    <tr>
                      <th>OR / Ref</th>
                      <th>Vendor</th>
                      <th>Stall</th>
                      <th>Period</th>
                      <th>Amount</th>
                      <th>Method</th>
                      <th>Posted</th>
                      <th>Source</th>
                    </tr>
                  </thead>
                  <tbody id="histTbody"></tbody>
                </table>
              </div>
              <div class="tbl-footer"><span class="tbl-info" id="histInfo">--</span></div>
            </div>
          </div>

          <!-- OVERDUE TAB -->
          <div id="tab-overdue" style="display:none">
            <div class="panel">
              <div class="ph">
                <div>
                  <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2">
                      <path
                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                      <line x1="12" y1="9" x2="12" y2="13" />
                      <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>Overdue Accounts</div>
                  <div class="ph-sub">
                    <%= overdueAccounts.length %> vendors with unpaid balances
                  </div>
                </div>
                <span class="bdg am">&#8369;38,400 total</span>
              </div>
              <div class="tbl-wrap">
                <table class="tbl">
                  <thead>
                    <tr>
                      <th>Vendor</th>
                      <th>Stall</th>
                      <th>Type</th>
                      <th>Rate</th>
                      <th>Days Overdue</th>
                      <th>Balance</th>
                      <th>Last Paid</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% overdueAccounts.forEach(a=> { %>
                      <tr>
                        <td>
                          <div class="vcell">
                            <div class="vav" style="background:linear-gradient(<%= a.grad %>)">
                              <%= a.init %>
                            </div>
                            <div>
                              <div style="font-size:12.5px;font-weight:600">
                                <%= a.vendor %>
                              </div>
                              <div style="font-size:11px;color:var(--t3)">
                                <%= a.vendorId %>
                              </div>
                            </div>
                          </div>
                        </td>
                        <td style="font-family:'DM Mono',monospace;font-weight:700">
                          <%= a.stall %>
                        </td>
                        <td><span class="bdg <%= a.typeCls %>">
                            <%= a.type %>
                          </span></td>
                        <td style="font-family:'DM Mono',monospace">&#8369;<%= a.rate.toLocaleString() %>
                        </td>
                        <td><span class="bdg rd">
                            <%= a.overdueDays %> days
                          </span></td>
                        <td style="font-family:'DM Mono',monospace;font-weight:800;color:var(--rd)">&#8369;<%=
                            a.balance.toLocaleString() %>
                        </td>
                        <td style="font-size:12px;color:var(--t3)">
                          <%= a.lastPaid %>
                        </td>
                        <td><button class="btn xs gh" onclick="showToast('SMS sent')">SMS</button></td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
              <div class="tbl-footer"><span class="tbl-info">Showing <%= overdueAccounts.length %> overdue
                    accounts</span></div>
            </div>
          </div>

        </div>
    </div>

    <div class="toast" id="toast"></div>

    <%# Inject server-side data as JS variables %>
      <script>
        let ONLINE_PAYMENTS = <%- JSON.stringify(onlinePayments) %>;
        let CONFIRMED_ONLINE = <%- JSON.stringify(confirmedOnline) %>;
        let CASH_RECEIPTS = <%- JSON.stringify(cashReceipts) %>;
        const HISTORY_BASE = <%- JSON.stringify(historyBase) %>;
        let OR_BASE = <%- orBase %>;
      </script>

      <script>
        /* ═══ SIDEBAR ═══ */
        let SB_OPEN = window.innerWidth >= 768;
        let DARK = false;

        function openSB() {
          SB_OPEN = true;
          document.getElementById('sb').style.transform = 'translateX(0)';
          if (window.innerWidth < 768) {
            document.getElementById('veil').style.display = 'block';
            document.getElementById('main').style.marginLeft = '0';
          } else {
            document.getElementById('veil').style.display = 'none';
            document.getElementById('main').style.marginLeft = 'var(--sidebar-w)';
          }
        }
        function closeSB() {
          SB_OPEN = false;
          document.getElementById('sb').style.transform = 'translateX(calc(-1 * var(--sidebar-w)))';
          document.getElementById('veil').style.display = 'none';
          document.getElementById('main').style.marginLeft = '0';
        }
        function toggleSB() { SB_OPEN ? closeSB() : openSB(); }

        (function () {
          if (window.innerWidth < 768) closeSB(); else openSB();
          window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) {
              document.getElementById('veil').style.display = 'none';
              if (SB_OPEN) document.getElementById('main').style.marginLeft = 'var(--sidebar-w)';
            } else {
              document.getElementById('main').style.marginLeft = '0';
              if (SB_OPEN) document.getElementById('veil').style.display = 'block';
            }
          });
        })();

        function toggleTheme() {
          DARK = !DARK;
          document.documentElement.classList.toggle('dark', DARK);
          const ico = document.getElementById('themeIco');
          ico.innerHTML = DARK
            ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'
            : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
        }

        /* ═══ TABS ═══ */
        function setTab(id, el) {
          ['online', 'cash', 'history', 'overdue'].forEach(t => {
            const p = document.getElementById('tab-' + t);
            if (p) p.style.display = t === id ? 'block' : 'none';
          });
          document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));
          if (el) el.classList.add('on');
        }

        /* ═══ OR NUMBER SYSTEM ═══ */
        function nextOR() {
          OR_BASE++;
          return 'OR-2026-' + String(OR_BASE).padStart(4, '0');
        }
        function currentNextOR() { return 'OR-2026-' + String(OR_BASE + 1).padStart(4, '0'); }
        function refreshORDisplay() {
          const el = document.getElementById('f-or');
          if (el) el.value = currentNextOR();
          const bi = document.getElementById('orBaseInput');
          if (bi) bi.value = OR_BASE + 1;
        }
        function updateORBase() {
          const val = parseInt(document.getElementById('orBaseInput').value);
          if (isNaN(val) || val < 1) { showToast('Invalid OR number'); return; }
          OR_BASE = val - 1;
          refreshORDisplay();
          showToast('Next OR set to OR-2026-' + String(val).padStart(4, '0'));
        }

        /* ═══ ONLINE PAYMENTS ═══ */
        function renderOnlineQueue() {
          const wrap = document.getElementById('onlineQueue');
          const cnt = document.getElementById('tabCntOnline');
          const stat = document.getElementById('pendingCountStat');
          if (cnt) cnt.textContent = ONLINE_PAYMENTS.length;
          if (stat) stat.textContent = ONLINE_PAYMENTS.length + ' awaiting OR';
          if (!ONLINE_PAYMENTS.length) {
            wrap.innerHTML = '<div style="padding:40px;text-align:center;color:var(--t3)">'
              + '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="opacity:.3;display:block;margin:0 auto 12px"><polyline points="20 6 9 17 4 12"/></svg>'
              + '<div style="font-weight:600;font-size:13.5px">All online payments have been assigned an OR</div></div>';
            return;
          }
          wrap.innerHTML = ONLINE_PAYMENTS.map(p => {
            const mc = p.method === 'GCash' ? 'gcash' : 'maya';
            return `<div class="online-item">
      <div class="oi-left">
        <div class="oi-av" style="background:linear-gradient(${p.grad})">${p.init}</div>
        <div><div class="oi-name">${p.vendor}</div><div class="oi-stall">Stall ${p.stall} &middot; ${p.period}</div></div>
      </div>
      <div class="oi-mid"><span class="method-badge ${mc}">&loz; ${p.method}</span><div class="oi-ref">${p.ref} &middot; ${p.time}</div></div>
      <div class="oi-right">
        <div class="oi-amount">&#8369;${p.amount.toLocaleString()}</div>
        <button class="btn xs gr" onclick="assignOR(${p.id})">Assign OR</button>
      </div>
    </div>`;
          }).join('');
        }

        function assignOR(id) {
          const p = ONLINE_PAYMENTS.find(x => x.id === id);
          if (!p) return;
          const orVal = nextOR();
          p.or = orVal;
          CONFIRMED_ONLINE.push({ vendor: p.vendor, stall: p.stall, amount: p.amount, method: p.method, ref: p.ref, time: p.time, or: orVal, period: p.period });
          ONLINE_PAYMENTS = ONLINE_PAYMENTS.filter(x => x.id !== id);
          renderOnlineQueue();
          renderConfirmedOnline();
          renderHistory();
          refreshORDisplay();
          showToast(orVal + ' assigned to ' + p.vendor);
        }

        function renderConfirmedOnline() {
          const tbody = document.getElementById('confirmedOnlineBody');
          if (!tbody) return;
          const mb = { GCash: '<span class="method-badge gcash">&loz; GCash</span>', Maya: '<span class="method-badge maya">&loz; Maya</span>' };
          if (!CONFIRMED_ONLINE.length) {
            tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:24px;color:var(--t3);font-size:13px">No OR assigned yet today</td></tr>';
            return;
          }
          tbody.innerHTML = CONFIRMED_ONLINE.map(p =>
            `<tr>
      <td style="font-family:DM Mono,monospace;font-size:12px;font-weight:700;color:var(--ac)">${p.or}</td>
      <td><div style="font-weight:600;font-size:12.5px">${p.vendor}</div></td>
      <td style="font-family:DM Mono,monospace;font-weight:700">${p.stall}</td>
      <td style="font-family:DM Mono,monospace;font-weight:700;color:var(--gr)">&#8369;${p.amount.toLocaleString()}</td>
      <td>${mb[p.method] || p.method}</td>
      <td style="font-size:12px;color:var(--t3)">${p.time}</td>
    </tr>`
          ).join('');
        }

        /* ═══ CASH FORM ═══ */
        function updateAmountHint() {
          const sel = document.getElementById('f-vendor');
          const opt = sel.options[sel.selectedIndex];
          const hint = document.getElementById('amtHint');
          document.getElementById('amtPreview').style.display = 'none';
          if (!opt.value) { hint.textContent = ''; return; }
          const rate = parseInt(opt.getAttribute('data-rate'));
          const bal = parseInt(opt.getAttribute('data-bal'));
          if (bal > 0) {
            hint.textContent = `Balance due: PHP ${bal.toLocaleString()} - Monthly rate: PHP ${rate.toLocaleString()}`;
            document.getElementById('f-amount').value = bal;
          } else {
            hint.textContent = `Monthly rate: PHP ${rate.toLocaleString()}`;
            document.getElementById('f-amount').value = rate;
          }
          updatePreview();
        }

        function updatePreview() {
          const amt = parseFloat(document.getElementById('f-amount').value);
          const sel = document.getElementById('f-vendor');
          const opt = sel.options[sel.selectedIndex];
          const prev = document.getElementById('amtPreview');
          if (isNaN(amt) || amt <= 0 || !opt.value) { prev.style.display = 'none'; return; }
          prev.style.display = 'flex';
          const name = (opt.text.split('--')[1] || opt.text).split(' (')[0].trim();
          document.getElementById('previewVendor').textContent = name;
          document.getElementById('previewAmt').innerHTML = '&#8369;' + amt.toLocaleString();
        }

        function clearForm() {
          document.getElementById('f-vendor').value = '';
          document.getElementById('f-amount').value = '';
          document.getElementById('f-remarks').value = '';
          document.getElementById('amtHint').textContent = '';
          document.getElementById('amtPreview').style.display = 'none';
          uploadedFiles = [];
          renderPreviews();
          refreshORDisplay();
        }

        function submitCash() {
          const vendor = document.getElementById('f-vendor').value;
          const amount = parseFloat(document.getElementById('f-amount').value);
          if (!vendor) { showToast('Please select a vendor'); return; }
          if (!amount || amount <= 0) { showToast('Please enter a valid amount'); return; }
          const orNum = nextOR();
          const sel = document.getElementById('f-vendor');
          const name = (sel.options[sel.selectedIndex].text.split('--')[1] || '').split(' (')[0].trim();
          const now = new Date();
          let hh = now.getHours(), mm = now.getMinutes();
          const ampm = hh >= 12 ? 'PM' : 'AM';
          hh = hh % 12 || 12;
          const timeStr = hh + ':' + (mm < 10 ? '0' + mm : mm) + ' ' + ampm;
          CASH_RECEIPTS.push({ or: orNum, vendor: name, stall: '--', period: document.getElementById('f-period').value, amount, time: timeStr });
          clearForm();
          renderCashTable();
          renderHistory();
          showToast(orNum + ' issued to ' + name);
        }

        function renderCashTable() {
          const tbody = document.getElementById('cashTbody');
          const info = document.getElementById('cashInfo');
          tbody.innerHTML = CASH_RECEIPTS.map(r =>
            `<tr>
      <td style="font-family:DM Mono,monospace;font-size:12px;font-weight:700;color:var(--ac)">${r.or}</td>
      <td><div style="font-weight:600">${r.vendor}</div></td>
      <td style="font-family:DM Mono,monospace;font-weight:700">${r.stall}</td>
      <td style="font-size:12px;color:var(--t3)">${r.period}</td>
      <td style="font-family:DM Mono,monospace;font-weight:700;color:var(--gr)">&#8369;${r.amount.toLocaleString()}</td>
      <td style="font-size:12px;color:var(--t3)">${r.time}</td>
    </tr>`
          ).join('');
          const total = CASH_RECEIPTS.reduce((s, r) => s + r.amount, 0);
          info.textContent = CASH_RECEIPTS.length + ' receipts -- Total: PHP ' + total.toLocaleString();
        }

        /* ═══ HISTORY ═══ */
        function getAllHistory() {
          const all = HISTORY_BASE.slice();
          CASH_RECEIPTS.forEach(r => {
            if (!HISTORY_BASE.find(h => h.or === r.or))
              all.push({ or: r.or, vendor: r.vendor, stall: r.stall, period: r.period, amount: r.amount, method: 'Cash', posted: r.time, source: 'manual' });
          });
          CONFIRMED_ONLINE.forEach(p => {
            if (p.or && !HISTORY_BASE.find(h => h.or === p.or))
              all.push({ or: p.or, vendor: p.vendor, stall: p.stall, period: p.period, amount: p.amount, method: p.method, posted: p.time, source: 'auto' });
          });
          return all;
        }

        function filterHistory(q) {
          const method = document.getElementById('histMethod')?.value || '';
          const month = document.getElementById('histMonth')?.value || '';
          const list = getAllHistory().filter(h => {
            if (method && !h.method.includes(method)) return false;
            if (month && !h.period.includes(month)) return false;
            if (q && !h.vendor.toLowerCase().includes(q.toLowerCase()) && !h.or.toLowerCase().includes(q.toLowerCase())) return false;
            return true;
          });
          renderHistory(list);
        }

        function renderHistory(list) {
          if (!list) list = getAllHistory();
          const tbody = document.getElementById('histTbody');
          const info = document.getElementById('histInfo');
          if (!tbody || !info) return;
          const mb = {
            Cash: '<span class="method-badge cash">Cash</span>',
            GCash: '<span class="method-badge gcash">&loz; GCash</span>',
            Maya: '<span class="method-badge maya">&loz; Maya</span>',
          };
          info.textContent = 'Showing ' + list.length + ' transactions';
          tbody.innerHTML = list.map(h => {
            const src = h.source === 'auto'
              ? '<span class="auto-tag"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="9" height="9"><polyline points="20 6 9 17 4 12"/></svg>Auto</span>'
              : '<span style="font-size:11px;color:var(--t3)">Manual</span>';
            return `<tr>
      <td style="font-family:DM Mono,monospace;font-size:11.5px;font-weight:700;color:var(--ac)">${h.or}</td>
      <td><div style="font-weight:600;font-size:12.5px">${h.vendor}</div></td>
      <td style="font-family:DM Mono,monospace;font-weight:700">${h.stall}</td>
      <td style="font-size:12px;color:var(--t3)">${h.period}</td>
      <td style="font-family:DM Mono,monospace;font-weight:700;color:var(--gr)">&#8369;${h.amount.toLocaleString()}</td>
      <td>${mb[h.method] || h.method}</td>
      <td style="font-size:12px;color:var(--t3)">${h.posted}</td>
      <td>${src}</td>
    </tr>`;
          }).join('');
        }

        /* ═══ UPLOAD ═══ */
        let uploadedFiles = [];
        function onDragOver(e) { e.preventDefault(); document.getElementById('uploadZone').classList.add('drag'); }
        function onDragLeave() { document.getElementById('uploadZone').classList.remove('drag'); }
        function onDrop(e) {
          e.preventDefault();
          document.getElementById('uploadZone').classList.remove('drag');
          addFiles(Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/') || f.type === 'application/pdf'));
        }
        function onFileChange(e) { addFiles(Array.from(e.target.files)); e.target.value = ''; }
        function addFiles(files) {
          files.forEach(f => {
            if (uploadedFiles.length >= 5) { showToast('Max 5 files allowed'); return; }
            uploadedFiles.push(f);
          });
          renderPreviews();
        }
        function removeFile(i) { uploadedFiles.splice(i, 1); renderPreviews(); }
        function renderPreviews() {
          const strip = document.getElementById('previewStrip');
          const zone = document.getElementById('uploadZone');
          if (!strip || !zone) return;
          if (!uploadedFiles.length) { strip.style.display = 'none'; zone.style.display = ''; return; }
          strip.style.display = 'flex';
          zone.style.display = uploadedFiles.length >= 5 ? 'none' : '';
          strip.innerHTML = uploadedFiles.map((f, i) => {
            const isImg = f.type.startsWith('image/');
            const inner = isImg
              ? `<img src="${URL.createObjectURL(f)}" alt="" style="width:100%;height:100%;object-fit:cover;display:block"/>`
              : `<div class="prev-file"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><span class="prev-ext">${f.name.split('.').pop().toUpperCase()}</span></div>`;
            return `<div class="prev-item">${inner}<button class="prev-del" onclick="removeFile(${i})" title="Remove">x</button></div>`;
          }).join('');
        }

        /* ═══ TOAST ═══ */
        let toastTimer = null;
        function showToast(msg) {
          const t = document.getElementById('toast');
          t.textContent = msg;
          t.classList.add('show');
          if (toastTimer) clearTimeout(toastTimer);
          toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
        }

        /* ═══ INIT ═══ */
        (function () {
          const today = new Date();
          const d = today.getFullYear() + '-' + String(today.getMonth() + 1).padStart(2, '0') + '-' + String(today.getDate()).padStart(2, '0');
          const fd = document.getElementById('f-date');
          if (fd) fd.value = d;
          refreshORDisplay();
          renderOnlineQueue();
          renderConfirmedOnline();
          renderCashTable();
          renderHistory();
        })();
      </script>
</body>

</html>