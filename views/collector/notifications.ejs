<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ARKIPAISI &mdash; Notifications</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f0f2f8;--surf:#fff;--s2:#f6f7fb;--s3:#eef0f7;
  --brd:#e2e6f0;--brd2:#eaecf5;
  --t1:#0c0f1e;--t2:#566080;--t3:#9099b8;
  --ac:#1d4ed8;--acl:#eff3ff;--acs:#c7d7fd;--acd:#1e3a8a;
  --rd:#b91c1c;--rdl:#fff1f2;--rds:#fecdd3;
  --sidebar-w:240px;--r:12px;--rs:7px;
  --sh:0 1px 3px rgba(12,18,60,.06),0 1px 2px rgba(12,18,60,.04);
  --shm:0 4px 16px rgba(12,18,60,.09),0 2px 5px rgba(12,18,60,.05);
}
html.dark{
  --bg:#080b15;--surf:#10152a;--s2:#151c32;--s3:#1c2440;
  --brd:#202844;--brd2:#1a2238;--t1:#e0e6f8;--t2:#6878a8;--t3:#384060;
  --ac:#4a6ef5;--acl:#171e48;--acs:#1f2e80;--rdl:#150408;--rds:#380412;
  --sh:0 1px 3px rgba(0,0,0,.4);
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t1);display:flex;min-height:100vh;overflow-x:hidden}

/* SIDEBAR */
.sb{width:var(--sidebar-w);min-height:100vh;background:var(--surf);border-right:1px solid var(--brd);display:flex;flex-direction:column;position:fixed;left:0;top:0;z-index:60;transition:transform .28s cubic-bezier(.4,0,.2,1)}
.sb-logo{height:56px;padding:0 16px 0 20px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-m{width:32px;height:32px;background:var(--ac);border-radius:8px;display:grid;place-items:center;color:#fff;font-size:12px;font-weight:800;flex-shrink:0}
.logo-n{font-size:14px;font-weight:800;letter-spacing:-.3px}
.logo-sub{font-size:9.5px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-top:1px}
.sb-x{width:26px;height:26px;border-radius:6px;border:1px solid var(--brd);background:var(--s2);display:grid;place-items:center;cursor:pointer;color:var(--t2);flex-shrink:0;transition:all .14s}
.sb-x:hover{background:var(--rdl);color:var(--rd);border-color:var(--rds)}
.sb-x svg{width:13px;height:13px}
.sb-nav{flex:1;padding:10px 8px;overflow-y:auto}
.nsec{font-size:9.5px;font-weight:700;color:var(--t3);letter-spacing:.9px;text-transform:uppercase;padding:10px 10px 4px;margin-top:4px}
.ni{display:flex;align-items:center;gap:9px;padding:8px 12px;border-radius:var(--rs);color:var(--t2);cursor:pointer;font-size:13px;font-weight:500;transition:all .14s;margin-bottom:1px}
.ni:hover{background:var(--s2);color:var(--t1)}
.ni.on{background:var(--acl);color:var(--ac);font-weight:600}
.ni svg{width:15px;height:15px;flex-shrink:0}
.nbdg{margin-left:auto;font-size:10px;font-weight:700;padding:1px 6px;border-radius:8px;font-family:'DM Mono',monospace;background:var(--rds);color:var(--rd)}
.nbdg.bl{background:var(--acs);color:var(--ac)}
.nbdg.am{background:#fde68a;color:#b45309}
.sb-foot{padding:12px 8px;border-top:1px solid var(--brd);flex-shrink:0}
.urow{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:var(--rs);cursor:pointer;transition:background .14s}
.urow:hover{background:var(--s2)}
.uav{width:30px;height:30px;border-radius:50%;background:var(--ac);display:grid;place-items:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0}
.veil{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:55;cursor:pointer}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;margin-left:var(--sidebar-w);min-height:100vh;transition:margin-left .28s cubic-bezier(.4,0,.2,1);min-width:0;overflow-x:hidden}
.nav{height:56px;background:var(--surf);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 16px;gap:10px;position:sticky;top:0;z-index:40;flex-shrink:0}
.togbtn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surf);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0}
.togbtn:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}
.togbtn svg{width:15px;height:15px}
.nav-info{flex:1;min-width:0}
.nav-ttl{font-size:14px;font-weight:700;letter-spacing:-.2px}
.nav-bc{font-size:11px;color:var(--t3)}
.nav-r{display:flex;align-items:center;gap:7px;flex-shrink:0}
.nico{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surf);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0}
.nico:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}
.nico svg{width:14px;height:14px}
.avp{display:flex;align-items:center;gap:7px;padding:3px 10px 3px 3px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surf);cursor:pointer;flex-shrink:0}
.avp-a{width:24px;height:24px;border-radius:50%;background:var(--ac);display:grid;place-items:center;color:#fff;font-size:9px;font-weight:700}
.content{padding:20px;flex:1}

/* PAGE HEADER */
.pghdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
.pghdr h1{font-size:20px;font-weight:800;letter-spacing:-.5px}
.pghdr p{font-size:13px;color:var(--t3);margin-top:3px}

/* FILTER TABS */
.ntabs{display:flex;gap:2px;background:var(--s2);border:1px solid var(--brd);border-radius:var(--r);padding:4px;margin-bottom:16px;overflow-x:auto;scrollbar-width:none;width:fit-content}
.ntabs::-webkit-scrollbar{display:none}
.ntab{padding:6px 16px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;color:var(--t2);transition:all .14s;white-space:nowrap;display:flex;align-items:center;gap:6px}
.ntab:hover{color:var(--t1)}
.ntab.on{background:var(--surf);color:var(--ac);box-shadow:var(--sh)}
.ntab-cnt{font-size:10px;font-weight:700;padding:1px 6px;border-radius:8px;font-family:'DM Mono',monospace;background:var(--acs);color:var(--ac)}

/* NOTIFICATION LIST */
.notif-list{background:var(--surf);border:1px solid var(--brd);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden}
.notif-header{padding:12px 18px;background:var(--s2);border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between}
.notif-count-lbl{font-size:12px;font-weight:600;color:var(--t2)}
.notif-count-lbl span{color:var(--ac)}

.notif-item{display:flex;align-items:flex-start;gap:13px;padding:15px 18px;border-bottom:1px solid var(--brd2);cursor:pointer;transition:background .12s;position:relative}
.notif-item:last-child{border-bottom:none}
.notif-item:hover{background:var(--s2)}
.notif-item.unread{background:var(--acl)}
.notif-item.unread:hover{background:#e0eaff}
.notif-item.unread::before{content:'';position:absolute;left:6px;top:50%;transform:translateY(-50%);width:5px;height:5px;background:var(--ac);border-radius:50%}

.notif-ico{width:36px;height:36px;border-radius:9px;display:grid;place-items:center;flex-shrink:0;margin-top:1px}
.notif-ico svg{width:16px;height:16px}
.notif-ico.payment{background:var(--acl);color:var(--ac)}
.notif-ico.overdue{background:#fee2e2;color:#b91c1c}
.notif-ico.system{background:var(--s3);color:var(--t2)}

.notif-body{flex:1;min-width:0}
.notif-title{font-size:13px;font-weight:700;line-height:1.4;color:var(--t1)}
.notif-item.unread .notif-title{color:var(--ac)}
.notif-desc{font-size:12px;color:var(--t2);margin-top:3px;line-height:1.5}
.notif-meta{display:flex;align-items:center;gap:8px;margin-top:5px}
.notif-time{font-size:11px;color:var(--t3)}
.notif-tag{font-size:10.5px;font-weight:700;padding:1px 7px;border-radius:20px;font-family:'DM Mono',monospace}
.notif-tag.payment{background:var(--acs);color:var(--ac)}
.notif-tag.overdue{background:#fecdd3;color:#b91c1c}
.notif-tag.system{background:var(--s3);color:var(--t3)}

.notif-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0}
.notif-chevron{color:var(--brd);transition:color .14s}
.notif-item:hover .notif-chevron{color:var(--ac)}

/* EMPTY */
.notif-empty{padding:60px 20px;text-align:center;color:var(--t3)}
.notif-empty svg{width:44px;height:44px;opacity:.25;display:block;margin:0 auto 12px}
.notif-empty p{font-size:13.5px;font-weight:600;color:var(--t2);margin-bottom:4px}

/* BUTTONS */
.btn{padding:7px 14px;border-radius:var(--rs);font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px;transition:all .14s}
.btn svg{width:12px;height:12px;flex-shrink:0}
.btn.pri{background:var(--ac);color:#fff}
.btn.pri:hover{background:var(--acd)}
.btn.gh{background:var(--surf);border:1px solid var(--brd);color:var(--t2)}
.btn.gh:hover{border-color:var(--ac);color:var(--ac)}
.btn.ghost-bl{background:transparent;border:none;color:var(--ac);font-size:12px;padding:4px 0;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:600}
.btn.ghost-bl:hover{text-decoration:underline}

/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(8px);background:var(--t1);color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;z-index:999;opacity:0;pointer-events:none;transition:all .22s;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

@media(max-width:768px){.main{margin-left:0!important}.sb{transform:translateX(calc(-1 * var(--sidebar-w)))}.avp span,.avp svg:last-child{display:none}.content{padding:14px}}
@media(max-width:540px){.content{padding:10px}.pghdr{flex-direction:column}}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--brd);border-radius:10px}
</style>
</head>
<body>
<div class="veil" id="veil" onclick="closeSB()"></div>

<%- include('../partials/sidebar.ejs') %>

<div class="main" id="main">
  <%- include('../partials/header.ejs') %>

  <div class="content">
    <div class="pghdr">
      <div><h1>Notifications</h1><p>Alerts and updates for your collection route</p></div>
      <button class="btn gh" onclick="markAllRead()">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Mark all as read
      </button>
    </div>

    <!-- Filter tabs — counts server-rendered initially -->
    <div class="ntabs">
      <div class="ntab on" onclick="setTab('all',this)">All <span class="ntab-cnt" id="cntAll"><%= counts.total %></span></div>
      <div class="ntab" onclick="setTab('unread',this)">Unread <span class="ntab-cnt" id="cntUnread"><%= counts.unread %></span></div>
      <div class="ntab" onclick="setTab('payment',this)">Payments</div>
      <div class="ntab" onclick="setTab('overdue',this)">Overdue</div>
      <div class="ntab" onclick="setTab('system',this)">System</div>
    </div>

    <!-- Notification list -->
    <div class="notif-list">
      <div class="notif-header">
        <span class="notif-count-lbl"><span id="visibleCount"><%= counts.total %></span> notifications</span>
        <button class="btn ghost-bl" onclick="markAllRead()">Mark all read</button>
      </div>
      <div id="notifList"></div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<%# Inject server-side notifications as a JS variable %>
<script>
  let NOTIFS = <%- JSON.stringify(notifications) %>;
</script>

<script>
let SB_OPEN = window.innerWidth >= 768;
let DARK = false;
let ACTIVE_TAB = 'all';

function openSB() {
  SB_OPEN = true;
  document.getElementById('sb').style.transform = 'translateX(0)';
  if (window.innerWidth < 768) {
    document.getElementById('veil').style.display = 'block';
    document.getElementById('main').style.marginLeft = '0';
  } else {
    document.getElementById('veil').style.display = 'none';
    document.getElementById('main').style.marginLeft = 'var(--sidebar-w)';
  }
}
function closeSB() {
  SB_OPEN = false;
  document.getElementById('sb').style.transform = 'translateX(calc(-1 * var(--sidebar-w)))';
  document.getElementById('veil').style.display = 'none';
  document.getElementById('main').style.marginLeft = '0';
}
function toggleSB() { SB_OPEN ? closeSB() : openSB(); }

(function () {
  if (window.innerWidth < 768) closeSB(); else openSB();
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) {
      document.getElementById('veil').style.display = 'none';
      if (SB_OPEN) document.getElementById('main').style.marginLeft = 'var(--sidebar-w)';
    } else {
      document.getElementById('main').style.marginLeft = '0';
      if (SB_OPEN) document.getElementById('veil').style.display = 'block';
    }
  });
})();

function toggleTheme() {
  DARK = !DARK;
  document.documentElement.classList.toggle('dark', DARK);
  const ico = document.getElementById('themeIco');
  ico.innerHTML = DARK
    ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'
    : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
}

/* ═══ ICONS ═══ */
const ICONS = {
  payment: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  overdue: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  system:  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
};

const TAG_LABELS = { payment: 'Payment', overdue: 'Overdue', system: 'System' };

function getFiltered() {
  return NOTIFS.filter(n => {
    if (ACTIVE_TAB === 'all')    return true;
    if (ACTIVE_TAB === 'unread') return !n.read;
    return n.type === ACTIVE_TAB;
  });
}

function render() {
  const list   = getFiltered();
  const wrap   = document.getElementById('notifList');
  const unread = NOTIFS.filter(n => !n.read).length;

  document.getElementById('cntAll').textContent     = NOTIFS.length;
  document.getElementById('cntUnread').textContent  = unread;
  document.getElementById('visibleCount').textContent = list.length;

  if (!list.length) {
    wrap.innerHTML = `<div class="notif-empty">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <p>No notifications here</p><span>You are all caught up</span>
    </div>`;
    return;
  }

  wrap.innerHTML = list.map(n => `
    <div class="notif-item${n.read ? '' : ' unread'}" onclick="markRead(${n.id})">
      <div class="notif-ico ${n.type}">${ICONS[n.type] || ICONS.system}</div>
      <div class="notif-body">
        <div class="notif-title">${n.title}</div>
        <div class="notif-desc">${n.desc}</div>
        <div class="notif-meta">
          <span class="notif-time">${n.time}</span>
          <span class="notif-tag ${n.tag}">${TAG_LABELS[n.tag] || n.tag}</span>
        </div>
      </div>
      <div class="notif-right">
        <svg class="notif-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="9 18 15 12 9 6"/></svg>
      </div>
    </div>
  `).join('');
}

function setTab(tab, el) {
  ACTIVE_TAB = tab;
  document.querySelectorAll('.ntab').forEach(t => t.classList.remove('on'));
  if (el) el.classList.add('on');
  render();
}

function markRead(id) {
  const n = NOTIFS.find(x => x.id === id);
  if (n) n.read = true;
  render();
}

function markAllRead() {
  NOTIFS.forEach(n => { n.read = true; });
  render();
  showToast('All notifications marked as read');
}

/* ═══ TOAST ═══ */
let toastTimer = null;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

/* ═══ INIT ═══ */
render();
</script>
</body>
</html>
