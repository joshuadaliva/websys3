<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARKIPAISI — Public Market Stall Rentals</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/index.css">

</head>

<body>

  <a class="raffle-ann" href="/raffle/live">🎥 Live Raffle Draw for Stall #06 on March 22, 2026 – Click to Watch</a>

  <!-- ═══ TOP NAV ═══ -->
  <nav class="topnav">
    <div class="topnav-inner">
      <a class="brand" href="#">
        <div class="brand-seal">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        </div>
        <div class="brand-text">
          <div class="brand-name">ARKIPAISI</div>
          <div class="brand-sub">Public Market Office</div>
        </div>
      </a>
      <div class="nav-links">
        <a class="nav-link" href="#stalls">Available Stalls</a>
        <a class="nav-link" href="#how">How It Works</a>
        <a class="nav-link" href="#faq">FAQ</a>
        <a class="nav-link" onclick="openM('trackModal')" style="cursor:pointer">Track Application</a>
      </div>
      <button class="nav-burger" onclick="toggleMob()">
        <svg id="burger-ico" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div class="mob-menu" id="mob-menu">
    <div class="mob-link" onclick="scrollTo('#stalls');toggleMob()">Available Stalls</div>
    <div class="mob-link" onclick="scrollTo('#how');toggleMob()">How It Works</div>
    <div class="mob-link" onclick="scrollTo('#faq');toggleMob()">FAQ</div>
    <div class="mob-link" onclick="openM('trackModal');toggleMob()">Track Application</div>
    <div class="mob-link cta" onclick="openM('applyModal');toggleMob()">↗ Apply for a Stall</div>
  </div>

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="home">
    <div class="hero-bg">
      <div class="hero-bg-img"></div>
      <div class="hero-bg-overlay"></div>
      <div class="hero-bg-tint"></div>
    </div>
    <div class="hero-inner">
      <div>
        <div class="hero-eyebrow">
          <div class="hero-eyebrow-dot"></div>
          <span>Currently Accepting Applications</span>
        </div>
        <h1>Rent a stall at the<br /><em>ARKIPAISI</em><br />Public Market</h1>
        <p class="hero-desc">Browse available stalls, submit your pre-screening application online, and track your
          application status — all in one place.</p>
        <div class="hero-actions">
          <a class="btn-hero primary" href="#stalls">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            </svg>
            View Available Stalls
          </a>
          <a class="btn-hero secondary" onclick="openM('trackModal')" href="#">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            Track My Application
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hero-stat-val" id="stat-available">7</div>
            <div class="hero-stat-lbl">Stalls Available</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-val">32</div>
            <div class="hero-stat-lbl">Total Stalls</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-val">9</div>
            <div class="hero-stat-lbl">Active Vendors</div>
          </div>
        </div>
      </div>
      <!-- Track / quick links card -->
      <div class="hero-card">
        <div class="hero-card-title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          Track Your Application
        </div>
        <div class="track-input-wrap">
          <input class="track-input" id="hero-track-input" placeholder="Enter Application No. (e.g. APP-2026-001)"
            maxlength="20" />
        </div>
        <button class="track-btn" onclick="doHeroTrack()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          Check Status
        </button>
        <div class="track-divider">or jump to</div>
        <div class="track-links">
          <a class="track-shortcut" href="#stalls">
            <div class="track-shortcut-ico a"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              </svg></div>
            <div class="track-shortcut-text">
              <div class="track-shortcut-name">Browse Stall Listings</div>
              <div class="track-shortcut-sub">7 stalls currently open for application</div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.4)"
              stroke-width="2" width="14" height="14">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </a>
          <a class="track-shortcut" href="#" onclick="openM('applyModal');return false">
            <div class="track-shortcut-ico b"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="12" y1="18" x2="12" y2="12" />
                <line x1="9" y1="15" x2="15" y2="15" />
              </svg></div>
            <div class="track-shortcut-text">
              <div class="track-shortcut-name">Submit Pre-Screening Form</div>
              <div class="track-shortcut-sub">Fill out the online application</div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.4)"
              stroke-width="2" width="14" height="14">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="how-section" id="how">
    <div class="section-inner">
      <div class="section-header" style="margin-bottom:48px">
        <div class="section-eyebrow" style="color:var(--or3)">Process</div>
        <div class="section-title" style="color:#fff">How the Application Works</div>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-title">Browse Stalls</div>
          <div class="step-desc">View all available stalls, their sizes, location in the market, and monthly rental
            rates.</div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-title">Submit Application</div>
          <div class="step-desc">Fill out the online pre-screening form. Upload your valid ID and selfie with ID.</div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-title">Wait for Review</div>
          <div class="step-desc">The AMRC committee reviews your application. You will receive SMS and email updates.
          </div>
        </div>
        <div class="step">
          <div class="step-num">4</div>
          <div class="step-title">Get Awarded</div>
          <div class="step-desc">If qualified and selected, you'll be contacted to sign the contract and begin rental.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STALL LISTINGS ═══ -->
  <section class="section" id="stalls" style="background:var(--offwhite)">
    <div class="section-inner">
      <div class="section-header-row">
        <div class="section-header" style="margin-bottom:0">
          <div class="section-eyebrow">Open for Application</div>
          <div class="section-title">Available Stalls</div>
          <div class="section-sub">Click any stall to view full details and submit your application.</div>
        </div>
      </div>

      <!-- Filters -->
      <div class="filter-bar" style="margin-top:28px">
        <div class="fsearch">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input id="stall-search" placeholder="Search by stall no. or section…" oninput="renderStalls()" />
        </div>
        <button class="fpill on" data-f="all" onclick="setFilter(this)">All Stalls</button>
        <button class="fpill" data-f="open" onclick="setFilter(this)">Open Now</button>
        <button class="fpill" data-f="small" onclick="setFilter(this)">Small (3×3m)</button>
        <button class="fpill" data-f="medium" onclick="setFilter(this)">Medium (4×4m)</button>
        <button class="fpill" data-f="large" onclick="setFilter(this)">Large (5×5m)</button>
        <div class="sort-wrap">
          <span class="sort-lbl">Sort:</span>
          <select class="sort-sel" id="sort-sel" onchange="renderStalls()">
            <option value="default">Featured</option>
            <option value="rate-low">Rate: Low–High</option>
            <option value="rate-high">Rate: High–Low</option>
            <option value="section">By Section</option>
          </select>
        </div>
      </div>

      <div class="stall-grid" id="stall-grid"></div>
      <div class="pagination" id="pagination"></div>
    </div>
  </section>

  <!-- ═══ PROCESS + FAQ ═══ -->
  <section class="section" style="background:var(--cream)">
    <div class="section-inner">
      <div class="callout-grid">
        <div class="callout">
          <div class="callout-ico or">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="12" y1="18" x2="12" y2="12" />
              <line x1="9" y1="15" x2="15" y2="15" />
            </svg>
          </div>
          <div class="callout-title">Pre-Screening Application</div>
          <div class="callout-desc">Submit your interest online before visiting the market office. You will need a valid
            government-issued ID and a selfie holding it. The office will contact you for the next steps.</div>
          <a class="callout-link" onclick="openM('applyModal')" href="#">Apply online now <svg
              xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg></a>
        </div>
        <div class="callout">
          <div class="callout-ico amber">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
          </div>
          <div class="callout-title">Track Your Application</div>
          <div class="callout-desc">Already submitted? Use your Application Number to check where your application
            stands in the review process — from submission to qualification and awarding.</div>
          <a class="callout-link" onclick="openM('trackModal')" href="#">Check application status <svg
              xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="section" id="faq">
    <div class="section-inner" style="max-width:720px">
      <div class="section-header">
        <div class="section-eyebrow">Questions & Answers</div>
        <div class="section-title">Frequently Asked Questions</div>
      </div>
      <div class="faq-list" id="faq-list"></div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer>
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <div class="footer-brand">
            <div class="brand-seal" style="width:32px;height:32px"><svg xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              </svg></div>
            <div class="footer-brand-name">ARKIPAISI</div>
          </div>
          <div class="footer-desc">Official public market stall rental system of the municipal government. For
            inquiries, visit the Market Administration Office during office hours.</div>
        </div>
        <div>
          <div class="footer-col-title">Quick Links</div>
          <a class="footer-link" href="#stalls">Available Stalls</a>
          <a class="footer-link" href="#how">How It Works</a>
          <a class="footer-link" href="#faq">FAQ</a>
          <a class="footer-link" onclick="openM('applyModal')" href="#">Apply for a Stall</a>
          <a class="footer-link" onclick="openM('trackModal')" href="#">Track Application</a>
        </div>
        <div>
          <div class="footer-col-title">Contact</div>
          <a class="footer-link">Market Administration Office</a>
          <a class="footer-link">Mon–Fri · 8:00 AM – 5:00 PM</a>
          <a class="footer-link">market.office@lgu.gov.ph</a>
          <a class="footer-link">(044) 123-4567</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-copy">© 2026 ARKIPAISI Market Management System · Municipal Government</div>
        <a href="#" style="font-size:12px;color:rgba(255,255,255,.3);text-decoration:none">Admin Login</a>
      </div>
    </div>
  </footer>

  <!-- ══════════════════════════════
     STALL DETAIL + APPLY MODAL
══════════════════════════════ -->
  <div class="mbg" id="stallModal">
    <div class="modal">
      <div class="mhd">
        <div class="mtit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--or)"
            stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          </svg><span id="stall-modal-title">Stall Details</span></div>
        <div class="mx" onclick="closeM('stallModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy" id="stall-modal-body"></div>
      <div class="mft" id="stall-modal-footer"></div>
    </div>
  </div>

  <!-- ══════════════════════════════
     APPLY MODAL (multi-step)
══════════════════════════════ -->
  <div class="mbg" id="applyModal">
    <div class="modal">
      <div class="mhd">
        <div class="mtit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--amber)"
            stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="12" y1="18" x2="12" y2="12" />
            <line x1="9" y1="15" x2="15" y2="15" />
          </svg>Stall Application</div>
        <div class="mx" onclick="closeM('applyModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy" id="apply-body"></div>
      <div class="mft" id="apply-footer"></div>
    </div>
  </div>

  <!-- ══════════════════════════════
     TRACK MODAL
══════════════════════════════ -->
  <div class="mbg" id="trackModal">
    <div class="modal track-modal">
      <div class="mhd">
        <div class="mtit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--or)"
            stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>Track Application</div>
        <div class="mx" onclick="closeM('trackModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy" id="track-body"></div>
    </div>
  </div>

  <script src="/js/index.js"></script>
</body>

</html>