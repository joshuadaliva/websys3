<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ARKIPAISI &mdash; My Profile</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#f4f5f7;--surface:#fff;--s2:#f9fafb;--s3:#f3f4f6;--brd:#e5e7eb;--brd2:#f0f1f3;--t1:#0f1117;--t2:#6b7280;--t3:#9ca3af;--ac:#1d4ed8;--acl:#eff3ff;--acs:#dbeafe;--acd:#1e3a8a;--gr:#16a34a;--grl:#f0fdf4;--grs:#dcfce7;--am:#d97706;--aml:#fffbeb;--ams:#fef3c7;--rd:#dc2626;--rdl:#fef2f2;--rds:#fee2e2;--sidebar-w:240px;--r:10px;--rs:6px;--sh:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04)}
html.dark{--bg:#0d0f14;--surface:#161b27;--s2:#1e2535;--s3:#222840;--brd:#2a3245;--brd2:#222840;--t1:#f1f5f9;--t2:#94a3b8;--t3:#64748b;--ac:#3b82f6;--acl:#1e2d4a;--acs:#1e3a5f;--grl:#0d2318;--grs:#0f3a20;--aml:#1a1200;--ams:#2d1f00;--rdl:#1a0a0a;--rds:#2d1010}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t1);display:flex;min-height:100vh}
.sb{width:var(--sidebar-w);min-height:100vh;background:var(--surface);border-right:1px solid var(--brd);display:flex;flex-direction:column;position:fixed;left:0;top:0;z-index:60;transition:transform .28s cubic-bezier(.4,0,.2,1)}
.sb-logo{height:60px;padding:0 16px 0 20px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-m{width:32px;height:32px;background:var(--ac);border-radius:8px;display:grid;place-items:center;color:#fff;font-size:12px;font-weight:800;flex-shrink:0}
.logo-n{font-size:14px;font-weight:800;letter-spacing:-.3px}.logo-sub{font-size:9.5px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-top:1px}
.sb-x{width:26px;height:26px;border-radius:6px;border:1px solid var(--brd);background:var(--s2);display:grid;place-items:center;cursor:pointer;color:var(--t2);flex-shrink:0;transition:all .14s}.sb-x:hover{background:var(--rdl);color:var(--rd)}.sb-x svg{width:13px;height:13px}
.sb-nav{flex:1;padding:10px 8px;overflow-y:auto}
.nsec{font-size:9.5px;font-weight:700;color:var(--t3);letter-spacing:.9px;text-transform:uppercase;padding:10px 10px 4px;margin-top:4px}
.ni{display:flex;align-items:center;gap:9px;padding:8px 12px;border-radius:var(--rs);color:var(--t2);cursor:pointer;font-size:13px;font-weight:500;transition:all .14s;margin-bottom:1px;text-decoration:none}.ni:hover{background:var(--s2);color:var(--t1)}.ni.on{background:var(--acl);color:var(--ac);font-weight:600}.ni svg{width:15px;height:15px;flex-shrink:0}
.nbdg{margin-left:auto;font-size:10px;font-weight:700;padding:1px 6px;border-radius:8px;font-family:'DM Mono',monospace;background:var(--rds);color:var(--rd)}.nbdg.am{background:var(--ams);color:var(--am)}.nbdg.bl{background:var(--acs);color:var(--ac)}
.sb-foot{padding:12px 8px;border-top:1px solid var(--brd);flex-shrink:0}.urow{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:var(--rs);cursor:pointer;transition:background .14s}.urow:hover{background:var(--s2)}
.uav{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--ac),var(--acd));display:grid;place-items:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0}
.veil{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:55;cursor:pointer}
.main{flex:1;display:flex;flex-direction:column;margin-left:var(--sidebar-w);min-height:100vh;transition:margin-left .28s;min-width:0;overflow-x:hidden}
.navbar{height:60px;background:var(--surface);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 20px;gap:12px;position:sticky;top:0;z-index:40;flex-shrink:0}
.togbtn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surface);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0}.togbtn:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}.togbtn svg{width:15px;height:15px}
.page-title{font-size:14px;font-weight:700;flex:1}.nb-r{display:flex;align-items:center;gap:8px}
.theme-btn,.icon-btn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surface);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;position:relative}.theme-btn:hover,.icon-btn:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}.theme-btn svg,.icon-btn svg{width:14px;height:14px}
.notif-dot{position:absolute;top:5px;right:5px;width:7px;height:7px;background:var(--rd);border-radius:50%;border:1.5px solid var(--surface)}
.av-btn{display:flex;align-items:center;gap:7px;padding:3px 10px 3px 3px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surface);cursor:pointer}.av-sm{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--ac),var(--acd));display:grid;place-items:center;color:#fff;font-size:9px;font-weight:700}.av-btn-name{font-size:12px;font-weight:600}
.content{padding:22px;flex:1}
.page-header{margin-bottom:20px}.page-header h1{font-size:21px;font-weight:800;letter-spacing:-.5px}.page-header p{font-size:13px;color:var(--t2);margin-top:3px}
.pgrid{display:grid;grid-template-columns:1fr 300px;gap:16px;align-items:start}
.panel{background:var(--surface);border:1px solid var(--brd);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden;margin-bottom:16px}.panel:last-child{margin-bottom:0}
.ph{padding:14px 18px;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between;gap:10px}.ph-ttl{font-size:13.5px;font-weight:700}
.prof-banner{height:64px;background:linear-gradient(135deg,var(--ac),var(--acd))}
.prof-av-row{padding:0 18px;margin-top:-28px;margin-bottom:14px;display:flex;align-items:flex-end;justify-content:space-between}
.prof-av{width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--ac),var(--acd));display:grid;place-items:center;color:#fff;font-size:18px;font-weight:800;border:3px solid var(--surface)}
.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:14px}.fg:last-child{margin-bottom:0}.fg label{font-size:11px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.3px}
.finp{background:var(--s2);border:1px solid var(--brd);border-radius:var(--rs);padding:9px 12px;font-size:13px;color:var(--t1);font-family:'DM Sans',sans-serif;outline:none;transition:border .14s;width:100%}.finp:focus{border-color:var(--ac);background:var(--surface)}.finp::placeholder{color:var(--t3)}
.fgrid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.si-row{display:flex;justify-content:space-between;align-items:center;padding:8px 18px;border-bottom:1px solid var(--brd2)}.si-row:last-child{border-bottom:none}.si-lbl{font-size:12px;color:var(--t2);font-weight:500}.si-val{font-size:13px;font-weight:700}.si-val.mono{font-family:'DM Mono',monospace;font-size:12.5px}.si-val.bl{color:var(--ac)}
.toggle{width:38px;height:22px;background:var(--brd);border-radius:20px;position:relative;cursor:pointer;transition:background .18s;flex-shrink:0}.toggle.on{background:var(--ac)}.toggle::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:#fff;transition:transform .18s;box-shadow:0 1px 3px rgba(0,0,0,.2)}.toggle.on::after{transform:translateX(16px)}
.btn{padding:7px 14px;border-radius:var(--rs);font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px;transition:all .14s}.btn svg{width:12px;height:12px}.btn.pri{background:var(--ac);color:#fff}.btn.pri:hover{background:var(--acd)}.btn.gh{background:var(--surface);border:1px solid var(--brd);color:var(--t2)}.btn.gh:hover{border-color:var(--ac);color:var(--ac)}.btn.sm{padding:5px 10px;font-size:12px}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(8px);background:var(--t1);color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;z-index:999;opacity:0;pointer-events:none;transition:all .22s;white-space:nowrap}.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
@media(max-width:900px){.pgrid{grid-template-columns:1fr}}
@media(max-width:768px){.main{margin-left:0!important}.sb{transform:translateX(calc(-1 * var(--sidebar-w)))}.av-btn-name{display:none}.content{padding:14px}}
@media(max-width:540px){.fgrid2{grid-template-columns:1fr}}
::-webkit-scrollbar{width:4px;height:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--brd);border-radius:10px}
</style>
</head>
<body>
<div class="veil" id="veil" onclick="closeSB()"></div>
<%- include('../partials/sidebar.ejs') %>
<div class="main" id="main">
  <%- include('../partials/header.ejs') %>
  <div class="content">
    <div class="page-header"><h1>My Profile</h1><p>Manage your vendor account information</p></div>

    <!-- Profile banner card -->
    <div class="panel" style="margin-bottom:16px">
      <div class="prof-banner"></div>
      <div class="prof-av-row">
        <div class="prof-av"><%= vendor.initials %></div>
        <button class="btn gh sm" onclick="showToast('Changes saved')">Save Changes</button>
      </div>
      <div style="padding:0 20px 20px">
        <div style="font-size:18px;font-weight:800;letter-spacing:-.3px"><%= vendor.fullName %></div>
        <div style="font-size:12.5px;color:var(--ac);font-weight:600;margin-top:2px">Vendor &bull; Stall <%= stall.number %> &bull; <%= stall.type %></div>
        <div style="font-size:11.5px;color:var(--t3);font-family:'DM Mono',monospace;margin-top:2px"><%= vendor.vendorId %></div>
      </div>
    </div>

    <div class="pgrid">
      <!-- Left: personal info form -->
      <div>
        <div class="panel" style="margin-bottom:16px">
          <div class="ph"><div class="ph-ttl">Personal Information</div></div>
          <div style="padding:18px">
            <div class="fgrid2">
              <div class="fg"><label>First Name</label><input class="finp" value="<%= vendor.firstName %>"/></div>
              <div class="fg"><label>Last Name</label><input class="finp" value="<%= vendor.lastName %>"/></div>
            </div>
            <div class="fg"><label>Middle Name</label><input class="finp" value="<%= vendor.middleName %>"/></div>
            <div class="fg"><label>Phone Number</label><input class="finp" value="<%= vendor.phone %>"/></div>
            <div class="fg"><label>Email Address</label><input class="finp" value="<%= vendor.email %>"/></div>
            <div class="fg"><label>Home Address</label><input class="finp" value="<%= vendor.address %>"/></div>
          </div>
        </div>
        <div class="panel">
          <div class="ph"><div class="ph-ttl">Change Password</div></div>
          <div style="padding:18px">
            <div class="fg"><label>Current Password</label><input class="finp" type="password" placeholder="Enter current password"/></div>
            <div class="fgrid2">
              <div class="fg"><label>New Password</label><input class="finp" type="password" placeholder="Min. 8 chars"/></div>
              <div class="fg"><label>Confirm</label><input class="finp" type="password" placeholder="Repeat new password"/></div>
            </div>
            <div style="display:flex;justify-content:flex-end;margin-top:4px">
              <button class="btn pri" onclick="showToast('Password updated')">Update Password</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: stall & contract info -->
      <div>
        <div class="panel" style="margin-bottom:16px">
          <div class="ph"><div class="ph-ttl">Stall &amp; Contract</div></div>
          <div class="si-row"><span class="si-lbl">Stall Number</span><span class="si-val mono bl"><%= stall.number %></span></div>
          <div class="si-row"><span class="si-lbl">Location</span><span class="si-val"><%= stall.locationShort %></span></div>
          <div class="si-row"><span class="si-lbl">Type</span><span class="si-val"><%= stall.type %></span></div>
          <div class="si-row"><span class="si-lbl">Size</span><span class="si-val mono"><%= stall.size %></span></div>
          <div class="si-row"><span class="si-lbl">Monthly Rate</span><span class="si-val mono bl">&#8369;<%= stall.monthlyRate.toLocaleString() %>.00</span></div>
          <div class="si-row"><span class="si-lbl">Contract Start</span><span class="si-val"><%= stall.contractStart %></span></div>
          <div class="si-row"><span class="si-lbl">Contract Expires</span><span class="si-val"><%= stall.contractExpires %></span></div>
          <div class="si-row"><span class="si-lbl">Vendor ID</span><span class="si-val mono bl"><%= vendor.vendorId %></span></div>
          <div class="si-row"><span class="si-lbl">Assigned Collector</span><span class="si-val"><%= stall.collector %></span></div>
        </div>
        <div class="panel">
          <div class="ph"><div class="ph-ttl">Notification Settings</div></div>
          <div class="si-row"><span class="si-lbl">Payment reminders</span><div class="toggle on" onclick="this.classList.toggle('on')"></div></div>
          <div class="si-row"><span class="si-lbl">New notices from market office</span><div class="toggle on" onclick="this.classList.toggle('on')"></div></div>
          <div class="si-row"><span class="si-lbl">Inquiry replies</span><div class="toggle on" onclick="this.classList.toggle('on')"></div></div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="toast" id="toast"></div>
<script>
let SB_OPEN=window.innerWidth>=768,isDark=false;
function openSB(){SB_OPEN=true;document.getElementById('sb').style.transform='translateX(0)';if(window.innerWidth<768){document.getElementById('veil').style.display='block';document.getElementById('main').style.marginLeft='0';}else{document.getElementById('veil').style.display='none';document.getElementById('main').style.marginLeft='var(--sidebar-w)';}}
function closeSB(){SB_OPEN=false;document.getElementById('sb').style.transform='translateX(calc(-1 * var(--sidebar-w)))';document.getElementById('veil').style.display='none';document.getElementById('main').style.marginLeft='0';}
function toggleSB(){SB_OPEN?closeSB():openSB();}
(function(){if(window.innerWidth<768)closeSB();else openSB();window.addEventListener('resize',function(){if(window.innerWidth>=768){document.getElementById('veil').style.display='none';if(SB_OPEN)document.getElementById('main').style.marginLeft='var(--sidebar-w)';}else{document.getElementById('main').style.marginLeft='0';if(SB_OPEN)document.getElementById('veil').style.display='block';}});})();
function toggleTheme(){isDark=!isDark;document.documentElement.classList.toggle('dark',isDark);const i=document.getElementById('themeIcon');i.innerHTML=isDark?'<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>':'<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';}
let toastTimer=null;
function showToast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');if(toastTimer)clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2500);}
</script>
</body>
</html>
