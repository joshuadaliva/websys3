<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Payments</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --bg: #f4f5f7;
      --surface: #fff;
      --surf: #fff;
      --s2: #f9fafb;
      --s3: #f3f4f6;
      --brd: #e5e7eb;
      --brd2: #f0f1f3;
      --t1: #0f1117;
      --t2: #6b7280;
      --t3: #9ca3af;
      --ac: #1d4ed8;
      --acl: #eff3ff;
      --acs: #dbeafe;
      --acd: #1e3a8a;
      --gr: #16a34a;
      --grl: #f0fdf4;
      --grs: #dcfce7;
      --am: #d97706;
      --aml: #fffbeb;
      --ams: #fef3c7;
      --rd: #dc2626;
      --rdl: #fef2f2;
      --rds: #fee2e2;
      --gcash: #1a51cf;
      --gcashl: #eef2ff;
      --maya: #00b373;
      --mayal: #e6f9f2;
      --sidebar-w: 240px;
      --r: 10px;
      --rs: 6px;
      --sh: 0 1px 3px rgba(0, 0, 0, .06), 0 1px 2px rgba(0, 0, 0, .04);
      --shm: 0 4px 12px rgba(0, 0, 0, .08);
      --shl: 0 20px 60px rgba(0, 0, 0, .15), 0 8px 20px rgba(0, 0, 0, .08)
    }

    html.dark {
      --bg: #0d0f14;
      --surface: #161b27;
      --s2: #1e2535;
      --s3: #222840;
      --brd: #2a3245;
      --brd2: #222840;
      --t1: #f1f5f9;
      --t2: #94a3b8;
      --t3: #64748b;
      --ac: #3b82f6;
      --acl: #1e2d4a;
      --acs: #1e3a5f;
      --grl: #0d2318;
      --grs: #0f3a20;
      --aml: #1a1200;
      --ams: #2d1f00;
      --rdl: #1a0a0a;
      --rds: #2d1010;
      --gcashl: #1a1e40;
      --mayal: #0d2018
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--t1);
      display: flex;
      min-height: 100vh
    }

    .sb {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--brd);
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0;
      top: 0;
      z-index: 60;
      transition: transform .28s cubic-bezier(.4, 0, .2, 1)
    }

    .sb-logo {
      height: 60px;
      padding: 0 16px 0 20px;
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0
    }

    .logo-m {
      width: 32px;
      height: 32px;
      background: var(--ac);
      border-radius: 8px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 12px;
      font-weight: 800;
      flex-shrink: 0
    }

    .logo-n {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -.3px
    }

    .logo-sub {
      font-size: 9.5px;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-top: 1px
    }

    .sb-x {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      border: 1px solid var(--brd);
      background: var(--s2);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      flex-shrink: 0;
      transition: all .14s
    }

    .sb-x:hover {
      background: var(--rdl);
      color: var(--rd)
    }

    .sb-x svg {
      width: 13px;
      height: 13px
    }

    .sb-nav {
      flex: 1;
      padding: 10px 8px;
      overflow-y: auto
    }

    .nsec {
      font-size: 9.5px;
      font-weight: 700;
      color: var(--t3);
      letter-spacing: .9px;
      text-transform: uppercase;
      padding: 10px 10px 4px;
      margin-top: 4px
    }

    .ni {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      border-radius: var(--rs);
      color: var(--t2);
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      transition: all .14s;
      margin-bottom: 1px;
      text-decoration: none
    }

    .ni:hover {
      background: var(--s2);
      color: var(--t1)
    }

    .ni.on {
      background: var(--acl);
      color: var(--ac);
      font-weight: 600
    }

    .ni svg {
      width: 15px;
      height: 15px;
      flex-shrink: 0
    }

    .nbdg {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 8px;
      font-family: 'DM Mono', monospace;
      background: var(--rds);
      color: var(--rd)
    }

    .nbdg.am {
      background: var(--ams);
      color: var(--am)
    }

    .nbdg.bl {
      background: var(--acs);
      color: var(--ac)
    }

    .sb-foot {
      padding: 12px 8px;
      border-top: 1px solid var(--brd);
      flex-shrink: 0
    }

    .urow {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 9px 12px;
      border-radius: var(--rs);
      cursor: pointer;
      transition: background .14s
    }

    .urow:hover {
      background: var(--s2)
    }

    .uav {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--ac), var(--acd));
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0
    }

    .veil {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .4);
      z-index: 55;
      cursor: pointer
    }

    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      transition: margin-left .28s;
      min-width: 0;
      overflow-x: hidden
    }

    /* ══ NAVBAR ══ */
.nav {
    height: 56px;
    background: var(--surf);
    border-bottom: 1px solid var(--brd);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 10px;
    position: sticky;
    top: 0;
    z-index: 40;
    flex-shrink: 0
}

.togbtn {
    width: 32px;
    height: 32px;
    border-radius: var(--rs);
    border: 1px solid var(--brd);
    background: var(--surf);
    display: grid;
    place-items: center;
    cursor: pointer;
    color: var(--t2);
    transition: all .14s;
    flex-shrink: 0
}

.togbtn:hover {
    border-color: var(--ac);
    color: var(--ac);
    background: var(--acl)
}

.togbtn svg {
    width: 15px;
    height: 15px
}

.nav-info {
    flex: 1;
    min-width: 0
}

.nav-ttl {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -.2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis
}

.nav-bc {
    font-size: 11px;
    color: var(--t3)
}

.nav-r {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-shrink: 0
}

.nsrch {
    display: flex;
    align-items: center;
    gap: 7px;
    background: var(--s2);
    border: 1px solid var(--brd);
    border-radius: var(--rs);
    padding: 6px 10px;
    font-size: 12px;
    color: var(--t3);
    cursor: text;
    min-width: 170px;
    transition: border .14s
}

.nsrch:hover {
    border-color: var(--ac)
}

.nsrch svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0
}

.nsrch kbd {
    margin-left: auto;
    font-size: 9.5px;
    background: var(--surf);
    border: 1px solid var(--brd);
    border-radius: 3px;
    padding: 1px 5px;
    font-family: 'DM Mono', monospace;
    color: var(--t3)
}

.nico {
    width: 32px;
    height: 32px;
    border-radius: var(--rs);
    border: 1px solid var(--brd);
    background: var(--surf);
    display: grid;
    place-items: center;
    cursor: pointer;
    color: var(--t2);
    transition: all .14s;
    flex-shrink: 0
}

.nico:hover {
    border-color: var(--ac);
    color: var(--ac);
    background: var(--acl)
}

.nico svg {
    width: 14px;
    height: 14px
}

.avp {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 3px 10px 3px 3px;
    border-radius: var(--rs);
    border: 1px solid var(--brd);
    background: var(--surf);
    cursor: pointer;
    transition: all .14s;
    flex-shrink: 0
}

.avp:hover {
    border-color: var(--ac)
}

.avp-a {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ac), var(--ac));
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 9px;
    font-weight: 700
}

    .content {
      padding: 22px;
      flex: 1
    }

    .pghdr {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 12px
    }

    .pghdr h1 {
      font-size: 21px;
      font-weight: 800;
      letter-spacing: -.5px
    }

    .pghdr p {
      font-size: 13px;
      color: var(--t2);
      margin-top: 3px
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 20px
    }

    .sc {
      background: var(--surface);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      padding: 16px 18px;
      box-shadow: var(--sh)
    }

    .sc-icon {
      width: 38px;
      height: 38px;
      border-radius: 9px;
      display: grid;
      place-items: center;
      margin-bottom: 10px
    }

    .sc-icon svg {
      width: 18px;
      height: 18px
    }

    .sc-icon.bl {
      background: var(--acl);
      color: var(--ac)
    }

    .sc-icon.gr {
      background: var(--grl);
      color: var(--gr)
    }

    .sc-icon.am {
      background: var(--aml);
      color: var(--am)
    }

    .sc-icon.rd {
      background: var(--rdl);
      color: var(--rd)
    }

    .sc-val {
      font-size: 22px;
      font-weight: 800;
      font-family: 'DM Mono', monospace;
      letter-spacing: -.5px;
      line-height: 1
    }

    .sc-lbl {
      font-size: 11.5px;
      color: var(--t3);
      margin-top: 4px
    }

    .sc-sub {
      font-size: 11px;
      font-weight: 600;
      margin-top: 4px
    }

    .sc-sub.gr {
      color: var(--gr)
    }

    .sc-sub.rd {
      color: var(--rd)
    }

    .sc-sub.am {
      color: var(--am)
    }

    .ref-box {
      background: var(--acl);
      border: 1px solid var(--acs);
      border-radius: var(--r);
      padding: 14px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 20px
    }

    .ref-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--ac);
      margin-bottom: 3px
    }

    .ref-code {
      font-size: 19px;
      font-weight: 900;
      font-family: 'DM Mono', monospace;
      color: var(--acd);
      letter-spacing: .5px
    }

    .panel {
      background: var(--surface);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      box-shadow: var(--sh);
      overflow: hidden;
      margin-bottom: 16px
    }

    .panel:last-child {
      margin-bottom: 0
    }

    .ph {
      padding: 14px 18px;
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap
    }

    .ph-ttl {
      font-size: 13.5px;
      font-weight: 700
    }

    .ph-sub {
      font-size: 11.5px;
      color: var(--t2);
      margin-top: 1px
    }

    .pay-guide {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--brd)
    }

    .pay-guide-item {
      padding: 16px 18px;
      background: var(--surface)
    }

    .pgi-label {
      font-size: 11.5px;
      font-weight: 700;
      color: var(--ac);
      margin-bottom: 6px
    }

    .pgi-text {
      font-size: 12.5px;
      color: var(--t2);
      line-height: 1.6
    }

    .tbl-wrap {
      overflow-x: auto
    }

    .tbl {
      width: 100%;
      border-collapse: collapse;
      min-width: 620px
    }

    .tbl th {
      font-size: 10px;
      font-weight: 700;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .5px;
      padding: 10px 14px;
      background: var(--s2);
      border-bottom: 1px solid var(--brd);
      text-align: left;
      white-space: nowrap
    }

    .tbl td {
      padding: 12px 14px;
      font-size: 13px;
      border-bottom: 1px solid var(--brd2);
      vertical-align: middle
    }

    .tbl tr:last-child td {
      border-bottom: none
    }

    .tbl tbody tr:hover td {
      background: var(--s2)
    }

    .bdg {
      display: inline-flex;
      align-items: center;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap
    }

    .bdg.gr {
      background: var(--grs);
      color: var(--gr)
    }

    .bdg.am {
      background: var(--ams);
      color: var(--am)
    }

    .bdg.rd {
      background: var(--rds);
      color: var(--rd)
    }

    .bdg.bl {
      background: var(--acs);
      color: var(--ac)
    }

    .bdg.gy {
      background: var(--s3);
      color: var(--t3)
    }

    .mbdg {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700
    }

    .mbdg.cash {
      background: var(--grs);
      color: var(--gr)
    }

    .mbdg.gcash {
      background: #ede9fe;
      color: #7c3aed
    }

    .mbdg.maya {
      background: #cffafe;
      color: #0e7490
    }

    .pay-action-btn {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 10px;
      border-radius: 6px;
      border: none;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: all .14s
    }

    .pay-action-btn.unpaid {
      background: var(--rdl);
      color: var(--rd);
      border: 1px solid var(--rds)
    }

    .pay-action-btn.unpaid:hover {
      background: var(--rd);
      color: #fff
    }

    .pay-action-btn.overdue {
      background: var(--aml);
      color: var(--am);
      border: 1px solid var(--ams)
    }

    .pay-action-btn.overdue:hover {
      background: var(--am);
      color: #fff
    }

    .pay-action-btn svg {
      width: 11px;
      height: 11px
    }

    /* PAYMENT MODAL */
    .modal-ov {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .55);
      z-index: 200;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px
    }

    .modal-ov.open {
      display: flex
    }

    .pay-modal {
      width: 100%;
      max-width: 440px;
      background: var(--surface);
      border-radius: 14px;
      box-shadow: var(--shl);
      overflow: hidden
    }

    .pm-head {
      padding: 18px 20px;
      border-bottom: 1px solid var(--brd)
    }

    .pm-head h2 {
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -.3px
    }

    .pm-head p {
      font-size: 12.5px;
      color: var(--t2);
      margin-top: 3px
    }

    .pm-period {
      font-size: 13px;
      font-weight: 700;
      color: var(--ac);
      font-family: 'DM Mono', monospace;
      margin-top: 4px
    }

    .pm-body {
      padding: 18px
    }

    .method-grid {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 18px
    }

    .method-card {
      border: 2px solid var(--brd);
      border-radius: 10px;
      padding: 14px 16px;
      cursor: pointer;
      transition: all .18s;
      display: flex;
      align-items: center;
      gap: 14px
    }

    .method-card:hover {
      border-color: var(--acs)
    }

    .method-card.selected {
      border-color: var(--ac);
      background: var(--acl)
    }

    .method-card.gcash-card:hover,
    .method-card.gcash-card.selected {
      border-color: var(--gcash);
      background: var(--gcashl)
    }

    .method-card.maya-card:hover,
    .method-card.maya-card.selected {
      border-color: var(--maya);
      background: var(--mayal)
    }

    .method-logo {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: -.5px;
      flex-shrink: 0
    }

    .method-logo.gcash {
      background: #1a51cf;
      color: #fff
    }

    .method-logo.maya {
      background: #00b373;
      color: #fff
    }

    .method-logo.cash {
      background: var(--grl);
      border: 1.5px solid var(--grs);
      color: var(--gr)
    }

    .method-logo.cash svg {
      width: 20px;
      height: 20px
    }

    .method-info {
      flex: 1
    }

    .method-name {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -.2px
    }

    .method-desc {
      font-size: 12px;
      color: var(--t2);
      margin-top: 2px;
      line-height: 1.4
    }

    .method-tag {
      font-size: 10.5px;
      font-weight: 700;
      padding: 1px 7px;
      border-radius: 20px;
      margin-top: 5px;
      display: inline-block
    }

    .method-tag.auto {
      background: var(--grs);
      color: var(--gr)
    }

    .method-tag.manual {
      background: var(--acs);
      color: var(--ac)
    }

    .method-radio {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      border: 2px solid var(--brd);
      flex-shrink: 0;
      transition: all .16s;
      display: grid;
      place-items: center
    }

    .method-card.selected .method-radio {
      border-color: var(--ac);
      background: var(--ac)
    }

    .method-card.gcash-card.selected .method-radio {
      border-color: var(--gcash);
      background: var(--gcash)
    }

    .method-card.maya-card.selected .method-radio {
      border-color: var(--maya);
      background: var(--maya)
    }

    .method-radio::after {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #fff;
      opacity: 0;
      transition: opacity .14s
    }

    .method-card.selected .method-radio::after {
      opacity: 1
    }

    .ref-panel {
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: 8px;
      padding: 14px;
      margin-top: 14px;
      display: none
    }

    .ref-panel.show {
      display: block
    }

    .rp-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--t2);
      text-transform: uppercase;
      letter-spacing: .4px;
      margin-bottom: 6px
    }

    .rp-code {
      font-size: 20px;
      font-weight: 900;
      font-family: 'DM Mono', monospace;
      letter-spacing: .5px;
      margin-bottom: 6px
    }

    .rp-hint {
      font-size: 12px;
      color: var(--t2);
      line-height: 1.5
    }

    .rp-copy {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 8px;
      padding: 5px 11px;
      border-radius: 6px;
      border: 1px solid var(--brd);
      background: var(--surface);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      color: var(--t2);
      transition: all .14s
    }

    .rp-copy:hover {
      border-color: var(--ac);
      color: var(--ac)
    }

    .rp-copy svg {
      width: 12px;
      height: 12px
    }

    .pm-foot {
      padding: 14px 20px;
      border-top: 1px solid var(--brd);
      background: var(--s2);
      display: flex;
      justify-content: flex-end;
      gap: 8px
    }

    .btn {
      padding: 8px 16px;
      border-radius: var(--rs);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      font-family: 'DM Sans', sans-serif;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all .14s
    }

    .btn svg {
      width: 13px;
      height: 13px;
      flex-shrink: 0
    }

    .btn.pri {
      background: var(--ac);
      color: #fff
    }

    .btn.pri:hover {
      background: var(--acd)
    }

    .btn.gh {
      background: var(--surface);
      border: 1px solid var(--brd);
      color: var(--t2)
    }

    .btn.gh:hover {
      border-color: var(--ac);
      color: var(--ac)
    }

    .btn.sm {
      padding: 6px 12px;
      font-size: 12px
    }

    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--t1);
      color: #fff;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: all .22s;
      white-space: nowrap
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0)
    }

    @media(max-width:1100px) {
      .stats {
        grid-template-columns: repeat(2, 1fr)
      }
    }

    @media(max-width:768px) {
      .main {
        margin-left: 0 !important
      }

      .sb {
        transform: translateX(calc(-1 * var(--sidebar-w)))
      }

      .av-btn-name {
        display: none
      }

      .content {
        padding: 14px
      }

      .stats {
        grid-template-columns: repeat(2, 1fr)
      }

      .pay-guide {
        grid-template-columns: 1fr
      }
    }

    @media(max-width:480px) {
      .content {
        padding: 10px
      }

      .stats {
        grid-template-columns: 1fr 1fr
      }
    }

    @media(max-width:540px) {
      .modal-ov {
        padding: 0;
        align-items: flex-end
      }

      .pay-modal {
        border-radius: 14px 14px 0 0;
        max-width: 100%
      }
    }

    ::-webkit-scrollbar {
      width: 4px;
      height: 4px
    }

    ::-webkit-scrollbar-track {
      background: transparent
    }

    ::-webkit-scrollbar-thumb {
      background: var(--brd);
      border-radius: 10px
    }
  </style>
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>
  <%- include("../partials/sidebar.ejs", { currentRoute, role: "vendor" , initials: "vendor" , fullName: "joshua daliva", stallNumber: 06}) %>
    <div class="main" id="main">
      <%- include("../partials/header.ejs", {role: "vendor" , initials: "vendor" , lastName: "daliva" , }) %>
        <div class="content">
          <div class="pghdr">
            <div>
              <h1>Payments</h1>
              <p>Your rental fee history and official receipts &mdash; Stall <%= stall.number %>
              </p>
            </div>
            <button class="btn gh sm" onclick="showToast('Downloading PDF...')">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              Download All
            </button>
          </div>

          <!-- Stats — server-rendered -->
          <div class="stats">
            <div class="sc">
              <div class="sc-icon rd"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                </svg></div>
              <div class="sc-val">&#8369;<%= pStats.balanceDue.toLocaleString() %>
              </div>
              <div class="sc-lbl">Balance Due</div>
              <div class="sc-sub rd">
                <%= pStats.duePeriod || 'None' %>
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon gr"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg></div>
              <div class="sc-val" id="totalPaidVal">&#8369;<%= pStats.totalPaid.toLocaleString() %>
              </div>
              <div class="sc-lbl">Total Paid 2026</div>
              <div class="sc-sub gr" id="paidCountSub">
                <%= pStats.paidCount %> payments
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="1" y="4" width="22" height="16" rx="2" />
                  <line x1="1" y1="10" x2="23" y2="10" />
                </svg></div>
              <div class="sc-val">&#8369;<%= stall.monthlyRate.toLocaleString() %>
              </div>
              <div class="sc-lbl">Monthly Rate</div>
              <div class="sc-sub">
                <%= stall.type %>
                  <%= stall.number %>
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon am"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg></div>
              <div class="sc-val">Dec 31</div>
              <div class="sc-lbl">Contract Expires</div>
              <div class="sc-sub">2026</div>
            </div>
          </div>

          <!-- Reference code banner -->
          <div class="ref-box">
            <div>
              <div class="ref-label">Your payment reference code for March 2026</div>
              <div class="ref-code">
                <%= stall.referenceCode %>
              </div>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              <button class="btn gh sm" onclick="copyRef()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" />
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </svg>
                Copy Code
              </button>
              <button class="btn pri sm" onclick="openPayModal(null)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
                Pay Now
              </button>
            </div>
          </div>

          <!-- How to pay -->
          <div class="panel" style="margin-bottom:16px">
            <div class="ph">
              <div class="ph-ttl">How to Pay</div>
            </div>
            <div class="pay-guide">
              <div class="pay-guide-item">
                <div class="pgi-label">GCash / Maya</div>
                <div class="pgi-text">Send to the market account using your reference code <strong>
                    <%= stall.referenceCode %>
                  </strong>. Payment is auto-detected within minutes and an OR is issued automatically.</div>
              </div>
              <div class="pay-guide-item">
                <div class="pgi-label">Cash Payment</div>
                <div class="pgi-text">Pay your assigned collector (<strong>
                    <%= stall.collector %>
                  </strong>) in person. They will issue an Official Receipt from their numbered booklet.</div>
              </div>
              <div class="pay-guide-item">
                <div class="pgi-label">Market Office</div>
                <div class="pgi-text">Visit the Revenue Collection window at the Market Admin office. Open Monday to
                  Saturday, 8:00 AM to 5:00 PM.</div>
              </div>
            </div>
          </div>

          <!-- Payment table — JS-rendered, data injected from server -->
          <div class="panel">
            <div class="ph">
              <div>
                <div class="ph-ttl">Payment History</div>
                <div class="ph-sub">All official receipts on your account</div>
              </div>
              <button class="btn gh sm" onclick="showToast('Exporting CSV...')">Export</button>
            </div>
            <div class="tbl-wrap">
              <table class="tbl">
                <thead>
                  <tr>
                    <th>Period</th>
                    <th>OR No.</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th>Issued By</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="payTable"></tbody>
              </table>
            </div>
            <div
              style="padding:10px 16px;background:var(--s2);border-top:1px solid var(--brd);font-size:12px;color:var(--t3)"
              id="tblInfo">--</div>
          </div>
        </div>
    </div>

    <!-- PAYMENT METHOD MODAL -->
    <div class="modal-ov" id="payModalOv" onclick="if(event.target===this)closePayModal()">
      <div class="pay-modal">
        <div class="pm-head">
          <h2>Pay Rental Fee</h2>
          <p>Choose how you want to pay</p>
          <div class="pm-period" id="pmPeriod">March 2026 &mdash; PHP <%= stall.monthlyRate.toLocaleString() %>
          </div>
        </div>
        <div class="pm-body">
          <div class="method-grid">
            <div class="method-card gcash-card" id="mc-gcash" onclick="selectMethod('gcash')">
              <div class="method-logo gcash">G</div>
              <div class="method-info">
                <div class="method-name">GCash</div>
                <div class="method-desc">Send via GCash using your reference code. Auto-detected within minutes.</div>
                <span class="method-tag auto">Auto-detected</span>
              </div>
              <div class="method-radio" id="mr-gcash"></div>
            </div>
            <div class="method-card maya-card" id="mc-maya" onclick="selectMethod('maya')">
              <div class="method-logo maya">M</div>
              <div class="method-info">
                <div class="method-name">Maya</div>
                <div class="method-desc">Send via Maya using your reference code. Auto-detected and posted immediately.
                </div><span class="method-tag auto">Auto-detected</span>
              </div>
              <div class="method-radio" id="mr-maya"></div>
            </div>
            <div class="method-card" id="mc-cash" onclick="selectMethod('cash')">
              <div class="method-logo cash"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg></div>
              <div class="method-info">
                <div class="method-name">Cash</div>
                <div class="method-desc">Pay your collector in person or at the market office. An OR will be issued.
                </div><span class="method-tag manual">Manual OR issuance</span>
              </div>
              <div class="method-radio" id="mr-cash"></div>
            </div>
          </div>
          <div class="ref-panel" id="refPanel">
            <div class="rp-label" id="rpLabel">GCash Reference Code</div>
            <div class="rp-code">
              <%= stall.referenceCode %>
            </div>
            <div class="rp-hint" id="rpHint">Open GCash &rarr; Send Money &rarr; paste this code as the reference.</div>
            <button class="rp-copy" onclick="copyRef()">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" />
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg>
              Copy <%= stall.referenceCode %>
            </button>
          </div>
          <div class="ref-panel" id="cashPanel">
            <div class="rp-label">Pay in Person</div>
            <div style="font-size:13px;color:var(--t2);line-height:1.6">Your assigned collector is <strong
                style="color:var(--t1)">
                <%= stall.collector %>
              </strong>. Contact them at your stall or at the market office. They will issue an Official Receipt upon
              payment.</div>
          </div>
        </div>
        <div class="pm-foot">
          <button class="btn gh" onclick="closePayModal()">Cancel</button>
          <button class="btn pri" id="pmConfirmBtn" onclick="confirmPayment()" disabled
            style="opacity:.4;cursor:not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            Confirm
          </button>
        </div>
      </div>
    </div>
    <div class="toast" id="toast"></div>

    <script>
      const PAYMENTS = <%- JSON.stringify(payments) %>;
      const REF_CODE = '<%= stall.referenceCode %>';
      const COLLECTOR = '<%= stall.collector %>';
    </script>
    <script>
      let SB_OPEN = window.innerWidth >= 768, isDark = false;
      function openSB() { SB_OPEN = true; document.getElementById('sb').style.transform = 'translateX(0)'; if (window.innerWidth < 768) { document.getElementById('veil').style.display = 'block'; document.getElementById('main').style.marginLeft = '0'; } else { document.getElementById('veil').style.display = 'none'; document.getElementById('main').style.marginLeft = 'var(--sidebar-w)'; } }
      function closeSB() { SB_OPEN = false; document.getElementById('sb').style.transform = 'translateX(calc(-1 * var(--sidebar-w)))'; document.getElementById('veil').style.display = 'none'; document.getElementById('main').style.marginLeft = '0'; }
      function toggleSB() { SB_OPEN ? closeSB() : openSB(); }
      (function () { if (window.innerWidth < 768) closeSB(); else openSB(); window.addEventListener('resize', function () { if (window.innerWidth >= 768) { document.getElementById('veil').style.display = 'none'; if (SB_OPEN) document.getElementById('main').style.marginLeft = 'var(--sidebar-w)'; } else { document.getElementById('main').style.marginLeft = '0'; if (SB_OPEN) document.getElementById('veil').style.display = 'block'; } }); })();
      function toggleTheme() { isDark = !isDark; document.documentElement.classList.toggle('dark', isDark); const i = document.getElementById('themeIcon'); i.innerHTML = isDark ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>' : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>'; }

      const MBDG = {
        Cash: '<span class="mbdg cash">Cash</span>',
        GCash: '<span class="mbdg gcash">&loz; GCash</span>',
        Maya: '<span class="mbdg maya">&loz; Maya</span>',
      };

      function renderTable() {
        const tbody = document.getElementById('payTable');
        const info = document.getElementById('tblInfo');
        const paid = PAYMENTS.filter(p => p.status === 'paid');
        const total = paid.reduce((s, p) => s + p.amount, 0);
        info.textContent = `${PAYMENTS.length} records — Total paid 2026: PHP ${total.toLocaleString()}`;
        tbody.innerHTML = PAYMENTS.map(p => {
          let statusCell, actionCell;
          if (p.status === 'paid') {
            statusCell = '<span class="bdg gr">Paid</span>';
            actionCell = `<button class="btn gh sm" onclick="showToast('Downloading OR...')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>OR</button>`;
          } else if (p.status === 'unpaid') {
            statusCell = '<span class="bdg rd">Unpaid</span>';
            actionCell = `<button class="pay-action-btn unpaid" onclick="openPayModal(${p.id})"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>Pay Now</button>`;
          } else {
            statusCell = '<span class="bdg am">Overdue</span>';
            actionCell = `<button class="pay-action-btn overdue" onclick="openPayModal(${p.id})">Pay Overdue</button>`;
          }
          return `<tr>
      <td style="font-weight:700">${p.period}</td>
      <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:700;color:var(--ac)">${p.or || '<span style="color:var(--t3)">Not yet issued</span>'}</td>
      <td style="font-family:'DM Mono',monospace;font-weight:700;color:${p.status === 'paid' ? 'var(--gr)' : 'var(--rd)'}">&#8369;${p.amount.toLocaleString()}</td>
      <td>${p.method ? (MBDG[p.method] || p.method) : '<span style="color:var(--t3)">--</span>'}</td>
      <td style="font-size:12px;color:var(--t2)">${p.issuedBy || '--'}</td>
      <td style="font-size:12px;color:var(--t3)">${p.date || '--'}</td>
      <td>${statusCell}</td>
      <td>${actionCell}</td>
    </tr>`;
        }).join('');
      }

      let ACTIVE_PAYMENT_ID = null, SELECTED_METHOD = null;

      function openPayModal(payId) {
        ACTIVE_PAYMENT_ID = payId;
        SELECTED_METHOD = null;
        const p = payId !== null ? PAYMENTS.find(x => x.id === payId) : null;
        document.getElementById('pmPeriod').textContent = (p ? p.period : 'March 2026') + ' — PHP ' + (p ? p.amount.toLocaleString() : '1,200');
        ['gcash', 'maya', 'cash'].forEach(m => { document.getElementById('mc-' + m).classList.remove('selected'); document.getElementById('mr-' + m).classList.remove('selected'); });
        document.getElementById('refPanel').classList.remove('show');
        document.getElementById('cashPanel').classList.remove('show');
        const btn = document.getElementById('pmConfirmBtn');
        btn.disabled = true; btn.style.opacity = '.4'; btn.style.cursor = 'not-allowed';
        document.getElementById('payModalOv').classList.add('open');
      }

      function closePayModal() {
        document.getElementById('payModalOv').classList.remove('open');
        ACTIVE_PAYMENT_ID = null; SELECTED_METHOD = null;
      }

      function selectMethod(m) {
        SELECTED_METHOD = m;
        ['gcash', 'maya', 'cash'].forEach(x => {
          document.getElementById('mc-' + x).classList.toggle('selected', x === m);
          document.getElementById('mr-' + x).classList.toggle('selected', x === m);
        });
        document.getElementById('refPanel').classList.remove('show');
        document.getElementById('cashPanel').classList.remove('show');
        if (m === 'gcash') {
          document.getElementById('refPanel').classList.add('show');
          document.getElementById('rpLabel').textContent = 'GCash Payment Reference';
          document.getElementById('rpHint').textContent = 'Open GCash → Send Money → paste this reference. Your payment will be auto-detected and posted within minutes.';
        } else if (m === 'maya') {
          document.getElementById('refPanel').classList.add('show');
          document.getElementById('rpLabel').textContent = 'Maya Payment Reference';
          document.getElementById('rpHint').textContent = 'Open Maya → Send Money → paste this reference. Your payment will be auto-detected and posted immediately.';
        } else {
          document.getElementById('cashPanel').classList.add('show');
        }
        const btn = document.getElementById('pmConfirmBtn');
        btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer';
      }

      function confirmPayment() {
        if (!SELECTED_METHOD) return;
        closePayModal();
        if (SELECTED_METHOD === 'gcash' || SELECTED_METHOD === 'maya') {
          showToast('Reference code ready — complete payment in ' + (SELECTED_METHOD === 'gcash' ? 'GCash' : 'Maya'));
        } else {
          showToast('Noted! Pay your collector or visit the market office.');
        }
      }

      function copyRef() {
        navigator.clipboard.writeText(REF_CODE).catch(() => { });
        showToast('Reference code copied!');
      }

      renderTable();

      let toastTimer = null;
      function showToast(m) { const t = document.getElementById('toast'); t.textContent = m; t.classList.add('show'); if (toastTimer) clearTimeout(toastTimer); toastTimer = setTimeout(() => t.classList.remove('show'), 2500); }
    </script>
</body>

</html>