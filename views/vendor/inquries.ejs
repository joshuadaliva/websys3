<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Inquiry</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    :root {
      --bg: #f4f5f7;
      --surface: #fff;
      --surf: #fff;
      --s2: #f9fafb;
      --s3: #f3f4f6;
      --brd: #e5e7eb;
      --brd2: #f0f1f3;
      --t1: #0f1117;
      --t2: #6b7280;
      --t3: #9ca3af;
      --ac: #1d4ed8;
      --acl: #eff3ff;
      --acs: #dbeafe;
      --acd: #1e3a8a;
      --gr: #16a34a;
      --grl: #f0fdf4;
      --grs: #dcfce7;
      --am: #d97706;
      --aml: #fffbeb;
      --ams: #fef3c7;
      --rd: #dc2626;
      --rdl: #fef2f2;
      --rds: #fee2e2;
      --sidebar-w: 240px;
      --r: 10px;
      --rs: 6px;
      --sh: 0 1px 3px rgba(0, 0, 0, .06), 0 1px 2px rgba(0, 0, 0, .04);
      --shl: 0 20px 60px rgba(0, 0, 0, .15), 0 8px 20px rgba(0, 0, 0, .08)
    }

    html.dark {
      --bg: #0d0f14;
      --surface: #161b27;
      --s2: #1e2535;
      --s3: #222840;
      --brd: #2a3245;
      --brd2: #222840;
      --t1: #f1f5f9;
      --t2: #94a3b8;
      --t3: #64748b;
      --ac: #3b82f6;
      --acl: #1e2d4a;
      --acs: #1e3a5f;
      --grl: #0d2318;
      --grs: #0f3a20;
      --aml: #1a1200;
      --ams: #2d1f00;
      --rdl: #1a0a0a;
      --rds: #2d1010
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--t1);
      display: flex;
      min-height: 100vh
    }

    .sb {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--brd);
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0;
      top: 0;
      z-index: 60;
      transition: transform .28s cubic-bezier(.4, 0, .2, 1)
    }

    .sb-logo {
      height: 60px;
      padding: 0 16px 0 20px;
      border-bottom: 1px solid var(--brd);
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0
    }

    .logo-m {
      width: 32px;
      height: 32px;
      background: var(--ac);
      border-radius: 8px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 12px;
      font-weight: 800;
      flex-shrink: 0
    }

    .logo-n {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -.3px
    }

    .logo-sub {
      font-size: 9.5px;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-top: 1px
    }

    .sb-x {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      border: 1px solid var(--brd);
      background: var(--s2);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      flex-shrink: 0;
      transition: all .14s
    }

    .sb-x:hover {
      background: var(--rdl);
      color: var(--rd)
    }

    .sb-x svg {
      width: 13px;
      height: 13px
    }

    .sb-nav {
      flex: 1;
      padding: 10px 8px;
      overflow-y: auto
    }

    .nsec {
      font-size: 9.5px;
      font-weight: 700;
      color: var(--t3);
      letter-spacing: .9px;
      text-transform: uppercase;
      padding: 10px 10px 4px;
      margin-top: 4px
    }

    .ni {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      border-radius: var(--rs);
      color: var(--t2);
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      transition: all .14s;
      margin-bottom: 1px;
      text-decoration: none
    }

    .ni:hover {
      background: var(--s2);
      color: var(--t1)
    }

    .ni.on {
      background: var(--acl);
      color: var(--ac);
      font-weight: 600
    }

    .ni svg {
      width: 15px;
      height: 15px;
      flex-shrink: 0
    }

    .nbdg {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 8px;
      font-family: 'DM Mono', monospace;
      background: var(--rds);
      color: var(--rd)
    }

    .nbdg.am {
      background: var(--ams);
      color: var(--am)
    }

    .nbdg.bl {
      background: var(--acs);
      color: var(--ac)
    }

    .sb-foot {
      padding: 12px 8px;
      border-top: 1px solid var(--brd);
      flex-shrink: 0
    }

    .urow {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 9px 12px;
      border-radius: var(--rs);
      cursor: pointer;
      transition: background .14s
    }

    .urow:hover {
      background: var(--s2)
    }

    .uav {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--ac), var(--acd));
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0
    }

    .veil {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .4);
      z-index: 55;
      cursor: pointer
    }

    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      transition: margin-left .28s;
      min-width: 0;
      overflow-x: hidden
    }

    /* ══ NAVBAR ══ */
.nav {
    height: 56px;
    background: var(--surf);
    border-bottom: 1px solid var(--brd);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 10px;
    position: sticky;
    top: 0;
    z-index: 40;
    flex-shrink: 0
}

.togbtn {
    width: 32px;
    height: 32px;
    border-radius: var(--rs);
    border: 1px solid var(--brd);
    background: var(--surf);
    display: grid;
    place-items: center;
    cursor: pointer;
    color: var(--t2);
    transition: all .14s;
    flex-shrink: 0
}

.togbtn:hover {
    border-color: var(--ac);
    color: var(--ac);
    background: var(--acl)
}

.togbtn svg {
    width: 15px;
    height: 15px
}

.nav-info {
    flex: 1;
    min-width: 0
}

.nav-ttl {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -.2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis
}

.nav-bc {
    font-size: 11px;
    color: var(--t3)
}

.nav-r {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-shrink: 0
}

.nsrch {
    display: flex;
    align-items: center;
    gap: 7px;
    background: var(--s2);
    border: 1px solid var(--brd);
    border-radius: var(--rs);
    padding: 6px 10px;
    font-size: 12px;
    color: var(--t3);
    cursor: text;
    min-width: 170px;
    transition: border .14s
}

.nsrch:hover {
    border-color: var(--ac)
}

.nsrch svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0
}

.nsrch kbd {
    margin-left: auto;
    font-size: 9.5px;
    background: var(--surf);
    border: 1px solid var(--brd);
    border-radius: 3px;
    padding: 1px 5px;
    font-family: 'DM Mono', monospace;
    color: var(--t3)
}

.nico {
    width: 32px;
    height: 32px;
    border-radius: var(--rs);
    border: 1px solid var(--brd);
    background: var(--surf);
    display: grid;
    place-items: center;
    cursor: pointer;
    color: var(--t2);
    transition: all .14s;
    flex-shrink: 0
}

.nico:hover {
    border-color: var(--ac);
    color: var(--ac);
    background: var(--acl)
}

.nico svg {
    width: 14px;
    height: 14px
}

.avp {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 3px 10px 3px 3px;
    border-radius: var(--rs);
    border: 1px solid var(--brd);
    background: var(--surf);
    cursor: pointer;
    transition: all .14s;
    flex-shrink: 0
}

.avp:hover {
    border-color: var(--ac)
}

.avp-a {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ac), var(--ac));
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 9px;
    font-weight: 700
}


    .content {
      padding: 22px;
      flex: 1
    }

    .pghdr {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 12px
    }

    .pghdr h1 {
      font-size: 21px;
      font-weight: 800;
      letter-spacing: -.5px
    }

    .pghdr p {
      font-size: 13px;
      color: var(--t2);
      margin-top: 3px
    }

    /* FILTER BAR */
    .filter-bar {
      background: var(--surface);
      border: 1px solid var(--brd);
      border-radius: var(--r);
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 16px;
      box-shadow: var(--sh)
    }

    .srch {
      display: flex;
      align-items: center;
      gap: 7px;
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 7px 10px;
      font-size: 13px;
      color: var(--t1);
      flex: 1;
      min-width: 160px
    }

    .srch svg {
      width: 13px;
      height: 13px;
      color: var(--t3);
      flex-shrink: 0
    }

    .srch input {
      background: transparent;
      border: none;
      outline: none;
      flex: 1;
      font-size: 13px;
      color: var(--t1);
      font-family: 'DM Sans', sans-serif
    }

    .srch input::placeholder {
      color: var(--t3)
    }

    .fsel {
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 7px 10px;
      font-size: 12.5px;
      font-family: 'DM Sans', sans-serif;
      color: var(--t1);
      cursor: pointer;
      outline: none
    }

    /* CARDS GRID */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
      gap: 14px
    }

    /* TICKET CARD */
    .ticket-card {
      background: var(--surface);
      border: 1.5px solid var(--brd);
      border-radius: var(--r);
      padding: 16px 18px;
      cursor: pointer;
      transition: all .16s;
      box-shadow: var(--sh)
    }

    .ticket-card:hover {
      box-shadow: var(--shm);
      border-color: var(--acs)
    }

    .ticket-card.status-open {
      border-left: 3px solid var(--ac)
    }

    .ticket-card.status-waiting {
      border-left: 3px solid var(--am)
    }

    .ticket-card.status-resolved {
      border-left: 3px solid var(--gr)
    }

    .ticket-card.status-closed {
      border-left: 3px solid var(--t3)
    }

    .tc-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 6px
    }

    .tc-subject {
      font-size: 13.5px;
      font-weight: 700;
      color: var(--t1);
      line-height: 1.3
    }

    .tc-unread {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--ac);
      flex-shrink: 0;
      margin-top: 4px
    }

    .tc-preview {
      font-size: 12px;
      color: var(--t2);
      line-height: 1.5;
      margin-bottom: 10px;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical
    }

    .tc-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap
    }

    .tc-meta {
      display: flex;
      align-items: center;
      gap: 6px
    }

    .tc-status {
      font-size: 10.5px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 20px
    }

    .tc-status.open {
      background: var(--acs);
      color: var(--ac)
    }

    .tc-status.waiting {
      background: var(--ams);
      color: var(--am)
    }

    .tc-status.resolved {
      background: var(--grs);
      color: var(--gr)
    }

    .tc-status.closed {
      background: var(--s3);
      color: var(--t3)
    }

    .tc-cat {
      font-size: 11px;
      color: var(--t3);
      background: var(--s2);
      padding: 2px 7px;
      border-radius: 20px
    }

    .tc-msgs {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 11.5px;
      color: var(--t3)
    }

    .tc-msgs svg {
      width: 11px;
      height: 11px
    }

    .tc-time {
      font-size: 11px;
      color: var(--t3)
    }

    .inq-empty {
      padding: 60px 20px;
      text-align: center;
      color: var(--t3)
    }

    .inq-empty svg {
      width: 44px;
      height: 44px;
      opacity: .2;
      display: block;
      margin: 0 auto 12px
    }

    .inq-empty p {
      font-size: 13.5px;
      font-weight: 600;
      color: var(--t2)
    }

    .inq-empty span {
      font-size: 12px;
      display: block;
      margin-top: 4px
    }

    /* MESSENGER MODAL */
    .messenger-ov {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .5);
      z-index: 200;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px
    }

    .messenger-ov.open {
      display: flex
    }

    .messenger-modal {
      width: 100%;
      max-width: 520px;
      height: 80vh;
      max-height: 680px;
      background: var(--surface);
      border-radius: 14px;
      box-shadow: var(--shl);
      display: flex;
      flex-direction: column;
      overflow: hidden
    }

    .mm-head {
      padding: 14px 18px;
      border-bottom: 1px solid var(--brd);
      flex-shrink: 0
    }

    .mm-subject {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -.2px
    }

    .mm-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 4px
    }

    .mm-status {
      font-size: 10.5px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 20px
    }

    .mm-status.open {
      background: var(--acs);
      color: var(--ac)
    }

    .mm-status.waiting {
      background: var(--ams);
      color: var(--am)
    }

    .mm-status.resolved {
      background: var(--grs);
      color: var(--gr)
    }

    .mm-status.closed {
      background: var(--s3);
      color: var(--t3)
    }

    .mm-cat {
      font-size: 11px;
      color: var(--t3)
    }

    /* PROGRESS TRACKER */
    .prog-bar {
      display: flex;
      align-items: center;
      padding: 12px 18px;
      border-bottom: 1px solid var(--brd);
      gap: 0;
      flex-shrink: 0
    }

    .prog-step {
      display: flex;
      align-items: center;
      flex: 1
    }

    .prog-step:last-child {
      flex: none
    }

    .prog-step-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px
    }

    .prog-dot {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid var(--brd);
      background: var(--s2);
      display: grid;
      place-items: center;
      font-size: 10px;
      font-weight: 700;
      color: var(--t3);
      flex-shrink: 0;
      transition: all .2s
    }

    .prog-dot.active {
      border-color: var(--ac);
      background: var(--ac);
      color: #fff
    }

    .prog-dot.done {
      border-color: var(--gr);
      background: var(--gr);
      color: #fff
    }

    .prog-lbl {
      font-size: 10px;
      font-weight: 600;
      color: var(--t3);
      white-space: nowrap
    }

    .prog-lbl.active {
      color: var(--ac)
    }

    .prog-lbl.done {
      color: var(--gr)
    }

    .prog-line {
      flex: 1;
      height: 2px;
      background: var(--brd);
      margin: 0 4px;
      margin-bottom: 14px
    }

    .prog-line.done {
      background: var(--gr)
    }

    /* MESSAGES */
    .mm-msgs {
      flex: 1;
      overflow-y: auto;
      padding: 16px
    }

    .msg-group {
      margin-bottom: 12px
    }

    .msg-group.mine {
      text-align: right
    }

    .msg-group.theirs {
      text-align: left
    }

    .msg-sender-lbl {
      font-size: 10.5px;
      color: var(--t3);
      margin-bottom: 4px
    }

    .bubble {
      display: inline-block;
      padding: 10px 14px;
      border-radius: 12px;
      font-size: 13px;
      line-height: 1.5;
      max-width: 80%;
      text-align: left;
      word-break: break-word
    }

    .mine .bubble {
      background: var(--ac);
      color: #fff;
      border-radius: 12px 12px 4px 12px
    }

    .theirs .bubble {
      background: var(--s2);
      color: var(--t1);
      border-radius: 12px 12px 12px 4px
    }

    .sys-pill {
      font-size: 11px;
      color: var(--t3);
      text-align: center;
      background: var(--s2);
      border-radius: 20px;
      padding: 4px 12px;
      display: inline-block;
      margin: 8px auto;
      display: block;
      max-width: fit-content;
      margin-left: auto;
      margin-right: auto
    }

    /* INPUT */
    .mm-input-row {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      padding: 12px 16px;
      border-top: 1px solid var(--brd);
      flex-shrink: 0
    }

    .mm-textarea {
      flex: 1;
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: 8px;
      padding: 9px 12px;
      font-size: 13px;
      color: var(--t1);
      font-family: 'DM Sans', sans-serif;
      outline: none;
      resize: none;
      max-height: 100px;
      transition: border .14s;
      line-height: 1.5
    }

    .mm-textarea:focus {
      border-color: var(--ac);
      background: var(--surface)
    }

    .mm-textarea::placeholder {
      color: var(--t3)
    }

    .mm-textarea:disabled {
      opacity: .5;
      cursor: not-allowed
    }

    .mm-hint {
      font-size: 10.5px;
      color: var(--t3);
      padding: 0 16px 8px;
      flex-shrink: 0
    }

    .send-btn {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: var(--ac);
      border: none;
      display: grid;
      place-items: center;
      cursor: pointer;
      color: #fff;
      transition: all .14s;
      flex-shrink: 0
    }

    .send-btn:hover {
      background: var(--acd)
    }

    .send-btn:disabled {
      opacity: .4;
      cursor: not-allowed
    }

    .send-btn svg {
      width: 14px;
      height: 14px
    }

    .mm-close {
      position: absolute;
      top: 14px;
      right: 16px;
      width: 28px;
      height: 28px;
      border-radius: 6px;
      border: 1px solid var(--brd);
      background: var(--s2);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--t2);
      transition: all .14s
    }

    .mm-close:hover {
      background: var(--rdl);
      color: var(--rd)
    }

    .mm-close svg {
      width: 13px;
      height: 13px
    }

    .mm-head {
      position: relative
    }

    /* NEW TICKET MODAL */
    .nt-ov {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .5);
      z-index: 201;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px
    }

    .nt-ov.open {
      display: flex
    }

    .nt-modal {
      width: 100%;
      max-width: 440px;
      background: var(--surface);
      border-radius: 14px;
      box-shadow: var(--shl);
      overflow: hidden
    }

    .nt-head {
      padding: 16px 20px;
      border-bottom: 1px solid var(--brd)
    }

    .nt-head h2 {
      font-size: 15px;
      font-weight: 800
    }

    .nt-head p {
      font-size: 12.5px;
      color: var(--t2);
      margin-top: 3px
    }

    .nt-body {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 12px
    }

    .fg {
      display: flex;
      flex-direction: column;
      gap: 5px
    }

    .fg label {
      font-size: 11px;
      font-weight: 700;
      color: var(--t2);
      text-transform: uppercase;
      letter-spacing: .3px
    }

    .finp {
      background: var(--s2);
      border: 1px solid var(--brd);
      border-radius: var(--rs);
      padding: 8px 11px;
      font-size: 13px;
      color: var(--t1);
      font-family: 'DM Sans', sans-serif;
      outline: none;
      transition: border .14s;
      width: 100%
    }

    .finp:focus {
      border-color: var(--ac);
      background: var(--surface)
    }

    .finp::placeholder {
      color: var(--t3)
    }

    select.finp {
      cursor: pointer
    }

    textarea.finp {
      resize: vertical;
      min-height: 80px
    }

    .nt-foot {
      padding: 14px 20px;
      border-top: 1px solid var(--brd);
      background: var(--s2);
      display: flex;
      justify-content: flex-end;
      gap: 8px
    }

    .btn {
      padding: 8px 16px;
      border-radius: var(--rs);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      font-family: 'DM Sans', sans-serif;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all .14s
    }

    .btn svg {
      width: 13px;
      height: 13px;
      flex-shrink: 0
    }

    .btn.pri {
      background: var(--ac);
      color: #fff
    }

    .btn.pri:hover {
      background: var(--acd)
    }

    .btn.gh {
      background: var(--surface);
      border: 1px solid var(--brd);
      color: var(--t2)
    }

    .btn.gh:hover {
      border-color: var(--ac);
      color: var(--ac)
    }

    .btn.sm {
      padding: 6px 12px;
      font-size: 12px
    }

    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--t1);
      color: #fff;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: all .22s;
      white-space: nowrap
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0)
    }

    @media(max-width:768px) {
      .main {
        margin-left: 0 !important
      }

      .sb {
        transform: translateX(calc(-1 * var(--sidebar-w)))
      }

      .av-btn-name {
        display: none
      }

      .content {
        padding: 14px
      }

      .cards-grid {
        grid-template-columns: 1fr
      }

      .messenger-modal {
        height: 95vh;
        max-height: none;
        border-radius: 10px
      }
    }

    ::-webkit-scrollbar {
      width: 4px;
      height: 4px
    }

    ::-webkit-scrollbar-track {
      background: transparent
    }

    ::-webkit-scrollbar-thumb {
      background: var(--brd);
      border-radius: 10px
    }
  </style>
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>
  <%- include("../partials/sidebar.ejs", { currentRoute, role: "vendor" , initials: "vendor" , fullName: "joshua daliva", stallNumber: 06 }) %>
    <div class="main" id="main">
      <%- include("../partials/header.ejs", {role: "vendor" , initials: "vendor" , lastName: "daliva" , }) %>
        <div class="content">
          <div class="pghdr">
            <div>
              <h1>Inquiries</h1>
              <p>Send messages and track issues with the market office</p>
            </div>
            <button class="btn pri sm" onclick="openNewTicket()">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              New Inquiry
            </button>
          </div>

          <!-- Filter bar -->
          <div class="filter-bar">
            <div class="srch">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
              <input id="searchInp" placeholder="Search inquiries..." oninput="renderCards()" />
            </div>
            <select class="fsel" id="statusFil" onchange="renderCards()">
              <option value="">All Statuses</option>
              <option value="open">Open</option>
              <option value="waiting">Awaiting Reply</option>
              <option value="resolved">Resolved</option>
              <option value="closed">Closed</option>
            </select>
            <select class="fsel" id="catFil" onchange="renderCards()">
              <option value="">All Categories</option>
              <option>Payment Concern</option>
              <option>Stall Condition</option>
              <option>Contract Renewal</option>
              <option>Market Rules</option>
              <option>Collector Issue</option>
              <option>Other</option>
            </select>
          </div>

          <div class="cards-grid" id="cardsGrid"></div>
        </div>
    </div>

    <!-- MESSENGER MODAL -->
    <div class="messenger-ov" id="messengerOv" onclick="if(event.target===this)closeMessenger()">
      <div class="messenger-modal">
        <div class="mm-head">
          <div class="mm-subject" id="mmSubject">Inquiry</div>
          <div class="mm-meta">
            <span class="mm-status" id="mmStatus">Open</span>
            <span class="mm-cat" id="mmCat"></span>
          </div>
          <div class="mm-close" onclick="closeMessenger()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg></div>
        </div>
        <div class="prog-bar" id="progSteps"></div>
        <div class="mm-msgs" id="mmMsgs"></div>
        <div class="mm-hint" id="mmHint">Press Enter to send &bull; Shift+Enter for new line</div>
        <div class="mm-input-row">
          <textarea class="mm-textarea" id="mmInput" placeholder="Type your message..." rows="1"
            onkeydown="onMsgKey(event)" oninput="autoGrow(this)"></textarea>
          <button class="send-btn" id="sendBtn" onclick="sendMessage()"><svg xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13" />
              <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg></button>
        </div>
      </div>
    </div>

    <!-- NEW TICKET MODAL -->
    <div class="nt-ov" id="ntModalOv" onclick="if(event.target===this)closeNewTicket()">
      <div class="nt-modal">
        <div class="nt-head">
          <h2>New Inquiry</h2>
          <p>Describe your concern and the market office will respond within 1-2 business days.</p>
        </div>
        <div class="nt-body">
          <div class="fg">
            <label>Category</label>
            <select class="finp" id="ntCat">
              <option value="">-- Select a category --</option>
              <option>Payment Concern</option>
              <option>Stall Condition</option>
              <option>Contract Renewal</option>
              <option>Market Rules</option>
              <option>Collector Issue</option>
              <option>Other</option>
            </select>
          </div>
          <div class="fg"><label>Subject</label><input class="finp" id="ntSubject"
              placeholder="Brief description of your concern" /></div>
          <div class="fg"><label>Message</label><textarea class="finp" id="ntMsg"
              placeholder="Describe your concern in detail..."></textarea></div>
        </div>
        <div class="nt-foot">
          <button class="btn gh" onclick="closeNewTicket()">Cancel</button>
          <button class="btn pri" onclick="submitTicket()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13" />
              <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
            Submit
          </button>
        </div>
      </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
      let TICKETS = <%- JSON.stringify(tickets) %>;
      const VENDOR_NAME = '<%= vendor.fullName %>';
    </script>
    <script>
      let SB_OPEN = window.innerWidth >= 768, isDark = false;
      function openSB() { SB_OPEN = true; document.getElementById('sb').style.transform = 'translateX(0)'; if (window.innerWidth < 768) { document.getElementById('veil').style.display = 'block'; document.getElementById('main').style.marginLeft = '0'; } else { document.getElementById('veil').style.display = 'none'; document.getElementById('main').style.marginLeft = 'var(--sidebar-w)'; } }
      function closeSB() { SB_OPEN = false; document.getElementById('sb').style.transform = 'translateX(calc(-1 * var(--sidebar-w)))'; document.getElementById('veil').style.display = 'none'; document.getElementById('main').style.marginLeft = '0'; }
      function toggleSB() { SB_OPEN ? closeSB() : openSB(); }
      (function () { if (window.innerWidth < 768) closeSB(); else openSB(); window.addEventListener('resize', function () { if (window.innerWidth >= 768) { document.getElementById('veil').style.display = 'none'; if (SB_OPEN) document.getElementById('main').style.marginLeft = 'var(--sidebar-w)'; } else { document.getElementById('main').style.marginLeft = '0'; if (SB_OPEN) document.getElementById('veil').style.display = 'block'; } }); })();
      function toggleTheme() { isDark = !isDark; document.documentElement.classList.toggle('dark', isDark); const i = document.getElementById('themeIcon'); i.innerHTML = isDark ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>' : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>'; }

      let ACTIVE_ID = null;
      const STATUS_CFG = { open: { label: 'Open', cls: 'open' }, waiting: { label: 'Awaiting Reply', cls: 'waiting' }, resolved: { label: 'Resolved', cls: 'resolved' }, closed: { label: 'Closed', cls: 'closed' } };
      const PROGRESS_STEPS = ['Submitted', 'Under Review', 'Replied', 'Resolved'];
      function getStepIdx(status) { return { open: 1, waiting: 2, resolved: 3, closed: 3 }[status] || 0; }

      function renderCards() {
        const q = (document.getElementById('searchInp').value || '').toLowerCase();
        const stFil = document.getElementById('statusFil').value;
        const catFil = document.getElementById('catFil').value;
        const filtered = TICKETS.filter(t => {
          if (stFil && t.status !== stFil) return false;
          if (catFil && t.category !== catFil) return false;
          if (q && !t.subject.toLowerCase().includes(q) && !t.category.toLowerCase().includes(q)) return false;
          return true;
        });
        const grid = document.getElementById('cardsGrid');
        const openCount = TICKETS.filter(t => t.status === 'open' || t.status === 'waiting').length;
        const badge = document.getElementById('sbBadge');
        if (badge) badge.textContent = openCount;
        if (!filtered.length) {
          grid.innerHTML = '<div class="inq-empty" style="grid-column:1/-1"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><p>No inquiries found</p><span>Try adjusting your filters or create a new inquiry.</span></div>';
          return;
        }
        grid.innerHTML = filtered.map(t => {
          const sc = STATUS_CFG[t.status] || STATUS_CFG.open;
          const last = t.messages[t.messages.length - 1];
          const preview = last ? (last.from === 'system' ? '— ' + last.text : last.name + ': ' + last.text) : '';
          return `<div class="ticket-card status-${t.status}" onclick="openMessenger(${t.id})">
      <div class="tc-top"><div class="tc-subject">${t.subject}</div>${t.unread ? '<div class="tc-unread"></div>' : ''}</div>
      <div class="tc-preview">${preview}</div>
      <div class="tc-bottom">
        <div class="tc-meta"><span class="tc-status ${sc.cls}">${sc.label}</span><span class="tc-cat">${t.category}</span></div>
        <div style="display:flex;align-items:center;gap:10px">
          <div class="tc-msgs"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>${t.messages.length}</div>
          <div class="tc-time">${t.createdAt}</div>
        </div>
      </div>
    </div>`;
        }).join('');
      }

      function openMessenger(id) {
        const t = TICKETS.find(x => x.id === id);
        if (!t) return;
        ACTIVE_ID = id; t.unread = false;
        document.getElementById('mmSubject').textContent = t.subject;
        const stEl = document.getElementById('mmStatus');
        stEl.textContent = STATUS_CFG[t.status].label;
        stEl.className = 'mm-status ' + STATUS_CFG[t.status].cls;
        document.getElementById('mmCat').textContent = ' ' + t.category;
        const stepIdx = getStepIdx(t.status);
        document.getElementById('progSteps').innerHTML = PROGRESS_STEPS.map((label, i) => {
          const done = i < stepIdx, active = i === stepIdx, state = done ? 'done' : active ? 'active' : 'pending';
          const lineHtml = i < PROGRESS_STEPS.length - 1 ? `<div class="prog-line ${i < stepIdx ? 'done' : 'pending'}"></div>` : '';
          return `<div class="prog-step"><div class="prog-step-wrap"><div class="prog-dot ${state}">${i + 1}</div><div class="prog-lbl ${state}">${label}</div></div>${lineHtml}</div>`;
        }).join('');
        renderMessages(t);
        const inp = document.getElementById('mmInput'), btn = document.getElementById('sendBtn'), hint = document.getElementById('mmHint');
        if (t.status === 'resolved' || t.status === 'closed') { inp.disabled = true; btn.disabled = true; inp.placeholder = 'This ticket is ' + t.status + '. Create a new inquiry to continue.'; hint.textContent = ''; }
        else { inp.disabled = false; btn.disabled = false; inp.placeholder = 'Type your message...'; hint.textContent = 'Press Enter to send \u2022 Shift+Enter for new line'; }
        document.getElementById('messengerOv').classList.add('open');
        renderCards();
        setTimeout(() => { const msgs = document.getElementById('mmMsgs'); msgs.scrollTop = msgs.scrollHeight; if (!inp.disabled) inp.focus(); }, 80);
      }

      function renderMessages(t) {
        const msgs = document.getElementById('mmMsgs');
        msgs.innerHTML = t.messages.map(m => {
          if (m.from === 'system') return `<div class="sys-pill">${m.text} &bull; ${m.time}</div>`;
          const mine = m.from === 'vendor';
          return `<div class="msg-group ${mine ? 'mine' : 'theirs'}"><div class="msg-sender-lbl">${m.name} &bull; ${m.time}</div><div class="bubble">${m.text}</div></div>`;
        }).join('');
        setTimeout(() => { msgs.scrollTop = msgs.scrollHeight; }, 20);
      }

      function closeMessenger() { document.getElementById('messengerOv').classList.remove('open'); ACTIVE_ID = null; renderCards(); }

      function sendMessage() {
        if (ACTIVE_ID === null) return;
        const t = TICKETS.find(x => x.id === ACTIVE_ID);
        const inp = document.getElementById('mmInput');
        const txt = inp.value.trim();
        if (!txt || !t || t.status === 'resolved' || t.status === 'closed') return;
        const now = new Date(), hh = now.getHours(), mm = now.getMinutes(), ap = hh >= 12 ? 'PM' : 'AM';
        const ts = 'Today, ' + (hh % 12 || 12) + ':' + (mm < 10 ? '0' + mm : mm) + ' ' + ap;
        t.messages.push({ from: 'vendor', name: VENDOR_NAME, text: txt, time: ts });
        t.status = 'waiting'; t.unread = false;
        inp.value = ''; inp.style.height = '';
        renderMessages(t);
        setTimeout(() => { t.messages.push({ from: 'office', name: 'Market Office', text: 'Thank you for your message. We have received it and will respond within 1 to 2 business days.', time: ts }); if (ACTIVE_ID === t.id) renderMessages(t); renderCards(); }, 2000);
      }

      function onMsgKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } }
      function autoGrow(el) { el.style.height = ''; el.style.height = Math.min(el.scrollHeight, 100) + 'px'; }
      function openNewTicket() { document.getElementById('ntModalOv').classList.add('open'); }
      function closeNewTicket() { document.getElementById('ntModalOv').classList.remove('open'); }

      function submitTicket() {
        const cat = document.getElementById('ntCat').value, subj = document.getElementById('ntSubject').value.trim(), msg = document.getElementById('ntMsg').value.trim();
        if (!cat) { showToast('Please select a category'); return; }
        if (!subj) { showToast('Please enter a subject'); return; }
        if (!msg) { showToast('Please enter a message'); return; }
        const now = new Date(), hh = now.getHours(), mm = now.getMinutes(), ap = hh >= 12 ? 'PM' : 'AM';
        const ts = 'Today, ' + (hh % 12 || 12) + ':' + (mm < 10 ? '0' + mm : mm) + ' ' + ap;
        const newId = TICKETS.length;
        TICKETS.unshift({ id: newId, subject: subj, category: cat, status: 'open', unread: false, createdAt: ts, messages: [{ from: 'vendor', name: VENDOR_NAME, text: msg, time: ts }, { from: 'system', text: 'Inquiry submitted. The market office will respond within 1-2 business days.', time: ts }] });
        TICKETS.forEach((t, i) => { t.id = i; });
        document.getElementById('ntCat').value = ''; document.getElementById('ntSubject').value = ''; document.getElementById('ntMsg').value = '';
        closeNewTicket(); renderCards(); showToast('Inquiry submitted successfully');
        setTimeout(() => { openMessenger(0); }, 300);
      }

      renderCards();
      let toastTimer = null;
      function showToast(m) { const t = document.getElementById('toast'); t.textContent = m; t.classList.add('show'); if (toastTimer) clearTimeout(toastTimer); toastTimer = setTimeout(() => t.classList.remove('show'), 2500); }
    </script>
</body>

</html>