<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ARKIPAISI &mdash; Vendor Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f4f5f7;--surface:#fff;--s2:#f9fafb;--s3:#f3f4f6;
  --brd:#e5e7eb;--brd2:#f0f1f3;
  --t1:#0f1117;--t2:#6b7280;--t3:#9ca3af;
  --ac:#1d4ed8;--acl:#eff3ff;--acs:#dbeafe;--acd:#1e3a8a;
  --gr:#16a34a;--grl:#f0fdf4;--grs:#dcfce7;
  --am:#d97706;--aml:#fffbeb;--ams:#fef3c7;
  --rd:#dc2626;--rdl:#fef2f2;--rds:#fee2e2;
  --sidebar-w:240px;--r:10px;--rs:6px;
  --sh:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --shm:0 4px 12px rgba(0,0,0,.08),0 2px 4px rgba(0,0,0,.04);
  --shl:0 10px 30px rgba(0,0,0,.1),0 4px 8px rgba(0,0,0,.06);
}
html.dark{--bg:#0d0f14;--surface:#161b27;--s2:#1e2535;--s3:#222840;--brd:#2a3245;--brd2:#222840;--t1:#f1f5f9;--t2:#94a3b8;--t3:#64748b;--ac:#3b82f6;--acl:#1e2d4a;--acs:#1e3a5f;--grl:#0d2318;--grs:#0f3a20;--aml:#1a1200;--ams:#2d1f00;--rdl:#1a0a0a;--rds:#2d1010}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t1);display:flex;min-height:100vh}
.sb{width:var(--sidebar-w);min-height:100vh;background:var(--surface);border-right:1px solid var(--brd);display:flex;flex-direction:column;position:fixed;left:0;top:0;z-index:60;transition:transform .28s cubic-bezier(.4,0,.2,1)}
.sb-logo{height:60px;padding:0 16px 0 20px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-m{width:32px;height:32px;background:var(--ac);border-radius:8px;display:grid;place-items:center;color:#fff;font-size:12px;font-weight:800;flex-shrink:0}
.logo-n{font-size:14px;font-weight:800;letter-spacing:-.3px}
.logo-sub{font-size:9.5px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-top:1px}
.sb-x{width:26px;height:26px;border-radius:6px;border:1px solid var(--brd);background:var(--s2);display:grid;place-items:center;cursor:pointer;color:var(--t2);flex-shrink:0;transition:all .14s}
.sb-x:hover{background:var(--rdl);color:var(--rd)}
.sb-x svg{width:13px;height:13px}
.sb-nav{flex:1;padding:10px 8px;overflow-y:auto}
.nsec{font-size:9.5px;font-weight:700;color:var(--t3);letter-spacing:.9px;text-transform:uppercase;padding:10px 10px 4px;margin-top:4px}
.ni{display:flex;align-items:center;gap:9px;padding:8px 12px;border-radius:var(--rs);color:var(--t2);cursor:pointer;font-size:13px;font-weight:500;transition:all .14s;margin-bottom:1px;text-decoration:none}
.ni:hover{background:var(--s2);color:var(--t1)}
.ni.on{background:var(--acl);color:var(--ac);font-weight:600}
.ni svg{width:15px;height:15px;flex-shrink:0}
.nbdg{margin-left:auto;font-size:10px;font-weight:700;padding:1px 6px;border-radius:8px;font-family:'DM Mono',monospace;background:var(--rds);color:var(--rd)}
.nbdg.am{background:var(--ams);color:var(--am)}
.nbdg.gr{background:var(--grs);color:var(--gr)}
.nbdg.bl{background:var(--acs);color:var(--ac)}
.sb-foot{padding:12px 8px;border-top:1px solid var(--brd);flex-shrink:0}
.urow{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:var(--rs);cursor:pointer;transition:background .14s}
.urow:hover{background:var(--s2)}
.uav{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--ac),var(--acd));display:grid;place-items:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0}
.veil{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:55;cursor:pointer}
.main{flex:1;display:flex;flex-direction:column;margin-left:var(--sidebar-w);min-height:100vh;transition:margin-left .28s cubic-bezier(.4,0,.2,1);min-width:0;overflow-x:hidden}
.navbar{height:60px;background:var(--surface);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 20px;gap:12px;position:sticky;top:0;z-index:40;flex-shrink:0}
.togbtn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surface);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0}
.togbtn:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}
.togbtn svg{width:15px;height:15px}
.page-title{font-size:14px;font-weight:700;letter-spacing:-.2px;flex:1}
.nb-r{display:flex;align-items:center;gap:8px}
.theme-btn,.icon-btn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surface);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;position:relative}
.theme-btn:hover,.icon-btn:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}
.theme-btn svg,.icon-btn svg{width:14px;height:14px}
.notif-dot{position:absolute;top:5px;right:5px;width:7px;height:7px;background:var(--rd);border-radius:50%;border:1.5px solid var(--surface)}
.av-btn{display:flex;align-items:center;gap:7px;padding:3px 10px 3px 3px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surface);cursor:pointer}
.av-sm{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--ac),var(--acd));display:grid;place-items:center;color:#fff;font-size:9px;font-weight:700}
.av-btn-name{font-size:12px;font-weight:600}
.content{padding:22px;flex:1}
.welcome-banner{background:linear-gradient(135deg,var(--ac) 0%,var(--acd) 100%);border-radius:var(--r);padding:20px 24px;color:#fff;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.wb-left h2{font-size:18px;font-weight:800;letter-spacing:-.3px}
.wb-left p{font-size:13px;opacity:.82;margin-top:4px}
.wb-stall{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:8px;padding:8px 16px;text-align:center}
.wb-stall-num{font-size:22px;font-weight:900;font-family:'DM Mono',monospace;letter-spacing:-1px}
.wb-stall-lbl{font-size:11px;opacity:.75;margin-top:2px;text-transform:uppercase;letter-spacing:.5px}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.sc{background:var(--surface);border:1px solid var(--brd);border-radius:var(--r);padding:16px 18px;box-shadow:var(--sh)}
.sc-icon{width:38px;height:38px;border-radius:9px;display:grid;place-items:center;margin-bottom:10px}
.sc-icon svg{width:18px;height:18px}
.sc-icon.bl{background:var(--acl);color:var(--ac)}
.sc-icon.gr{background:var(--grl);color:var(--gr)}
.sc-icon.am{background:var(--aml);color:var(--am)}
.sc-icon.rd{background:var(--rdl);color:var(--rd)}
.sc-val{font-size:22px;font-weight:800;font-family:'DM Mono',monospace;letter-spacing:-.5px;line-height:1}
.sc-lbl{font-size:11.5px;color:var(--t3);margin-top:4px}
.sc-sub{font-size:11px;font-weight:600;margin-top:4px}
.sc-sub.gr{color:var(--gr)}
.sc-sub.rd{color:var(--rd)}
.sc-sub.am{color:var(--am)}
.mgrid{display:grid;grid-template-columns:1fr 320px;gap:16px;align-items:start}
.panel{background:var(--surface);border:1px solid var(--brd);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden;margin-bottom:16px}
.panel:last-child{margin-bottom:0}
.ph{padding:14px 18px;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between;gap:10px}
.ph-ttl{font-size:13.5px;font-weight:700}
.ph-sub{font-size:11.5px;color:var(--t2);margin-top:1px}
.pay-status{padding:16px 18px}
.pay-bar-wrap{height:10px;background:var(--brd);border-radius:5px;overflow:hidden;margin-bottom:8px}
.pay-bar{height:100%;background:linear-gradient(90deg,var(--gr),#22c55e);border-radius:5px;transition:width .6s ease}
.pay-bar-labels{display:flex;justify-content:space-between;font-size:11.5px;color:var(--t2)}
.tbl-wrap{overflow-x:auto}
.tbl{width:100%;border-collapse:collapse;min-width:480px}
.tbl th{font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;padding:10px 14px;background:var(--s2);border-bottom:1px solid var(--brd);white-space:nowrap;text-align:left}
.tbl td{padding:11px 14px;font-size:13px;border-bottom:1px solid var(--brd2);vertical-align:middle}
.tbl tr:last-child td{border-bottom:none}
.tbl tbody tr:hover td{background:var(--s2)}
.bdg{display:inline-flex;align-items:center;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap}
.bdg.gr{background:var(--grs);color:var(--gr)}
.bdg.am{background:var(--ams);color:var(--am)}
.bdg.rd{background:var(--rds);color:var(--rd)}
.bdg.bl{background:var(--acs);color:var(--ac)}
.bdg.gy{background:var(--s3);color:var(--t3)}
.mbdg{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700}
.mbdg.cash{background:var(--grs);color:var(--gr)}
.mbdg.gcash{background:#ede9fe;color:#7c3aed}
.mbdg.maya{background:#cffafe;color:#0e7490}
.stall-info{padding:16px 18px}
.si-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--brd2)}
.si-row:last-child{border-bottom:none;padding-bottom:0}
.si-lbl{font-size:12px;color:var(--t2);font-weight:500}
.si-val{font-size:13px;font-weight:700}
.si-val.mono{font-family:'DM Mono',monospace;font-size:12.5px}
.si-val.bl{color:var(--ac)}
.notice-item{display:flex;gap:12px;padding:12px 18px;border-bottom:1px solid var(--brd2)}
.notice-item:last-child{border-bottom:none}
.notice-dot{width:8px;height:8px;border-radius:50%;background:var(--acs);border:2px solid var(--ac);flex-shrink:0;margin-top:4px}
.notice-ttl{font-size:12.5px;font-weight:600;color:var(--t1)}
.notice-time{font-size:11px;color:var(--t3);margin-top:2px}
.qa-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:14px 16px}
.qa-btn{background:var(--s2);border:1px solid var(--brd);border-radius:8px;padding:12px 14px;cursor:pointer;transition:all .14s;text-align:left}
.qa-btn:hover{border-color:var(--ac);background:var(--acl)}
.qa-icon{width:28px;height:28px;border-radius:7px;background:var(--acl);display:grid;place-items:center;color:var(--ac);margin-bottom:7px}
.qa-icon svg{width:13px;height:13px}
.qa-lbl{font-size:12.5px;font-weight:700;color:var(--t1)}
.qa-desc{font-size:11px;color:var(--t3);margin-top:2px}
.btn{padding:7px 14px;border-radius:var(--rs);font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px;transition:all .14s}
.btn svg{width:12px;height:12px}
.btn.pri{background:var(--ac);color:#fff}
.btn.pri:hover{background:var(--acd)}
.btn.gh{background:var(--surface);border:1px solid var(--brd);color:var(--t2)}
.btn.gh:hover{border-color:var(--ac);color:var(--ac)}
.btn.sm{padding:5px 10px;font-size:12px}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(8px);background:var(--t1);color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;z-index:999;opacity:0;pointer-events:none;transition:all .22s;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
@media(max-width:1100px){.stats{grid-template-columns:repeat(2,1fr)}}
@media(max-width:1000px){.mgrid{grid-template-columns:1fr}}
@media(max-width:768px){.main{margin-left:0!important}.sb{transform:translateX(calc(-1 * var(--sidebar-w)))}.av-btn-name{display:none}.content{padding:14px}.stats{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.content{padding:10px}.stats{grid-template-columns:1fr 1fr}}
::-webkit-scrollbar{width:4px;height:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--brd);border-radius:10px}
</style>
</head>
<body>
<div class="veil" id="veil" onclick="closeSB()"></div>
<%- include('../partials/sidebar.ejs') %>
<div class="main" id="main">
  <%- include('../partials/header.ejs') %>
  <div class="content">

    <!-- Welcome banner -->
    <div class="welcome-banner">
      <div class="wb-left">
        <h2>Good morning, <%= vendor.firstName %>!</h2>
        <p>Here is your stall summary for March 2026.<% if(pStats.unpaidCount > 0) { %> You have <%= pStats.unpaidCount %> pending payment.<% } %></p>
      </div>
      <div class="wb-stall">
        <div class="wb-stall-num"><%= stall.number %></div>
        <div class="wb-stall-lbl"><%= stall.type %> &bull; GF</div>
      </div>
    </div>

    <!-- Stat cards -->
    <div class="stats">
      <div class="sc">
        <div class="sc-icon rd"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
        <div class="sc-val">&#8369;<%= pStats.balanceDue.toLocaleString() %></div>
        <div class="sc-lbl">Current Balance Due</div>
        <div class="sc-sub rd"><%= pStats.duePeriod || 'None due' %></div>
      </div>
      <div class="sc">
        <div class="sc-icon gr"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="sc-val">&#8369;<%= pStats.totalPaid.toLocaleString() %></div>
        <div class="sc-lbl">Total Paid This Year</div>
        <div class="sc-sub gr"><%= pStats.paidCount %> months paid</div>
      </div>
      <div class="sc">
        <div class="sc-icon bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        <div class="sc-val">Dec 31</div>
        <div class="sc-lbl">Contract Expires</div>
        <div class="sc-sub">2026</div>
      </div>
      <div class="sc">
        <div class="sc-icon am"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <div class="sc-val"><%= iStats.totalCount %></div>
        <div class="sc-lbl">Open Inquiries</div>
        <div class="sc-sub am"><%= iStats.openCount %> awaiting reply</div>
      </div>
    </div>

    <div class="mgrid">
      <!-- LEFT -->
      <div>
        <!-- Payment status -->
        <div class="panel">
          <div class="ph">
            <div>
              <div class="ph-ttl">March 2026 Payment Status</div>
              <div class="ph-sub">Monthly rental fee: PHP <%= stall.monthlyRate.toLocaleString() %></div>
            </div>
            <span class="bdg rd">Unpaid</span>
          </div>
          <div class="pay-status">
            <div style="font-size:13.5px;font-weight:700;margin-bottom:12px">PHP 0 paid of PHP <%= stall.monthlyRate.toLocaleString() %></div>
            <div class="pay-bar-wrap"><div class="pay-bar" style="width:0%"></div></div>
            <div class="pay-bar-labels"><span>PHP 0</span><span>PHP <%= stall.monthlyRate.toLocaleString() %></span></div>
            <div style="margin-top:14px;padding:12px 14px;background:var(--rdl);border:1px solid var(--rds);border-radius:8px;font-size:12.5px;color:var(--rd);display:flex;align-items:center;gap:8px">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
              Your March 2026 payment is due. Please coordinate with your assigned collector or pay via GCash/Maya using reference code <strong><%= stall.referenceCode %></strong>.
            </div>
          </div>
        </div>

        <!-- Payment history (recent) -->
        <div class="panel">
          <div class="ph">
            <div><div class="ph-ttl">Payment History</div><div class="ph-sub">All official receipts issued to your account</div></div>
            <button class="btn gh sm" onclick="showToast('Downloading history...')">Export</button>
          </div>
          <div class="tbl-wrap">
            <table class="tbl">
              <thead><tr><th>OR No.</th><th>Period</th><th>Amount</th><th>Method</th><th>Date</th><th>Status</th></tr></thead>
              <tbody>
                <% recentPayments.forEach(p => { %>
                <tr>
                  <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:700;color:var(--ac)"><%= p.or || '--' %></td>
                  <td><%= p.period %></td>
                  <td style="font-family:'DM Mono',monospace;font-weight:700;color:<%= p.status==='paid' ? 'var(--gr)' : 'var(--rd)' %>">&#8369;<%= p.amount.toLocaleString() %></td>
                  <td>
                    <% if(p.method === 'Cash') { %><span class="mbdg cash">Cash</span>
                    <% } else if(p.method === 'GCash') { %><span class="mbdg gcash">&loz; GCash</span>
                    <% } else if(p.method === 'Maya') { %><span class="mbdg maya">&loz; Maya</span>
                    <% } else { %><span class="bdg gy">Unpaid</span><% } %>
                  </td>
                  <td style="color:var(--t3)"><%= p.date || '--' %></td>
                  <td><span class="bdg <%= p.status === 'paid' ? 'gr' : 'rd' %>"><%= p.status === 'paid' ? 'Paid' : 'Due' %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <div>
        <!-- Stall info -->
        <div class="panel">
          <div class="ph"><div class="ph-ttl">My Stall</div><span class="bdg bl">Active</span></div>
          <div class="stall-info">
            <div class="si-row"><span class="si-lbl">Stall Number</span><span class="si-val mono bl"><%= stall.number %></span></div>
            <div class="si-row"><span class="si-lbl">Section</span><span class="si-val"><%= stall.location %></span></div>
            <div class="si-row"><span class="si-lbl">Type</span><span class="si-val"><%= stall.type %></span></div>
            <div class="si-row"><span class="si-lbl">Size</span><span class="si-val mono"><%= stall.size %></span></div>
            <div class="si-row"><span class="si-lbl">Monthly Rate</span><span class="si-val mono bl">&#8369;<%= stall.monthlyRate.toLocaleString() %>.00</span></div>
            <div class="si-row"><span class="si-lbl">Contract</span><span class="si-val"><%= stall.contractStart.slice(0,8) %> &ndash; Dec 2026</span></div>
            <div class="si-row"><span class="si-lbl">Reference Code</span><span class="si-val mono" style="font-size:11.5px"><%= stall.referenceCode %></span></div>
          </div>
        </div>

        <!-- Quick actions -->
        <div class="panel">
          <div class="ph"><div class="ph-ttl">Quick Actions</div></div>
          <div class="qa-grid">
            <div class="qa-btn" onclick="showToast('Opening payment guide...')">
              <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
              <div class="qa-lbl">How to Pay</div>
              <div class="qa-desc">GCash, Maya, or cash</div>
            </div>
            <div class="qa-btn" onclick="showToast('Opening inquiry form...')">
              <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
              <div class="qa-lbl">New Inquiry</div>
              <div class="qa-desc">Send a message to the office</div>
            </div>
            <div class="qa-btn" onclick="showToast('Downloading receipt...')">
              <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
              <div class="qa-lbl">Download ORs</div>
              <div class="qa-desc">Get your receipts as PDF</div>
            </div>
            <div class="qa-btn" onclick="showToast('Opening contract...')">
              <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
              <div class="qa-lbl">My Contract</div>
              <div class="qa-desc">View stall lease details</div>
            </div>
          </div>
        </div>

        <!-- Notices -->
        <div class="panel">
          <div class="ph"><div class="ph-ttl">Recent Notices</div></div>
          <% notices.forEach(n => { %>
          <div class="notice-item">
            <div class="notice-dot"></div>
            <div>
              <div class="notice-ttl"><%= n.title %></div>
              <div class="notice-time"><%= n.date %></div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="toast" id="toast"></div>
<script>
let SB_OPEN = window.innerWidth >= 768, isDark = false;
function openSB(){SB_OPEN=true;document.getElementById('sb').style.transform='translateX(0)';if(window.innerWidth<768){document.getElementById('veil').style.display='block';document.getElementById('main').style.marginLeft='0';}else{document.getElementById('veil').style.display='none';document.getElementById('main').style.marginLeft='var(--sidebar-w)';}}
function closeSB(){SB_OPEN=false;document.getElementById('sb').style.transform='translateX(calc(-1 * var(--sidebar-w)))';document.getElementById('veil').style.display='none';document.getElementById('main').style.marginLeft='0';}
function toggleSB(){SB_OPEN?closeSB():openSB();}
(function(){if(window.innerWidth<768)closeSB();else openSB();window.addEventListener('resize',function(){if(window.innerWidth>=768){document.getElementById('veil').style.display='none';if(SB_OPEN)document.getElementById('main').style.marginLeft='var(--sidebar-w)';}else{document.getElementById('main').style.marginLeft='0';if(SB_OPEN)document.getElementById('veil').style.display='block';}});})();
function toggleTheme(){isDark=!isDark;document.documentElement.classList.toggle('dark',isDark);const i=document.getElementById('themeIcon');i.innerHTML=isDark?'<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>':'<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';}
let toastTimer=null;
function showToast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');if(toastTimer)clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2500);}
</script>
</body>
</html>
