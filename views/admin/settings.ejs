<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>ARKIPAISI — Admin Settings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/admin/settings.css">
</head>

<body>

  <%- include("../partials/sidebar.ejs" , { currentRoute, role: "admin", initials: "admin", fullName: "joshua daliva"}) %>
  
  <div class="main" id="main">
        <%- include("../partials/header.ejs", {role: "admin", initials: "admin", lastName: "daliva", }) %>
        

        <div class="content">
            <div class="pghdr">
                <div>
                    <h1>Settings</h1>
                    <p>Configure market operations, payments, and system preferences</p>
                </div>
            </div>

            <div class="settings-wrap">
                <!-- LEFT NAV -->
                <div class="settings-nav">
                    <div class="sn-item on" onclick="setTab('market',this)"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        </svg>Market Info</div>
                    <div class="sn-item" onclick="setTab('payment',this)"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="4" width="22" height="16" rx="2" />
                            <line x1="1" y1="10" x2="23" y2="10" />
                        </svg>Payment</div>
                    <div class="sn-item" onclick="setTab('fees',this)"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>Fees &amp; Rates</div>
                    <div class="sn-item" onclick="setTab('notif',this)"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                        </svg>Notifications</div>
                    <div class="sn-item" onclick="setTab('users',this)"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>Users &amp; Access</div>
                    <div class="sn-item" onclick="setTab('profile',this)"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>My Profile</div>
                    <div class="sn-sep"></div>
                    <div class="sn-item danger" onclick="setTab('danger',this)"><svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path
                                d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                            <line x1="12" y1="9" x2="12" y2="13" />
                            <line x1="12" y1="17" x2="12.01" y2="17" />
                        </svg>Danger Zone</div>
                </div>

                <!-- PANELS -->
                <div>
                    <!-- MARKET INFO -->
                    <div id="tab-market" class="settings-panel on">
                        <div class="scard">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                        </svg>Market Information</div>
                                    <div class="scard-sub">Basic details about the public market</div>
                                </div>
                            </div>
                            <div class="scard-body">
                                <div class="fgrid full" style="margin-bottom:13px">
                                    <div class="fg"><label>Market Name</label><input class="finp"
                                            value="Pili Public Market" /></div>
                                </div>
                                <div class="fgrid" style="margin-bottom:13px">
                                    <div class="fg"><label>Municipality / City</label><input class="finp"
                                            value="Pili" /></div>
                                    <div class="fg"><label>Province</label><input class="finp" value="Camarines Sur" />
                                    </div>
                                </div>
                                <div class="fgrid full" style="margin-bottom:13px">
                                    <div class="fg"><label>Complete Address</label><input class="finp"
                                            value="Pili Public Market, Pili, Camarines Sur, Philippines" /></div>
                                </div>
                                <div class="fgrid" style="margin-bottom:13px">
                                    <div class="fg"><label>Market Code</label><input class="finp"
                                            value="MKT-PIL-2024-001" style="font-family:'DM Mono',monospace" /></div>
                                    <div class="fg"><label>LGU / Office</label><input class="finp"
                                            value="Office of the Market Administrator" /></div>
                                </div>
                                <div class="fgrid">
                                    <div class="fg"><label>Contact Number</label><input class="finp"
                                            value="+63 54 477 1234" /></div>
                                    <div class="fg"><label>Email Address</label><input class="finp"
                                            value="market@pili.gov.ph" /></div>
                                </div>
                            </div>
                            <div class="scard-foot"><button class="btn gh sm">Cancel</button><button class="btn pri sm"
                                    onclick="showToast('Market info saved')"><svg xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>Save Changes</button></div>
                        </div>
                        <div class="scard">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10" />
                                            <polyline points="12 6 12 12 16 14" />
                                        </svg>Operating Hours</div>
                                    <div class="scard-sub">Market open and close schedules</div>
                                </div>
                            </div>
                            <div class="scard-body">
                                <div class="fgrid tri" style="margin-bottom:13px">
                                    <div class="fg"><label>Opening Time</label><input class="finp" type="time"
                                            value="05:00" /></div>
                                    <div class="fg"><label>Closing Time</label><input class="finp" type="time"
                                            value="20:00" /></div>
                                    <div class="fg"><label>Rest Day</label><select class="finp">
                                            <option selected>None (Open Daily)</option>
                                            <option>Sunday</option>
                                            <option>Monday</option>
                                        </select></div>
                                </div>
                                <div class="sw-row">
                                    <div>
                                        <div class="sw-lbl">Holiday Closure</div>
                                        <div class="sw-desc">Auto-mark market closed on national holidays</div>
                                    </div>
                                    <div class="sw on" onclick="this.classList.toggle('on')"></div>
                                </div>
                                <div class="sw-row">
                                    <div>
                                        <div class="sw-lbl">Show Hours on Public Page</div>
                                        <div class="sw-desc">Display hours on the vendor application portal</div>
                                    </div>
                                    <div class="sw on blue" onclick="this.classList.toggle('on')"></div>
                                </div>
                            </div>
                            <div class="scard-foot"><button class="btn gh sm">Cancel</button><button class="btn pri sm"
                                    onclick="showToast('Hours saved')"><svg xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>Save Changes</button></div>
                        </div>
                    </div>

                    <!-- PAYMENT -->
                    <div id="tab-payment" class="settings-panel">

                        <!-- Method selector card -->
                        <div class="scard">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="1" y="4" width="22" height="16" rx="2" />
                                            <line x1="1" y1="10" x2="23" y2="10" />
                                        </svg>Accepted Payment Methods</div>
                                    <div class="scard-sub">Click a method to configure its setup details</div>
                                </div>
                            </div>
                            <div class="scard-body">
                                <div class="pm-grid">
                                    <div class="pm-card" data-pm="cash" onclick="selectPM(this)">
                                        <div class="pm-top">
                                            <div class="pm-icon cash"><svg xmlns="http://www.w3.org/2000/svg"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2">
                                                    <rect x="2" y="6" width="20" height="12" rx="2" />
                                                    <circle cx="12" cy="12" r="2" />
                                                </svg></div>
                                            <div class="pm-radio"></div>
                                        </div>
                                        <div class="pm-name">Cash</div>
                                        <div class="pm-desc">In-person at market office or collector</div>
                                    </div>
                                    <div class="pm-card" data-pm="bank" onclick="selectPM(this)">
                                        <div class="pm-top">
                                            <div class="pm-icon bank"><svg xmlns="http://www.w3.org/2000/svg"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2">
                                                    <line x1="12" y1="1" x2="12" y2="23" />
                                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                                                </svg></div>
                                            <div class="pm-radio"></div>
                                        </div>
                                        <div class="pm-name">Bank Transfer / OTC</div>
                                        <div class="pm-desc">Land Bank, DBP, PNB over-the-counter</div>
                                    </div>
                                    <div class="pm-card" data-pm="gcash" onclick="selectPM(this)">
                                        <div class="pm-top">
                                            <div class="pm-icon gcash"><svg xmlns="http://www.w3.org/2000/svg"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2">
                                                    <rect x="5" y="2" width="14" height="20" rx="2" />
                                                    <line x1="12" y1="18" x2="12.01" y2="18" />
                                                </svg></div>
                                            <div class="pm-radio"></div>
                                        </div>
                                        <div class="pm-name">GCash</div>
                                        <div class="pm-desc">Mobile wallet via GCash QR or number</div>
                                    </div>
                                    <div class="pm-card" data-pm="maya" onclick="selectPM(this)">
                                        <div class="pm-top">
                                            <div class="pm-icon maya"><svg xmlns="http://www.w3.org/2000/svg"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2">
                                                    <rect x="5" y="2" width="14" height="20" rx="2" />
                                                    <polyline points="12 6 12 12 16 14" />
                                                </svg></div>
                                            <div class="pm-radio"></div>
                                        </div>
                                        <div class="pm-name">Maya (PayMaya)</div>
                                        <div class="pm-desc">Mobile wallet via Maya QR or number</div>
                                    </div>
                                </div>
                                <p class="pm-hint">Select a payment method above to view and edit its configuration.</p>
                            </div>
                        </div>

                        <!-- Config cards: only one shows at a time -->
                        <div id="cfg-cash" class="scard" style="display:none">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="2" y="6" width="20" height="12" rx="2" />
                                            <circle cx="12" cy="12" r="2" />
                                        </svg>Cash Collection Setup</div>
                                    <div class="scard-sub">Configure how cash payments are collected and recorded</div>
                                </div>
                                <button class="btn gh xs" onclick="clearPM()"><svg xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18" />
                                        <line x1="6" y1="6" x2="18" y2="18" />
                                    </svg>Close</button>
                            </div>
                            <div class="scard-body">
                                <div class="fgrid" style="margin-bottom:13px">
                                    <div class="fg"><label>Collection Office</label><input class="finp"
                                            value="Market Administration Office" /></div>
                                    <div class="fg"><label>Collection Hours</label><input class="finp"
                                            value="8:00 AM - 5:00 PM, Mon-Fri" /></div>
                                </div>
                                <div class="fgrid full" style="margin-bottom:13px">
                                    <div class="fg"><label>Official Receipt Series</label><input class="finp"
                                            value="OR-PIL-2026-XXXX" style="font-family:'DM Mono',monospace" /><span
                                            class="hint">XXXX is auto-incremented for each receipt issued.</span></div>
                                </div>
                                <div class="sw-row">
                                    <div>
                                        <div class="sw-lbl">Require Official Receipt</div>
                                        <div class="sw-desc">Always issue an OR for every cash payment collected</div>
                                    </div>
                                    <div class="sw on" onclick="this.classList.toggle('on')"></div>
                                </div>
                                <div class="sw-row">
                                    <div>
                                        <div class="sw-lbl">Mobile Collector Enabled</div>
                                        <div class="sw-desc">Allow designated collectors to accept field payments</div>
                                    </div>
                                    <div class="sw on" onclick="this.classList.toggle('on')"></div>
                                </div>
                            </div>
                            <div class="scard-foot"><button class="btn gh sm" onclick="clearPM()">Cancel</button><button
                                    class="btn pri sm" onclick="showToast('Cash setup saved')"><svg
                                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>Save Changes</button></div>
                        </div>

                        <div id="cfg-bank" class="scard" style="display:none">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <line x1="12" y1="1" x2="12" y2="23" />
                                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                                        </svg>Bank Account Details</div>
                                    <div class="scard-sub">For over-the-counter and online bank transfers</div>
                                </div>
                                <button class="btn gh xs" onclick="clearPM()"><svg xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18" />
                                        <line x1="6" y1="6" x2="18" y2="18" />
                                    </svg>Close</button>
                            </div>
                            <div class="scard-body">
                                <div class="fgrid" style="margin-bottom:13px">
                                    <div class="fg"><label>Bank Name</label><select class="finp">
                                            <option selected>Land Bank of the Philippines</option>
                                            <option>Development Bank of the Philippines</option>
                                            <option>Philippine National Bank</option>
                                            <option>BDO Unibank</option>
                                            <option>Metrobank</option>
                                        </select></div>
                                    <div class="fg"><label>Branch</label><input class="finp"
                                            value="Pili, Camarines Sur Branch" /></div>
                                </div>
                                <div class="fgrid" style="margin-bottom:13px">
                                    <div class="fg"><label>Account Number</label><input class="finp"
                                            value="1234-5678-90" style="font-family:'DM Mono',monospace" /></div>
                                    <div class="fg"><label>Account Name</label><input class="finp"
                                            value="LGU Pili - Market Fund" /></div>
                                </div>
                                <div class="fgrid">
                                    <div class="fg"><label>Account Type</label><select class="finp">
                                            <option selected>Savings Account</option>
                                            <option>Current Account</option>
                                        </select></div>
                                    <div class="fg"><label>Swift / BIC Code</label><input class="finp" value="LBPHPHMM"
                                            style="font-family:'DM Mono',monospace" /></div>
                                </div>
                            </div>
                            <div class="scard-foot"><button class="btn gh sm" onclick="clearPM()">Cancel</button><button
                                    class="btn pri sm" onclick="showToast('Bank details saved')"><svg
                                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>Save Changes</button></div>
                        </div>

                        <div id="cfg-gcash" class="scard" style="display:none">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="5" y="2" width="14" height="20" rx="2" />
                                            <line x1="12" y1="18" x2="12.01" y2="18" />
                                        </svg>GCash Account Details</div>
                                    <div class="scard-sub">Published on the vendor portal for payment instructions</div>
                                </div>
                                <button class="btn gh xs" onclick="clearPM()"><svg xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18" />
                                        <line x1="6" y1="6" x2="18" y2="18" />
                                    </svg>Close</button>
                            </div>
                            <div class="scard-body">
                                <div class="infobox bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="8" x2="12" y2="12" />
                                        <line x1="12" y1="16" x2="12.01" y2="16" />
                                    </svg>
                                    <div>These details are shown to vendors when they select GCash as their payment
                                        method.</div>
                                </div>
                                <div class="fgrid" style="margin-bottom:13px">
                                    <div class="fg"><label>GCash Number</label>
                                        <div class="pfx"><span class="pfx-lbl">+63</span><input class="finp"
                                                value="917 123 4567" placeholder="9XX XXX XXXX" /></div>
                                    </div>
                                    <div class="fg"><label>Account Name</label><input class="finp"
                                            value="PILI PUBLIC MARKET" /></div>
                                </div>
                                <div class="fgrid full">
                                    <div class="fg"><label>Payment Reference Format</label><input class="finp"
                                            value="PIL-[STALL]-[DATE]" /><span class="hint">[STALL] and [DATE] are
                                            auto-filled per transaction.</span></div>
                                </div>
                            </div>
                            <div class="scard-foot"><button class="btn gh sm" onclick="clearPM()">Cancel</button><button
                                    class="btn pri sm" onclick="showToast('GCash details saved')"><svg
                                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>Save Changes</button></div>
                        </div>

                        <div id="cfg-maya" class="scard" style="display:none">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="5" y="2" width="14" height="20" rx="2" />
                                            <polyline points="12 6 12 12 16 14" />
                                        </svg>Maya Account Details</div>
                                    <div class="scard-sub">Published on the vendor portal for Maya payment instructions
                                    </div>
                                </div>
                                <button class="btn gh xs" onclick="clearPM()"><svg xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18" />
                                        <line x1="6" y1="6" x2="18" y2="18" />
                                    </svg>Close</button>
                            </div>
                            <div class="scard-body">
                                <div class="infobox bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="8" x2="12" y2="12" />
                                        <line x1="12" y1="16" x2="12.01" y2="16" />
                                    </svg>
                                    <div>These details are shown to vendors when they select Maya as their payment
                                        method.</div>
                                </div>
                                <div class="fgrid" style="margin-bottom:13px">
                                    <div class="fg"><label>Maya Number</label>
                                        <div class="pfx"><span class="pfx-lbl">+63</span><input class="finp"
                                                value="918 765 4321" placeholder="9XX XXX XXXX" /></div>
                                    </div>
                                    <div class="fg"><label>Account Name</label><input class="finp"
                                            value="PILI PUBLIC MARKET" /></div>
                                </div>
                                <div class="fgrid full">
                                    <div class="fg"><label>Payment Reference Format</label><input class="finp"
                                            value="PIL-[STALL]-[DATE]" /><span class="hint">[STALL] and [DATE] are
                                            auto-filled per transaction.</span></div>
                                </div>
                            </div>
                            <div class="scard-foot"><button class="btn gh sm" onclick="clearPM()">Cancel</button><button
                                    class="btn pri sm" onclick="showToast('Maya details saved')"><svg
                                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>Save Changes</button></div>
                        </div>

                        <!-- Payment Rules always visible -->
                        <div class="scard">
                            <div class="scard-head">
                                <div>
                                    <div class="scard-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="9 11 12 14 22 4" />
                                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                                        </svg>Payment Rules</div>
                                    <div class="scard-sub">Due dates, grace periods, and penalty settings</div>
                                </div>
                            </div>
                            <div class="scard-body">
                                <div class="fgrid tri" style="margin-bottom:13px">
                                    <div class="fg"><label>Payment Due Date</label><select class="finp">
                                            <option selected>5th of the Month</option>
                                            <option>10th of the Month</option>
                                            <option>15th of the Month</option>
