                                <path
                                    d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                                <line x1="12" y1="9" x2="12" y2="13" />
                                <line x1="12" y1="17" x2="12.01" y2="17" />
                            </svg>
                            <div>Actions here are <strong>irreversible</strong>. Proceed only if absolutely sure.</div>
                        </div>
                        <div class="dz">
                            <div class="dz-head"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2">
                                    <path
                                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                                </svg><span>Danger Zone</span></div>
                            <div class="dz-row">
                                <div>
                                    <div class="dz-lbl">Clear All Archived Records</div>
                                    <div class="dz-desc">Permanently delete all archived vendor and payment records.
                                    </div>
                                </div><button class="btn rd-gh sm" onclick="showToast('Confirmation required')">Clear
                                    Archives</button>
                            </div>
                            <div class="dz-row">
                                <div>
                                    <div class="dz-lbl">Reset Payment Ledger</div>
                                    <div class="dz-desc">Wipe all payment history for the current fiscal year.</div>
                                </div><button class="btn rd-gh sm" onclick="showToast('Confirmation required')">Reset
                                    Ledger</button>
                            </div>
                            <div class="dz-row">
                                <div>
                                    <div class="dz-lbl">Export All Data</div>
                                    <div class="dz-desc">Download a full export of all market, vendor, and payment data.
                                    </div>
                                </div><button class="btn gh sm" onclick="showToast('Export started')"><svg
                                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2">
                                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                        <polyline points="7 10 12 15 17 10" />
                                        <line x1="12" y1="15" x2="12" y2="3" />
                                    </svg>Export</button>
                            </div>
                            <div class="dz-row">
                                <div>
                                    <div class="dz-lbl">Reset System to Default</div>
                                    <div class="dz-desc">Remove all configuration and restore factory settings.</div>
                                </div><button class="btn rd sm" onclick="showToast('Confirmation required')">Reset
                                    System</button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>


    <!-- Edit Rate Modal -->
    <div class="modal-bg" id="editRateModal">
        <div class="modal">
            <div class="modal-head">
                <div class="modal-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                    </svg>Edit Rental Rate</div>
                <div class="modal-x" onclick="closeModal('editRateModal')"><svg xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg></div>
            </div>
            <div class="modal-body">
                <div class="fgrid">
                    <div class="fg"><label>Stall Type</label><input class="finp" id="er-type"
                            placeholder="e.g. Dry Goods" /></div>
                    <div class="fg"><label>Status</label><select class="finp" id="er-status">
                            <option value="active">Active</option>
                            <option value="draft">Draft</option>
                            <option value="inactive">Inactive</option>
                        </select></div>
                </div>
                <div class="fgrid">
                    <div class="fg"><label>Stall Size (m)</label>
                        <div class="pfx"><span class="pfx-lbl">m</span><input class="finp" id="er-size"
                                placeholder="e.g. 3x3" /></div>
                    </div>
                    <div class="fg"><label>Monthly Rate (PHP)</label>
                        <div class="pfx"><span class="pfx-lbl">P</span><input class="finp" id="er-rate" type="number"
                                min="0" step="50" placeholder="0" /></div>
                    </div>
                </div>
                <div class="fgrid full">
                    <div class="fg"><label>Description (optional)</label><input class="finp" id="er-desc"
                            placeholder="e.g. Standard covered stall" /></div>
                </div>
                <div class="fgrid">
                    <div class="fg"><label>Effective Date</label><input class="finp" id="er-date" type="date" /></div>
                    <div class="fg"><label>Section / Zone</label><input class="finp" id="er-zone"
                            placeholder="e.g. Section B" /></div>
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn gh sm" onclick="closeModal('editRateModal')">Cancel</button>
                <button class="btn pri sm" onclick="saveRate()"><svg xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>Save Changes</button>
            </div>
        </div>
    </div>

    <!-- Add Rate Modal -->
    <div class="modal-bg" id="addRateModal">
        <div class="modal">
            <div class="modal-head">
                <div class="modal-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>Add New Rate</div>
                <div class="modal-x" onclick="closeModal('addRateModal')"><svg xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg></div>
            </div>
            <div class="modal-body">
                <div class="fgrid">
                    <div class="fg"><label>Stall Type</label><input class="finp" id="ar-type"
                            placeholder="e.g. Bakery, Cosmetics" /></div>
                    <div class="fg"><label>Status</label><select class="finp" id="ar-status">
                            <option value="draft" selected>Draft</option>
                            <option value="active">Active</option>
                        </select></div>
                </div>
                <div class="fgrid">
                    <div class="fg"><label>Stall Size (m)</label>
                        <div class="pfx"><span class="pfx-lbl">m</span><input class="finp" id="ar-size"
                                placeholder="e.g. 3x3" /></div>
                    </div>
                    <div class="fg"><label>Monthly Rate (PHP)</label>
                        <div class="pfx"><span class="pfx-lbl">P</span><input class="finp" id="ar-rate" type="number"
                                min="0" step="50" placeholder="0" /></div>
                    </div>
                </div>
                <div class="fgrid full">
                    <div class="fg"><label>Description (optional)</label><input class="finp" id="ar-desc"
                            placeholder="e.g. Standard covered stall" /></div>
                </div>
                <div class="fgrid">
                    <div class="fg"><label>Effective Date</label><input class="finp" id="ar-date" type="date" /></div>
                    <div class="fg"><label>Section / Zone</label><input class="finp" id="ar-zone"
                            placeholder="e.g. Section A" /></div>
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn gh sm" onclick="closeModal('addRateModal')">Cancel</button>
                <button class="btn pri sm" onclick="addRate()"><svg xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>Add Rate</button>
            </div>
        </div>
    </div>
    <script src="/js/admin/settings.js"></script>
</body>

</html>