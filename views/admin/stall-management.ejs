<!DOCTYPE html>
<html lang="en" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARKIPAISI — Stall Management</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin/stall-management.css">
</head>

<body>

  <%- include("../partials/sidebar.ejs" , { currentRoute, role: "admin", initials: "admin", fullName: "joshua daliva"}) %>
  
  <!-- ── MAIN ── -->
  <div class="main" id="main">
    <%- include("../partials/header.ejs", {role: "admin", initials: "admin", lastName: "daliva", }) %>


    <!-- Content -->
    <div class="content">

      <!-- Page Header -->
      <div class="page-header">
        <div class="page-header-left">
          <div class="ph-title">Stall Management</div>
          <div class="ph-sub">Manage all public market stalls, monitor status, and post for vendor applications</div>
        </div>
        <div class="page-header-actions">
          <button class="btn ghost" onclick="openUploadModal()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="17 8 12 3 7 8" />
              <line x1="12" y1="3" x2="12" y2="15" />
            </svg>
            Upload Map
          </button>
          <button class="btn primary" onclick="openAddModal()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add New Stall
          </button>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        <div class="mini-stat">
          <div class="ms-icon blue"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            </svg></div>
          <div>
            <div class="ms-val">58</div>
            <div class="ms-lbl">Total Stalls</div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="ms-icon green"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
            </svg></div>
          <div>
            <div class="ms-val">42</div>
            <div class="ms-lbl">Occupied</div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="ms-icon amber"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <rect x="2" y="7" width="20" height="14" rx="2" />
              <path d="M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z" />
            </svg></div>
          <div>
            <div class="ms-val">11</div>
            <div class="ms-lbl">Vacant</div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="ms-icon red"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg></div>
          <div>
            <div class="ms-val">5</div>
            <div class="ms-lbl">Under Maintenance</div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="ms-icon teal"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <line x1="2" y1="12" x2="22" y2="12" />
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg></div>
          <div>
            <div class="ms-val" >4</div>
            <div class="ms-lbl">Publicly Posted</div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs-bar">
        <button class="tab-btn active" onclick="switchTab('list', this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <line x1="8" y1="6" x2="21" y2="6" />
            <line x1="8" y1="12" x2="21" y2="12" />
            <line x1="8" y1="18" x2="21" y2="18" />
            <line x1="3" y1="6" x2="3.01" y2="6" />
            <line x1="3" y1="12" x2="3.01" y2="12" />
            <line x1="3" y1="18" x2="3.01" y2="18" />
          </svg>
          Stall List
        </button>
        <button class="tab-btn" onclick="switchTab('map', this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
            <line x1="8" y1="2" x2="8" y2="18" />
            <line x1="16" y1="6" x2="16" y2="22" />
          </svg>
          Map View
        </button>
        <button class="tab-btn" onclick="switchTab('posted', this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="2" y1="12" x2="22" y2="12" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
          Publicly Posted
          <span
            style="background:var(--cy);color:white;font-size:10px;padding:1px 6px;border-radius:10px;font-weight:700">4</span>
        </button>
      </div>

      <!-- ── LIST TAB ── -->
      <div id="tab-list">
        <div class="filters-bar">
          <div class="filter-input">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text" placeholder="Search stall number, vendor, location..." />
          </div>
          <select class="filter-select">
            <option>All Types</option>
            <option>Wet Market</option>
            <option>Dry Goods</option>
            <option>Meat Section</option>
            <option>Vegetables</option>
            <option>Fish Section</option>
            <option>General</option>
          </select>
          <div class="filter-badge all active" onclick="filterStatus('all', this)"><span class="dot"></span>All (58)
          </div>
          <div class="filter-badge occupied" onclick="filterStatus('occupied', this)"><span class="dot"></span>Occupied
            (42)</div>
          <div class="filter-badge vacant" onclick="filterStatus('vacant', this)"><span class="dot"></span>Vacant (11)
          </div>
          <div class="filter-badge maintenance" onclick="filterStatus('maintenance', this)"><span
              class="dot"></span>Maintenance (5)</div>
          <div class="view-toggle">
            <button class="view-btn active tooltip" data-tip="Table View" onclick="switchView('table', this)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <line x1="3" y1="9" x2="21" y2="9" />
                <line x1="3" y1="15" x2="21" y2="15" />
                <line x1="9" y1="3" x2="9" y2="21" />
              </svg>
            </button>
            <button class="view-btn tooltip" data-tip="Card View" onclick="switchView('grid', this)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
                <rect x="14" y="14" width="7" height="7" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Table View -->
        <div id="view-table" class="table-panel">
          <div class="tbl-wrap">
            <table class="stall-table">
              <thead>
                <tr>
                  <th class="sortable">Stall # <span class="sort-icon"><svg viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="3">
                        <polyline points="18 15 12 9 6 15" />
                      </svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <polyline points="6 9 12 15 18 9" />
                      </svg></span></th>
                  <th class="sortable">Type</th>
                  <th>Location</th>
                  <th>Size</th>
                  <th>Vendor / Occupant</th>
                  <th>Status</th>
                  <th>Posted</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><span class="stall-num">#01</span></td>
                  <td><span class="stall-type-pill wet">Wet Market</span></td>
                  <td style="font-size:12.5px;color:var(--t2)">Section A · Row 1</td>
                  <td style="font-size:12px;color:var(--t3);font-family:'DM Mono',monospace">4×4 m²</td>
                  <td><span class="vendor-link">Juan Dela Cruz</span></td>
                  <td><span class="status-badge occupied">Occupied</span></td>
                  <td><span class="posted-badge not-posted">Not Posted</span></td>
                  <td>
                    <div class="row-actions">
                      <div class="action-icon tooltip" data-tip="View Details"
                        onclick="openViewModal('#01','Wet Market','Section A · Row 1','Juan Dela Cruz','occupied')"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                          <circle cx="12" cy="12" r="3" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Edit Stall" onclick="openEditModal()"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Post Stall"
                        onclick="openPostModal('#01','Wet Market','Section A · Row 1')"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <circle cx="12" cy="12" r="10" />
                          <line x1="2" y1="12" x2="22" y2="12" />
                          <path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg></div>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td><span class="stall-num">#03</span></td>
                  <td><span class="stall-type-pill meat">Meat Section</span></td>
                  <td style="font-size:12.5px;color:var(--t2)">Section A · Row 2</td>
                  <td style="font-size:12px;color:var(--t3);font-family:'DM Mono',monospace">5×4 m²</td>
                  <td><span class="vendor-link">Pedro Reyes</span></td>
                  <td><span class="status-badge occupied">Occupied</span></td>
                  <td><span class="posted-badge not-posted">Not Posted</span></td>
                  <td>
                    <div class="row-actions">
                      <div class="action-icon tooltip" data-tip="View Details"
                        onclick="openViewModal('#03','Meat Section','Section A · Row 2','Pedro Reyes','occupied')"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                          <circle cx="12" cy="12" r="3" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Edit Stall" onclick="openEditModal()"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Post Stall"
                        onclick="openPostModal('#03','Meat Section','Section A · Row 2')"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <circle cx="12" cy="12" r="10" />
                          <line x1="2" y1="12" x2="22" y2="12" />
                          <path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg></div>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td><span class="stall-num">#06</span></td>
                  <td><span class="stall-type-pill dry">Dry Goods</span></td>
                  <td style="font-size:12.5px;color:var(--t2)">Section B · Row 1</td>
                  <td style="font-size:12px;color:var(--t3);font-family:'DM Mono',monospace">3×3 m²</td>
                  <td style="font-size:12.5px;color:var(--t3);font-style:italic">— Vacant —</td>
                  <td><span class="status-badge vacant">Vacant</span></td>
                  <td><span class="posted-badge posted">
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="3">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      Posted
                    </span></td>
                  <td>
                    <div class="row-actions">
                      <div class="action-icon tooltip" data-tip="View Details"
                        onclick="openViewModal('#06','Dry Goods','Section B · Row 1','','vacant')"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                          <circle cx="12" cy="12" r="3" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Edit Stall" onclick="openEditModal()"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg></div>
                      <div class="action-icon success tooltip" data-tip="Manage Posting"
                        onclick="openPostModal('#06','Dry Goods','Section B · Row 1')"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <circle cx="12" cy="12" r="10" />
                          <line x1="2" y1="12" x2="22" y2="12" />
                          <path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg></div>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td><span class="stall-num">#07</span></td>
                  <td><span class="stall-type-pill dry">Dry Goods</span></td>
                  <td style="font-size:12.5px;color:var(--t2)">Section B · Row 1</td>
                  <td style="font-size:12px;color:var(--t3);font-family:'DM Mono',monospace">3×3 m²</td>
                  <td><span class="vendor-link">Maria Santos</span></td>
                  <td><span class="status-badge occupied">Occupied</span></td>
                  <td><span class="posted-badge not-posted">Not Posted</span></td>
                  <td>
                    <div class="row-actions">
                      <div class="action-icon tooltip" data-tip="View Details"><svg xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                          <circle cx="12" cy="12" r="3" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Edit Stall" onclick="openEditModal()"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Post Stall"><svg xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <circle cx="12" cy="12" r="10" />
                          <line x1="2" y1="12" x2="22" y2="12" />
                          <path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg></div>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td><span class="stall-num">#11</span></td>
                  <td><span class="stall-type-pill veggie">Vegetables</span></td>
                  <td style="font-size:12.5px;color:var(--t2)">Section C · Row 2</td>
                  <td style="font-size:12px;color:var(--t3);font-family:'DM Mono',monospace">4×3 m²</td>
                  <td style="font-size:12.5px;color:var(--t3);font-style:italic">— Vacant —</td>
                  <td><span class="status-badge vacant">Vacant</span></td>
                  <td><span class="posted-badge posted">
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="3">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      Posted
                    </span></td>
                  <td>
                    <div class="row-actions">
                      <div class="action-icon tooltip" data-tip="View Details"><svg xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                          <circle cx="12" cy="12" r="3" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Edit Stall" onclick="openEditModal()"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg></div>
                      <div class="action-icon success tooltip" data-tip="Manage Posting"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <circle cx="12" cy="12" r="10" />
                          <line x1="2" y1="12" x2="22" y2="12" />
                          <path
                            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg></div>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td><span class="stall-num">#14</span></td>
                  <td><span class="stall-type-pill fish">Fish Section</span></td>
                  <td style="font-size:12.5px;color:var(--t2)">Section D · Row 1</td>
                  <td style="font-size:12px;color:var(--t3);font-family:'DM Mono',monospace">6×4 m²</td>
                  <td style="font-size:12px;color:var(--t3);font-style:italic">— Under Maintenance —</td>
                  <td><span class="status-badge maintenance">Maintenance</span></td>
                  <td><span class="posted-badge not-posted">Not Posted</span></td>
                  <td>
                    <div class="row-actions">
                      <div class="action-icon tooltip" data-tip="View Details"><svg xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                          <circle cx="12" cy="12" r="3" />
                        </svg></div>
                      <div class="action-icon tooltip" data-tip="Edit Stall" onclick="openEditModal()"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg></div>
                      <div class="action-icon danger tooltip" data-tip="Cannot Post — Maintenance"><svg
                          xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
