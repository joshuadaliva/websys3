<!DOCTYPE html>
<html lang="en" class="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>ARKIPAISI — Stall Management</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root{
  --bg:#f0f2f8;--surf:#fff;--s2:#f6f7fb;--s3:#eef0f7;
  --brd:#e2e6f0;--brd2:#eaecf5;
  --t1:#0c0f1e;--t2:#566080;--t3:#9099b8;
  --ac:#1d4ed8;--acl:#eff3ff;--acs:#c7d7fd;
  --gr:#15803d;--grl:#f0fdf4;--grs:#bbf7d0;
  --am:#b45309;--aml:#fffbeb;--ams:#fde68a;
  --rd:#b91c1c;--rdl:#fff1f2;--rds:#fecdd3;
  --vi:#6d28d9;--vil:#f5f3ff;--vis:#ddd6fe;
  --cy:#0e7490;--cyl:#ecfeff;--cys:#a5f3fc;
  --or:#c2410c;--orl:#fff7ed;--ors:#fed7aa;
  --sidebar-w:240px;--r:10px;--rs:6px;
  --sh:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --shm:0 4px 12px rgba(0,0,0,.08),0 2px 4px rgba(0,0,0,.04);
  --shl:0 10px 30px rgba(0,0,0,.1),0 4px 8px rgba(0,0,0,.06);
}
html.dark{
  --bg:#0d0f14;--surf:#161b27;--s2:#1e2535;--s3:#222840;
  --brd:#2a3245;--brd2:#222840;
  --t1:#f1f5f9;--t2:#94a3b8;--t3:#64748b;
  --ac:#3b82f6;--acl:#1e2d4a;--acs:#1e3a5f;
  --grl:#0d2318;--grs:#15382a;
  --aml:#221a07;--ams:#3d2e0d;
  --rdl:#1f0c0c;--rds:#3b1111;
  --vil:#1a1234;--vis:#2d1f5e;
  --cyl:#0a1f1d;--cys:#0d2e2a;
  --sh:0 1px 3px rgba(0,0,0,.3);--shm:0 4px 12px rgba(0,0,0,.4);--shl:0 10px 30px rgba(0,0,0,.5);
}

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--t1);
  min-height: 100vh;
  display: flex;
  overflow-x: hidden;
  transition: background .3s, color .3s;
}

/* ── SIDEBAR ── */
/* ══ SIDEBAR (archiving pattern) ══ */
.sb{width:var(--sidebar-w);min-height:100vh;background:var(--surf);border-right:1px solid var(--brd);display:flex;flex-direction:column;position:fixed;left:0;top:0;z-index:60;transition:transform .28s cubic-bezier(.4,0,.2,1)}
.sb-logo{height:56px;padding:0 16px 0 20px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-m{width:32px;height:32px;background:var(--ac);border-radius:8px;display:grid;place-items:center;color:#fff;font-size:12px;font-weight:800;flex-shrink:0}
.logo-n{font-size:14px;font-weight:800;letter-spacing:-.3px}
.logo-sub{font-size:9.5px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-top:1px}
.sb-x{width:26px;height:26px;border-radius:6px;border:1px solid var(--brd);background:var(--s2);display:grid;place-items:center;cursor:pointer;color:var(--t2);flex-shrink:0;transition:all .14s}
.sb-x:hover{background:var(--rdl);color:var(--rd);border-color:var(--rds)}
.sb-x svg{width:13px;height:13px}
.sb-nav{flex:1;padding:10px 8px;overflow-y:auto}
.nsec{font-size:9.5px;font-weight:700;color:var(--t3);letter-spacing:.9px;text-transform:uppercase;padding:10px 10px 4px;margin-top:4px}
.ni{display:flex;align-items:center;gap:9px;padding:8px 12px;border-radius:var(--rs);color:var(--t2);cursor:pointer;font-size:13px;font-weight:500;transition:all .14s;margin-bottom:1px;text-decoration:none}
.ni:hover{background:var(--s2);color:var(--t1)}
.ni.on{background:var(--acl);color:var(--ac)}
.ni svg{width:15px;height:15px;flex-shrink:0}
.nbdg{margin-left:auto;font-size:10px;font-weight:700;padding:1px 6px;border-radius:8px;font-family:'DM Mono',monospace;background:var(--rds);color:var(--rd)}
.nbdg.am{background:var(--ams);color:var(--am)}
.nbdg.gr{background:var(--grs);color:var(--gr)}
.sb-foot{padding:12px 8px;border-top:1px solid var(--brd);flex-shrink:0}
.urow{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:var(--rs);cursor:pointer;transition:background .14s}
.urow:hover{background:var(--s2)}
.uav{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--ac),#7c3aed);display:grid;place-items:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0}
.veil{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:55;cursor:pointer}

/* ── MAIN ── */
.main{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;min-height:100vh;transition:margin-left .28s cubic-bezier(.4,0,.2,1);min-width:0}

/* ── NAVBAR ── */
.navbar { height: var(--navbar-h); background: var(--surf); border-bottom: 1px solid var(--brd); display: flex; align-items: center; padding: 0 24px; gap: 12px; position: sticky; top: 0; z-index: 40; transition: background .3s; }
.togbtn{width:32px;height:32px;border-radius:var(--rs);border:1px solid var(--brd);background:var(--surf);display:grid;place-items:center;cursor:pointer;color:var(--t2);transition:all .14s;flex-shrink:0}
.togbtn:hover{border-color:var(--ac);color:var(--ac);background:var(--acl)}
.togbtn svg{width:15px;height:15px}
.menu-btn { display: none; background: none; border: none; cursor: pointer; padding: 6px; border-radius: var(--rs); color: var(--t2); align-items: center; transition: background .15s; }
.menu-btn:hover { background: var(--s2); }
.page-title { font-size: 15px; font-weight: 600; letter-spacing: -.2px; }
.breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--t3); margin-left: 4px; }
.breadcrumb .sep { color: var(--brd); }
.breadcrumb .current { color: var(--t2); font-weight: 500; }
.navbar-actions { margin-left: auto; display: flex; align-items: center; gap: 8px; }
.search-bar { display: flex; align-items: center; gap: 8px; background: var(--s2); border: 1px solid var(--brd); border-radius: var(--rs); padding: 6px 12px; font-size: 13px; color: var(--t3); cursor: pointer; transition: all .15s; min-width: 220px; }
.search-bar:hover { border-color: var(--ac); }
.search-bar svg { width: 14px; height: 14px; }
.search-bar kbd { margin-left: auto; background: var(--surf); border: 1px solid var(--brd); border-radius: 4px; font-size: 10px; padding: 1px 5px; font-family: 'DM Mono', monospace; color: var(--t3); }
.icon-btn { width: 34px; height: 34px; border-radius: var(--rs); border: 1px solid var(--brd); background: var(--surf); display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--t2); position: relative; transition: all .15s; }
.icon-btn:hover { border-color: var(--ac); color: var(--ac); background: var(--acl); }
.icon-btn svg { width: 15px; height: 15px; }
.notif-dot { position: absolute; top: 6px; right: 7px; width: 7px; height: 7px; background: var(--rd); border-radius: 50%; border: 1.5px solid var(--surf); }
.theme-toggle { width: 34px; height: 34px; border-radius: var(--rs); border: 1px solid var(--brd); background: var(--surf); display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--t2); transition: all .15s; }
.theme-toggle:hover { background: var(--aml); border-color: var(--am); color: var(--am); }
.theme-toggle svg { width: 15px; height: 15px; }
.avatar-btn { display: flex; align-items: center; gap: 8px; padding: 4px 10px 4px 4px; border-radius: var(--rs); border: 1px solid var(--brd); background: var(--surf); cursor: pointer; transition: all .15s; }
.avatar-btn:hover { border-color: var(--ac); }
.avatar-sm { width: 26px; height: 26px; border-radius: 50%; background: linear-gradient(135deg, var(--ac), #7c3aed); display: flex; align-items: center; justify-content: center; color: white; font-size: 10px; font-weight: 700; }
.avatar-btn-name { font-size: 12.5px; font-weight: 600; }
.avatar-btn svg { width: 12px; height: 12px; color: var(--t3); }

/* ── CONTENT ── */
.content { padding: 24px; flex: 1; }

/* ── PAGE HEADER ── */
.page-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
.page-header-left .ph-title { font-size: 20px; font-weight: 700; letter-spacing: -.5px; }
.page-header-left .ph-sub { font-size: 13px; color: var(--t3); margin-top: 3px; }
.page-header-actions { display: flex; gap: 8px; flex-wrap: wrap; }

/* ── BUTTONS ── */
.btn { padding: 8px 16px; border-radius: var(--rs); font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: all .15s; font-family: 'DM Sans', sans-serif; display: inline-flex; align-items: center; gap: 6px; }
.btn svg { width: 14px; height: 14px; }
.btn.primary { background: var(--ac); color: white; }
.btn.primary:hover { background: #1e40af; }
.btn.success { background: var(--gr); color: white; }
.btn.success:hover { background: #15803d; }
.btn.ghost { background: var(--surf); border: 1px solid var(--brd); color: var(--t2); }
.btn.ghost:hover { border-color: var(--ac); color: var(--ac); background: var(--acl); }
.btn.danger-ghost { background: transparent; border: 1px solid var(--rds); color: var(--rd); }
.btn.danger-ghost:hover { background: var(--rds); }
.btn.sm { padding: 6px 12px; font-size: 12px; }
.btn.xs { padding: 4px 9px; font-size: 11.5px; }

/* ── STATS ── */
.stats-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 20px; }
.mini-stat { background: var(--surf); border: 1px solid var(--brd); border-radius: var(--r); padding: 14px 16px; display: flex; align-items: center; gap: 12px; box-shadow: var(--sh); transition: all .2s; cursor: default; }
.mini-stat:hover { box-shadow: var(--shm); transform: translateY(-1px); }
.ms-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.ms-icon svg { width: 16px; height: 16px; }
.ms-icon.blue { background: var(--acl); color: var(--ac); }
.ms-icon.green { background: var(--grl); color: var(--gr); }
.ms-icon.amber { background: var(--aml); color: var(--am); }
.ms-icon.red { background: var(--rdl); color: var(--rd); }
.ms-icon.teal { background: var(--cyl); color: var(--cy); }
.ms-val { font-size: 22px; font-weight: 700; font-family: 'DM Mono', monospace; letter-spacing: -.5px; line-height: 1; }
.ms-lbl { font-size: 11px; color: var(--t3); font-weight: 500; margin-top: 2px; }

/* ── TABS ── */
.tabs-bar { display: flex; gap: 2px; background: var(--s2); border: 1px solid var(--brd); border-radius: var(--rs); padding: 3px; margin-bottom: 18px; width: fit-content; }
.tab-btn { padding: 7px 16px; border-radius: 5px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; background: transparent; color: var(--t2); transition: all .15s; display: flex; align-items: center; gap: 6px; font-family: 'DM Sans', sans-serif; }
.tab-btn svg { width: 14px; height: 14px; }
.tab-btn.active { background: var(--surf); color: var(--t1); box-shadow: var(--sh); font-weight: 600; }
.tab-btn:hover:not(.active) { color: var(--t1); }

/* ── FILTERS ── */
.filters-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
.filter-input { display: flex; align-items: center; gap: 8px; background: var(--surf); border: 1px solid var(--brd); border-radius: var(--rs); padding: 7px 12px; font-size: 13px; color: var(--t1); min-width: 260px; transition: border .15s; }
.filter-input:focus-within { border-color: var(--ac); }
.filter-input input { border: none; background: transparent; outline: none; color: var(--t1); font-family: 'DM Sans', sans-serif; font-size: 13px; flex: 1; }
.filter-input input::placeholder { color: var(--t3); }
.filter-input svg { width: 14px; height: 14px; color: var(--t3); flex-shrink: 0; }
.filter-select { background: var(--surf); border: 1px solid var(--brd); border-radius: var(--rs); padding: 7px 10px; font-size: 13px; color: var(--t2); cursor: pointer; font-family: 'DM Sans', sans-serif; outline: none; transition: border .15s; }
.filter-select:focus { border-color: var(--ac); }
.filter-badge { display: flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: var(--rs); font-size: 12.5px; font-weight: 600; cursor: pointer; border: 1.5px solid transparent; transition: all .15s; }
.filter-badge.all { background: var(--s2); color: var(--t2); border-color: var(--brd); }
.filter-badge.all.active, .filter-badge.all:hover { background: var(--surf); border-color: var(--t1); color: var(--t1); }
.filter-badge.occupied { background: var(--acl); color: var(--ac); border-color: var(--acs); }
.filter-badge.occupied.active, .filter-badge.occupied:hover { border-color: var(--ac); }
.filter-badge.vacant { background: var(--aml); color: var(--am); border-color: var(--ams); }
.filter-badge.vacant.active, .filter-badge.vacant:hover { border-color: var(--am); }
.filter-badge.maintenance { background: var(--rdl); color: var(--rd); border-color: var(--rds); }
.filter-badge.maintenance.active, .filter-badge.maintenance:hover { border-color: var(--rd); }
.filter-badge .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
.view-toggle { display: flex; background: var(--s2); border: 1px solid var(--brd); border-radius: var(--rs); overflow: hidden; margin-left: auto; }
.view-btn { padding: 7px 10px; background: transparent; border: none; cursor: pointer; color: var(--t3); transition: all .15s; display: flex; align-items: center; }
.view-btn svg { width: 15px; height: 15px; }
.view-btn.active { background: var(--surf); color: var(--t1); box-shadow: var(--sh); }

/* ── TABLE VIEW ── */
.table-panel { background: var(--surf); border: 1px solid var(--brd); border-radius: var(--r); box-shadow: var(--sh); overflow: hidden; }
.tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;width:100%}
.tbl-wrap .stall-table{min-width:680px}
.stall-table { width: 100%; border-collapse: collapse; }
.stall-table th { font-size: 11px; font-weight: 600; color: var(--t3); text-transform: uppercase; letter-spacing: .5px; padding: 11px 16px; text-align: left; background: var(--s2); border-bottom: 1px solid var(--brd); white-space: nowrap; }
.stall-table th.sortable { cursor: pointer; user-select: none; }
.stall-table th.sortable:hover { color: var(--t1); }
.stall-table th .sort-icon { display: inline-flex; flex-direction: column; gap: 1px; margin-left: 4px; vertical-align: middle; opacity: .5; }
.stall-table th .sort-icon svg { width: 8px; height: 8px; }
.stall-table td { padding: 13px 16px; font-size: 13px; border-bottom: 1px solid var(--brd2); vertical-align: middle; }
.stall-table tr:last-child td { border-bottom: none; }
.stall-table tr:hover td { background: var(--s2); }
.stall-table tr.selected td { background: var(--acl); }
.stall-num { font-family: 'DM Mono', monospace; font-weight: 700; font-size: 13px; background: var(--s2); border: 1px solid var(--brd); padding: 3px 8px; border-radius: 5px; display: inline-block; }
.stall-type-pill { display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px; border-radius: 20px; font-size: 11.5px; font-weight: 600; }
.stall-type-pill.wet { background: var(--cys); color: var(--cy); }
.stall-type-pill.dry { background: var(--ams); color: var(--am); }
.stall-type-pill.meat { background: var(--rds); color: var(--rd); }
.stall-type-pill.veggie { background: var(--grs); color: var(--gr); }
.stall-type-pill.fish { background: var(--acs); color: var(--ac); }
.stall-type-pill.general { background: var(--vis); color: var(--vi); }
.status-badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 11.5px; font-weight: 600; }
.status-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.status-badge.occupied { background: var(--acl); color: var(--ac); }
.status-badge.vacant { background: var(--aml); color: var(--am); }
.status-badge.maintenance { background: var(--rdl); color: var(--rd); }
.posted-badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 8px; border-radius: 5px; font-size: 11px; font-weight: 600; }
.posted-badge.posted { background: var(--grs); color: var(--gr); }
.posted-badge.not-posted { background: var(--s2); color: var(--t3); border: 1px solid var(--brd); }
.row-actions { display: flex; gap: 6px; align-items: center; }
.action-icon { width: 28px; height: 28px; border-radius: var(--rs); border: 1px solid var(--brd); background: var(--surf); display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--t3); transition: all .15s; }
.action-icon:hover { border-color: var(--ac); color: var(--ac); background: var(--acl); }
.action-icon.danger:hover { border-color: var(--rd); color: var(--rd); background: var(--rdl); }
.action-icon.success:hover { border-color: var(--gr); color: var(--gr); background: var(--grl); }
.action-icon svg { width: 13px; height: 13px; }
.vendor-link { font-size: 12.5px; color: var(--ac); font-weight: 500; cursor: pointer; }
.vendor-link:hover { text-decoration: underline; }
.table-footer { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-top: 1px solid var(--brd); background: var(--s2); }
.table-info { font-size: 12.5px; color: var(--t3); }
.pagination { display: flex; gap: 4px; align-items: center; }
.pg-btn { width: 30px; height: 30px; border-radius: var(--rs); border: 1px solid var(--brd); background: var(--surf); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 12.5px; font-weight: 600; color: var(--t2); transition: all .15s; }
.pg-btn:hover { border-color: var(--ac); color: var(--ac); }
.pg-btn.active { background: var(--ac); border-color: var(--ac); color: white; }
.pg-btn svg { width: 12px; height: 12px; }
.checkbox { width: 15px; height: 15px; border-radius: 3px; border: 1.5px solid var(--brd); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .15s; background: var(--surf); }
.checkbox.checked { background: var(--ac); border-color: var(--ac); }
.checkbox.checked::after { content: '✓'; color: white; font-size: 10px; font-weight: 700; }

/* ── GRID VIEW ── */
.stall-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
.stall-card { background: var(--surf); border: 1px solid var(--brd); border-radius: var(--r); padding: 16px; box-shadow: var(--sh); transition: all .2s; cursor: default; position: relative; overflow: hidden; }
.stall-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
.stall-card.occupied::before { background: var(--ac); }
.stall-card.vacant::before { background: var(--am); }
.stall-card.maintenance::before { background: var(--rd); }
.stall-card:hover { box-shadow: var(--shm); transform: translateY(-2px); }
.sc-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
.sc-num { font-family: 'DM Mono', monospace; font-size: 20px; font-weight: 700; letter-spacing: -.5px; }
.sc-status { }
.sc-body { margin-bottom: 14px; }
.sc-type { font-size: 12.5px; font-weight: 600; margin-bottom: 4px; }
.sc-loc { font-size: 12px; color: var(--t3); display: flex; align-items: center; gap: 4px; }
.sc-loc svg { width: 11px; height: 11px; }
.sc-vendor { margin-top: 8px; padding-top: 8px; border-top: 1px dashed var(--brd); font-size: 12px; }
.sc-vendor-label { color: var(--t3); font-size: 10.5px; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 2px; }
.sc-vendor-name { font-weight: 600; font-size: 12.5px; }
.sc-size { font-size: 11px; color: var(--t3); font-family: 'DM Mono', monospace; }
.sc-footer { display: flex; gap: 6px; }
.sc-btn { flex: 1; padding: 6px 0; border-radius: var(--rs); border: 1px solid var(--brd); background: var(--s2); font-size: 11.5px; font-weight: 600; cursor: pointer; color: var(--t2); transition: all .15s; font-family: 'DM Sans', sans-serif; text-align: center; }
.sc-btn:hover { border-color: var(--ac); color: var(--ac); background: var(--acl); }
.sc-btn.post { border-color: var(--grs); background: var(--grl); color: var(--gr); }
.sc-btn.post:hover { background: var(--gr); color: white; border-color: var(--gr); }
.posted-ribbon { position: absolute; top: 10px; right: -22px; background: var(--gr); color: white; font-size: 9px; font-weight: 700; padding: 3px 28px; transform: rotate(35deg); letter-spacing: .5px; }

/* ── MAP VIEW ── */
.map-container { background: var(--surf); border: 1px solid var(--brd); border-radius: var(--r); box-shadow: var(--sh); overflow: hidden; }
.map-header { padding: 14px 20px; border-bottom: 1px solid var(--brd); display: flex; align-items: center; justify-content: space-between; }
.map-title { font-size: 13.5px; font-weight: 600; }
.map-legend { display: flex; gap: 14px; }
.map-legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--t2); }
.map-legend-swatch { width: 12px; height: 12px; border-radius: 3px; }
.map-body { padding: 20px; overflow-x: auto; }
.market-map { display: flex; flex-direction: column; gap: 16px; min-width: 600px; }
.map-section-label { font-size: 11px; font-weight: 700; color: var(--t3); text-transform: uppercase; letter-spacing: .8px; display: flex; align-items: center; gap: 8px; }
.map-section-label::after { content: ''; flex: 1; height: 1px; background: var(--brd); }
.map-row { display: flex; gap: 8px; flex-wrap: wrap; }
.map-stall { width: 72px; height: 72px; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; transition: all .15s; position: relative; border: 2px solid transparent; }
.map-stall:hover { transform: scale(1.08); z-index: 2; }
.map-stall.occupied { background: var(--acl); border-color: var(--acs); }
.map-stall.occupied:hover { border-color: var(--ac); }
.map-stall.vacant { background: var(--aml); border-color: var(--ams); }
.map-stall.vacant:hover { border-color: var(--am); }
.map-stall.maintenance { background: var(--rdl); border-color: var(--rds); }
.map-stall.maintenance:hover { border-color: var(--rd); }
.map-stall.posted { background: var(--grl); border-color: var(--grs); }
.map-stall.posted:hover { border-color: var(--gr); }
.map-stall-num { font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 700; }
.map-stall.occupied .map-stall-num { color: var(--ac); }
.map-stall.vacant .map-stall-num { color: var(--am); }
.map-stall.maintenance .map-stall-num { color: var(--rd); }
.map-stall.posted .map-stall-num { color: var(--gr); }
.map-stall-type { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: .3px; margin-top: 2px; }
.map-stall.occupied .map-stall-type { color: var(--ac); opacity: .7; }
.map-stall.vacant .map-stall-type { color: var(--am); opacity: .7; }
.map-stall.maintenance .map-stall-type { color: var(--rd); opacity: .7; }
.map-stall.posted .map-stall-type { color: var(--gr); opacity: .7; }
.map-stall-posted-dot { position: absolute; top: 4px; right: 4px; width: 8px; height: 8px; background: var(--gr); border-radius: 50%; border: 1.5px solid var(--surf); }
.map-aisle { display: flex; align-items: center; justify-content: center; height: 20px; font-size: 10px; font-weight: 600; color: var(--t3); letter-spacing: .5px; text-transform: uppercase; }
.map-entrance { background: var(--s2); border: 2px dashed var(--brd); border-radius: 8px; padding: 10px 24px; font-size: 11px; font-weight: 700; color: var(--t3); text-align: center; letter-spacing: 1px; text-transform: uppercase; }

/* ── MODAL BACKDROP ── */
.modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.5); backdrop-filter: blur(2px); z-index: 100; display: flex; align-items: center; justify-content: center; padding: 20px; opacity: 0; pointer-events: none; transition: opacity .2s; }
.modal-backdrop.open { opacity: 1; pointer-events: all; }

/* ── ADD/EDIT STALL MODAL ── */
.modal { background: var(--surf); border-radius: 14px; box-shadow: var(--shl); width: 100%; max-width: 560px; max-height: 90vh; overflow-y: auto; transform: translateY(10px); transition: transform .2s; }
.modal-backdrop.open .modal { transform: translateY(0); }
.modal-head { padding: 20px 24px; border-bottom: 1px solid var(--brd); display: flex; align-items: center; justify-content: space-between; }
.modal-title { font-size: 16px; font-weight: 700; letter-spacing: -.3px; }
.modal-close { width: 30px; height: 30px; border-radius: var(--rs); border: 1px solid var(--brd); background: var(--s2); display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--t2); transition: all .15s; }
.modal-close:hover { background: var(--rdl); border-color: var(--rds); color: var(--rd); }
.modal-close svg { width: 14px; height: 14px; }
.modal-body { padding: 24px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.form-row.single { grid-template-columns: 1fr; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label { font-size: 12px; font-weight: 600; color: var(--t2); }
.form-control { background: var(--s2); border: 1px solid var(--brd); border-radius: var(--rs); padding: 9px 12px; font-size: 13px; color: var(--t1); font-family: 'DM Sans', sans-serif; outline: none; transition: border .15s; }
.form-control:focus { border-color: var(--ac); background: var(--surf); }
.form-control::placeholder { color: var(--t3); }
select.form-control { cursor: pointer; }
textarea.form-control { resize: vertical; min-height: 80px; }
.status-selector { display: flex; gap: 8px; }
.status-opt { flex: 1; padding: 8px 10px; border-radius: var(--rs); border: 1.5px solid var(--brd); cursor: pointer; text-align: center; font-size: 12px; font-weight: 600; transition: all .15s; background: var(--s2); color: var(--t2); }
.status-opt.occupied.active { background: var(--acl); border-color: var(--ac); color: var(--ac); }
.status-opt.vacant.active { background: var(--aml); border-color: var(--am); color: var(--am); }
.status-opt.maintenance.active { background: var(--rdl); border-color: var(--rds); color: var(--rd); }
.upload-zone { border: 2px dashed var(--brd); border-radius: var(--r); padding: 20px; text-align: center; cursor: pointer; transition: all .15s; background: var(--s2); }
.upload-zone:hover { border-color: var(--ac); background: var(--acl); }
.upload-zone svg { width: 28px; height: 28px; color: var(--t3); margin: 0 auto 8px; display: block; }
.upload-zone-text { font-size: 13px; font-weight: 500; color: var(--t2); }
.upload-zone-sub { font-size: 11px; color: var(--t3); margin-top: 3px; }
.section-divider { font-size: 11px; font-weight: 700; color: var(--t3); text-transform: uppercase; letter-spacing: .8px; display: flex; align-items: center; gap: 10px; margin: 20px 0 16px; }
.section-divider::before, .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--brd); }
.post-toggle { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; background: var(--grl); border: 1px solid var(--grs); border-radius: var(--rs); }
.post-toggle-info { }
.post-toggle-label { font-size: 13px; font-weight: 600; color: var(--gr); }
.post-toggle-desc { font-size: 11.5px; color: var(--t3); margin-top: 2px; }
.toggle-switch { width: 42px; height: 24px; background: var(--brd); border-radius: 12px; cursor: pointer; position: relative; transition: background .2s; flex-shrink: 0; }
.toggle-switch.on { background: var(--gr); }
.toggle-switch::after { content: ''; position: absolute; width: 18px; height: 18px; background: white; border-radius: 50%; top: 3px; left: 3px; transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.2); }
.toggle-switch.on::after { transform: translateX(18px); }
.modal-footer { padding: 16px 24px; border-top: 1px solid var(--brd); display: flex; justify-content: flex-end; gap: 8px; background: var(--s2); border-radius: 0 0 14px 14px; }

/* ── POST MODAL ── */
.post-modal { max-width: 480px; }
.post-preview { background: var(--s2); border: 1px solid var(--brd); border-radius: var(--r); overflow: hidden; margin-bottom: 16px; }
.post-preview-img { height: 120px; background: linear-gradient(135deg, var(--acs), var(--acl)); display: flex; align-items: center; justify-content: center; }
.post-preview-img svg { width: 40px; height: 40px; color: var(--ac); opacity: .5; }
.post-preview-body { padding: 14px 16px; }
.post-preview-stall { font-size: 18px; font-weight: 700; letter-spacing: -.3px; }
.post-preview-meta { display: flex; gap: 12px; margin-top: 6px; flex-wrap: wrap; }
.post-meta-item { display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--t2); }
.post-meta-item svg { width: 12px; height: 12px; }
.post-preview-desc { font-size: 12.5px; color: var(--t2); margin-top: 8px; line-height: 1.5; }
.post-preview-deadline { display: flex; align-items: center; gap: 8px; margin-top: 10px; padding: 8px 10px; background: var(--aml); border-radius: var(--rs); }
.post-preview-deadline svg { width: 13px; height: 13px; color: var(--am); }
.post-preview-deadline-text { font-size: 12px; font-weight: 600; color: var(--am); }
.post-preview-apply { margin-top: 10px; width: 100%; padding: 9px; background: var(--ac); color: white; border: none; border-radius: var(--rs); font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background .15s; }
.post-preview-apply:hover { background: #1e40af; }

/* ── RESPONSIVE ── */
@media (max-width: 1200px) {
  .stats-row { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 900px) {
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .stall-table th:nth-child(5), .stall-table td:nth-child(5) { display: none; }
}
@media (max-width: 768px) {
  .main { margin-left: 0 !important; min-width: 0; }
  .sb { transform: translateX(calc(-1 * var(--sidebar-w))); }
  .search-bar { display: none; }
  .navbar-actions .avatar-btn-name, .navbar-actions .avatar-btn svg:last-child { display: none; }
  .content { padding: 16px; min-width: 0; overflow-x: hidden; }
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .filters-bar { flex-wrap: wrap; gap: 8px; }
  .filter-input { min-width: unset; flex: 1; }
  .view-toggle { margin-left: 0; }
  .tabs-bar { width: 100%; overflow-x: auto; scrollbar-width: none; }
  .tabs-bar::-webkit-scrollbar { display: none; }
  .stall-table th:nth-child(6), .stall-table td:nth-child(6) { display: none; }
  .page-header { flex-direction: column; align-items: flex-start; gap: 10px; }
  .page-header-actions { width: 100%; justify-content: flex-start; flex-wrap: wrap; }
  .navbar { padding: 0 14px; }
}
@media (max-width: 540px) {
  .content { padding: 10px; }
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .filters-bar { flex-direction: column; align-items: stretch; }
  .view-toggle { margin-left: 0; align-self: flex-start; }
  .navbar { padding: 0 10px; gap: 8px; }
  .stall-grid { grid-template-columns: 1fr 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .modal-backdrop { padding: 0; align-items: flex-end; }
  .modal { max-width: 100%; border-radius: 14px 14px 0 0; max-height: 96vh; }
  .stall-table th:nth-child(4), .stall-table td:nth-child(4) { display: none; }
  .table-footer { flex-direction: column; align-items: flex-start; gap: 8px; }
  .map-body { padding: 12px; }
}
@media (max-width: 380px) {
  .stats-row { grid-template-columns: 1fr 1fr; }
  .stall-grid { grid-template-columns: 1fr; }
  .mini-stat { padding: 10px 12px; }
}
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--brd); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: var(--t3); }
</style>
</head>
