<!DOCTYPE html>
<html lang="en" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARKIPAISI — RCD Reports</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin/rcd-reports.css">
</head>

<body>


  <!-- ═══ SIDEBAR ═══ -->
  <%- include("../partials/sidebar.ejs") %>
  
  <!-- ═══ MAIN ═══ -->
  <div class="main" id="main">
      <%- include("../partials/header.ejs") %>

    <div class="content">

      <!-- Page Header -->
      <div class="pghdr">
        <div>
          <h1>Report of Collection and Deposit</h1>
          <p>Official RCD reports for the Municipal Treasurer · Payments auto-reflect in real time</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn gh sm" onclick="openM('generateModal')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            Select Period
          </button>
          <button class="btn gh sm" onclick="exportExcel()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
            Export Excel
          </button>
          <button class="btn pr sm" onclick="openM('previewModal')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <polyline points="6 9 6 2 18 2 18 9" />
              <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
              <rect x="6" y="14" width="12" height="8" />
            </svg>
            Print / PDF
          </button>
        </div>
      </div>

      <!-- RCD Report Header Block -->
      <div class="rcd-header">
        <div class="rcd-gov-header">
          <div class="rcd-seal">LGU<br />SEAL</div>
          <div class="rcd-gov-info">
            <div class="l1">Republic of the Philippines · Local Government Unit</div>
            <div class="l2">Municipal Public Market — ARKIPAISI</div>
            <div class="l3">Report of Collection and Deposit (RCD) · Market Revenue Division</div>
          </div>
          <div style="text-align:right;flex-shrink:0">
            <div style="font-size:10px;color:var(--t3)">RCD Number</div>
            <div class="mono" style="font-size:18px;font-weight:800;color:var(--ac)" id="rcd-number">RCD-2026-03</div>
            <div style="font-size:10px;color:var(--t3);margin-top:3px" id="rcd-status-tag">
              <span class="bdg dep">Deposited</span>
            </div>
          </div>
        </div>
        <div class="rcd-meta-grid">
          <div class="rcd-meta-item">
            <div class="rcd-meta-lbl">Reporting Period</div>
            <div class="rcd-meta-val" id="rcd-period">March 1–10, 2026</div>
          </div>
          <div class="rcd-meta-item">
            <div class="rcd-meta-lbl">Collecting Officer</div>
            <div class="rcd-meta-val" style="font-size:13px">Maria A. Torres</div>
          </div>
          <div class="rcd-meta-item">
            <div class="rcd-meta-lbl">Date Generated</div>
            <div class="rcd-meta-val" style="font-size:13px" id="rcd-gen-date">March 10, 2026</div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats">
        <div class="sc cg" style="animation-delay:.04s">
          <div class="si g"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23" />
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg></div>
          <div>
            <div class="sv" style="color:var(--gr)" id="stat-collected">₱14,700</div>
            <div class="sl">Total Collected</div>
            <div class="sd up" id="stat-collected-sub">↑ ₱1,200 vs Feb</div>
          </div>
        </div>
        <div class="sc cb" style="animation-delay:.08s">
          <div class="si b"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <rect x="2" y="5" width="20" height="14" rx="2" />
              <line x1="2" y1="10" x2="22" y2="10" />
            </svg></div>
          <div>
            <div class="sv" id="stat-deposited">₱12,500</div>
            <div class="sl">Total Deposited</div>
            <div class="sd" style="color:var(--t3)" id="stat-deposited-sub">3 deposits made</div>
          </div>
        </div>
        <div class="sc ca" style="animation-delay:.12s">
          <div class="si a"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg></div>
          <div>
            <div class="sv" style="color:var(--am)" id="stat-undeposited">₱2,200</div>
            <div class="sl">Undeposited Cash</div>
            <div class="sd dn" id="stat-undeposited-sub">Pending deposit</div>
          </div>
        </div>
        <div class="sc cb" style="animation-delay:.16s">
          <div class="si b"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <polyline points="9 11 12 14 22 4" />
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
            </svg></div>
          <div>
            <div class="sv" id="stat-or-count">8</div>
            <div class="sl">OR Receipts Issued</div>
            <div class="sd" style="color:var(--t3)">OR# 0123456–63</div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs">
        <button class="tab on" onclick="setTab('collection',this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <line x1="8" y1="6" x2="21" y2="6" />
            <line x1="8" y1="12" x2="21" y2="12" />
            <line x1="8" y1="18" x2="21" y2="18" />
            <line x1="3" y1="6" x2="3.01" y2="6" />
            <line x1="3" y1="12" x2="3.01" y2="12" />
            <line x1="3" y1="18" x2="3.01" y2="18" />
          </svg>
          Collection List
        </button>
        <button class="tab" onclick="setTab('summary',this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <path d="M3 9h18M9 21V9" />
          </svg>
          Daily Summary
        </button>
        <button class="tab" onclick="setTab('deposit',this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <rect x="2" y="5" width="20" height="14" rx="2" />
            <line x1="2" y1="10" x2="22" y2="10" />
          </svg>
          Deposit Report
        </button>
        <button class="tab" onclick="setTab('chart',this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <line x1="18" y1="20" x2="18" y2="10" />
            <line x1="12" y1="20" x2="12" y2="4" />
            <line x1="6" y1="20" x2="6" y2="14" />
          </svg>
          Collection Chart
        </button>
      </div>

      <!-- ══ TAB: COLLECTION LIST ══ -->
      <div id="tab-collection">
        <div class="panel">
          <div class="ph">
            <div class="ph-t">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <line x1="8" y1="6" x2="21" y2="6" />
                <line x1="8" y1="12" x2="21" y2="12" />
                <line x1="8" y1="18" x2="21" y2="18" />
              </svg>
              Collection List — March 2026
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              <button class="btn gh sm" onclick="openM('recordDepositModal')">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <rect x="2" y="5" width="20" height="14" rx="2" />
                  <line x1="2" y1="10" x2="22" y2="10" />
                </svg>
                Record Deposit
              </button>
            </div>
          </div>
          <div class="fbar">
            <div class="fsrch">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
              <input id="col-srch" placeholder="Search vendor, OR number…" oninput="renderCollection()" />
            </div>
            <select class="fsel" id="col-method" onchange="renderCollection()">
              <option value="">All Methods</option>
              <option value="office">Direct Office</option>
              <option value="collector">Collector</option>
              <option value="portal">Vendor Portal</option>
            </select>
            <select class="fsel" id="col-day" onchange="renderCollection()">
              <option value="">All Dates</option>
              <option value="Mar 1">Mar 1</option>
              <option value="Mar 2">Mar 2</option>
              <option value="Mar 3">Mar 3</option>
              <option value="Mar 4">Mar 4</option>
              <option value="Mar 5">Mar 5</option>
              <option value="Mar 6">Mar 6</option>
              <option value="Mar 7">Mar 7</option>
              <option value="Mar 8">Mar 8</option>
              <option value="Mar 9">Mar 9</option>
              <option value="Mar 10">Mar 10</option>
            </select>
          </div>
          <div class="tbl-wrap" style="overflow-x:auto">
            <table class="tbl">
              <thead>
                <tr>
                  <th>OR No.</th>
                  <th>Date</th>
                  <th>Vendor</th>
                  <th>Stall</th>
                  <th>Nature of Collection</th>
                  <th>Method</th>
                  <th style="text-align:right">Amount</th>
                  <th>Deposit Ref</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="col-tbody"></tbody>
              <tfoot>
                <tr>
                  <td colspan="6" style="font-size:12px;color:var(--t3)">Total (filtered)</td>
                  <td style="text-align:right;font-family:'DM Mono',monospace;color:var(--gr)" id="col-total">₱0.00</td>
                  <td colspan="2"></td>
                </tr>
              </tfoot>
            </table>
          </div>
          <div class="tbl-footer" id="col-foot"></div>
        </div>
      </div>

      <!-- ══ TAB: DAILY SUMMARY ══ -->
      <div id="tab-summary" style="display:none">
        <div class="sum-row">
          <div class="sum-card">
            <div class="sum-card-lbl">Highest Day</div>
            <div class="sum-card-val" style="color:var(--gr)">₱4,500</div>
            <div class="sum-card-sub">March 5, 2026 · 3 collections</div>
          </div>
          <div class="sum-card">
            <div class="sum-card-lbl">Average Daily</div>
            <div class="sum-card-val">₱1,470</div>
            <div class="sum-card-sub">Based on 10 active days</div>
          </div>
          <div class="sum-card">
            <div class="sum-card-lbl">Days with Collections</div>
            <div class="sum-card-val">10 <span style="font-size:13px;color:var(--t3)">/ 10</span></div>
            <div class="sum-card-sub">March 1–10, 2026</div>
          </div>
        </div>
        <div class="panel">
          <div class="ph">
            <div class="ph-t">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M3 9h18M9 21V9" />
              </svg>
              Daily Collection Summary
            </div>
            <button class="btn gh sm" onclick="exportExcel()">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              Export
            </button>
          </div>
          <div class="tbl-wrap" style="overflow-x:auto">
            <div id="sum-tbl-wrap"></div>
          </div>
        </div>
      </div>

      <!-- ══ TAB: DEPOSIT REPORT ══ -->
      <div id="tab-deposit" style="display:none">
        <div id="deposit-list"></div>
        <div style="margin-top:14px">
          <button class="btn pr sm" onclick="openM('recordDepositModal')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add New Deposit Entry
          </button>
        </div>
      </div>

      <!-- ══ TAB: COLLECTION CHART ══ -->
      <div id="tab-chart" style="display:none">
        <div class="panel">
          <div class="ph">
            <div class="ph-t">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <line x1="18" y1="20" x2="18" y2="10" />
                <line x1="12" y1="20" x2="12" y2="4" />
                <line x1="6" y1="20" x2="6" y2="14" />
              </svg>
              Daily Collection Chart — March 2026
            </div>
            <div style="font-size:11.5px;color:var(--t3)">Stacked by payment method</div>
          </div>
          <div class="chart-wrap">
            <div class="bar-chart" id="bar-chart"></div>
          </div>
          <div class="bar-legend">
            <div class="bar-leg-item">
              <div class="bar-leg-dot" style="background:#15803d"></div>Direct Office
            </div>
            <div class="bar-leg-item">
              <div class="bar-leg-dot" style="background:#6d28d9"></div>Collector
            </div>
            <div class="bar-leg-item">
              <div class="bar-leg-dot" style="background:#1d4ed8"></div>Vendor Portal
            </div>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->

  <!-- ═══ MODALS ═══ -->

  <!-- GENERATE PERIOD MODAL -->
  <div class="mbg" id="generateModal">
    <div class="modal sm">
      <div class="mhd">
        <div class="mtit">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          Select Reporting Period
        </div>
        <div class="mx" onclick="closeM('generateModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div class="frow">
          <div class="fg">
            <label class="fl">Month</label>
            <select class="fc">
              <option>March 2026</option>
              <option>February 2026</option>
              <option>January 2026</option>
            </select>
          </div>
          <div class="fg">
            <label class="fl">RCD Type</label>
            <select class="fc">
              <option>Monthly RCD</option>
              <option>Weekly RCD</option>
              <option>Daily RCD</option>
            </select>
          </div>
        </div>
        <div class="frow">
          <div class="fg">
            <label class="fl">Date From</label>
            <input class="fc" type="date" value="2026-03-01" />
          </div>
          <div class="fg">
            <label class="fl">Date To</label>
            <input class="fc" type="date" value="2026-03-10" />
          </div>
        </div>
        <div class="fg">
          <label class="fl">Collecting Officer</label>
          <input class="fc" value="Maria A. Torres" readonly style="background:var(--s2)" />
        </div>
        <div class="chip b">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          <div>All payments recorded within the selected period will automatically be included in the RCD.</div>
        </div>
      </div>
      <div class="mft">
        <button class="btn gh sm" onclick="closeM('generateModal')">Cancel</button>
        <button class="btn pr sm"
          onclick="closeM('generateModal');showToast('RCD report generated for March 1–10, 2026','g')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <polyline points="9 11 12 14 22 4" />
          </svg>
          Generate RCD
        </button>
      </div>
    </div>
  </div>

  <!-- RECORD DEPOSIT MODAL -->
  <div class="mbg" id="recordDepositModal">
    <div class="modal">
      <div class="mhd">
        <div class="mtit">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--gr)" stroke-width="2">
            <rect x="2" y="5" width="20" height="14" rx="2" />
            <line x1="2" y1="10" x2="22" y2="10" />
          </svg>
          Record Bank Deposit
        </div>
        <div class="mx" onclick="closeM('recordDepositModal')"><svg xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div class="sec-lbl">Deposit Details</div>
        <div class="frow">
          <div class="fg">
            <label class="fl">Deposit Date *</label>
            <input class="fc" type="date" value="2026-03-10" id="dep-date" />
          </div>
          <div class="fg">
            <label class="fl">Deposit Slip No. *</label>
            <input class="fc" id="dep-slip-no" placeholder="e.g. DS-2026-003" />
          </div>
        </div>
        <div class="fg">
          <label class="fl">Bank / Branch *</label>
          <select class="fc" id="dep-bank">
            <option>Land Bank of the Philippines — Municipal Branch</option>
            <option>Development Bank of the Philippines</option>
            <option>Philippine National Bank</option>
          </select>
        </div>
        <div class="frow">
          <div class="fg">
            <label class="fl">Amount Deposited (₱) *</label>
            <input class="fc" type="number" id="dep-amount" placeholder="0.00" />
          </div>
          <div class="fg">
            <label class="fl">Deposited By *</label>
            <input class="fc" id="dep-by" value="Maria A. Torres" />
          </div>
        </div>

        <div class="sec-lbl">Coverage</div>
        <div class="chip g">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <polyline points="9 11 12 14 22 4" />
          </svg>
          <div>This deposit will cover the undeposited collections currently in queue. Select the ORs to include:</div>
        </div>
        <div id="dep-or-list" style="display:flex;flex-direction:column;gap:5px;margin-bottom:14px"></div>
        <div class="fg">
          <label class="fl">Remarks</label>
          <textarea class="fc" style="min-height:60px" placeholder="Optional remarks…"></textarea>
        </div>
      </div>
      <div class="mft">
        <button class="btn gh sm" onclick="closeM('recordDepositModal')">Cancel</button>
        <button class="btn su sm" onclick="saveDeposit()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <rect x="2" y="5" width="20" height="14" rx="2" />
            <line x1="2" y1="10" x2="22" y2="10" />
          </svg>
          Record Deposit
        </button>
      </div>
    </div>
  </div>

  <!-- PRINT PREVIEW MODAL -->
  <div class="mbg" id="previewModal">
    <div class="modal lg">
      <div class="mhd">
        <div class="mtit">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2">
            <polyline points="6 9 6 2 18 2 18 9" />
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
            <rect x="6" y="14" width="12" height="8" />
          </svg>
          RCD Print Preview
        </div>
        <div class="mx" onclick="closeM('previewModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div class="rcd-preview-wrap" id="rcd-preview-content"></div>
      </div>
      <div class="mft">
        <button class="btn gh sm" onclick="closeM('previewModal')">Close</button>
        <button class="btn gh sm" onclick="exportExcel()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
          </svg>
          Export Excel
        </button>
        <button class="btn pr sm" onclick="showToast('RCD sent to printer','g');closeM('previewModal')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <polyline points="6 9 6 2 18 2 18 9" />
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
            <rect x="6" y="14" width="12" height="8" />
          </svg>
          Print / Save PDF
        </button>
      </div>
    </div>
  </div>

  <!-- VIEW OR MODAL -->
  <div class="mbg" id="viewORModal">
    <div class="modal sm">
      <div class="mhd">
        <div class="mtit">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
          </svg>
          Official Receipt Detail
        </div>
        <div class="mx" onclick="closeM('viewORModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy" id="or-detail-body"></div>
      <div class="mft">
        <button class="btn gh sm" onclick="closeM('viewORModal')">Close</button>
        <button class="btn pr sm" onclick="showToast('OR printed','g');closeM('viewORModal')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <polyline points="6 9 6 2 18 2 18 9" />
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
            <rect x="6" y="14" width="12" height="8" />
          </svg>
          Print OR
        </button>
      </div>
    </div>
  </div>

  <script src="/js/admin/rcd-reports.js"></script>
</body>

</html>