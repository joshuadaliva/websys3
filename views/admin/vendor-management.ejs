<!DOCTYPE html>
<html lang="en" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARKIPAISI — Vendor Management</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin/vendor-management.css">
</head>

<body>


  <!-- ═══ SIDEBAR ═══ -->
 <%- include("../partials/sidebar.ejs") %>
 
 <!-- ═══ MAIN ═══ -->
 <div class="main" id="main">
    <%- include("../partials/header.ejs") %>

    <div class="content">

      <!-- Page Header -->
      <div class="pghdr">
        <div>
          <h1>Vendor Management</h1>
          <p>Manage approved vendors, stall assignments, contracts, and portal access</p>
        </div>
        <div class="pg-acts">
          <button class="btn gh sm" onclick="openConvertModal()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <polyline points="17 1 21 5 17 9" />
              <path d="M3 11V9a4 4 0 0 1 4-4h14" />
              <polyline points="7 23 3 19 7 15" />
              <path d="M21 13v2a4 4 0 0 1-4 4H3" />
            </svg>
            <span class="btn-lbl">Convert Applicant</span>
          </button>
          <button class="btn pr sm" onclick="openCreateModal()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="8.5" cy="7" r="4" />
              <line x1="20" y1="8" x2="20" y2="14" />
              <line x1="23" y1="11" x2="17" y2="11" />
            </svg>
            <span class="btn-lbl">Create Vendor</span>
          </button>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats">
        <div class="sc cb">
          <div class="si b"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg></div>
          <div>
            <div class="sv">42</div>
            <div class="sl">Total Vendors</div>
          </div>
        </div>
        <div class="sc cg">
          <div class="si g"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <polyline points="9 11 12 14 22 4" />
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
            </svg></div>
          <div>
            <div class="sv" style="color:var(--gr)">35</div>
            <div class="sl">Active</div>
          </div>
        </div>
        <div class="sc ca">
          <div class="si a"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <line x1="10" y1="15" x2="10" y2="9" />
              <line x1="14" y1="15" x2="14" y2="9" />
            </svg></div>
          <div>
            <div class="sv" style="color:var(--am)">4</div>
            <div class="sl">Suspended</div>
          </div>
        </div>
        <div class="sc cr">
          <div class="si r"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg></div>
          <div>
            <div class="sv" style="color:var(--rd)">2</div>
            <div class="sl">Expired</div>
          </div>
        </div>
        <div class="sc cv">
          <div class="si v"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <line x1="17" y1="11" x2="23" y2="17" />
              <line x1="23" y1="11" x2="17" y2="17" />
            </svg></div>
          <div>
            <div class="sv" style="color:var(--vi)">1</div>
            <div class="sl">Terminated</div>
          </div>
        </div>
      </div>

      <!-- Two-column layout -->
      <div class="layout">
        <!-- LEFT: Vendor List -->
        <div>
          <div class="panel">
            <div class="ph">
              <div class="ph-t">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <line x1="8" y1="6" x2="21" y2="6" />
                  <line x1="8" y1="12" x2="21" y2="12" />
                  <line x1="8" y1="18" x2="21" y2="18" />
                  <line x1="3" y1="6" x2="3.01" y2="6" />
                </svg>
                Vendor List
              </div>
              <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                <div class="vtg">
                  <button class="vb on" id="vb-c" onclick="setView('card',this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2">
                      <rect x="3" y="3" width="7" height="7" />
                      <rect x="14" y="3" width="7" height="7" />
                      <rect x="3" y="14" width="7" height="7" />
                      <rect x="14" y="14" width="7" height="7" />
                    </svg>Cards
                  </button>
                  <button class="vb" id="vb-t" onclick="setView('tbl',this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2">
                      <line x1="8" y1="6" x2="21" y2="6" />
                      <line x1="8" y1="12" x2="21" y2="12" />
                      <line x1="8" y1="18" x2="21" y2="18" />
                    </svg>Table
                  </button>
                </div>
                <button class="btn gh sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="7 10 12 15 17 10" />
                    <line x1="12" y1="15" x2="12" y2="3" />
                  </svg>Export
                </button>
              </div>
            </div>
            <!-- Filters -->
            <div class="fbar">
              <div class="fsrch">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input id="vsrch" placeholder="Search name, stall, contact…" oninput="renderView()" />
              </div>
              <select class="fsel" id="vtype" onchange="renderView()">
                <option value="">All Types</option>
                <option>Wet Market</option>
                <option>Dry Goods</option>
                <option>Meat Section</option>
                <option>Vegetables</option>
                <option>Fish Section</option>
                <option>General</option>
              </select>
              <div class="spills">
                <div class="sp s-all on" onclick="setSF('all',this)">All</div>
                <div class="sp s-ac" onclick="setSF('active',this)">Active</div>
                <div class="sp s-su" onclick="setSF('suspended',this)">Suspended</div>
                <div class="sp s-ex" onclick="setSF('expired',this)">Expired</div>
                <div class="sp s-tm" onclick="setSF('terminated',this)">Terminated</div>
              </div>
            </div>
            <!-- Cards view -->
            <div class="vgrid" id="vgrid"></div>
            <!-- Table view -->
            <div id="vtbl-container" style="display:none">
              <div id="vtbl-wrap"></div>
              <div class="tbl-footer">
                <span class="tbl-footer-info" id="tbl-info">—</span>
                <div class="pg-wrap" id="pgr-wrap"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Profile Column -->
        <div class="rpcol" id="rpcol">
          <div class="panel">
            <div class="empty-ph">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
              <p>Select a vendor to view their profile, contract details, and account information</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ MODALS ══ -->

  <!-- CREATE VENDOR -->
  <div class="mbg" id="createModal">
    <div class="modal">
      <div class="mhd">
        <div class="mtit">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="8.5" cy="7" r="4" />
            <line x1="20" y1="8" x2="20" y2="14" />
            <line x1="23" y1="11" x2="17" y2="11" />
          </svg>
          Create Vendor Account
        </div>
        <div class="mx" onclick="closeM('createModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div class="steps">
          <div class="step active" id="st1">
            <div class="sdot">1</div><span>Vendor Info</span>
          </div>
          <div class="sline" id="sl1"></div>
          <div class="step" id="st2">
            <div class="sdot">2</div><span>Stall & Contract</span>
          </div>
          <div class="sline" id="sl2"></div>
          <div class="step" id="st3">
            <div class="sdot">3</div><span>Credentials</span>
          </div>
        </div>
        <div id="cs1">
          <div class="sec-lbl">Personal Information</div>
          <div class="frow">
            <div class="fg"><label class="fl">First Name *</label><input class="fc" placeholder="e.g. Juan" /></div>
            <div class="fg"><label class="fl">Last Name *</label><input class="fc" placeholder="e.g. Dela Cruz" /></div>
          </div>
          <div class="frow">
            <div class="fg"><label class="fl">Middle Name</label><input class="fc" placeholder="Optional" /></div>
            <div class="fg"><label class="fl">Gender</label><select class="fc">
                <option>Male</option>
                <option>Female</option>
                <option>Prefer not to say</option>
              </select></div>
          </div>
          <div class="frow">
            <div class="fg"><label class="fl">Contact Number *</label><input class="fc"
                placeholder="+63 9XX XXX XXXX" /></div>
            <div class="fg"><label class="fl">Email Address *</label><input class="fc" type="email"
                placeholder="email@example.com" /></div>
          </div>
          <div class="frow full">
            <div class="fg"><label class="fl">Home Address *</label><input class="fc"
                placeholder="Barangay, Municipality/City" /></div>
          </div>
          <div class="frow">
            <div class="fg"><label class="fl">Date of Birth</label><input class="fc" type="date" /></div>
            <div class="fg"><label class="fl">Valid ID Type</label><select class="fc">
                <option>PhilHealth</option>
                <option>SSS</option>
                <option>Passport</option>
                <option>Voter's ID</option>
                <option>Driver's License</option>
              </select></div>
          </div>
        </div>
        <div id="cs2" style="display:none">
          <div class="sec-lbl">Stall Assignment</div>
          <div class="frow">
            <div class="fg"><label class="fl">Assigned Stall *</label><select class="fc">
                <option value="">Select stall…</option>
                <option>#06 — Dry Goods</option>
                <option>#11 — Vegetables</option>
                <option>#22 — General</option>
                <option>#25 — General</option>
              </select></div>
            <div class="fg"><label class="fl">Trade Type *</label><select class="fc">
                <option>Wet Market</option>
                <option>Dry Goods</option>
                <option>Meat Section</option>
                <option>Vegetables</option>
                <option>Fish Section</option>
                <option>General</option>
              </select></div>
          </div>
          <div class="frow">
            <div class="fg"><label class="fl">Monthly Rate (₱) *</label><input class="fc" type="number"
                placeholder="e.g. 1500" /></div>
            <div class="fg"><label class="fl">Assignment Date</label><input class="fc" type="date" /></div>
          </div>
          <div class="sec-lbl" style="margin-top:2px">Contract Details</div>
          <div class="frow">
            <div class="fg"><label class="fl">Contract Start *</label><input class="fc" type="date" /></div>
            <div class="fg"><label class="fl">Duration</label><select class="fc">
                <option>6 Months</option>
                <option selected>1 Year</option>
                <option>2 Years</option>
                <option>3 Years</option>
              </select></div>
          </div>
          <div class="frow">
            <div class="fg"><label class="fl">Contract End *</label><input class="fc" type="date" /></div>
            <div class="fg"><label class="fl">Security Deposit (₱)</label><input class="fc" type="number"
                placeholder="e.g. 3000" /></div>
          </div>
          <div class="frow full">
            <div class="fg"><label class="fl">Contract Notes</label><textarea class="fc"
                placeholder="Special terms or conditions…"></textarea></div>
          </div>
        </div>
        <div id="cs3" style="display:none">
          <div class="chip g"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <polyline points="9 11 12 14 22 4" />
            </svg>
            <div>Account ready. These auto-generated credentials will be sent to the vendor upon account creation.</div>
          </div>
          <div class="credbox">
            <div class="credtit">Auto-Generated Login Credentials</div>
            <div class="credrow"><span class="credlbl">Username</span><span class="credval">jdelacruz.stall06</span>
              <div class="credcp tt" data-tip="Copy"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" />
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </svg></div>
            </div>
            <div class="credrow"><span class="credlbl">Password</span><span class="credval">Ap@2026#xK9m</span>
              <div class="credcp tt" data-tip="Copy"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" />
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </svg></div>
            </div>
            <div class="credrow"><span class="credlbl">Portal URL</span><span
                class="credval">arkipaisi.gov.ph/vendor</span>
              <div class="credcp tt" data-tip="Copy"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" />
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </svg></div>
            </div>
          </div>
          <div class="trow">
            <div>
              <div style="font-size:12.5px;font-weight:600">Send credentials via SMS & Email</div>
              <div style="font-size:11px;color:var(--t3);margin-top:2px">To registered contact and email on file</div>
            </div>
            <div class="sw on" onclick="this.classList.toggle('on')"></div>
          </div>
        </div>
      </div>
      <div class="mft" id="create-mft">
        <button class="btn gh sm" onclick="closeM('createModal')">Cancel</button>
        <button class="btn pr sm" onclick="nextStep()">Next <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6" />
          </svg></button>
      </div>
    </div>
  </div>

  <!-- CONVERT APPLICANT -->
  <div class="mbg" id="convertModal">
    <div class="modal sm">
      <div class="mhd">
        <div class="mtit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--gr)"
            stroke-width="2">
            <polyline points="17 1 21 5 17 9" />
            <path d="M3 11V9a4 4 0 0 1 4-4h14" />
            <polyline points="7 23 3 19 7 15" />
            <path d="M21 13v2a4 4 0 0 1-4 4H3" />
          </svg>Convert Applicant to Vendor</div>
        <div class="mx" onclick="closeM('convertModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div class="chip b"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          <div>Select a stall awardee to convert. Their application data will be pre-filled automatically.</div>
        </div>
        <div class="fg" style="margin-bottom:14px">
          <label class="fl">Select Stall Awardee *</label>
          <div class="aplist">
            <div class="apitem sel" onclick="pickAp(this)">
              <div class="apav" style="background:linear-gradient(135deg,#3b82f6,#6366f1)">CB</div>
              <div style="flex:1">
                <div style="font-size:13px;font-weight:600">Carla M. Bautista</div>
                <div style="font-size:11px;color:var(--t3)">Stall #06 · Dry Goods · Awardee</div>
              </div><svg class="ap-chk" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="var(--ac)" stroke-width="2.5" width="16" height="16">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div class="apitem" onclick="pickAp(this)">
              <div class="apav" style="background:linear-gradient(135deg,#0f766e,#0891b2)">NE</div>
              <div style="flex:1">
                <div style="font-size:13px;font-weight:600">Nena E. Estrada</div>
                <div style="font-size:11px;color:var(--t3)">Stall #22 · General · Awardee</div>
              </div>
            </div>
            <div class="apitem" onclick="pickAp(this)">
              <div class="apav" style="background:linear-gradient(135deg,#7c3aed,#db2777)">RF</div>
              <div style="flex:1">
                <div style="font-size:13px;font-weight:600">Ramon A. Flores</div>
                <div style="font-size:11px;color:var(--t3)">Stall #11 · Vegetables · Awardee</div>
              </div>
            </div>
            <div class="apitem" onclick="pickAp(this)">
              <div class="apav" style="background:linear-gradient(135deg,#d97706,#f59e0b)">LV</div>
              <div style="flex:1">
                <div style="font-size:13px;font-weight:600">Luis T. Villanueva</div>
                <div style="font-size:11px;color:var(--t3)">Stall #25 · General · Awardee</div>
              </div>
            </div>
          </div>
        </div>
        <div class="frow">
          <div class="fg"><label class="fl">Contract Start *</label><input class="fc" type="date" value="2026-03-09" />
          </div>
          <div class="fg"><label class="fl">Duration *</label><select class="fc">
              <option>1 Year</option>
              <option>6 Months</option>
              <option>2 Years</option>
            </select></div>
        </div>
        <div class="trow">
          <div>
            <div style="font-size:12.5px;font-weight:600">Send login credentials via SMS & Email</div>
            <div style="font-size:11px;color:var(--t3);margin-top:2px">Auto-generated upon account creation</div>
          </div>
          <div class="sw on" onclick="this.classList.toggle('on')"></div>
        </div>
      </div>
      <div class="mft"><button class="btn gh sm" onclick="closeM('convertModal')">Cancel</button><button
          class="btn su sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <polyline points="17 1 21 5 17 9" />
            <path d="M3 11V9a4 4 0 0 1 4-4h14" />
          </svg>Convert to Vendor</button></div>
    </div>
  </div>

  <!-- EDIT VENDOR -->
  <div class="mbg" id="editModal">
    <div class="modal">
      <div class="mhd">
        <div class="mtit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)"
            stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>Edit Vendor Information</div>
        <div class="mx" onclick="closeM('editModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div class="sec-lbl">Personal Information</div>
        <div class="frow">
          <div class="fg"><label class="fl">First Name</label><input class="fc" id="ef-fn" /></div>
          <div class="fg"><label class="fl">Last Name</label><input class="fc" id="ef-ln" /></div>
        </div>
        <div class="frow">
          <div class="fg"><label class="fl">Contact Number</label><input class="fc" id="ef-ph" /></div>
          <div class="fg"><label class="fl">Email Address</label><input class="fc" id="ef-em" type="email" /></div>
        </div>
        <div class="frow full">
          <div class="fg"><label class="fl">Home Address</label><input class="fc" id="ef-ad" /></div>
        </div>
        <div class="sec-lbl">Stall Assignment</div>
        <div class="frow">
          <div class="fg"><label class="fl">Assigned Stall</label><select class="fc">
              <option>#01 — Wet Market</option>
              <option>#03 — Meat</option>
              <option>#06 — Dry Goods</option>
              <option>#07 — Dry Goods</option>
              <option>#11 — Vegetables</option>
            </select></div>
          <div class="fg"><label class="fl">Trade Type</label><select class="fc">
              <option>Wet Market</option>
              <option>Dry Goods</option>
              <option>Meat Section</option>
              <option>Vegetables</option>
              <option>Fish Section</option>
              <option>General</option>
            </select></div>
        </div>
        <div class="sec-lbl">Contract</div>
        <div class="frow">
          <div class="fg"><label class="fl">Contract Start</label><input class="fc" type="date" id="ef-cs" /></div>
          <div class="fg"><label class="fl">Contract End</label><input class="fc" type="date" id="ef-ce" /></div>
        </div>
        <div class="frow">
          <div class="fg"><label class="fl">Monthly Rate (₱)</label><input class="fc" type="number" id="ef-rate" />
          </div>
          <div class="fg"><label class="fl">Security Deposit (₱)</label><input class="fc" type="number" value="3000" />
          </div>
        </div>
      </div>
      <div class="mft"><button class="btn gh sm" onclick="closeM('editModal')">Cancel</button><button
          class="btn pr sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <polyline points="9 11 12 14 22 4" />
          </svg>Save Changes</button></div>
    </div>
  </div>

  <!-- STATUS MODAL -->
  <div class="mbg" id="statusModal">
    <div class="modal sm">
      <div class="mhd">
        <div class="mtit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)"
            stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>Change Vendor Status</div>
        <div class="mx" onclick="closeM('statusModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div style="font-size:12.5px;color:var(--t3);margin-bottom:16px">Updating status for: <strong id="sm-name"
            style="color:var(--t1)">—</strong></div>
        <div class="vsgrid">
          <div class="vsopt sg" onclick="pickSt(this,'sg')">
            <div class="vsem">✅</div>
            <div class="vslbl" style="color:var(--gr)">Active</div>
            <div class="vssub">Account fully operational</div>
          </div>
          <div class="vsopt" onclick="pickSt(this,'sa')">
            <div class="vsem">⏸️</div>
            <div class="vslbl" style="color:var(--am)">Suspended</div>
            <div class="vssub">Temporary access block</div>
          </div>
          <div class="vsopt" onclick="pickSt(this,'sr')">
            <div class="vsem">📋</div>
            <div class="vslbl" style="color:var(--rd)">Contract Expired</div>
            <div class="vssub">Renewal required</div>
          </div>
          <div class="vsopt" onclick="pickSt(this,'sv')">
            <div class="vsem">🚫</div>
            <div class="vslbl" style="color:var(--vi)">Terminated</div>
            <div class="vssub">Permanent removal</div>
          </div>
        </div>
        <div class="frow full" style="margin-top:14px;margin-bottom:0">
          <div class="fg"><label class="fl">Reason / Remarks</label><textarea class="fc" style="min-height:58px"
              placeholder="Reason for this status change…"></textarea></div>
        </div>
        <div class="trow"><span style="font-size:12.5px;font-weight:600">Notify vendor via SMS & Email</span>
          <div class="sw on" onclick="this.classList.toggle('on')"></div>
        </div>
      </div>
      <div class="mft"><button class="btn gh sm" onclick="closeM('statusModal')">Cancel</button><button
          class="btn pr sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <polyline points="9 11 12 14 22 4" />
          </svg>Update Status</button></div>
    </div>
  </div>

  <!-- CREDENTIALS MODAL -->
  <div class="mbg" id="credModal">
    <div class="modal sm">
      <div class="mhd">
        <div class="mtit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)"
            stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>Resend Login Credentials</div>
        <div class="mx" onclick="closeM('credModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <div class="chip a"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            <line x1="12" y1="9" x2="12" y2="13" />
          </svg>
          <div>A new temporary password will be generated. The previous password will be <strong>immediately
              invalidated</strong>.</div>
        </div>
        <div class="credbox">
          <div class="credtit">Credentials for <span id="cred-nm">—</span></div>
          <div class="credrow"><span class="credlbl">Username</span><span class="credval" id="cred-un">—</span>
            <div class="credcp tt" data-tip="Copy"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" />
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg></div>
          </div>
          <div class="credrow"><span class="credlbl">New Password</span><span class="credval">Ap@2026#xK9m</span>
            <div class="credcp tt" data-tip="Copy"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" />
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg></div>
          </div>
          <div class="credrow"><span class="credlbl">Portal</span><span class="credval">arkipaisi.gov.ph/vendor</span>
            <div class="credcp tt" data-tip="Copy"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" />
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg></div>
          </div>
        </div>
        <div class="trow">
          <div>
            <div style="font-size:12.5px;font-weight:600">Send via SMS & Email</div>
            <div style="font-size:11px;color:var(--t3);margin-top:2px" id="cred-contact">—</div>
          </div>
          <div class="sw on" onclick="this.classList.toggle('on')"></div>
        </div>
      </div>
      <div class="mft"><button class="btn gh sm" onclick="closeM('credModal')">Cancel</button><button
          class="btn pr sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <line x1="22" y1="2" x2="11" y2="13" />
            <polygon points="22 2 15 22 11 13 2 9 22 2" />
          </svg>Send Credentials</button></div>
    </div>
  </div>

  <script src="/js/admin/vendor-management.js"></script>
</body>

</html>