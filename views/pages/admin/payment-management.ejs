          <div style="margin-top:8px;display:grid;grid-template-columns:1fr 1fr;gap:8px">
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" width="12" height="12">
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.4 19.79 19.79 0 0 1 1.62 4.82a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.64 17z" />
              </svg>
              <span id="vc-phone"></span>
            </div>
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t2)">
