                stroke-width="2" width="12" height="12">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              <span id="vc-email" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></span>
            </div>
          </div>
        </div>
        <!-- hidden inputs for form use -->
        <input type="hidden" id="rec-vendor" />
        <input type="hidden" id="rec-stall" />
        <input type="hidden" id="rec-rate" />

        <!-- OR Details -->
        <div class="sec-lbl">Official Receipt (OR)</div>
        <div class="chip b">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
