<!DOCTYPE html>
<html lang="en" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARKIPAISI — Payment Management</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
    <link rel="stylesheet" href="/css/admin/payment-management.css">
</head>

<body>

  <!-- ═══ SIDEBAR ═══ -->
   <%- include("../../partials/sidebar.ejs", { currentRoute, role: "admin", initials: "admin", fullName: "joshua daliva"}) %>
   
   <!-- ═══ MAIN ═══ -->
   <div class="main" id="main">
    <%- include("../../partials/header.ejs", {role: "admin", initials: "admin", lastName: "daliva", }) %>

    <div class="content">

      <!-- Page Header -->
      <div class="pghdr">
        <div>
          <h1>Payment Management</h1>
          <p>Record rental payments, monitor collection status, and view vendor ledgers</p>
        </div>
        <div class="pg-acts">
          <button class="btn gh sm" onclick="openM('exportModal')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            <span class="btn-lbl">Export</span>
          </button>
          <button class="btn ao sm" onclick="openBulkReminder()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
              <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            </svg>
            <span class="btn-lbl">Send Reminders to All</span>
          </button>
          <button class="btn pr sm" onclick="openM('recordModal')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            <span class="btn-lbl">Record Payment</span>
          </button>
        </div>
      </div>

      <!-- Overdue Alert -->
      <div class="alert-bar">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
          <line x1="12" y1="9" x2="12" y2="13" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        <span class="alert-bar-txt">3 vendors have overdue payments — <span>₱11,000.00 total outstanding
            balance</span></span>
        <button class="btn ro xs" onclick="setSF2('overdue')">View Overdue</button>
      </div>

      <!-- Stats -->
      <div class="stats">
        <div class="sc cg">
          <div class="si g"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23" />
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg></div>
          <div>
            <div class="sv">₱87.4K</div>
            <div class="sl">March Collection</div>
          </div>
        </div>
        <div class="sc cb">
          <div class="si b"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <polyline points="9 11 12 14 22 4" />
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
            </svg></div>
          <div>
            <div class="sv">35</div>
            <div class="sl">Paid This Month</div>
          </div>
        </div>
        <div class="sc ca">
          <div class="si a"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg></div>
          <div>
            <div class="sv">4</div>
            <div class="sl">Pending</div>
          </div>
        </div>
        <div class="sc cr">
          <div class="si r"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            </svg></div>
          <div>
            <div class="sv">3</div>
            <div class="sl">Overdue</div>
          </div>
        </div>
        <div class="sc co">
          <div class="si o"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg></div>
          <div>
            <div class="sv">2</div>
            <div class="sl">Due Today</div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs" id="tabs">
        <button class="tab on" onclick="setTab('records',this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
          </svg>
          <span>Payment Records</span><span class="tab-cnt">42</span>
        </button>
        <button class="tab" onclick="setTab('ledger',this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
          </svg>
          <span>Vendor Ledger</span>
        </button>
        <button class="tab" onclick="setTab('summary',this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
          </svg>
          <span>Collection Summary</span>
        </button>
      </div>

      <!-- TAB: PAYMENT RECORDS -->
      <div id="tab-records">
        <div class="panel">
          <div class="ph">
            <div class="ph-t">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              </svg>
              Payment Records
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              <button class="btn gh sm" onclick="openM('exportModal')">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Export
              </button>
            </div>
          </div>
          <div class="fbar">
            <div class="fsrch">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
              <input id="psrch" placeholder="Search vendor, OR number, stall…" oninput="renderRecords()" />
            </div>
            <select class="fsel" id="pmethod" onchange="renderRecords()">
              <option value="">All Methods</option>
              <option value="portal">Vendor Portal</option>
              <option value="collector">Staff Collector</option>
              <option value="office">Direct Office</option>
            </select>
            <select class="fsel" id="pmonth" onchange="renderRecords()">
              <option value="">All Months</option>
              <option value="2026-03" selected>March 2026</option>
              <option value="2026-02">February 2026</option>
              <option value="2026-01">January 2026</option>
              <option value="2025-12">December 2025</option>
            </select>
            <div style="display:flex;gap:5px;flex-wrap:wrap" id="status-pills">
              <div class="sp s-all on" onclick="setSF2('all',this)">All</div>
              <div class="sp" style="color:var(--gr)" onclick="setSF2('paid',this)">Paid</div>
              <div class="sp" style="color:var(--am)" onclick="setSF2('pending',this)">Pending</div>
              <div class="sp" style="color:var(--or)" onclick="setSF2('due',this)">Due Today</div>
              <div class="sp" style="color:var(--rd)" onclick="setSF2('overdue',this)">Overdue</div>
              <div class="sp" style="color:var(--cy)" onclick="setSF2('review',this)">Under Review</div>
            </div>
          </div>
          <div class="tbl-wrap">
            <table class="ptbl" id="prec-tbl"></table>
          </div>
          <div class="tbl-foot">
            <div class="tbl-info" id="prec-info">—</div>
            <div class="pgr">
              <div class="pg"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6" />
                </svg></div>
              <div class="pg on">1</div>
              <div class="pg">2</div>
              <div class="pg">3</div>
              <div class="pg"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6" />
                </svg></div>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: MONTHLY RENTAL LIST -->
      <div id="tab-monthly" style="display:none">
        <div class="panel" style="margin-bottom:14px">
          <div class="ph">
            <div class="ph-t">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
              Monthly Rental Status — March 2026
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
              <select class="fsel" style="width:auto">
                <option>March 2026</option>
                <option>February 2026</option>
                <option>January 2026</option>
              </select>
              <button class="btn pr sm" onclick="openM('recordModal')">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Record Payment
              </button>
            </div>
          </div>
          <div style="display:flex;gap:0;border-bottom:1px solid var(--brd)">
            <div style="flex:1;padding:10px 16px;text-align:center;border-right:1px solid var(--brd)">
              <div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--gr)">35</div>
              <div style="font-size:10.5px;color:var(--t3);font-weight:600;margin-top:2px">Paid</div>
            </div>
            <div style="flex:1;padding:10px 16px;text-align:center;border-right:1px solid var(--brd)">
              <div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--am)">4</div>
              <div style="font-size:10.5px;color:var(--t3);font-weight:600;margin-top:2px">Pending</div>
            </div>
            <div style="flex:1;padding:10px 16px;text-align:center;border-right:1px solid var(--brd)">
              <div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--or)">2</div>
              <div style="font-size:10.5px;color:var(--t3);font-weight:600;margin-top:2px">Due Today</div>
            </div>
            <div style="flex:1;padding:10px 16px;text-align:center">
              <div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--rd)">3</div>
              <div style="font-size:10.5px;color:var(--t3);font-weight:600;margin-top:2px">Overdue</div>
            </div>
          </div>
        </div>
        <div class="mr-grid" id="mr-grid"></div>
      </div>

      <!-- TAB: VENDOR LEDGER -->
      <div id="tab-ledger" style="display:none">
        <!-- Search view -->
        <div id="ldgr-search">
          <div class="panel">
            <div class="ph">
              <div class="ph-t">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                </svg>
                Vendor Ledger
              </div>
            </div>
            <div class="fbar" style="border-bottom:none">
              <div class="fsrch" style="max-width:400px">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input id="lsrch" placeholder="Search vendor name or ID…" oninput="renderLedgerSearch()" />
              </div>
            </div>
            <div id="ldgr-list"
              style="padding:10px 14px;display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px">
            </div>
          </div>
        </div>
        <!-- Ledger detail view -->
        <div class="ldgr-detail" id="ldgr-detail">
          <div class="back-btn" onclick="closeLedger()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <polyline points="15 18 9 12 15 6" />
            </svg>
            Back to Vendor List
          </div>
          <div class="ldgr-info-grid" id="ldgr-info-grid"></div>
          <div class="panel">
            <div class="ph">
              <div class="ph-t">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                </svg>
                Payment History
              </div>
              <div style="display:flex;gap:8px;flex-wrap:wrap">
                <select class="fsel" style="width:auto">
                  <option>All Time</option>
                  <option>2026</option>
                  <option>2025</option>
                </select>
                <button class="btn gh sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="7 10 12 15 17 10" />
                    <line x1="12" y1="15" x2="12" y2="3" />
                  </svg>Export</button>
              </div>
            </div>
            <div class="tbl-wrap">
              <table class="ptbl" id="ldgr-tbl"></table>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: COLLECTION SUMMARY -->
      <div id="tab-summary" style="display:none">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px" id="summ-grid">
          <div class="panel">
            <div class="ph">
              <div class="ph-t"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>Monthly Collection (2026)</div>
            </div>
            <div class="chart-wrap">
              <div class="chart-bars" id="chart-bars"></div>
            </div>
            <div class="chart-legend">
              <div class="clg">
                <div class="clg-dot" style="background:var(--ac)"></div>Total Collection
              </div>
              <div class="clg">
                <div class="clg-dot" style="background:var(--grs)"></div>Paid
              </div>
              <div class="clg">
                <div class="clg-dot" style="background:var(--rds)"></div>Outstanding
              </div>
            </div>
          </div>
          <div class="panel">
            <div class="ph">
              <div class="ph-t"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>Payment Methods — March 2026</div>
            </div>
            <div style="padding:14px 16px;display:flex;flex-direction:column;gap:10px">
              <div style="display:flex;align-items:center;justify-content:space-between;font-size:13px">
                <div style="display:flex;align-items:center;gap:8px">
                  <div style="width:10px;height:10px;border-radius:50%;background:var(--ac)"></div><span>Vendor Portal
                    (Online)</span>
                </div>
                <div style="display:flex;align-items:center;gap:10px"><span class="mono"
                    style="font-weight:700">₱32,400</span><span style="font-size:11px;color:var(--t3)">37%</span></div>
              </div>
              <div style="height:8px;background:var(--brd);border-radius:4px;overflow:hidden">
                <div style="height:100%;width:37%;background:var(--ac);border-radius:4px"></div>
              </div>
              <div style="display:flex;align-items:center;justify-content:space-between;font-size:13px">
                <div style="display:flex;align-items:center;gap:8px">
                  <div style="width:10px;height:10px;border-radius:50%;background:var(--vi)"></div><span>Staff
                    Collector</span>
                </div>
                <div style="display:flex;align-items:center;gap:10px"><span class="mono"
                    style="font-weight:700">₱41,200</span><span style="font-size:11px;color:var(--t3)">47%</span></div>
              </div>
              <div style="height:8px;background:var(--brd);border-radius:4px;overflow:hidden">
                <div style="height:100%;width:47%;background:var(--vi);border-radius:4px"></div>
              </div>
              <div style="display:flex;align-items:center;justify-content:space-between;font-size:13px">
                <div style="display:flex;align-items:center;gap:8px">
                  <div style="width:10px;height:10px;border-radius:50%;background:var(--gr)"></div><span>Direct
                    Office</span>
                </div>
                <div style="display:flex;align-items:center;gap:10px"><span class="mono"
                    style="font-weight:700">₱13,800</span><span style="font-size:11px;color:var(--t3)">16%</span></div>
              </div>
              <div style="height:8px;background:var(--brd);border-radius:4px;overflow:hidden">
                <div style="height:100%;width:16%;background:var(--gr);border-radius:4px"></div>
              </div>
            </div>
            <div
              style="padding:12px 16px;border-top:1px solid var(--brd);background:var(--s2);display:flex;align-items:center;justify-content:space-between">
              <span
                style="font-size:11px;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.4px">Total
                Collected</span>
              <span
                style="font-size:17px;font-weight:800;font-family:'DM Mono',monospace;color:var(--gr)">₱87,400</span>
            </div>
          </div>
        </div>
        <div class="panel">
          <div class="ph">
            <div class="ph-t"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
              </svg>Top Outstanding Balances</div><button class="btn ro sm"><svg xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
              </svg>Send Reminders</button>
          </div>
          <div class="tbl-wrap">
            <table class="ptbl" id="out-tbl"></table>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->

  <!-- ══ MODALS ══ -->

  <!-- RECORD PAYMENT MODAL -->
  <div class="mbg" id="recordModal">
    <div class="modal">
      <div class="mhd">
        <div class="mtit">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2">
            <line x1="12" y1="1" x2="12" y2="23" />
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
          </svg>
          Record Payment
        </div>
        <div class="mx" onclick="closeM('recordModal')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg></div>
      </div>
      <div class="mbdy">
        <!-- Payment Method -->
        <div class="sec-lbl">Payment Method</div>
        <div
          style="display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--grl);border:1.5px solid var(--grs);border-radius:8px;margin-bottom:14px">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--gr)" stroke-width="2"
            width="20" height="20">
