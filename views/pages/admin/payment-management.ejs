              </svg>
              <input id="vsrch-input"
                style="border:none;background:transparent;outline:none;color:var(--t1);font-family:'DM Sans',sans-serif;font-size:13px;flex:1;width:0"
                placeholder="Type vendor name or stall number…" oninput="showVSugg(this.value)" autocomplete="off" />
