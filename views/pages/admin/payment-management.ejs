            <div>
              <div style="font-size:12.5px;font-weight:700">Send via SMS</div>
              <div style="font-size:11px;color:var(--t3);margin-top:1px">Text message to each vendor's phone</div>
            </div>
            <div class="sw on" id="bulk-sms" onclick="this.classList.toggle('on')"></div>
          </div>
          <div class="trow" style="margin-top:0">
            <div>
              <div style="font-size:12.5px;font-weight:700">Send via Email</div>
              <div style="font-size:11px;color:var(--t3);margin-top:1px">Email to each vendor's address</div>
            </div>
            <div class="sw on" id="bulk-email" onclick="this.classList.toggle('on')"></div>
          </div>
        </div>
        <!-- message template -->
        <div class="fg" style="margin-bottom:14px">
          <label class="fl">Message Template</label>
          <textarea class="fc" id="bulk-msg" style="min-height:80px">Dear [Vendor Name],

This is a reminder that your rental fee for Stall [Stall No.] is due. Please settle your balance of ₱[Amount] at your earliest convenience.

Thank you,
ARKIPAISI Market Office</textarea>
          <div style="font-size:10.5px;color:var(--t3);margin-top:4px">Placeholders [Vendor Name], [Stall No.], [Amount]
            will be replaced per vendor</div>
        </div>
        <!-- vendor list -->
        <div
          style="font-size:10.5px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px;display:flex;align-items:center;gap:8px">
          Recipients <span id="bulk-count-lbl"
            style="background:var(--ams);color:var(--am);padding:1px 7px;border-radius:10px;font-size:10px;font-weight:800">0</span>
        </div>
        <div id="bulk-vendor-list"
          style="display:flex;flex-direction:column;gap:6px;max-height:220px;overflow-y:auto;padding-right:2px"></div>
      </div>
      <div class="mft" style="justify-content:space-between">
        <span id="bulk-result"
          style="font-size:12px;color:var(--gr);font-weight:600;display:none;align-items:center;gap:6px">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            width="14" height="14">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          Reminders sent successfully!
        </span>
        <div style="display:flex;gap:8px;margin-left:auto">
          <button class="btn gh sm" onclick="closeM('bulkReminderModal')">Cancel</button>
          <button class="btn ao sm" onclick="sendBulkReminders()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13" />
              <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
            Send to All
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/admin/payment-management.js"></script>
</body>

</html>