          <div class="or-preview-row"><span class="or-preview-lbl">Amount</span><span class="or-preview-val"
              id="prev-amount" style="color:var(--gr)">—</span></div>
          <div class="or-preview-row"><span class="or-preview-lbl">Date</span><span class="or-preview-val"
              id="prev-date">—</span></div>
          <div class="or-preview-row"><span class="or-preview-lbl">Collected By</span><span class="or-preview-val"
              id="prev-collector">—</span></div>
        </div>

        <!-- OR Upload -->
        <div class="sec-lbl">OR Documentation (Optional)</div>
        <div class="upzone" onclick="fakeUpload()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
