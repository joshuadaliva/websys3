            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="17 8 12 3 7 8" />
            <line x1="12" y1="3" x2="12" y2="15" />
          </svg>
          <div class="upzone-txt"><strong>Click to upload</strong> or drag and drop OR image or PDF</div>
          <div style="font-size:11px;color:var(--t3);margin-top:4px">PNG, JPG, PDF up to 10MB</div>
        </div>
        <div id="ufile-slot"></div>
        <div class="trow">
          <div>
            <div style="font-size:12.5px;font-weight:600">Send payment confirmation to vendor</div>
            <div style="font-size:11px;color:var(--t3);margin-top:2px">Via SMS and Email</div>
          </div>
          <div class="sw on" onclick="this.classList.toggle('on')"></div>
        </div>
      </div>
      <div class="mft">
        <button class="btn gh sm" onclick="closeM('recordModal')">Cancel</button>
        <button class="btn pr sm" onclick="savePayment()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
