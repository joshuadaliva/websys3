        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <div style="font-size:13px;font-weight:500">${d.name}</div>
        <div style="font-size:11px">${d.size}</div>
      </div>
      <div class="img-card-body">
        <div class="id-field"><div class="id-field-label">Document</div><div class="id-field-val sm">${d.name}</div></div>
        <div class="id-field" style="margin-top:8px"><div class="id-field-label">Applicant</div><div class="id-field-val sm">Carla M. Bautista</div></div>
      </div>
    </div>`;
  }
  return `<div class="pdf-card">
    <div class="pdf-card-hdr">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <div><div class="ph-name">${d.name}</div><div class="ph-sub">${d.size}</div></div>
    </div>
    <div class="pdf-body">
      <div class="pdf-row"><span class="pdf-lbl">Issued To</span><span class="pdf-val">Carla M. Bautista</span></div>
      <div class="pdf-row"><span class="pdf-lbl">Address</span><span class="pdf-val">Brgy. Doon, Arkipaisi</span></div>
      <div class="pdf-row"><span class="pdf-lbl">Date Issued</span><span class="pdf-val">February 12, 2024</span></div>
      <div class="pdf-row"><span class="pdf-lbl">Valid Until</span><span class="pdf-val">February 12, 2025</span></div>
      <div class="pdf-gap"></div>
      <div class="pdf-line" style="width:100%"></div>
      <div class="pdf-line" style="width:75%"></div>
      <div class="pdf-line" style="width:100%"></div>
