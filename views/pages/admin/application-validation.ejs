<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Application Validation</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin/application-validation.css" />
</head>
<body>
  <main class="wrap">
    <div class="card">
      <div class="top">
        <div>
          <h1>Document Validation</h1>
          <p id="contextLine">Loading review context...</p>
        </div>
        <button class="btn ghost" onclick="window.close()">Close</button>
      </div>

      <div class="section">
        <h2>Step 1: Pre-Screening</h2>
        <p>Verify identity requirements then mark pass/fail.</p>
      </div>
      <div id="step1Docs" class="docs"></div>
      <div class="actions">
        <button class="btn danger" id="step1FailBtn">Fail Step 1</button>
        <button class="btn success" id="step1PassBtn">Pass Step 1</button>
      </div>

      <div class="section">
        <h2>Step 2: Qualification</h2>
        <p>Validate uploaded qualification documents.</p>
      </div>
      <div id="step2Docs" class="docs"></div>
      <div class="actions">
        <button class="btn danger" id="step2FailBtn">Fail Step 2</button>
        <button class="btn success" id="step2PassBtn">Pass Step 2</button>
      </div>

      <div class="section">
        <h2>Step 3: Final Decision</h2>
        <p>Finalize the application outcome.</p>
      </div>
      <div class="actions">
        <button class="btn danger" id="finalRejectBtn">Reject Application</button>
        <button class="btn success" id="finalApproveBtn">Approve Application</button>
      </div>
      <p class="note">All decisions sync back to Application Management table automatically.</p>
    </div>
  </main>

  <script src="/js/admin/application-validation.js"></script>
</body>
</html>
