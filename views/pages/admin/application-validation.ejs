<script>
/* ════ DATA ════ */
const docs = {
  1: [
    { id:'s1d0', name:'Valid ID (Front)',    kind:'id',  type:'IMG', size:'JPG · 1.2 MB', status:'pending' },
    { id:'s1d1', name:'Valid ID (Back)',     kind:'id',  type:'IMG', size:'JPG · 0.9 MB', status:'pending' },
    { id:'s1d2', name:'Proof of Residency', kind:'pdf', type:'PDF', size:'PDF · 2.1 MB', status:'pending' },
  ],
  2: [
    { id:'s2d0', name:'Business Permit',    kind:'pdf', type:'PDF', size:'PDF · 1.8 MB', status:'pending' },
    { id:'s2d1', name:'BIR Certificate',    kind:'pdf', type:'PDF', size:'PDF · 0.7 MB', status:'pending' },
    { id:'s2d2', name:'DTI Registration',   kind:'pdf', type:'PDF', size:'PDF · 1.1 MB', status:'pending' },
    { id:'s2d3', name:'Product Photos',     kind:'img', type:'IMG', size:'JPG · 3.4 MB', status:'pending' },
    { id:'s2d4', name:'Bank Statement',     kind:'pdf', type:'PDF', size:'PDF · 0.5 MB', status:'pending' },
  ]
};

let activeStep = null, activeIdx = null;
let sendVia = 'sms';
let step1Result = null; // 'pass' | 'fail'
let linkSent = false;

/* ════ ICONS ════ */
function svgIcon(kind) {
  if (kind==='id')  return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`;
  if (kind==='img') return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
  return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
}
function iconCls(kind) { return kind==='id'?'id-type':kind==='img'?'img-type':'pdf-type'; }
function cap(s) { return s.charAt(0).toUpperCase()+s.slice(1); }

/* ════ RENDER TABLES ════ */
function renderTable(step) {
  const tbody = document.getElementById('tbody'+step);
  tbody.innerHTML = docs[step].map((d,i)=>`
    <tr id="row_${d.id}">
      <td><div class="doc-file-row">
        <div class="doc-icon-sm ${iconCls(d.kind)}">${svgIcon(d.kind)}</div>
        <div><div class="doc-file-name">${d.name}</div><div class="doc-file-meta">${d.size}</div></div>
      </div></td>
      <td style="color:var(--text-muted);font-size:12px">${d.type}</td>
      <td style="color:var(--text-muted);font-size:12px">${d.size.split('·')[1]?.trim()||d.size}</td>
      <td><span class="doc-status-pill ${d.status}" id="pill_${d.id}">${cap(d.status)}</span></td>
      <td><button class="btn-view" onclick="openDocDialog(${step},${i})">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>View
      </button></td>
    </tr>`).join('');
}
renderTable(1);
renderTable(2);

/* ════ SMART BUTTON REFRESH ════ */
function refreshButtons(step) {
  const list = docs[step];
  const statuses = list.map(d=>d.status);
  const allReviewed = statuses.every(s=>s!=='pending');
  const anyRejected = statuses.some(s=>s==='rejected');
  const allApproved = statuses.every(s=>s==='approved');

  if (step === 1) {
    // Fail enables as soon as ANY doc is rejected
    document.getElementById('s1fail').disabled = !anyRejected;
    // Pass enables only when ALL are approved
    document.getElementById('s1pass').disabled = !allApproved;
  } else {
    document.getElementById('s2fail').disabled = !anyRejected;
    document.getElementById('s2pass').disabled = !allApproved;
  }
}

/* ════ TAB SWITCH ════ */
function switchTab(n) {
  [1,2,3,4].forEach(i=>{
    document.getElementById('tab'+i).classList.remove('active');
    document.getElementById('panel'+i).classList.remove('active');
  });
  document.getElementById('tab'+n).classList.add('active');
  document.getElementById('panel'+n).classList.add('active');
}

/* ════ SEND VIA TOGGLE ════ */
function selectVia(v) {
  sendVia = v;
  document.getElementById('viaSmS').classList.toggle('selected', v==='sms');
  document.getElementById('viaEmail').classList.toggle('selected', v==='email');
}

/* ════ SEND LINK ════ */
function sendLink() {
  if (linkSent) return;
  linkSent = true;

  // Mark tab 2 done
  const tab2 = document.getElementById('tab2');
  tab2.classList.add('done-pass');

  // Unlock tab 3, mark as pending
  const tab3 = document.getElementById('tab3');
  tab3.disabled = false;
  tab3.classList.add('tab-pending');

  // Show badge on tab3
  const b3 = document.getElementById('tab3badge');
  b3.style.display = 'inline-flex';
  b3.className = 'badge badge-yellow';
  b3.textContent = 'Pending';

  // Switch to qualification tab showing pending state
  switchTab(3);
  document.getElementById('qual-pending').style.display = 'flex';
  document.getElementById('qual-review').style.display  = 'none';

  // Show progress bar and start 5s countdown
  const wrap = document.getElementById('pendingProgressWrap');
  wrap.style.display = 'block';

  // After 5 seconds → transition to Under Review
  setTimeout(()=>{
    // Update tab 3 style
    tab3.classList.remove('tab-pending');
    tab3.classList.add('tab-review');
    b3.className = 'badge badge-blue';
    b3.textContent = 'Under Review';

    // Show review content
    document.getElementById('qual-pending').style.display = 'none';
    document.getElementById('qual-review').style.display  = 'block';
  }, 5000);
}

/* ════ OPEN DOC DIALOG ════ */
function openDocDialog(step, i) {
  const d = docs[step][i];
  activeStep = step; activeIdx = i;
  document.getElementById('dlgName').textContent = d.name;
  document.getElementById('dlgSub').textContent  = d.size + ' · Submitted by Carla M. Bautista';
  const icon = document.getElementById('dlgIcon');
  icon.className = 'dlg-doc-icon ' + iconCls(d.kind);
  icon.innerHTML = svgIcon(d.kind);
  document.getElementById('dlgPreview').innerHTML = buildPreview(d);
  updateDlgStatus(d.status);
  document.getElementById('overlay').classList.add('open');
}

function closeDocDialog() {
  document.getElementById('overlay').classList.remove('open');
  activeStep = activeIdx = null;
}
document.getElementById('overlay').addEventListener('click', e=>{ if(e.target===e.currentTarget) closeDocDialog(); });

function updateDlgStatus(s) {
  const el = document.getElementById('dlgStatus');
  el.textContent = cap(s);
  el.className = 'badge '+(s==='approved'?'badge-green':s==='rejected'?'badge-red':'badge-yellow');
}

function dialogDecide(decision) {
  if (activeStep===null) return;
  const d = docs[activeStep][activeIdx];
  d.status = decision;
  const pill = document.getElementById('pill_'+d.id);
  if (pill) { pill.className='doc-status-pill '+decision; pill.textContent=cap(decision); }
  updateDlgStatus(decision);
  refreshButtons(activeStep);
  setTimeout(closeDocDialog, 480);
}

/* ════ STEP PASS/FAIL ════ */
function setStep(step, result) {
  if (step === 1) {
    step1Result = result;
    const tab1 = document.getElementById('tab1');
    tab1.classList.remove('done-pass','done-fail');
    tab1.classList.add(result==='pass'?'done-pass':'done-fail');

    const sum1 = document.getElementById('sum1');
    if (result==='pass') {
      sum1.style.color='var(--success)'; sum1.textContent='Passed ✓';
      // Unlock step 2 (Send Link)
      document.getElementById('tab2').disabled = false;
      switchTab(2);
    } else {
      sum1.style.color='var(--danger)'; sum1.textContent='Failed ✗';
      // Block steps 2, 3, 4 — show fail state
      [2,3,4].forEach(i=>{ document.getElementById('tab'+i).disabled=true; });
      // Keep on current tab but show it's done
    }
  } else if (step === 2) {
    // This is qualification
    const tab3 = document.getElementById('tab3');
    tab3.classList.remove('tab-review','tab-pending','done-pass','done-fail');

    const sum2 = document.getElementById('sum2');
    if (result==='pass') {
      tab3.classList.add('done-pass');
      sum2.style.color='var(--success)'; sum2.textContent='Passed ✓';
      // Unlock Final Decision
      document.getElementById('tab4').disabled = false;
      switchTab(4);
    } else {
      tab3.classList.add('done-fail');
      sum2.style.color='var(--danger)'; sum2.textContent='Failed ✗';
    }
    // Hide badge
    document.getElementById('tab3badge').style.display='none';
  }
}

/* ════ FINAL DECISION ════ */
function finalDecision(decision) {
  const tab4    = document.getElementById('tab4');
  const badge   = document.getElementById('appBadge');
  const approve = document.getElementById('finalApprove');
  const reject  = document.getElementById('finalReject');
  tab4.classList.remove('done-pass','done-fail');

  if (decision==='approve') {
    tab4.classList.add('done-pass');
    badge.className='badge badge-green'; badge.textContent='Approved';
    approve.innerHTML=`<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Approved`;
    approve.style.cssText='background:var(--success);color:#fff;border-color:var(--success);';
    reject.disabled=true;
  } else {
    tab4.classList.add('done-fail');
    badge.className='badge badge-red'; badge.textContent='Rejected';
    reject.innerHTML=`<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>Rejected`;
    reject.style.cssText='background:var(--danger);color:#fff;border-color:var(--danger);';
    approve.disabled=true;
  }
}

