<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Document Validation — Stall #06</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root {
      --border:#e8eaf0; --border-light:#f0f2f7;
      --text-primary:#1a1d2e; --text-secondary:#6b7280; --text-muted:#9ca3af;
      --accent:#5b5ef6; --accent-light:#ededfd; --accent-hover:#4a4de0;
      --success:#16a34a; --success-bg:#f0fdf4; --success-border:#bbf7d0;
      --danger:#dc2626; --danger-bg:#fef2f2; --danger-border:#fecaca;
      --warning:#d97706; --warning-bg:#fffbeb; --warning-border:#fde68a;
      --blue:#2563eb; --blue-bg:#eff6ff; --blue-border:#bfdbfe;
      --gray-bg:#f5f6fa; --radius:12px; --radius-sm:8px;
    }
    html,body { font-family:'Poppins',sans-serif; background:#fff; color:var(--text-primary); height:100%; }
    .app-shell { display:flex; flex-direction:column; min-height:100vh; }

    /* ── TOP BAR ── */
    .top-bar { display:flex; align-items:center; justify-content:space-between; padding:13px 32px; border-bottom:1px solid var(--border); background:#fff; gap:12px; flex-shrink:0; }
    .top-bar h1 { font-size:16px; font-weight:700; letter-spacing:-.2px; }
    .top-title-row { display:flex; align-items:center; gap:10px; }
    .breadcrumb { font-size:12px; color:var(--text-muted); }
    .breadcrumb b { color:var(--text-secondary); font-weight:500; }

    /* ── BADGES ── */
    .badge { display:inline-flex; align-items:center; gap:5px; font-size:10.5px; font-weight:600; padding:2px 9px; border-radius:20px; text-transform:uppercase; letter-spacing:.3px; }
    .badge::before { content:''; width:5px; height:5px; border-radius:50%; background:currentColor; flex-shrink:0; }
    .badge-blue   { background:var(--blue-bg);      color:var(--blue);    border:1px solid var(--blue-border); }
    .badge-green  { background:var(--success-bg);   color:var(--success); border:1px solid var(--success-border); }
    .badge-yellow { background:var(--warning-bg);   color:var(--warning); border:1px solid var(--warning-border); }
    .badge-red    { background:var(--danger-bg);    color:var(--danger);  border:1px solid var(--danger-border); }
    .badge-purple { background:var(--accent-light); color:var(--accent);  border:1px solid #d0d0fb; }
    .badge-gray   { background:#f3f4f6; color:#6b7280; border:1px solid #e5e7eb; }
    .badge-orange { background:#fff7ed; color:#ea580c; border:1px solid #fed7aa; }

    .btn-icon { display:flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:8px; border:1px solid var(--border); background:#fff; cursor:pointer; color:var(--text-secondary); transition:all .14s; }
    .btn-icon:hover { background:var(--gray-bg); color:var(--text-primary); }

    /* ── APPLICANT BANNER ── */
    .appl-banner { display:flex; align-items:center; gap:16px; padding:14px 32px; border-bottom:1px solid var(--border); background:#fafbff; flex-shrink:0; }
    .avatar { width:40px; height:40px; border-radius:50%; background:var(--accent-light); color:var(--accent); font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; border:2px solid #d0d0fb; }
    .appl-info { flex:1; min-width:0; }
    .appl-name { font-size:14px; font-weight:700; }
    .appl-meta { font-size:12px; color:var(--text-secondary); margin-top:1px; }
    .appl-contacts { display:flex; gap:14px; flex-wrap:wrap; margin-top:5px; }
    .ci { display:flex; align-items:center; gap:4px; font-size:11.5px; color:var(--text-secondary); }
    .ci svg { opacity:.55; flex-shrink:0; }
    .stall-pill { display:flex; align-items:center; gap:10px; background:var(--accent-light); border:1px solid #d0d0fb; border-radius:10px; padding:8px 14px; flex-shrink:0; }
    .stall-num { font-size:20px; font-weight:800; color:var(--accent); letter-spacing:-.5px; }
    .stall-sub { font-size:11px; color:var(--text-secondary); line-height:1.5; }

    /* ── STEP TABS ── */
    .step-tabs-bar { display:flex; align-items:stretch; padding:0 32px; border-bottom:1px solid var(--border); background:#fff; flex-shrink:0; overflow-x:auto; }
    .step-tab-btn { display:flex; align-items:center; gap:8px; padding:13px 18px; font-family:inherit; font-size:13px; font-weight:500; background:none; border:none; border-bottom:2.5px solid transparent; cursor:pointer; color:var(--text-muted); white-space:nowrap; transition:all .16s; }
    .step-tab-btn:disabled { opacity:.38; pointer-events:none; }
    .step-tab-btn:not(:disabled):not(.active):hover { color:var(--text-secondary); background:var(--gray-bg); }
    .step-tab-btn.active { color:var(--accent); font-weight:600; border-bottom-color:var(--accent); }
    .step-tab-btn.done-pass  { color:var(--success); }
    .step-tab-btn.done-pass.active { border-bottom-color:var(--success); }
    .step-tab-btn.done-fail  { color:var(--danger); }
    .step-tab-btn.done-fail.active  { border-bottom-color:var(--danger); }
    .step-tab-btn.tab-pending { color:var(--warning); }
    .step-tab-btn.tab-pending.active { border-bottom-color:var(--warning); }
    .step-tab-btn.tab-review { color:var(--blue); }
    .step-tab-btn.tab-review.active { border-bottom-color:var(--blue); }

    .tab-num { width:21px; height:21px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; flex-shrink:0; background:#f0f1f5; color:var(--text-muted); border:1.5px solid var(--border); transition:all .16s; }
    .step-tab-btn.active .tab-num         { background:var(--accent);    color:#fff; border-color:var(--accent); }
    .step-tab-btn.done-pass .tab-num      { background:var(--success-bg); color:var(--success); border-color:var(--success-border); }
    .step-tab-btn.done-pass.active .tab-num { background:var(--success);  color:#fff; }
    .step-tab-btn.done-fail .tab-num      { background:var(--danger-bg);  color:var(--danger);  border-color:var(--danger-border); }
    .step-tab-btn.done-fail.active .tab-num { background:var(--danger);   color:#fff; }
    .step-tab-btn.tab-pending .tab-num    { background:var(--warning-bg); color:var(--warning); border-color:var(--warning-border); }
    .step-tab-btn.tab-review .tab-num     { background:var(--blue-bg);    color:var(--blue);    border-color:var(--blue-border); }

    .tab-sep { display:flex; align-items:center; color:#d1d5db; font-size:16px; padding:0 2px; user-select:none; }

    /* ── PANELS ── */
    .panels-area { flex:1; overflow-y:auto; }
    .tab-panel { display:none; }
    .tab-panel.active { display:flex; flex-direction:column; }
    .panel-body { flex:1; padding:24px 32px; }
    .section-title { font-size:11.5px; font-weight:600; text-transform:uppercase; letter-spacing:.6px; color:var(--text-muted); margin-bottom:14px; }

    /* ── DOC TABLE ── */
    .doc-table-wrap { border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
    .doc-table { width:100%; border-collapse:collapse; }
    .doc-table thead tr { background:var(--gray-bg); border-bottom:1px solid var(--border); }
    .doc-table th { padding:10px 16px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.5px; color:var(--text-muted); text-align:left; }
    .doc-table td { padding:13px 16px; font-size:13px; border-bottom:1px solid var(--border-light); vertical-align:middle; }
    .doc-table tbody tr:last-child td { border-bottom:none; }
    .doc-table tbody tr:hover { background:#fafbff; }
    .doc-file-row { display:flex; align-items:center; gap:10px; }
    .doc-icon-sm { width:34px; height:34px; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .doc-icon-sm.id-type  { background:var(--blue-bg);   color:var(--blue); }
    .doc-icon-sm.img-type { background:#fff0f9;           color:#db2777; }
    .doc-icon-sm.pdf-type { background:var(--danger-bg);  color:var(--danger); }
    .doc-file-name { font-size:13px; font-weight:600; }
    .doc-file-meta { font-size:11px; color:var(--text-muted); margin-top:1px; }

    .doc-status-pill { display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.3px; padding:3px 9px; border-radius:20px; }
    .doc-status-pill::before { content:''; width:5px; height:5px; border-radius:50%; background:currentColor; }
    .doc-status-pill.pending  { background:var(--warning-bg); color:var(--warning); border:1px solid var(--warning-border); }
    .doc-status-pill.approved { background:var(--success-bg); color:var(--success); border:1px solid var(--success-border); }
    .doc-status-pill.rejected { background:var(--danger-bg);  color:var(--danger);  border:1px solid var(--danger-border); }

    .btn-view { display:inline-flex; align-items:center; gap:5px; padding:6px 13px; border-radius:6px; font-family:inherit; font-size:12px; font-weight:500; cursor:pointer; border:1px solid var(--border); background:#fff; color:var(--accent); transition:all .13s; }
    .btn-view:hover { background:var(--accent-light); border-color:#d0d0fb; }

    /* ── ACTION BAR ── */
    .action-bar { display:flex; align-items:center; justify-content:space-between; padding:14px 32px; border-top:1px solid var(--border); background:#fff; gap:12px; flex-wrap:wrap; flex-shrink:0; }
    .action-note { font-size:12px; color:var(--text-muted); display:flex; align-items:center; gap:6px; }
    .action-btns { display:flex; gap:8px; }

    /* ── BUTTONS ── */
    .btn { display:inline-flex; align-items:center; gap:6px; padding:9px 20px; border-radius:var(--radius-sm); font-family:inherit; font-size:13px; font-weight:600; cursor:pointer; border:1.5px solid transparent; transition:all .15s; white-space:nowrap; }
    .btn:disabled { opacity:.35; pointer-events:none; }
    .btn-danger  { background:var(--danger-bg);  color:var(--danger);  border-color:var(--danger-border); }
    .btn-danger:not(:disabled):hover  { background:var(--danger);  color:#fff; }
    .btn-success { background:var(--success-bg); color:var(--success); border-color:var(--success-border); }
    .btn-success:not(:disabled):hover { background:var(--success); color:#fff; }
    .btn-primary { background:var(--accent); color:#fff; border-color:var(--accent); }
    .btn-primary:not(:disabled):hover { background:var(--accent-hover); }
    .btn-outline { background:#fff; color:var(--text-secondary); border-color:var(--border); }
    .btn-outline:not(:disabled):hover { background:var(--gray-bg); }
    .btn-blue { background:var(--blue-bg); color:var(--blue); border-color:var(--blue-border); }
    .btn-blue:not(:disabled):hover { background:var(--blue); color:#fff; }
    .btn-sm { padding:7px 14px; font-size:12.5px; }

    /* ── PANEL 2: SEND LINK ── */
    .slc-body  { padding:0; }

    .info-banner { display:flex; align-items:flex-start; gap:10px; background:var(--blue-bg); border:1px solid var(--blue-border); border-radius:9px; padding:11px 14px; margin-bottom:18px; font-size:12.5px; color:var(--blue); line-height:1.5; }
    .info-banner svg { flex-shrink:0; margin-top:1px; }
    .info-banner b { font-weight:700; }

    .form-field { margin-bottom:14px; }
    .form-label { font-size:12px; font-weight:600; color:var(--text-secondary); margin-bottom:6px; display:block; }
    .form-input { width:100%; padding:9px 13px; border:1px solid var(--border); border-radius:var(--radius-sm); font-family:inherit; font-size:13px; color:var(--text-primary); background:var(--gray-bg); outline:none; transition:border-color .14s; }
    .form-input:focus { border-color:var(--accent); background:#fff; }

    .send-via-row { display:flex; gap:10px; margin-bottom:14px; }
    .send-via-btn { flex:1; display:flex; align-items:center; justify-content:center; gap:8px; padding:10px; border-radius:var(--radius-sm); border:1.5px solid var(--border); background:#fff; font-family:inherit; font-size:13px; font-weight:500; cursor:pointer; color:var(--text-secondary); transition:all .14s; }
    .send-via-btn.selected { border-color:var(--accent); background:var(--accent-light); color:var(--accent); font-weight:600; }
    .send-via-btn:not(.selected):hover { border-color:#c4c4fb; background:#f8f8ff; }

    .link-preview-box { background:var(--gray-bg); border:1px solid var(--border); border-radius:var(--radius-sm); padding:12px 14px; margin-bottom:14px; }
    .link-preview-label { font-size:10.5px; font-weight:600; text-transform:uppercase; letter-spacing:.5px; color:var(--text-muted); margin-bottom:7px; }
    .link-url-row { display:flex; align-items:center; gap:8px; }
    .link-url-row svg { color:var(--text-muted); flex-shrink:0; }
    .link-url { font-size:12.5px; color:var(--text-primary); font-family:monospace; word-break:break-all; }
    .link-url b { color:var(--accent); }
    .link-badges { display:flex; gap:6px; margin-top:7px; }
    .link-badge-https { display:inline-flex; align-items:center; gap:4px; font-size:11px; font-weight:600; color:var(--success); background:var(--success-bg); border:1px solid var(--success-border); border-radius:5px; padding:2px 7px; }
    .link-badge-exp   { display:inline-flex; align-items:center; gap:4px; font-size:11px; font-weight:600; color:var(--warning); background:var(--warning-bg); border:1px solid var(--warning-border); border-radius:5px; padding:2px 7px; }

    .expiry-warning { display:flex; align-items:center; gap:8px; background:var(--warning-bg); border:1px solid var(--warning-border); border-radius:8px; padding:9px 13px; margin-bottom:16px; font-size:12.5px; color:var(--warning); font-weight:500; }

    .req-docs-section { margin-bottom:18px; }
    .req-docs-label { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.6px; color:var(--text-muted); margin-bottom:9px; }
    .req-doc-row { display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:7px; border:1px solid var(--border); margin-bottom:6px; background:#fff; font-size:13px; color:var(--text-primary); }
    .req-doc-row:last-child { margin-bottom:0; }
    .req-doc-row svg { color:var(--accent); flex-shrink:0; opacity:.7; }

    .add-note-label { font-size:12.5px; font-weight:600; color:var(--text-primary); margin-bottom:7px; }
    textarea.add-note { width:100%; height:72px; border:1px solid var(--border); border-radius:var(--radius-sm); padding:9px 13px; font-family:inherit; font-size:13px; color:var(--text-primary); background:var(--gray-bg); resize:vertical; outline:none; transition:border-color .14s; }
    textarea.add-note:focus { border-color:var(--accent); background:#fff; }

    .slc-footer { padding:16px 22px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; gap:8px; }

    /* ── QUALIFICATION PENDING STATE ── */
    .qual-pending-state { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:48px 32px; gap:16px; text-align:center; }
    .qual-pending-icon { width:64px; height:64px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:4px; }
    .qual-pending-icon.pending-style { background:var(--warning-bg); color:var(--warning); }
    .qual-pending-icon.review-style  { background:var(--blue-bg);    color:var(--blue); }
    .qual-pending-title { font-size:17px; font-weight:700; }
    .qual-pending-desc  { font-size:13px; color:var(--text-secondary); max-width:380px; line-height:1.6; }
    .progress-bar-wrap { width:100%; max-width:320px; height:6px; background:var(--border); border-radius:10px; overflow:hidden; }
    .progress-bar-fill { height:100%; border-radius:10px; background:var(--blue); transition:width .3s; animation:prog 5s linear forwards; }
    @keyframes prog { from{width:0%} to{width:100%} }

    /* ── FINAL PANEL ── */
    .final-summary { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:20px; }
    .sum-item { padding:14px; border-radius:var(--radius-sm); border:1px solid var(--border); text-align:center; }
    .sum-label { font-size:10.5px; text-transform:uppercase; letter-spacing:.5px; font-weight:600; color:var(--text-muted); margin-bottom:5px; }
    .sum-val   { font-size:14px; font-weight:700; }
    .remarks-label { font-size:13px; font-weight:600; margin-bottom:7px; }
    textarea.remarks { width:100%; height:84px; border:1px solid var(--border); border-radius:var(--radius-sm); padding:10px 14px; font-family:inherit; font-size:13px; color:var(--text-primary); background:var(--gray-bg); resize:vertical; outline:none; transition:border-color .14s; }
    textarea.remarks:focus { border-color:var(--accent); background:#fff; }
    .footer-note { display:flex; align-items:center; gap:8px; font-size:12px; color:var(--text-muted); background:var(--blue-bg); border:1px solid var(--blue-border); border-radius:var(--radius-sm); padding:10px 14px; margin-top:16px; }

    /* ── FAILED BLOCKER STATE ── */
    .step-blocked { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:48px 32px; gap:12px; text-align:center; }
    .blocked-icon { width:60px; height:60px; border-radius:50%; background:var(--danger-bg); color:var(--danger); display:flex; align-items:center; justify-content:center; margin-bottom:4px; }
    .blocked-title { font-size:16px; font-weight:700; color:var(--danger); }
    .blocked-desc  { font-size:13px; color:var(--text-secondary); max-width:360px; line-height:1.6; }

    /* ═══════════════════════════════
       DOCUMENT VIEWER DIALOG
    ═══════════════════════════════ */
    .overlay { display:none; position:fixed; inset:0; background:rgba(15,17,30,.48); backdrop-filter:blur(4px); z-index:1000; align-items:center; justify-content:center; padding:24px; }
    .overlay.open { display:flex; }
    .dialog { background:#fff; border-radius:16px; width:100%; max-width:620px; box-shadow:0 24px 64px rgba(0,0,0,.18); overflow:hidden; display:flex; flex-direction:column; max-height:calc(100vh - 48px); animation:dlgIn .2s ease; }
    @keyframes dlgIn { from{opacity:0;transform:translateY(14px) scale(.98)} to{opacity:1;transform:none} }
    .dlg-header { display:flex; align-items:center; justify-content:space-between; padding:18px 22px; border-bottom:1px solid var(--border); gap:12px; }
    .dlg-header-left { display:flex; align-items:center; gap:12px; }
    .dlg-doc-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .dlg-title { font-size:15px; font-weight:700; }
    .dlg-sub   { font-size:12px; color:var(--text-muted); margin-top:2px; }
    .dlg-preview { flex:1; overflow-y:auto; background:#f7f8fc; display:flex; align-items:flex-start; justify-content:center; min-height:280px; padding:28px 24px; }
    .dlg-footer { padding:14px 22px; border-top:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap; }
    .dlg-status-row { display:flex; align-items:center; gap:8px; }
    .dlg-status-label { font-size:12px; color:var(--text-muted); font-weight:500; }
    .dlg-btns { display:flex; gap:8px; }

    /* ── ID / PDF / IMG mocks ── */
    .id-card { background:#fff; border-radius:14px; box-shadow:0 6px 28px rgba(0,0,0,.11); overflow:hidden; width:100%; max-width:460px; }
    .id-card-hdr { background:linear-gradient(135deg,#5b5ef6 0%,#818cf8 100%); padding:16px 20px; color:#fff; display:flex; align-items:center; justify-content:space-between; }
    .id-hdr-title { font-size:13px; font-weight:700; letter-spacing:.3px; }
    .id-hdr-sub   { font-size:11px; opacity:.8; margin-top:2px; }
    .id-seal { width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; font-size:20px; }
    .id-body { padding:20px; }
    .id-photo-row { display:flex; gap:16px; margin-bottom:16px; }
    .id-photo { width:72px; height:86px; border-radius:8px; background:var(--gray-bg); border:2px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--text-muted); flex-shrink:0; }
    .id-fields { flex:1; }
    .id-field { margin-bottom:9px; }
    .id-field-label { font-size:9.5px; text-transform:uppercase; letter-spacing:.5px; font-weight:600; color:var(--text-muted); }
    .id-field-val   { font-size:14px; font-weight:700; margin-top:1px; }
    .id-field-val.sm { font-size:12.5px; font-weight:500; }
    .id-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px; }
    .id-divider { border:none; border-top:1px solid var(--border); margin:12px 0; }
    .id-barcode { display:flex; gap:2px; justify-content:center; margin-top:14px; }
    .id-bar { width:2px; border-radius:1px; background:var(--text-primary); }

    .pdf-card { background:#fff; border-radius:14px; box-shadow:0 6px 28px rgba(0,0,0,.11); overflow:hidden; width:100%; max-width:460px; }
    .pdf-card-hdr { background:var(--danger); padding:14px 20px; display:flex; align-items:center; gap:10px; }
    .ph-name { color:#fff; font-size:13px; font-weight:700; }
    .ph-sub  { color:rgba(255,255,255,.75); font-size:11px; margin-top:2px; }
    .pdf-body { padding:20px; }
    .pdf-row  { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
    .pdf-lbl  { font-size:10.5px; text-transform:uppercase; letter-spacing:.5px; font-weight:600; color:var(--text-muted); }
