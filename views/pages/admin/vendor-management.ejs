<!DOCTYPE html>
<html lang="en" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARKIPAISI — Vendor Management</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin/vendor-management.css">
</head>

<body>

  <%- include("../../partials/sidebar.ejs" , { currentRoute, role: "admin", initials: "admin", fullName: "joshua daliva"}) %>

  <div class="main" id="main">
    <%- include("../../partials/header.ejs", {role: "admin", initials: "admin", lastName: "daliva", }) %>

    <div class="content">

      <!-- Page Header -->
      <div class="pghdr">
        <div>
          <h1>Vendor Management</h1>
          <p>Manage approved vendors, stall assignments, contracts, and portal access</p>
        </div>
        <div class="pg-acts">
          <button class="btn btn-ghost btn-sm" onclick="openConvertModal()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="17 1 21 5 17 9" />
              <path d="M3 11V9a4 4 0 0 1 4-4h14" />
              <polyline points="7 23 3 19 7 15" />
              <path d="M21 13v2a4 4 0 0 1-4 4H3" />
            </svg>
            <span class="btn-lbl">Convert Applicant</span>
          </button>
          <button class="btn btn-primary btn-sm" onclick="openCreateModal()">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="8.5" cy="7" r="4" />
              <line x1="20" y1="8" x2="20" y2="14" />
              <line x1="23" y1="11" x2="17" y2="11" />
            </svg>
            <span class="btn-lbl">Create Vendor</span>
          </button>
        </div>
      </div>

      <!-- Stats — server-rendered counts -->
      <div class="stats">
        <div class="stat-card">
          <div class="stat-icon stat-icon-neutral">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= stats.total %></div>
            <div class="stat-label">Total Vendors</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon stat-icon-active">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 11 12 14 22 4" />
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= stats.active %></div>
            <div class="stat-label">Active</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon stat-icon-suspended">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <line x1="10" y1="15" x2="10" y2="9" />
              <line x1="14" y1="15" x2="14" y2="9" />
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= stats.suspended %></div>
            <div class="stat-label">Suspended</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon stat-icon-expired">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= stats.expired %></div>
            <div class="stat-label">Expired</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon stat-icon-terminated">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <line x1="17" y1="11" x2="23" y2="17" />
              <line x1="23" y1="11" x2="17" y2="17" />
            </svg>
          </div>
          <div>
            <div class="stat-value"><%= stats.terminated %></div>
            <div class="stat-label">Terminated</div>
          </div>
        </div>
      </div>

      <!-- Two-column layout -->
      <div class="layout">
        <!-- LEFT: Vendor List -->
        <div>
          <div class="panel">
            <div class="panel-header">
              <div class="panel-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="8" y1="6" x2="21" y2="6" />
                  <line x1="8" y1="12" x2="21" y2="12" />
                  <line x1="8" y1="18" x2="21" y2="18" />
                  <line x1="3" y1="6" x2="3.01" y2="6" />
                </svg>
                Vendor List
              </div>
              <div class="panel-header-actions">
                <div class="view-toggle-group">
                  <button class="view-btn active" id="vb-card" onclick="setView('card', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="7" height="7" />
                      <rect x="14" y="3" width="7" height="7" />
                      <rect x="3" y="14" width="7" height="7" />
                      <rect x="14" y="14" width="7" height="7" />
                    </svg>Cards
                  </button>
                  <button class="view-btn" id="vb-table" onclick="setView('table', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="8" y1="6" x2="21" y2="6" />
                      <line x1="8" y1="12" x2="21" y2="12" />
                      <line x1="8" y1="18" x2="21" y2="18" />
                    </svg>Table
                  </button>
                </div>
                <button class="btn btn-ghost btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="7 10 12 15 17 10" />
                    <line x1="12" y1="15" x2="12" y2="3" />
                  </svg>Export
                </button>
              </div>
            </div>

            <!-- Filters -->
            <div class="filter-bar">
              <div class="filter-search">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input id="vsrch" placeholder="Search name, stall, contact…" oninput="renderView()" />
              </div>
              <select class="filter-select" id="vtype" onchange="renderView()">
                <option value="">All Types</option>
                <option>Wet Market</option>
                <option>Dry Goods</option>
                <option>Meat Section</option>
                <option>Vegetables</option>
                <option>Fish Section</option>
                <option>General</option>
              </select>
              <div class="status-pills">
                <button class="pill pill-all active" onclick="setSF('all', this)">All</button>
                <button class="pill pill-active" onclick="setSF('active', this)">Active</button>
                <button class="pill pill-suspended" onclick="setSF('suspended', this)">Suspended</button>
                <button class="pill pill-expired" onclick="setSF('expired', this)">Expired</button>
                <button class="pill pill-terminated" onclick="setSF('terminated', this)">Terminated</button>
              </div>
            </div>

            <!-- Cards view — rendered by JS with injected vendor data -->
            <div class="vendor-grid" id="vgrid"></div>

            <!-- Table view — structure in EJS, rows rendered by JS -->
            <div id="vtbl-container" style="display:none">
              <div class="table-wrapper">
                <table class="vendor-table">
                  <thead>
                    <tr>
                      <th><div class="chk"></div></th>
                      <th>Vendor</th>
                      <th>Stall</th>
                      <th>Type</th>
                      <th>Contact</th>
                      <th>Contract End</th>
                      <th>Status</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody id="vtbl-body"></tbody>
                </table>
              </div>
              <div class="table-footer">
                <span class="table-footer-info" id="tbl-info">—</span>
                <div class="pagination" id="pgr-wrap"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Profile Column -->
        <div class="profile-col" id="rpcol">
          <div class="panel">
            <div class="empty-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
              <p>Select a vendor to view their profile, contract details, and account information</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ MODALS ══ -->

  <!-- CREATE VENDOR -->
  <div class="modal-backdrop" id="createModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="8.5" cy="7" r="4" />
            <line x1="20" y1="8" x2="20" y2="14" />
            <line x1="23" y1="11" x2="17" y2="11" />
          </svg>
          Create Vendor Account
        </div>
        <button class="modal-close" onclick="closeModal('createModal')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="stepper">
          <div class="stepper-step active" id="st1"><div class="step-dot">1</div><span>Vendor Info</span></div>
          <div class="stepper-line" id="sl1"></div>
          <div class="stepper-step" id="st2"><div class="step-dot">2</div><span>Stall & Contract</span></div>
          <div class="stepper-line" id="sl2"></div>
          <div class="stepper-step" id="st3"><div class="step-dot">3</div><span>Credentials</span></div>
        </div>

        <!-- Step 1 -->
        <div id="cs1">
          <div class="form-section-label">Personal Information</div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">First Name *</label><input class="form-control" placeholder="e.g. Juan" /></div>
            <div class="form-group"><label class="form-label">Last Name *</label><input class="form-control" placeholder="e.g. Dela Cruz" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Middle Name</label><input class="form-control" placeholder="Optional" /></div>
            <div class="form-group"><label class="form-label">Gender</label>
              <select class="form-control">
                <option>Male</option>
                <option>Female</option>
                <option>Prefer not to say</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Contact Number *</label><input class="form-control" placeholder="+63 9XX XXX XXXX" /></div>
            <div class="form-group"><label class="form-label">Email Address *</label><input class="form-control" type="email" placeholder="email@example.com" /></div>
          </div>
          <div class="form-row form-row-full">
            <div class="form-group"><label class="form-label">Home Address *</label><input class="form-control" placeholder="Barangay, Municipality/City" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Date of Birth</label><input class="form-control" type="date" /></div>
            <div class="form-group"><label class="form-label">Valid ID Type</label>
              <select class="form-control">
                <option>PhilHealth</option>
                <option>SSS</option>
                <option>Passport</option>
                <option>Voter's ID</option>
                <option>Driver's License</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div id="cs2" style="display:none">
          <div class="form-section-label">Stall Assignment</div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Assigned Stall *</label>
              <select class="form-control">
                <option value="">Select stall…</option>
                <option>#06 — Dry Goods</option>
                <option>#11 — Vegetables</option>
                <option>#22 — General</option>
                <option>#25 — General</option>
              </select>
            </div>
            <div class="form-group"><label class="form-label">Trade Type *</label>
              <select class="form-control">
                <option>Wet Market</option>
                <option>Dry Goods</option>
                <option>Meat Section</option>
                <option>Vegetables</option>
                <option>Fish Section</option>
                <option>General</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Monthly Rate (₱) *</label><input class="form-control" type="number" placeholder="e.g. 1500" /></div>
            <div class="form-group"><label class="form-label">Assignment Date</label><input class="form-control" type="date" /></div>
          </div>
          <div class="form-section-label" style="margin-top:2px">Contract Details</div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Contract Start *</label><input class="form-control" type="date" /></div>
            <div class="form-group"><label class="form-label">Contract Duration *</label>
              <select class="form-control">
                <option>1 Year</option>
                <option>6 Months</option>
                <option>2 Years</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">Security Deposit (₱)</label><input class="form-control" type="number" value="3000" /></div>
          </div>
        </div>

        <!-- Step 3 -->
        <div id="cs3" style="display:none">
          <div class="cred-box">
            <div class="cred-title">Auto-Generated Login Credentials</div>
            <div class="cred-row"><span class="cred-label">Username</span><span class="cred-value">jdelacruz.stall06</span>
              <button class="cred-copy tooltip" data-tip="Copy">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
              </button>
            </div>
            <div class="cred-row"><span class="cred-label">Password</span><span class="cred-value">Ap@2026#xK9m</span>
              <button class="cred-copy tooltip" data-tip="Copy">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
              </button>
            </div>
            <div class="cred-row"><span class="cred-label">Portal URL</span><span class="cred-value">arkipaisi.gov.ph/vendor</span>
              <button class="cred-copy tooltip" data-tip="Copy">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
              </button>
            </div>
          </div>
          <div class="toggle-row">
            <div>
              <div style="font-size:12.5px;font-weight:600">Send credentials via SMS & Email</div>
              <div style="font-size:11px;color:var(--t3);margin-top:2px">To registered contact and email on file</div>
            </div>
            <div class="toggle active" onclick="this.classList.toggle('active')"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer" id="create-modal-footer">
        <button class="btn btn-ghost btn-sm" onclick="closeModal('createModal')">Cancel</button>
        <button class="btn btn-primary btn-sm" onclick="nextStep()">Next
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- CONVERT APPLICANT -->
  <div class="modal-backdrop" id="convertModal">
    <div class="modal modal-sm">
      <div class="modal-header">
        <div class="modal-title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--status-active)" stroke-width="2">
            <polyline points="17 1 21 5 17 9" />
            <path d="M3 11V9a4 4 0 0 1 4-4h14" />
            <polyline points="7 23 3 19 7 15" />
            <path d="M21 13v2a4 4 0 0 1-4 4H3" />
          </svg>
          Convert Applicant to Vendor
        </div>
        <button class="modal-close" onclick="closeModal('convertModal')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="info-chip info-chip-blue">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
          <div>Select a stall awardee to convert. Their application data will be pre-filled automatically.</div>
        </div>
        <div class="form-group" style="margin-bottom:14px">
          <label class="form-label">Select Stall Awardee *</label>
          <div class="applicant-list">
            <div class="applicant-item selected" onclick="pickApplicant(this)">
              <div class="applicant-avatar" style="background:linear-gradient(135deg,#3b82f6,#6366f1)">CB</div>
              <div style="flex:1"><div style="font-size:13px;font-weight:600">Carla M. Bautista</div><div style="font-size:11px;color:var(--t3)">Stall #06 · Dry Goods · Awardee</div></div>
              <svg class="applicant-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2.5" width="16" height="16"><polyline points="20 6 9 17 4 12" /></svg>
            </div>
            <div class="applicant-item" onclick="pickApplicant(this)">
              <div class="applicant-avatar" style="background:linear-gradient(135deg,#0f766e,#0891b2)">NE</div>
              <div style="flex:1"><div style="font-size:13px;font-weight:600">Nena E. Estrada</div><div style="font-size:11px;color:var(--t3)">Stall #22 · General · Awardee</div></div>
            </div>
            <div class="applicant-item" onclick="pickApplicant(this)">
              <div class="applicant-avatar" style="background:linear-gradient(135deg,#7c3aed,#db2777)">RF</div>
              <div style="flex:1"><div style="font-size:13px;font-weight:600">Ramon A. Flores</div><div style="font-size:11px;color:var(--t3)">Stall #11 · Vegetables · Awardee</div></div>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Contract Start *</label><input class="form-control" type="date" value="2026-03-09" /></div>
          <div class="form-group"><label class="form-label">Duration *</label>
            <select class="form-control"><option>1 Year</option><option>6 Months</option><option>2 Years</option></select>
          </div>
        </div>
        <div class="toggle-row">
          <div>
            <div style="font-size:12.5px;font-weight:600">Send login credentials via SMS & Email</div>
            <div style="font-size:11px;color:var(--t3);margin-top:2px">Auto-generated upon account creation</div>
          </div>
          <div class="toggle active" onclick="this.classList.toggle('active')"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost btn-sm" onclick="closeModal('convertModal')">Cancel</button>
        <button class="btn btn-success btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 1 21 5 17 9" /><path d="M3 11V9a4 4 0 0 1 4-4h14" /></svg>
          Convert to Vendor
        </button>
      </div>
    </div>
  </div>

  <!-- EDIT VENDOR -->
  <div class="modal-backdrop" id="editModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
          Edit Vendor Information
        </div>
        <button class="modal-close" onclick="closeModal('editModal')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="form-section-label">Personal Information</div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">First Name</label><input class="form-control" id="ef-fn" /></div>
          <div class="form-group"><label class="form-label">Last Name</label><input class="form-control" id="ef-ln" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Contact Number</label><input class="form-control" id="ef-ph" /></div>
          <div class="form-group"><label class="form-label">Email Address</label><input class="form-control" id="ef-em" type="email" /></div>
        </div>
        <div class="form-row form-row-full">
          <div class="form-group"><label class="form-label">Home Address</label><input class="form-control" id="ef-ad" /></div>
        </div>
        <div class="form-section-label">Stall Assignment</div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Assigned Stall</label>
            <select class="form-control">
              <option>#01 — Wet Market</option>
              <option>#03 — Meat</option>
              <option>#06 — Dry Goods</option>
              <option>#07 — Dry Goods</option>
              <option>#11 — Vegetables</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Trade Type</label>
            <select class="form-control">
              <option>Wet Market</option>
              <option>Dry Goods</option>
              <option>Meat Section</option>
              <option>Vegetables</option>
              <option>Fish Section</option>
              <option>General</option>
            </select>
          </div>
        </div>
        <div class="form-section-label">Contract</div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Contract Start</label><input class="form-control" type="date" id="ef-cs" /></div>
          <div class="form-group"><label class="form-label">Contract End</label><input class="form-control" type="date" id="ef-ce" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Monthly Rate (₱)</label><input class="form-control" type="number" id="ef-rate" /></div>
          <div class="form-group"><label class="form-label">Security Deposit (₱)</label><input class="form-control" type="number" value="3000" /></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost btn-sm" onclick="closeModal('editModal')">Cancel</button>
        <button class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4" /></svg>
          Save Changes
        </button>
      </div>
    </div>
  </div>

  <!-- STATUS MODAL -->
  <div class="modal-backdrop" id="statusModal">
    <div class="modal modal-sm">
      <div class="modal-header">
        <div class="modal-title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
          Change Vendor Status
        </div>
        <button class="modal-close" onclick="closeModal('statusModal')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        </button>
      </div>
      <div class="modal-body">
        <div style="font-size:12.5px;color:var(--t3);margin-bottom:16px">Updating status for: <strong id="sm-name" style="color:var(--t1)">—</strong></div>
        <div class="status-grid">
          <div class="status-option status-opt-active" onclick="pickStatus(this, 'active')">
            <div class="status-opt-icon">✅</div>
            <div class="status-opt-label" style="color:var(--status-active)">Active</div>
            <div class="status-opt-sub">Account fully operational</div>
          </div>
          <div class="status-option" onclick="pickStatus(this, 'suspended')">
            <div class="status-opt-icon">⏸️</div>
            <div class="status-opt-label" style="color:var(--status-suspended)">Suspended</div>
            <div class="status-opt-sub">Temporary access block</div>
          </div>
          <div class="status-option" onclick="pickStatus(this, 'expired')">
            <div class="status-opt-icon">📋</div>
            <div class="status-opt-label" style="color:var(--status-expired)">Contract Expired</div>
            <div class="status-opt-sub">Renewal required</div>
          </div>
          <div class="status-option" onclick="pickStatus(this, 'terminated')">
            <div class="status-opt-icon">🚫</div>
            <div class="status-opt-label" style="color:var(--status-terminated)">Terminated</div>
            <div class="status-opt-sub">Permanent removal</div>
          </div>
        </div>
        <div class="form-row form-row-full" style="margin-top:14px;margin-bottom:0">
          <div class="form-group"><label class="form-label">Reason / Remarks</label><textarea class="form-control" style="min-height:58px" placeholder="Reason for this status change…"></textarea></div>
        </div>
        <div class="toggle-row">
          <span style="font-size:12.5px;font-weight:600">Notify vendor via SMS & Email</span>
          <div class="toggle active" onclick="this.classList.toggle('active')"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost btn-sm" onclick="closeModal('statusModal')">Cancel</button>
        <button class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4" /></svg>
          Update Status
        </button>
      </div>
    </div>
  </div>

  <!-- CREDENTIALS MODAL -->
  <div class="modal-backdrop" id="credModal">
    <div class="modal modal-sm">
      <div class="modal-header">
        <div class="modal-title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--ac)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
          Resend Login Credentials
        </div>
        <button class="modal-close" onclick="closeModal('credModal')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="info-chip info-chip-warning">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /></svg>
          <div>A new temporary password will be generated. The previous password will be <strong>immediately invalidated</strong>.</div>
        </div>
        <div class="cred-box">
          <div class="cred-title">Credentials for <span id="cred-nm">—</span></div>
          <div class="cred-row"><span class="cred-label">Username</span><span class="cred-value" id="cred-un">—</span>
            <button class="cred-copy tooltip" data-tip="Copy">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
            </button>
          </div>
          <div class="cred-row"><span class="cred-label">New Password</span><span class="cred-value">Ap@2026#xK9m</span>
            <button class="cred-copy tooltip" data-tip="Copy">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
            </button>
          </div>
          <div class="cred-row"><span class="cred-label">Portal</span><span class="cred-value">arkipaisi.gov.ph/vendor</span>
            <button class="cred-copy tooltip" data-tip="Copy">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
            </button>
          </div>
        </div>
        <div class="toggle-row">
          <div>
            <div style="font-size:12.5px;font-weight:600">Send via SMS & Email</div>
            <div style="font-size:11px;color:var(--t3);margin-top:2px" id="cred-contact">—</div>
          </div>
          <div class="toggle active" onclick="this.classList.toggle('active')"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost btn-sm" onclick="closeModal('credModal')">Cancel</button>
        <button class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
          Send Credentials
        </button>
      </div>
    </div>
  </div>

  <%# Inject server-side vendor data as a JS variable — single source of truth %>
  <script>
    const VENDORS = <%- JSON.stringify(vendors) %>;
  </script>
  <script src="/js/admin/vendor-management.js"></script>
</body>

</html>
