<!DOCTYPE html>
<html lang="en" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARKIPAISI — Application Management</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin/application-management.css">
</head>

<body>


  <!-- ═══ SIDEBAR ═══ -->
  <%- include("../../partials/sidebar.ejs", { currentRoute, role: "admin", initials: "admin", fullName: "joshua daliva"}) %>

  <!-- ── MAIN ── -->
  <div class="main" id="main">
    <header class="navbar">
      <div class="togbtn" onclick="toggleSB()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg></div>
      <div class="nb-left">
        <div>
          <div class="nb-page" id="navTitle">Application Management</div>
          <div class="nb-crumb" id="navCrumb"><span>ARKIPAISI</span><span class="sep">›</span><span>Applications</span>
          </div>
        </div>
      </div>
      <div class="nb-right">
        <div class="nb-search"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>Search applicants, stalls...<kbd>⌘K</kbd></div>
        <div class="nb-icon" onclick="toggleTheme()"><svg id="themeIcon" xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5" />
            <line x1="12" y1="1" x2="12" y2="3" />
            <line x1="12" y1="21" x2="12" y2="23" />
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
            <line x1="1" y1="12" x2="3" y2="12" />
            <line x1="21" y1="12" x2="23" y2="12" />
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg></div>
        <div class="nb-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
          </svg><span class="nb-dot"></span></div>
        <div class="av-pill">
          <div class="av-xs">admin</div><span class="av-pill-name">daliva</span><svg xmlns="http://www.w3.org/2000/svg"
            width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </div>
      </div>
    </header>

    <div class="content">

      <!-- ══════════════════════ VIEW 1: STALL LIST ══════════════════════ -->
      <div id="view-stalls">
        <div class="page-hdr">
          <div class="page-hdr-left">
            <h1>Vendor Applications</h1>
            <p>Select a publicly posted stall to manage its applications</p>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn ghost sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
              </svg>Export</button>
            <button class="btn primary sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>Post New Stall</button>
          </div>
        </div>

        <!-- Summary Stats -->
        <div class="summary-row">
          <div class="sum-card">
            <div class="sum-icon blue"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              </svg></div>
            <div>
              <div class="sum-val">4</div>
              <div class="sum-lbl">Stalls Accepting Applications</div>
            </div>
          </div>
          <div class="sum-card">
            <div class="sum-icon blue"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              </svg></div>
            <div>
              <div class="sum-val">24</div>
              <div class="sum-lbl">Total Applications Received</div>
            </div>
          </div>
          <div class="sum-card">
            <div class="sum-icon green"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <polyline points="9 11 12 14 22 4" />
              </svg></div>
            <div>
              <div class="sum-val">9</div>
              <div class="sum-lbl">Qualified Applicants</div>
            </div>
          </div>
          <div class="sum-card">
            <div class="sum-icon purple"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <path d="M8 14s1.5 2 4 2 4-2 4-2" />
                <line x1="9" y1="9" x2="9.01" y2="9" />
                <line x1="15" y1="9" x2="15.01" y2="9" />
              </svg></div>
            <div>
              <div class="sum-val">3</div>
              <div class="sum-lbl">Pending Raffle</div>
            </div>
          </div>
        </div>

        <!-- View/Sort Bar -->
        <div class="view-bar">
          <span class="view-bar-label">Posted Stalls</span>
          <div class="view-toggle">
            <button class="vt-btn active" id="vt-card" onclick="switchStallView('card')"><svg
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
                <rect x="14" y="14" width="7" height="7" />
              </svg>Cards</button>
            <button class="vt-btn" id="vt-list" onclick="switchStallView('list')"><svg
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <line x1="8" y1="6" x2="21" y2="6" />
                <line x1="8" y1="12" x2="21" y2="12" />
                <line x1="8" y1="18" x2="21" y2="18" />
                <line x1="3" y1="6" x2="3.01" y2="6" />
                <line x1="3" y1="12" x2="3.01" y2="12" />
                <line x1="3" y1="18" x2="3.01" y2="18" />
              </svg>List</button>
          </div>
          <div class="search-sm"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg><input placeholder="Search posted stalls..." id="stallSearch" oninput="filterStalls(this.value)" />
          </div>
          <select class="sort-select" style="margin-left:auto">
            <option>Sort: Most Applications</option>
            <option>Sort: Deadline Soon</option>
            <option>Sort: Stall Number</option>
          </select>
        </div>

        <!-- Stall Cards -->
        <div class="stalls-grid" id="stallsGrid">
          <!-- Stall 06 -->
          <div class="stall-card" onclick="openStallDetail(0)" style="animation-delay:.04s">
            <div class="sc-progress-bar">
              <div class="sc-progress-fill" style="width:60%"></div>
            </div>
            <div class="sc-top">
              <div class="sc-top-row">
                <div class="sc-num-wrap">
                  <div class="sc-num">#06</div>
                  <div style="display:flex;flex-direction:column;gap:4px">
                    <span class="sc-type-badge dry">Dry Goods</span>
                    <span class="sc-open-badge">Open</span>
                  </div>
                </div>
                <div style="text-align:right">
                  <div style="font-size:11px;color:var(--text-muted);font-weight:600;margin-bottom:3px">Posted</div>
                  <div style="font-size:12px;font-weight:700">Mar 1, 2026</div>
                </div>
              </div>
              <div class="sc-location"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>Section B · Row 1 &nbsp;·&nbsp; <span style="font-family:'DM Mono',monospace;font-size:11px">3×3
                  m²</span></div>
              <div class="sc-desc">A 3×3 m² dry goods stall ideal for general merchandise, clothing, and household
                goods. Good foot traffic area near the main aisle.</div>
            </div>
            <div class="sc-bottom">
              <div class="sc-stats">
                <div class="sc-stat-item applied">
                  <div class="sc-stat-num">7</div>
                  <div class="sc-stat-lbl">Applied</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item qualified">
                  <div class="sc-stat-num">3</div>
                  <div class="sc-stat-lbl">Qualified</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item raffle">
                  <div class="sc-stat-num">3</div>
                  <div class="sc-stat-lbl">Raffle</div>
                </div>
              </div>
              <div class="sc-deadline"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>Mar 20</div>
            </div>
            <div class="sc-arrow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6" />
              </svg></div>
          </div>

          <!-- Stall 11 -->
          <div class="stall-card" onclick="openStallDetail(1)" style="animation-delay:.09s">
            <div class="sc-progress-bar">
              <div class="sc-progress-fill" style="width:40%"></div>
            </div>
            <div class="sc-top">
              <div class="sc-top-row">
                <div class="sc-num-wrap">
                  <div class="sc-num">#11</div>
                  <div style="display:flex;flex-direction:column;gap:4px">
                    <span class="sc-type-badge veggie">Vegetables</span>
                    <span class="sc-open-badge">Open</span>
                  </div>
                </div>
                <div style="text-align:right">
                  <div style="font-size:11px;color:var(--text-muted);font-weight:600;margin-bottom:3px">Posted</div>
                  <div style="font-size:12px;font-weight:700">Mar 3, 2026</div>
                </div>
              </div>
              <div class="sc-location"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>Section C · Row 2 &nbsp;·&nbsp; <span style="font-family:'DM Mono',monospace;font-size:11px">4×3
                  m²</span></div>
              <div class="sc-desc">Fresh produce and vegetable stall. Located in the heart of the produce section with
                excellent visibility.</div>
            </div>
            <div class="sc-bottom">
              <div class="sc-stats">
                <div class="sc-stat-item applied">
                  <div class="sc-stat-num">5</div>
                  <div class="sc-stat-lbl">Applied</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item qualified">
                  <div class="sc-stat-num">2</div>
                  <div class="sc-stat-lbl">Qualified</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item raffle" style="opacity:.4">
                  <div class="sc-stat-num">0</div>
                  <div class="sc-stat-lbl">Raffle</div>
                </div>
              </div>
              <div class="sc-deadline"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>Mar 22</div>
            </div>
            <div class="sc-arrow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6" />
              </svg></div>
          </div>

          <!-- Stall 22 -->
          <div class="stall-card" onclick="openStallDetail(2)" style="animation-delay:.14s">
            <div class="sc-progress-bar">
              <div class="sc-progress-fill" style="width:75%"></div>
            </div>
            <div class="sc-top">
              <div class="sc-top-row">
                <div class="sc-num-wrap">
                  <div class="sc-num">#22</div>
                  <div style="display:flex;flex-direction:column;gap:4px">
                    <span class="sc-type-badge general">General</span>
                    <span class="sc-open-badge">Open</span>
                  </div>
                </div>
                <div style="text-align:right">
                  <div style="font-size:11px;color:var(--text-muted);font-weight:600;margin-bottom:3px">Posted</div>
                  <div style="font-size:12px;font-weight:700">Feb 28, 2026</div>
                </div>
              </div>
              <div class="sc-location"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>Section E · Row 1 &nbsp;·&nbsp; <span style="font-family:'DM Mono',monospace;font-size:11px">4×4
                  m²</span></div>
              <div class="sc-desc">Spacious general merchandise stall open for any trade. Prime corner location near the
                east entrance for high visibility.</div>
            </div>
            <div class="sc-bottom">
              <div class="sc-stats">
                <div class="sc-stat-item applied">
                  <div class="sc-stat-num">9</div>
                  <div class="sc-stat-lbl">Applied</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item qualified">
                  <div class="sc-stat-num">4</div>
                  <div class="sc-stat-lbl">Qualified</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item raffle">
                  <div class="sc-stat-num">0</div>
                  <div class="sc-stat-lbl">Raffle</div>
                </div>
              </div>
              <div class="sc-deadline" style="background:var(--red-light);color:var(--red);border:none"><svg
                  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>Mar 25 ⚠</div>
            </div>
            <div class="sc-arrow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6" />
              </svg></div>
          </div>

          <!-- Stall 25 -->
          <div class="stall-card" onclick="openStallDetail(3)" style="animation-delay:.19s">
            <div class="sc-progress-bar">
              <div class="sc-progress-fill" style="width:20%"></div>
            </div>
            <div class="sc-top">
              <div class="sc-top-row">
                <div class="sc-num-wrap">
                  <div class="sc-num">#25</div>
                  <div style="display:flex;flex-direction:column;gap:4px">
                    <span class="sc-type-badge general">General</span>
                    <span class="sc-open-badge">Open</span>
                  </div>
                </div>
                <div style="text-align:right">
                  <div style="font-size:11px;color:var(--text-muted);font-weight:600;margin-bottom:3px">Posted</div>
                  <div style="font-size:12px;font-weight:700">Mar 5, 2026</div>
                </div>
              </div>
              <div class="sc-location"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>Section E · Row 2 &nbsp;·&nbsp; <span style="font-family:'DM Mono',monospace;font-size:11px">3×4
                  m²</span></div>
              <div class="sc-desc">Recently renovated general stall with improved ventilation. Perfect for dry goods,
                personal care products or services.</div>
            </div>
            <div class="sc-bottom">
              <div class="sc-stats">
                <div class="sc-stat-item applied">
                  <div class="sc-stat-num">3</div>
                  <div class="sc-stat-lbl">Applied</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item qualified" style="opacity:.4">
                  <div class="sc-stat-num">0</div>
                  <div class="sc-stat-lbl">Qualified</div>
                </div>
                <div class="sc-divider"></div>
                <div class="sc-stat-item raffle" style="opacity:.4">
                  <div class="sc-stat-num">0</div>
                  <div class="sc-stat-lbl">Raffle</div>
                </div>
              </div>
              <div class="sc-deadline"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>Mar 30</div>
            </div>
            <div class="sc-arrow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6" />
              </svg></div>
          </div>
        </div>

        <!-- List View (hidden by default) -->
        <div id="stallListView" style="display:none">
          <div class="panel">
            <table class="app-table">
              <thead>
                <tr>
                  <th>Stall</th>
                  <th>Type</th>
                  <th>Location</th>
                  <th>Applications</th>
                  <th>Qualified</th>
                  <th>Status</th>
                  <th>Deadline</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <tr onclick="openStallDetail(0)">
                  <td><span style="font-family:'DM Mono',monospace;font-weight:800;color:var(--accent)">#06</span></td>
                  <td><span class="sc-type-badge dry">Dry Goods</span></td>
                  <td style="font-size:12px;color:var(--text-secondary)">Section B · Row 1</td>
                  <td><span style="font-weight:700;color:var(--accent)">7</span></td>
                  <td><span style="font-weight:700;color:var(--green)">3</span></td>
                  <td><span class="sc-open-badge" style="font-size:10px">Open</span></td>
                  <td style="font-size:12px;color:var(--amber);font-weight:600">Mar 20</td>
                  <td><button class="btn primary xs">View Applications →</button></td>
                </tr>
                <tr onclick="openStallDetail(1)">
                  <td><span style="font-family:'DM Mono',monospace;font-weight:800;color:var(--accent)">#11</span></td>
                  <td><span class="sc-type-badge veggie">Vegetables</span></td>
                  <td style="font-size:12px;color:var(--text-secondary)">Section C · Row 2</td>
                  <td><span style="font-weight:700;color:var(--accent)">5</span></td>
                  <td><span style="font-weight:700;color:var(--green)">2</span></td>
                  <td><span class="sc-open-badge" style="font-size:10px">Open</span></td>
                  <td style="font-size:12px;color:var(--amber);font-weight:600">Mar 22</td>
                  <td><button class="btn primary xs">View Applications →</button></td>
                </tr>
                <tr onclick="openStallDetail(2)">
                  <td><span style="font-family:'DM Mono',monospace;font-weight:800;color:var(--accent)">#22</span></td>
                  <td><span class="sc-type-badge general">General</span></td>
                  <td style="font-size:12px;color:var(--text-secondary)">Section E · Row 1</td>
                  <td><span style="font-weight:700;color:var(--accent)">9</span></td>
                  <td><span style="font-weight:700;color:var(--green)">4</span></td>
                  <td><span class="sc-open-badge" style="font-size:10px">Open</span></td>
                  <td style="font-size:12px;color:var(--red);font-weight:700">Mar 25 ⚠</td>
                  <td><button class="btn primary xs">View Applications →</button></td>
                </tr>
                <tr onclick="openStallDetail(3)">
                  <td><span style="font-family:'DM Mono',monospace;font-weight:800;color:var(--accent)">#25</span></td>
                  <td><span class="sc-type-badge general">General</span></td>
                  <td style="font-size:12px;color:var(--text-secondary)">Section E · Row 2</td>
