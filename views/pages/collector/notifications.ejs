<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Notifications</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/collector/notifications.css">
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">
          <div class="pghdr">
            <div>
              <h1>Notifications</h1>
              <p>Alerts and updates for your collection route</p>
            </div>
            <button class="btn gh" onclick="markAllRead()">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              Mark all as read
            </button>
          </div>

          <!-- Filter tabs — counts server-rendered initially -->
          <div class="ntabs">
            <div class="ntab on" onclick="setTab('all',this)">All <span class="ntab-cnt" id="cntAll">
                <%= counts.total %>
              </span></div>
            <div class="ntab" onclick="setTab('unread',this)">Unread <span class="ntab-cnt" id="cntUnread">
                <%= counts.unread %>
              </span></div>
            <div class="ntab" onclick="setTab('payment',this)">Payments</div>
            <div class="ntab" onclick="setTab('overdue',this)">Overdue</div>
            <div class="ntab" onclick="setTab('system',this)">System</div>
          </div>

          <!-- Notification list -->
          <div class="notif-list">
            <div class="notif-header">
              <span class="notif-count-lbl"><span id="visibleCount">
                  <%= counts.total %>
                </span> notifications</span>
              <button class="btn ghost-bl" onclick="markAllRead()">Mark all read</button>
            </div>
            <div id="notifList"></div>
          </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <%# Inject server-side notifications as a JS variable %>
      <script>
        let NOTIFS = <%- JSON.stringify(notifications) %>;
      </script>

      <script src="/js/collector/notifications.js"></script>
</body>

</html>