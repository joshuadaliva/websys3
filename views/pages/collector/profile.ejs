<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; My Profile</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/collector/profile.css">
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,
    fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">
          <div class="pghdr">
            <div>
              <h1>My Profile</h1>
              <p>Manage your account information and preferences</p>
            </div>
          </div>

          <div class="pgrid">
            <!-- LEFT: profile card + nav -->
            <div>
              <div class="profile-card">
                <div class="profile-banner"></div>
                <div class="profile-av-wrap">
                  <div class="profile-av">
                    <%= user.initials %>
                  </div>
                  <button class="profile-edit-btn" onclick="setSection('info')">Edit Profile</button>
                </div>
                <div class="profile-info">
                  <div class="profile-name">
                    <%= user.fullName %>
                  </div>
                  <div class="profile-role">
                    <%= user.role %>
                  </div>
                  <div class="profile-id">
                    <%= user.employeeId %>
                  </div>
                </div>
                <!-- Stats -->
                <div class="stat-strip">
                  <div class="stat-cell">
                    <div class="stat-val">
                      <%= stats.totalStalls %>
                    </div>
                    <div class="stat-lbl">Stalls</div>
                  </div>
                  <div class="stat-cell">
                    <div class="stat-val">
                      <%= stats.orsIssued %>
                    </div>
                    <div class="stat-lbl">ORs Issued</div>
                  </div>
                  <div class="stat-cell">
                    <div class="stat-val">
                      <%= stats.onTimeRate %>
                    </div>
                    <div class="stat-lbl">On-time</div>
                  </div>
                </div>
                <!-- Nav -->
                <div class="profile-nav">
                  <div class="pnav-item on" id="nav-info" onclick="setSection('info')">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </svg>
                    Personal Info
                  </div>
                  <div class="pnav-item" id="nav-assignment" onclick="setSection('assignment')">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2">
                      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                      <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Assignment
                  </div>
                  <div class="pnav-item" id="nav-activity" onclick="setSection('activity')">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2">
                      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                    </svg>
                    Activity Log
                  </div>
                  <div class="pnav-item" id="nav-security" onclick="setSection('security')">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2">
                      <rect x="3" y="11" width="18" height="11" rx="2" />
                      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                    Security
                  </div>
                </div>
              </div>
            </div>

            <!-- RIGHT: dynamic section content -->
            <div id="sectionContent"></div>
          </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <%# Inject server-side data as JS variables %>
      <script>
        const USER = <%- JSON.stringify(user) %>;
        const EMPLOYMENT = <%- JSON.stringify(employment) %>;
        const ASSIGNMENT = <%- JSON.stringify(assignment) %>;
        const PERFORMANCE = <%- JSON.stringify(performance) %>;
        const ACTIVITY_LOG = <%- JSON.stringify(activityLog) %>;
        const SECURITY = <%- JSON.stringify(security) %>;
      </script>

      <script src="/js/collector/profile.js"></script>
</body>

</html>