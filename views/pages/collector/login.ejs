<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ARKIPAISI — collector Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/collector/login.css">
</head>

<body>

    <!-- Theme toggle -->
    <button class="theme-btn" onclick="toggleTheme()" title="Toggle theme">
        <svg id="themeIco" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <circle cx="12" cy="12" r="5" />
            <line x1="12" y1="1" x2="12" y2="3" />
            <line x1="12" y1="21" x2="12" y2="23" />
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
            <line x1="1" y1="12" x2="3" y2="12" />
            <line x1="21" y1="12" x2="23" y2="12" />
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
    </button>

    <!-- ════ LEFT PANEL ════ -->
    <div class="left">
        <div class="left-photo"></div>
        <div class="left-grad1"></div>
        <div class="left-grad2"></div>
        <div class="left-edge"></div>
        <div class="left-content">

            <!-- Brand -->
            <div class="left-brand">
                <div class="brand-seal">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                </div>
                <div class="brand-text">
                    <div class="brand-name">ARKIPAISI</div>
                    <div class="brand-sub">Public Market Management System</div>
                </div>
            </div>

            <!-- Headline -->
            <div class="left-middle">
                <div class="left-headline">
                    Market Vendor<br />
                    <em>Command Center</em>
                </div>
                <!-- <p class="left-desc">
                    Manage stall assignments, vendor records, payment collections, and generate official reports — all
                    from one secure platform.
                </p> -->

                <!-- Live stats -->
                <div class="left-stats" style="margin-top:32px">
                    <div class="lst">
                        <div class="lst-val">9</div>
                        <div class="lst-lbl">Active Vendors</div>
                    </div>
                    <div class="lst">
                        <div class="lst-val">25</div>
                        <div class="lst-lbl">Stalls Occupied</div>
                    </div>
                    <div class="lst">
                        <div class="lst-val">₱14.7K</div>
                        <div class="lst-lbl">Collected Mar</div>
                    </div>
                </div>
            </div>

            <!-- Footer tag -->
            <div class="left-footer">
                <div class="lf-tag">
                    <div class="lf-dot pulse"></div>
                    System online · Last updated Mar 14, 2026
                </div>
            </div>

        </div>
    </div>

    <!-- ════ RIGHT PANEL ════ -->
    <div class="right">
        <div class="form-box" id="form-box">

            <!-- Shown on mobile only -->
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:28px" id="mobile-brand">
                <div class="brand-seal" style="width:36px;height:36px;flex-shrink:0">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2" width="16" height="16">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    </svg>
                </div>
                <div>
                    <div style="font-family:'DM Sans',sans-serif;font-size:16px;font-weight:800;color:var(--t1)">
                        ARKIPAISI</div>
                    <div style="font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.6px">Admin
                        Portal</div>
                </div>
            </div>

            <!-- Screens injected by JS -->
            <div id="screen-login"><!-- rendered by JS --></div>
            <div id="screen-forgot" style="display:none"><!-- rendered by JS --></div>
            <div id="screen-otp" style="display:none"><!-- rendered by JS --></div>
            <div id="screen-reset" style="display:none"><!-- rendered by JS --></div>

        </div>
    </div>

   <script src="/js/collector/login.js"></script>
</body>

</html>