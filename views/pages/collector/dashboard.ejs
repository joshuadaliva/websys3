<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Staff Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/collector/dashboard.css">
</head>

<body>

  <div class="veil" id="veil" onclick="closeSB()"></div>

  <%- include("../../partials/sidebar.ejs", { currentRoute, role: "collector" , initials: "collector" ,
    fullName: "joshua daliva" }) %>

    <div class="main" id="main">
      <%- include("../../partials/header.ejs", {role: "collector" , initials: "collector" , lastName: "daliva" , }) %>

        <div class="content">

          <!-- Greeting Banner -->
          <div class="date-banner">
            <div>
              <div class="db-greeting">Good morning</div>
              <div class="db-name">
                <%= user.fullName %>
              </div>
              <div class="db-sub">
                <%= user.role %> &mdash; <%= user.market %>
              </div>
            </div>
            <div class="db-right">
              <div class="db-time" id="liveClock">--:--</div>
              <div class="db-date" id="liveDate">Loading...</div>
            </div>
          </div>

          <!-- Stat Cards — server-rendered values -->
          <div class="stats">
            <div class="sc">
              <div class="sc-icon gr"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg></div>
              <div>
                <div class="sc-val">
                  <%= stats.collectedToday.value %>
                </div>
                <div class="sc-lbl">Collected Today</div>
                <div class="sc-change up"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="3">
                    <polyline points="18 15 12 9 6 15" />
                  </svg>
                  <%= stats.collectedToday.change %>
                </div>
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                </svg></div>
              <div>
                <div class="sc-val">
                  <%= stats.receiptsIssued.value %>
                </div>
                <div class="sc-lbl">Receipts Issued</div>
                <div class="sc-change up"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="3">
                    <polyline points="18 15 12 9 6 15" />
                  </svg>
                  <%= stats.receiptsIssued.change %>
                </div>
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon am"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                </svg></div>
              <div>
                <div class="sc-val">
                  <%= stats.overdueAccounts.value %>
                </div>
                <div class="sc-lbl">Overdue Accounts</div>
                <div class="sc-change down"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="3">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                  <%= stats.overdueAccounts.change %>
                </div>
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon vi"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                </svg></div>
              <div>
                <div class="sc-val">
                  <%= stats.assignedStalls.value %>
                </div>
                <div class="sc-lbl">Assigned Stalls</div>
                <div class="sc-change" style="color:var(--t3)">
                  <%= stats.assignedStalls.change %>
                </div>
              </div>
            </div>
          </div>

          <!-- Main 2-col grid -->
          <div class="dash-grid">

            <!-- LEFT COLUMN -->
            <div>

              <!-- Quick Actions -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                      </svg>Quick Actions</div>
                  </div>
                </div>
                <div class="qa-grid">
                  <div class="qa-btn" onclick="openPaymentModal()">
                    <div class="qa-icon gr"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                      </svg></div>
                    <div class="qa-lbl">Record Payment</div>
                    <div class="qa-desc">Collect and issue official receipt for a vendor</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Opening Overdue list...')">
                    <div class="qa-icon am"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path
                          d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                      </svg></div>
                    <div class="qa-lbl">View Overdue</div>
                    <div class="qa-desc">Check and follow up on overdue accounts</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Opening Monthly Summary...')">
                    <div class="qa-icon ac"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                      </svg></div>
                    <div class="qa-lbl">Monthly Summary</div>
                    <div class="qa-desc">View and download monthly collection report</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Opening Payment History...')">
                    <div class="qa-icon vi"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                      </svg></div>
                    <div class="qa-lbl">Payment History</div>
                    <div class="qa-desc">View and print past receipts</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Opening My Stalls...')">
                    <div class="qa-icon cy"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                      </svg></div>
                    <div class="qa-lbl">My Stalls</div>
                    <div class="qa-desc">View stalls assigned to your route</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Opening Monthly Report...')">
                    <div class="qa-icon rd"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg></div>
                    <div class="qa-lbl">Monthly Report</div>
                    <div class="qa-desc">View and download monthly summary</div>
                  </div>
                </div>
              </div>

              <!-- Recent Collections — server-rendered rows -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                      </svg>Recent Collections</div>
                    <div class="ph-sub">Today &mdash; March 19, 2026</div>
                  </div>
                  <button class="btn pri sm" onclick="openPaymentModal()"><svg xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>Record New</button>
                </div>
                <div class="tbl-wrap">
                  <table class="tbl">
                    <thead>
                      <tr>
                        <th>Vendor</th>
                        <th>Stall</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Time</th>
                        <th>OR No.</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% recentCollections.forEach(r=> { %>
                        <tr>
                          <td>
                            <div class="vcell">
                              <div class="vav" style="background:linear-gradient(<%= r.grad %>)">
                                <%= r.init %>
                              </div>
                              <div>
                                <div style="font-size:12.5px;font-weight:600">
                                  <%= r.name %>
                                </div>
                                <div style="font-size:11px;color:var(--t3)">
                                  <%= r.vendorId %>
                                </div>
                              </div>
                            </div>
                          </td>
                          <td><span style="font-family:'DM Mono',monospace;font-size:12px;font-weight:700">
                              <%= r.stall %>
                            </span></td>
                          <td style="font-family:'DM Mono',monospace;font-weight:700;color:var(--gr)">
                            <%= r.amount %>
                          </td>
                          <td><span class="bdg <%= r.methodClass %>">
                              <%= r.method %>
                            </span></td>
                          <td style="font-size:12px;color:var(--t3)">
                            <%= r.time %>
                          </td>
                          <td style="font-family:'DM Mono',monospace;font-size:11.5px;color:var(--t3)">
                            <%= r.or %>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                </div>
                <div
                  style="padding:10px 16px;background:var(--s2);border-top:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
                  <span style="font-size:12px;color:var(--t3)">Showing <%= recentCollections.length %> of 12 today
                      &mdash; <span style="font-weight:700;color:var(--gr)">Total: <%= collectionProgress.totalCollected
                          %></span></span>
                  <button class="btn gh xs" onclick="showToast('Loading full history...')">View All</button>
                </div>
              </div>

              <!-- Overdue Accounts — server-rendered -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path
                          d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                      </svg>Overdue Accounts</div>
                    <div class="ph-sub">
                      <%= overdueAccounts.length %> vendors require follow-up
                    </div>
                  </div>
                  <span class="bdg am">&#8369;38,400 total</span>
                </div>
                <% overdueAccounts.forEach(a=> { %>
                  <div class="overdue-item">
                    <div class="ov-left">
                      <div class="ov-av" style="background:linear-gradient(<%= a.grad %>)">
                        <%= a.init %>
                      </div>
                      <div>
                        <div class="ov-name">
                          <%= a.name %>
                        </div>
                        <div class="ov-stall">Stall <%= a.stall %> &middot; <%= a.type %>
                        </div>
                      </div>
                    </div>
                    <div style="text-align:right">
                      <div class="ov-amount">
                        <%= a.amount %>
                      </div>
                      <div class="ov-days">
                        <%= a.days %> days overdue
                      </div>
                    </div>
                  </div>
                  <% }) %>
                    <div
                      style="padding:10px 16px;background:var(--s2);border-top:1px solid var(--brd);display:flex;justify-content:flex-end">
                      <button class="btn gh xs" onclick="showToast('Loading all overdue...')">View All 8</button>
                    </div>
              </div>

              <!-- Recent Activity — server-rendered -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>Recent Activity</div>
                  </div>
                </div>
                <div class="act-list">
                  <% activityFeed.forEach(a=> { %>
                    <div class="act-item">
                      <div class="act-dot <%= a.dotClass %>">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <polyline points="20 6 9 17 4 12" />
                        </svg>
                      </div>
                      <div class="act-body">
                        <div class="act-text"><%- a.text %></div>
                        <div class="act-time">
                          <%= a.time %>
                        </div>
                      </div>
                    </div>
                    <% }) %>
                </div>
              </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div>

              <!-- Collection Progress -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                      </svg>Today's Progress</div>
                    <div class="ph-sub">vs. monthly target</div>
                  </div>
                </div>
                <div class="coll-bar-wrap">
                  <div class="coll-row">
                    <div class="coll-top"><span class="coll-lbl">Cash</span><span class="coll-val">
                        <%= collectionProgress.cash.collected %> / <%= collectionProgress.cash.target %>
                      </span></div>
                    <div class="bar-track">
                      <div class="bar-fill gr" style="width:<%= collectionProgress.cash.pct %>%"></div>
                    </div>
                  </div>
                  <div class="coll-row">
                    <div class="coll-top"><span class="coll-lbl">GCash</span><span class="coll-val">
                        <%= collectionProgress.gcash.collected %> / <%= collectionProgress.gcash.target %>
                      </span></div>
                    <div class="bar-track">
                      <div class="bar-fill ac" style="width:<%= collectionProgress.gcash.pct %>%"></div>
                    </div>
                  </div>
                  <div class="coll-row">
                    <div class="coll-top"><span class="coll-lbl">Maya</span><span class="coll-val">
                        <%= collectionProgress.maya.collected %> / <%= collectionProgress.maya.target %>
                      </span></div>
                    <div class="bar-track">
                      <div class="bar-fill am" style="width:<%= collectionProgress.maya.pct %>%"></div>
                    </div>
                  </div>
                  <div class="coll-row">
                    <div class="coll-top"><span class="coll-lbl" style="color:var(--rd)">Overdue Balance</span><span
                        class="coll-val" style="color:var(--rd)">
                        <%= collectionProgress.overdue.collected %>
                      </span></div>
                    <div class="bar-track">
                      <div class="bar-fill rd" style="width:<%= collectionProgress.overdue.pct %>%"></div>
                    </div>
                  </div>
                  <div
                    style="margin-top:14px;padding-top:12px;border-top:1px solid var(--brd2);display:flex;justify-content:space-between;align-items:center">
                    <div>
                      <div
                        style="font-size:11px;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.3px">
                        Total Collected</div>
                      <div
                        style="font-size:20px;font-weight:800;font-family:'DM Mono',monospace;color:var(--gr);letter-spacing:-1px">
                        <%= collectionProgress.totalCollected %>
                      </div>
                    </div>
                    <div style="text-align:right">
                      <div
                        style="font-size:11px;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.3px">
                        Month Target</div>
                      <div style="font-size:20px;font-weight:800;font-family:'DM Mono',monospace;letter-spacing:-1px">
                        <%= collectionProgress.monthTarget %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Mini Calendar -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg>Calendar</div>
                  </div>
                </div>
                <div class="cal-wrap">
                  <div class="cal-head">
                    <div class="cal-month" id="calMonth">March 2026</div>
                    <div class="cal-nav">
                      <div class="cal-nav-btn" onclick="changeMonth(-1)"><svg xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="15 18 9 12 15 6" />
                        </svg></div>
                      <div class="cal-nav-btn" onclick="changeMonth(1)"><svg xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="9 18 15 12 9 6" />
                        </svg></div>
                    </div>
                  </div>
                  <div class="cal-grid" id="calGrid"></div>
                </div>
              </div>

              <!-- Tasks — server-rendered -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <polyline points="9 11 12 14 22 4" />
                        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                      </svg>Today's Tasks</div>
                  </div>
                  <button class="btn gh xs" onclick="showToast('Add task')"><svg xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg></button>
                </div>
                <% tasks.forEach(t=> { %>
                  <div class="task-item">
                    <div class="task-cb <%= t.done ? 'done' : '' %>" onclick="toggleTask(this)">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="3">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    </div>
                    <div class="task-body">
                      <div class="task-lbl <%= t.done ? 'done' : '' %>">
                        <%= t.label %>
                      </div>
                      <div class="task-meta">
                        <%= t.meta %>
                      </div>
                    </div>
                    <div class="task-due <%= t.dueClass %>">
                      <%= t.due %>
                    </div>
                  </div>
                  <% }) %>
              </div>

            </div>
          </div>
        </div>
    </div>

    <!-- RECORD PAYMENT MODAL -->
    <div class="modal-bg" id="paymentModal">
      <div class="modal">
        <div class="modal-head">
          <div class="modal-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23" />
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>Record Payment</div>
          <div class="modal-x" onclick="closeModal('paymentModal')"><svg xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg></div>
        </div>
        <div class="modal-body">
          <div class="infobox bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <div>An Official Receipt will be auto-generated after saving.</div>
          </div>
          <div class="fgrid">
            <div class="fg">
              <label>Vendor / Stall</label>
              <select class="finp" id="pm-vendor">
                <option value="">-- Select Vendor --</option>
                <% vendorOptions.forEach(v=> { %>
                  <option><%- v.label %></option>
                  <% }) %>
              </select>
            </div>
            <div class="fg">
              <label>Payment Period</label>
              <select class="finp" id="pm-period">
                <option selected>March 2026</option>
                <option>February 2026</option>
                <option>January 2026</option>
              </select>
            </div>
          </div>
          <div class="fgrid">
            <div class="fg">
              <label>Amount (PHP)</label>
              <div class="pfx"><span class="pfx-lbl">&#8369;</span><input class="finp" id="pm-amount" type="number"
                  min="0" step="50" placeholder="0.00" /></div>
            </div>
            <div class="fg">
              <label>Payment Method</label>
              <select class="finp" id="pm-method">
                <option>Cash</option>
                <option>GCash</option>
                <option>Maya (PayMaya)</option>
                <option>Bank Transfer</option>
              </select>
            </div>
          </div>
          <div class="fgrid">
            <div class="fg"><label>Date Paid</label><input class="finp" id="pm-date" type="date" /></div>
            <div class="fg"><label>OR Number</label><input class="finp" id="pm-or" placeholder="Auto-generated" readonly
                style="background:var(--s3);color:var(--t3)" /></div>
          </div>
          <div class="fgrid full">
            <div class="fg"><label>Remarks (optional)</label><input class="finp" id="pm-remarks"
                placeholder="e.g. Partial payment, installment 1 of 2" /></div>
          </div>
        </div>
        <div class="modal-foot">
          <button class="btn gh sm" onclick="closeModal('paymentModal')">Cancel</button>
          <button class="btn gr sm" onclick="savePayment()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12" />
            </svg>Save &amp; Issue OR</button>
        </div>
      </div>
    </div>

    <div class="toast" id="toast"></div>

    <%# Inject server-side calendar events and OR counter %>
      <script>
        const CAL_EVENTS = <%- JSON.stringify(calendarEvents) %>;
        let OR_COUNTER = <%- orCounter %>;
      </script>

      <script src="/js/collector/dashboard.js"></script>
</body>

</html>