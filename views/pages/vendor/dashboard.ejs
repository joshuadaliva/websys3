<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Vendor Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/vendor/dashboard.css">
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>
  <%- include("../../partials/sidebar.ejs", { currentRoute, role: "vendor" , initials: "vendor" , fullName: "joshua daliva", stallNumber: 06}) %>
    <div class="main" id="main">
      <%- include("../../partials/header.ejs", {role: "vendor" , initials: "vendor" , lastName: "daliva" , }) %>
        <div class="content">

          <!-- Welcome banner -->
          <div class="welcome-banner">
            <div class="wb-left">
              <h2>Good morning, <%= vendor.firstName %>!</h2>
              <p>Here is your stall summary for March 2026.<% if(pStats.unpaidCount> 0) { %> You have <%=
                    pStats.unpaidCount %> pending payment.<% } %>
              </p>
            </div>
            <div class="wb-stall">
              <div class="wb-stall-num">
                <%= stall.number %>
              </div>
              <div class="wb-stall-lbl">
                <%= stall.type %> &bull; GF
              </div>
            </div>
          </div>

          <!-- Stat cards -->
          <div class="stats">
            <div class="sc">
              <div class="sc-icon rd"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                  <line x1="12" y1="9" x2="12" y2="13" />
                  <line x1="12" y1="17" x2="12.01" y2="17" />
                </svg></div>
              <div class="sc-val">&#8369;<%= pStats.balanceDue.toLocaleString() %>
              </div>
              <div class="sc-lbl">Current Balance Due</div>
              <div class="sc-sub rd">
                <%= pStats.duePeriod || 'None due' %>
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon gr"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg></div>
              <div class="sc-val">&#8369;<%= pStats.totalPaid.toLocaleString() %>
              </div>
              <div class="sc-lbl">Total Paid This Year</div>
              <div class="sc-sub gr">
                <%= pStats.paidCount %> months paid
              </div>
            </div>
            <div class="sc">
              <div class="sc-icon bl"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg></div>
              <div class="sc-val">Dec 31</div>
              <div class="sc-lbl">Contract Expires</div>
              <div class="sc-sub">2026</div>
            </div>
            <div class="sc">
              <div class="sc-icon am"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg></div>
              <div class="sc-val">
                <%= iStats.totalCount %>
              </div>
              <div class="sc-lbl">Open Inquiries</div>
              <div class="sc-sub am">
                <%= iStats.openCount %> awaiting reply
              </div>
            </div>
          </div>

          <div class="mgrid">
            <!-- LEFT -->
            <div>
              <!-- Payment status -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-ttl">March 2026 Payment Status</div>
                    <div class="ph-sub">Monthly rental fee: PHP <%= stall.monthlyRate.toLocaleString() %>
                    </div>
                  </div>
                  <span class="bdg rd">Unpaid</span>
                </div>
                <div class="pay-status">
                  <div style="font-size:13.5px;font-weight:700;margin-bottom:12px">PHP 0 paid of PHP <%=
                      stall.monthlyRate.toLocaleString() %>
                  </div>
                  <div class="pay-bar-wrap">
                    <div class="pay-bar" style="width:0%"></div>
                  </div>
                  <div class="pay-bar-labels"><span>PHP 0</span><span>PHP <%= stall.monthlyRate.toLocaleString() %>
                        </span></div>
                  <div
                    style="margin-top:14px;padding:12px 14px;background:var(--rdl);border:1px solid var(--rds);border-radius:8px;font-size:12.5px;color:var(--rd);display:flex;align-items:center;gap:8px">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2" width="14" height="14">
                      <path
                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                    </svg>
                    Your March 2026 payment is due. Please coordinate with your assigned collector or pay via GCash/Maya
                    using reference code <strong>
                      <%= stall.referenceCode %>
                    </strong>.
                  </div>
                </div>
              </div>

              <!-- Payment history (recent) -->
              <div class="panel">
                <div class="ph">
                  <div>
                    <div class="ph-ttl">Payment History</div>
                    <div class="ph-sub">All official receipts issued to your account</div>
                  </div>
                  <button class="btn gh sm" onclick="showToast('Downloading history...')">Export</button>
                </div>
                <div class="tbl-wrap">
                  <table class="tbl">
                    <thead>
                      <tr>
                        <th>OR No.</th>
                        <th>Period</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Date</th>
                        <th>Status</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% recentPayments.forEach(p=> { %>
                        <tr>
                          <td style="font-family:'DM Mono',monospace;font-size:12px;font-weight:700;color:var(--ac)">
                            <%= p.or || '--' %>
                          </td>
                          <td>
                            <%= p.period %>
                          </td>
                          <td
                            style="font-family:'DM Mono',monospace;font-weight:700;color:<%= p.status==='paid' ? 'var(--gr)' : 'var(--rd)' %>">
                            &#8369;<%= p.amount.toLocaleString() %>
                          </td>
                          <td>
                            <% if(p.method==='Cash' ) { %><span class="mbdg cash">Cash</span>
                              <% } else if(p.method==='GCash' ) { %><span class="mbdg gcash">&loz; GCash</span>
                                <% } else if(p.method==='Maya' ) { %><span class="mbdg maya">&loz; Maya</span>
                                  <% } else { %><span class="bdg gy">Unpaid</span>
                                    <% } %>
                          </td>
                          <td style="color:var(--t3)">
                            <%= p.date || '--' %>
                          </td>
                          <td><span class="bdg <%= p.status === 'paid' ? 'gr' : 'rd' %>">
                              <%= p.status==='paid' ? 'Paid' : 'Due' %>
                            </span></td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- RIGHT -->
            <div>
              <!-- Stall info -->
              <div class="panel">
                <div class="ph">
                  <div class="ph-ttl">My Stall</div><span class="bdg bl">Active</span>
                </div>
                <div class="stall-info">
                  <div class="si-row"><span class="si-lbl">Stall Number</span><span class="si-val mono bl">
                      <%= stall.number %>
                    </span></div>
                  <div class="si-row"><span class="si-lbl">Section</span><span class="si-val">
                      <%= stall.location %>
                    </span></div>
                  <div class="si-row"><span class="si-lbl">Type</span><span class="si-val">
                      <%= stall.type %>
                    </span></div>
                  <div class="si-row"><span class="si-lbl">Size</span><span class="si-val mono">
                      <%= stall.size %>
                    </span></div>
                  <div class="si-row"><span class="si-lbl">Monthly Rate</span><span class="si-val mono bl">&#8369;<%=
                        stall.monthlyRate.toLocaleString() %>.00</span></div>
                  <div class="si-row"><span class="si-lbl">Contract</span><span class="si-val">
                      <%= stall.contractStart.slice(0,8) %> &ndash; Dec 2026
                    </span></div>
                  <div class="si-row"><span class="si-lbl">Reference Code</span><span class="si-val mono"
                      style="font-size:11.5px">
                      <%= stall.referenceCode %>
                    </span></div>
                </div>
              </div>

              <!-- Quick actions -->
              <div class="panel">
                <div class="ph">
                  <div class="ph-ttl">Quick Actions</div>
                </div>
                <div class="qa-grid">
                  <div class="qa-btn" onclick="showToast('Opening payment guide...')">
                    <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                      </svg></div>
                    <div class="qa-lbl">How to Pay</div>
                    <div class="qa-desc">GCash, Maya, or cash</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Opening inquiry form...')">
                    <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                      </svg></div>
                    <div class="qa-lbl">New Inquiry</div>
                    <div class="qa-desc">Send a message to the office</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Downloading receipt...')">
                    <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                      </svg></div>
                    <div class="qa-lbl">Download ORs</div>
                    <div class="qa-desc">Get your receipts as PDF</div>
                  </div>
                  <div class="qa-btn" onclick="showToast('Opening contract...')">
                    <div class="qa-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg></div>
                    <div class="qa-lbl">My Contract</div>
                    <div class="qa-desc">View stall lease details</div>
                  </div>
                </div>
              </div>

              <!-- Notices -->
              <div class="panel">
                <div class="ph">
                  <div class="ph-ttl">Recent Notices</div>
                </div>
                <% notices.forEach(n=> { %>
                  <div class="notice-item">
                    <div class="notice-dot"></div>
                    <div>
                      <div class="notice-ttl">
                        <%= n.title %>
                      </div>
                      <div class="notice-time">
                        <%= n.date %>
                      </div>
                    </div>
                  </div>
                  <% }) %>
              </div>
            </div>
          </div>
        </div>
    </div>
    <div class="toast" id="toast"></div>
    <script src="/js/vendor/dashboard.js"></script>
</body>

</html>