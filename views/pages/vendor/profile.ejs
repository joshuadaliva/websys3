<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; My Profile</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/vendor/profile.css">
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>
  <%- include("../../partials/sidebar.ejs", { currentRoute, role: "vendor" , initials: "vendor" , fullName: "joshua daliva", stallNumber: 06}) %>
    <div class="main" id="main">
      <%- include("../../partials/header.ejs", {role: "vendor" , initials: "vendor" , lastName: "daliva" , }) %>
        <div class="content">
          <div class="page-header">
            <h1>My Profile</h1>
            <p>Manage your vendor account information</p>
          </div>

          <!-- Profile banner card -->
          <div class="panel" style="margin-bottom:16px">
            <div class="prof-banner"></div>
            <div class="prof-av-row">
              <div class="prof-av">
                <%= vendor.initials %>
              </div>
              <button class="btn gh sm" onclick="showToast('Changes saved')">Save Changes</button>
            </div>
            <div style="padding:0 20px 20px">
              <div style="font-size:18px;font-weight:800;letter-spacing:-.3px">
                <%= vendor.fullName %>
              </div>
              <div style="font-size:12.5px;color:var(--ac);font-weight:600;margin-top:2px">Vendor &bull; Stall <%=
                  stall.number %> &bull; <%= stall.type %>
              </div>
              <div style="font-size:11.5px;color:var(--t3);font-family:'DM Mono',monospace;margin-top:2px">
                <%= vendor.vendorId %>
              </div>
            </div>
          </div>

          <div class="pgrid">
            <!-- Left: personal info form -->
            <div>
              <div class="panel" style="margin-bottom:16px">
                <div class="ph">
                  <div class="ph-ttl">Personal Information</div>
                </div>
                <div style="padding:18px">
                  <div class="fgrid2">
                    <div class="fg"><label>First Name</label><input class="finp" value="<%= vendor.firstName %>" />
                    </div>
                    <div class="fg"><label>Last Name</label><input class="finp" value="<%= vendor.lastName %>" /></div>
                  </div>
                  <div class="fg"><label>Middle Name</label><input class="finp" value="<%= vendor.middleName %>" />
                  </div>
                  <div class="fg"><label>Phone Number</label><input class="finp" value="<%= vendor.phone %>" /></div>
                  <div class="fg"><label>Email Address</label><input class="finp" value="<%= vendor.email %>" /></div>
                  <div class="fg"><label>Home Address</label><input class="finp" value="<%= vendor.address %>" /></div>
                </div>
              </div>
              <div class="panel">
                <div class="ph">
                  <div class="ph-ttl">Change Password</div>
                </div>
                <div style="padding:18px">
                  <div class="fg"><label>Current Password</label><input class="finp" type="password"
                      placeholder="Enter current password" /></div>
                  <div class="fgrid2">
                    <div class="fg"><label>New Password</label><input class="finp" type="password"
                        placeholder="Min. 8 chars" /></div>
                    <div class="fg"><label>Confirm</label><input class="finp" type="password"
                        placeholder="Repeat new password" /></div>
                  </div>
                  <div style="display:flex;justify-content:flex-end;margin-top:4px">
                    <button class="btn pri" onclick="showToast('Password updated')">Update Password</button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right: stall & contract info -->
            <div>
              <div class="panel" style="margin-bottom:16px">
                <div class="ph">
                  <div class="ph-ttl">Stall &amp; Contract</div>
                </div>
                <div class="si-row"><span class="si-lbl">Stall Number</span><span class="si-val mono bl">
                    <%= stall.number %>
                  </span></div>
                <div class="si-row"><span class="si-lbl">Location</span><span class="si-val">
                    <%= stall.locationShort %>
                  </span></div>
                <div class="si-row"><span class="si-lbl">Type</span><span class="si-val">
                    <%= stall.type %>
                  </span></div>
                <div class="si-row"><span class="si-lbl">Size</span><span class="si-val mono">
                    <%= stall.size %>
                  </span></div>
                <div class="si-row"><span class="si-lbl">Monthly Rate</span><span class="si-val mono bl">&#8369;<%=
                      stall.monthlyRate.toLocaleString() %>.00</span></div>
                <div class="si-row"><span class="si-lbl">Contract Start</span><span class="si-val">
                    <%= stall.contractStart %>
                  </span></div>
                <div class="si-row"><span class="si-lbl">Contract Expires</span><span class="si-val">
                    <%= stall.contractExpires %>
                  </span></div>
                <div class="si-row"><span class="si-lbl">Vendor ID</span><span class="si-val mono bl">
                    <%= vendor.vendorId %>
                  </span></div>
                <div class="si-row"><span class="si-lbl">Assigned Collector</span><span class="si-val">
                    <%= stall.collector %>
                  </span></div>
              </div>
              <div class="panel">
                <div class="ph">
                  <div class="ph-ttl">Notification Settings</div>
                </div>
                <div class="si-row"><span class="si-lbl">Payment reminders</span>
                  <div class="toggle on" onclick="this.classList.toggle('on')"></div>
                </div>
                <div class="si-row"><span class="si-lbl">New notices from market office</span>
                  <div class="toggle on" onclick="this.classList.toggle('on')"></div>
                </div>
                <div class="si-row"><span class="si-lbl">Inquiry replies</span>
                  <div class="toggle on" onclick="this.classList.toggle('on')"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
    </div>
    <div class="toast" id="toast"></div>
    <script src="/js/vendor/profile.js"></script>
</body>

</html>