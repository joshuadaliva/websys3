<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ARKIPAISI &mdash; Settings</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/vendor/settings.css">
</head>

<body>
  <div class="veil" id="veil" onclick="closeSB()"></div>
  <%- include("../../partials/sidebar.ejs", { currentRoute, role: "vendor" , initials: "vendor" , fullName: "joshua daliva"
    , stallNumber: 06}) %>
    <div class="main" id="main">
      <%- include("../../partials/header.ejs", {role: "vendor" , initials: "vendor" , lastName: "daliva" , }) %>
        <div class="content">
          <div class="page-header">
            <h1>Settings</h1>
            <p>Customize your vendor portal experience</p>
          </div>

          <div style="max-width:680px">

            <!-- Appearance -->
            <div class="scard">
              <div class="scard-head">
                <div class="scard-ico"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="5" />
                    <line x1="12" y1="1" x2="12" y2="3" />
                    <line x1="12" y1="21" x2="12" y2="23" />
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                    <line x1="1" y1="12" x2="3" y2="12" />
                    <line x1="21" y1="12" x2="23" y2="12" />
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                  </svg></div>
                <div>
                  <div class="scard-ttl">Appearance</div>
                  <div class="scard-sub">Display preferences</div>
                </div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Theme</div>
                  <div class="s-desc">Light, dark, or follow system setting</div>
                </div>
                <div class="th-opts">
                  <div class="th-opt th-light <%= settings.appearance.theme === 'light' ? 'on' : '' %>"
                    onclick="setTh(this,'light')" title="Light"></div>
                  <div class="th-opt th-dark  <%= settings.appearance.theme === 'dark'  ? 'on' : '' %>"
                    onclick="setTh(this,'dark')" title="Dark"></div>
                  <div class="th-opt th-auto  <%= settings.appearance.theme === 'auto'  ? 'on' : '' %>"
                    onclick="setTh(this,'auto')" title="System"></div>
                </div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Language</div>
                  <div class="s-desc">Choose your preferred display language</div>
                </div>
                <select class="fsel" onchange="showToast('Language saved')">
                  <option <%=settings.appearance.language==='English' ? 'selected' : '' %>>English</option>
                  <option <%=settings.appearance.language==='Filipino' ? 'selected' : '' %>>Filipino</option>
                </select>
              </div>
            </div>

            <!-- Notifications -->
            <div class="scard">
              <div class="scard-head">
                <div class="scard-ico"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                  </svg></div>
                <div>
                  <div class="scard-ttl">Notifications</div>
                  <div class="scard-sub">Control what you get notified about</div>
                </div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Payment Reminders</div>
                  <div class="s-desc">Get notified when your monthly fee is due</div>
                </div>
                <div class="toggle <%= settings.notifications.paymentReminders ? 'on' : '' %>"
                  onclick="this.classList.toggle('on');showToast('Setting saved')"></div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Inquiry Replies</div>
                  <div class="s-desc">Get notified when the office replies to your ticket</div>
                </div>
                <div class="toggle <%= settings.notifications.inquiryReplies ? 'on' : '' %>"
                  onclick="this.classList.toggle('on');showToast('Setting saved')"></div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Market Announcements</div>
                  <div class="s-desc">New notices and updates from the market office</div>
                </div>
                <div class="toggle <%= settings.notifications.marketAnnouncements ? 'on' : '' %>"
                  onclick="this.classList.toggle('on');showToast('Setting saved')"></div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Contract Expiry Alerts</div>
                  <div class="s-desc">Remind me 60, 30, and 7 days before contract expires</div>
                </div>
                <div class="toggle <%= settings.notifications.contractExpiryAlerts ? 'on' : '' %>"
                  onclick="this.classList.toggle('on');showToast('Setting saved')"></div>
              </div>
            </div>

            <!-- Privacy & Security -->
            <div class="scard">
              <div class="scard-head">
                <div class="scard-ico"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                  </svg></div>
                <div>
                  <div class="scard-ttl">Privacy &amp; Security</div>
                  <div class="scard-sub">Account security settings</div>
                </div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Show payment history to collector</div>
                  <div class="s-desc">Allow your assigned collector to view your receipt history</div>
                </div>
                <div class="toggle <%= settings.privacy.showHistoryToCollector ? 'on' : '' %>"
                  onclick="this.classList.toggle('on');showToast('Setting saved')"></div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Two-factor Authentication</div>
                  <div class="s-desc">Require OTP when signing in from a new device</div>
                </div>
                <div class="toggle <%= settings.privacy.twoFactorAuth ? 'on' : '' %>"
                  onclick="this.classList.toggle('on');showToast('2FA updated')"></div>
              </div>
            </div>

            <!-- About -->
            <div class="scard">
              <div class="scard-head">
                <div class="scard-ico"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                  </svg></div>
                <div>
                  <div class="scard-ttl">About</div>
                </div>
              </div>
              <div class="s-row">
                <div class="s-lbl">Application</div>
                <div style="font-size:13px;font-weight:600;color:var(--t2)">
                  <%= settings.about.appName %>
                </div>
              </div>
              <div class="s-row">
                <div class="s-lbl">Version</div>
                <div style="font-size:13px;font-family:'DM Mono',monospace;color:var(--ac)">
                  <%= settings.about.version %>
                </div>
              </div>
              <div class="s-row">
                <div class="s-lbl">Market</div>
                <div style="font-size:13px;font-weight:600;color:var(--t2)">
                  <%= settings.about.market %>
                </div>
              </div>
            </div>

            <!-- Sign out -->
            <div class="scard danger-card">
              <div class="scard-head">
                <div class="scard-ico"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                  </svg></div>
                <div>
                  <div class="scard-ttl" style="color:var(--rd)">Sign Out</div>
                </div>
              </div>
              <div class="s-row">
                <div>
                  <div class="s-lbl">Sign out</div>
                  <div class="s-desc">End your session and return to the login page</div>
                </div>
                <button
                  style="background:var(--surface);border:1px solid var(--rds);color:var(--rd);padding:6px 12px;border-radius:var(--rs);font-size:12.5px;font-weight:600;cursor:pointer;font-family:'Poppins',sans-serif;display:inline-flex;align-items:center;gap:6px;transition:all .14s"
                  onclick="showToast('Signed out')">Sign Out</button>
              </div>
            </div>

          </div>
        </div>
    </div>
    <div class="toast" id="toast"></div>
    <script src="/js/vendor/settings.js"></script>
</body>

</html>